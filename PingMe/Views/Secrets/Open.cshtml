@model string
@{
    Layout = "~/Views/Shared/_EmptyLayout.cshtml";
    ViewData["Title"] = "Mở Secret — PingMe";
    var token = Model ?? "";
}

<style>
    body {
        background: var(--mud-palette-background);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        font-family: 'Inter', sans-serif;
        padding: 20px;
    }

    .pm-open-card {
        width: min(480px, 100%);
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        padding: 36px;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
    }

    .pm-open-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 24px;
    }

    .pm-open-header h2 {
        margin: 0;
        font-size: 1.3rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--mud-palette-text-primary);
    }

    .pm-open-header svg {
        width: 32px;
        height: 32px;
        fill: var(--mud-palette-warning);
    }

    .mud-alert {
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 14px;
        line-height: 1.5;
    }

    .mud-alert-filled-warning {
        background: rgba(245, 158, 11, 0.16);
        color: var(--mud-palette-warning);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }

    .mud-alert-filled-success {
        background: rgba(34, 197, 94, 0.16);
        color: var(--mud-palette-success);
        border: 1px solid rgba(34, 197, 94, 0.3);
    }

    .mud-alert-filled-error {
        background: rgba(239, 68, 68, 0.16);
        color: var(--mud-palette-error);
        border: 1px solid rgba(239, 68, 68, 0.3);
    }

    .mud-alert strong {
        font-weight: 700;
    }

    #secret-content {
        background: var(--mud-palette-background);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 10px;
        padding: 16px;
        white-space: pre-wrap;
        word-break: break-word;
        font-family: ui-monospace, 'Fira Code', Consolas, monospace;
        font-size: 0.875rem;
        max-height: 320px;
        overflow-y: auto;
        margin-bottom: 12px;
        line-height: 1.5;
        color: var(--mud-palette-text-primary);
    }

    .mud-button-root {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 10px 20px;
        border-radius: 6px;
        border: none;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        min-width: 100px;
    }

    .mud-button-filled-primary {
        background: var(--mud-palette-primary);
        color: white;
    }

    .mud-button-filled-primary:hover:not(:disabled) {
        background: var(--mud-palette-primary-darken-1);
    }

    .mud-button-filled-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .mud-button-outlined-primary {
        border: 2px solid var(--mud-palette-primary);
        color: var(--mud-palette-primary);
        background: transparent;
    }

    .mud-button-outlined-primary:hover {
        background: rgba(37, 99, 235, 0.08);
    }

    .mud-button-text-primary {
        color: var(--mud-palette-primary);
        background: transparent;
    }

    .mud-button-text-primary:hover {
        background: rgba(37, 99, 235, 0.08);
    }

    .full-width {
        width: 100%;
    }

    .btn-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .error-link {
        display: block;
        margin-top: 16px;
        text-align: center;
        color: var(--mud-palette-primary);
        text-decoration: none;
        font-weight: 600;
    }

    .error-link:hover {
        text-decoration: underline;
    }
</style>

<div class="pm-open-card">
    <div class="pm-open-header">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 1C6.48 1 2 5.48 2 11c0 5.52 4.48 10 10 10s10-4.48 10-10S17.52 1 12 1zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-2-13h4v6h-4z"/>
        </svg>
        <h2>Secret dùng một lần</h2>
    </div>

    <!-- State: warning (trước khi mở) -->
    <div id="state-warning">
        <div class="mud-alert mud-alert-filled-warning">
            ⚠️ Secret này chỉ có thể xem <strong>một lần duy nhất</strong>. Hãy chắc chắn bạn đã sẵn sàng sao chép nội dung trước khi mở.
        </div>
        <button type="button" id="btn-open" onclick="openSecret()"
                class="mud-button-root mud-button-filled-primary full-width">
            👁 Mở Secret
        </button>
    </div>

    <!-- State: success (đã mở) -->
    <div id="state-success" style="display:none;">
        <div class="mud-alert mud-alert-filled-success">
            ✅ Đây là nội dung secret. Sau khi rời trang, link sẽ không còn hiệu lực.
        </div>
        <pre id="secret-content"></pre>
        <button type="button" onclick="copySecret()"
                class="mud-button-root mud-button-outlined-primary full-width">
            📋 Sao chép nội dung
        </button>
    </div>

    <!-- State: error -->
    <div id="state-error" style="display:none;">
        <div class="mud-alert mud-alert-filled-error">
            <span id="error-msg">Secret đã hết hạn hoặc đã được xem rồi.</span>
        </div>
        <a href="/" class="error-link">Quay về trang chủ</a>
    </div>
</div>

@section Scripts {
<script>
    const TOKEN = '@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(token))';
    let secretText = '';

    async function openSecret() {
        const btn = document.getElementById('btn-open');
        btn.disabled = true;
        btn.textContent = '⏳ Đang mở...';

        try {
            const res = await fetch(`/api/one-time-secrets/open/${encodeURIComponent(TOKEN)}`, {
                method: 'GET',
                credentials: 'include'
            });

            if (!res.ok) {
                const data = await res.json().catch(() => ({}));
                showError(data.message || 'Secret đã hết hạn hoặc đã được xem rồi.');
                return;
            }

            const data = await res.json();
            secretText = data.secretText || '';
            document.getElementById('secret-content').textContent = secretText;
            document.getElementById('state-warning').style.display = 'none';
            document.getElementById('state-success').style.display = 'block';
        } catch (e) {
            console.error('Error opening secret:', e);
            showError('Không thể kết nối server. Vui lòng kiểm tra kết nối mạng.');
        }
    }

    function showError(msg) {
        document.getElementById('state-warning').style.display = 'none';
        document.getElementById('error-msg').textContent = msg;
        document.getElementById('state-error').style.display = 'block';
    }

    async function copySecret() {
        try {
            await navigator.clipboard.writeText(secretText);
            const btn = event.target;
            const oldText = btn.textContent;
            btn.textContent = '✅ Đã sao chép!';
            setTimeout(() => { btn.textContent = oldText; }, 2000);
        } catch (e) {
            // Fallback for older browsers
            const ta = document.createElement('textarea');
            ta.value = secretText;
            document.body.appendChild(ta);
            ta.select();
            try {
                document.execCommand('copy');
                alert('Đã sao chép vào clipboard!');
            } catch (err) {
                alert('Không thể sao chép. Vui lòng sao chép thủ công.');
            }
            document.body.removeChild(ta);
        }
    }
</script>
}
