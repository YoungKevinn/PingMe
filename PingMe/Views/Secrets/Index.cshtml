@{
    ViewData["Title"] = "One-Time Secrets - PingMe";
}

<style>
    .pm-secret-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .pm-secret-field label {
        font-size: .78rem;
        font-weight: 700;
        color: var(--mud-palette-text-secondary);
    }
    .pm-secret-select {
        width: 100%;
        height: 44px;
        border-radius: 8px;
        border: 1px solid var(--mud-palette-lines-inputs);
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        padding: 0 12px;
        outline: none;
        font-weight: 600;
    }
    .pm-secret-select:focus {
        border-color: var(--mud-palette-primary);
        box-shadow: 0 0 0 2px rgba(37, 99, 235, .18);
    }
    .pm-secret-share-alert {
        font-weight: 700;
    }
    .pm-secret-share-card {
        border-color: var(--mud-palette-warning);
        background: var(--mud-palette-surface);
    }
    .pm-secret-share-label {
        display: block;
        color: var(--mud-palette-text-secondary);
        font-weight: 700;
        margin-bottom: 6px;
    }
    .pm-secret-share-link {
        width: 100%;
        min-height: 78px;
        border: 1px solid var(--mud-palette-lines-inputs);
        border-radius: 8px;
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-primary);
        font: 600 .875rem/1.45 ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        padding: 10px 12px;
        resize: vertical;
        word-break: break-all;
        overflow-wrap: anywhere;
        box-sizing: border-box;
    }
    .pm-secret-viewer {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
        max-width: 220px;
    }
    .pm-secret-viewer span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .pm-secret-viewer-avatar {
        flex: 0 0 auto;
        font-size: .72rem;
        font-weight: 700;
    }
</style>

<!-- Main container matching MudContainer MaxWidth.Large mt-6 -->
<div class="mud-container mud-container-maxwidth-lg mt-6">
    <!-- Header row -->
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <h5 class="mud-typography mud-typography-h5 font-weight-bold">🔐 One-Time Secrets</h5>
            <p class="mud-typography mud-typography-body2 mud-secondary-text">
                Tin nhắn bí mật — tự hủy sau khi đọc
            </p>
        </div>
        <button type="button" onclick="pmSecrets.refresh()" class="mud-button-root mud-button mud-button-outlined mud-button-outlined-primary mud-ripple">
            <span class="mud-button-icon-start mud-button-icon-start-medium"><svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg></span>
            <span class="mud-button-label">Làm mới</span>
        </button>
    </div>

    <!-- Two-column layout matching MudGrid xs=12 md=5 / md=7 -->
    <div class="mud-grid">
        <!-- Left column: Create form -->
        <div class="mud-grid-item mud-grid-item-xs-12 mud-grid-item-md-5">
            <div class="mud-paper mud-elevation-0 mud-paper-outlined pa-4">
                <h6 class="mud-typography mud-typography-subtitle1 font-weight-bold mb-3">Tạo bí mật mới</h6>

                <!-- Secret text area -->
                <div class="mud-input-control mud-input-input-control mud-input-control-full-width">
                    <div class="mud-input-control-input-container">
                        <div class="mud-input mud-input-outlined mud-input-text">
                            <textarea id="secret-text" rows="8" class="mud-input-slot mud-input-root mud-input-root-outlined" maxlength="8000"></textarea>
                            <div class="mud-input-outlined-border"></div>
                        </div>
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol">Nội dung bí mật</label>
                    </div>
                    <div class="mud-input-control-helper-container">
                        <p class="mud-input-helper-text"><span id="secret-char-count">0</span> / 8000</p>
                    </div>
                </div>

                <!-- Expiration select -->
                <div class="pm-secret-field mt-3">
                    <label>Thời gian hết hạn</label>
                    <select id="secret-expires" class="pm-secret-select">
                        <option value="5m">5 phút</option>
                        <option value="1h">1 giờ</option>
                        <option value="1d">1 ngày</option>
                    </select>
                </div>

                <!-- Create button -->
                <button type="button" id="secret-create-btn" onclick="pmSecrets.create()" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple mt-4 mud-disabled" disabled>
                    <span class="mud-button-icon-start mud-button-icon-start-medium"><svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M12.65 10C11.83 7.67 9.61 6 7 6c-3.31 0-6 2.69-6 6s2.69 6 6 6c2.61 0 4.83-1.67 5.65-4H17v4h4v-4h2v-4H12.65zM7 14c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"/></svg></span>
                    <span class="mud-button-label">Tạo bí mật</span>
                </button>

                <!-- Share URL section (hidden by default) -->
                <div id="secret-share-section" style="display:none;">
                    <div class="mud-alert mud-alert-filled mud-alert-filled-warning mud-elevation-0 pm-secret-share-alert mt-4">
                        <div class="mud-alert-icon"><svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M12 5.99L19.53 19H4.47L12 5.99M12 2L1 21h22L12 2zm1 14h-2v2h2v-2zm0-6h-2v4h2v-4z"></path></svg></div>
                        <div class="mud-alert-message">Link chỉ hiển thị một lần! Hãy copy ngay.</div>
                    </div>
                    <div class="mud-paper mud-elevation-0 mud-paper-outlined pm-secret-share-card pa-3 mt-2">
                        <span class="mud-typography mud-typography-caption pm-secret-share-label">Link chia sẻ</span>
                        <textarea id="secret-share-url" class="pm-secret-share-link" readonly rows="3"></textarea>
                        <button type="button" onclick="pmSecrets.copyLink()" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple mt-2">
                            <span class="mud-button-icon-start mud-button-icon-start-medium"><svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg></span>
                            <span class="mud-button-label">Copy link</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right column: Secrets list/table -->
        <div class="mud-grid-item mud-grid-item-xs-12 mud-grid-item-md-7">
            <div class="mud-paper mud-elevation-0 mud-paper-outlined pa-4">
                <h6 class="mud-typography mud-typography-subtitle1 font-weight-bold mb-3">Danh sách bí mật đã tạo</h6>
                <div id="pm-secrets-list">
                    <div class="mud-progress-circular mud-progress-circular-primary mud-progress-circular-indeterminate" role="progressbar" aria-valuenow="0"><svg class="mud-progress-circular-svg" viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20"></circle></svg></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const pmSecrets = {
    _items: [],
    _shareUrl: null,

    async init() {
        document.getElementById('secret-text').addEventListener('input', (e) => {
            const len = e.target.value.length;
            document.getElementById('secret-char-count').textContent = len;
            const btn = document.getElementById('secret-create-btn');
            if (len === 0) {
                btn.disabled = true;
                btn.classList.add('mud-disabled');
            } else {
                btn.disabled = false;
                btn.classList.remove('mud-disabled');
            }
        });
        await this.load();
    },

    async load() {
        const list = document.getElementById('pm-secrets-list');
        list.innerHTML = '<div class="mud-progress-circular mud-progress-circular-primary mud-progress-circular-indeterminate" role="progressbar" aria-valuenow="0"><svg class="mud-progress-circular-svg" viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20"></circle></svg></div>';
        const items = await pmApi.get('/api/one-time-secrets') || [];
        this._items = items;
        this.render();
    },

    async refresh() {
        await this.load();
        pmToast.success('Đã làm mới');
    },

    _fmtDate(iso) {
        if (!iso) return '-';
        const d = new Date(iso);
        return d.toLocaleString('vi-VN', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
    },

    _getStatusText(s) {
        if (s.isRevoked) return 'Thu hồi';
        if (s.isViewed) return 'Đã xem';
        if (new Date(s.expiresAt) <= new Date()) return 'Hết hạn';
        return 'Hoạt động';
    },

    _getStatusColor(s) {
        if (s.isRevoked) return 'error';
        if (s.isViewed) return 'info';
        if (new Date(s.expiresAt) <= new Date()) return 'warning';
        return 'success';
    },

    _isActive(s) {
        return !s.isViewed && !s.isRevoked && new Date(s.expiresAt) > new Date();
    },

    _getInitials(name) {
        if (!name) return '?';
        const parts = name.trim().split(/\s+/);
        if (parts.length === 1) return parts[0][0].toUpperCase();
        return (parts[0][0] + parts[parts.length-1][0]).toUpperCase();
    },

    render() {
        const list = document.getElementById('pm-secrets-list');

        if (!this._items.length) {
            list.innerHTML = '<p class="mud-typography mud-typography-body1 mud-secondary-text">Chưa có bí mật nào</p>';
            return;
        }

        let html = `<div class="mud-paper mud-elevation-1 mud-table mud-table-dense mud-table-hover">
            <div class="mud-table-container">
                <table class="mud-table-root">
                    <thead class="mud-table-head">
                        <tr class="mud-table-row">
                            <th class="mud-table-cell">Tạo lúc</th>
                            <th class="mud-table-cell">Hết hạn</th>
                            <th class="mud-table-cell">Đã xem lúc</th>
                            <th class="mud-table-cell">Người xem</th>
                            <th class="mud-table-cell">Trạng thái</th>
                            <th class="mud-table-cell"></th>
                        </tr>
                    </thead>
                    <tbody class="mud-table-body">`;

        this._items.forEach(s => {
            const statusColor = this._getStatusColor(s);
            const statusText = this._getStatusText(s);
            const isActive = this._isActive(s);

            let viewerCell = '-';
            if (s.viewedAt) {
                if (s.viewedByDisplayName) {
                    const initials = this._getInitials(s.viewedByDisplayName);
                    const avatarUrl = s.viewedByAvatarUrl || '';
                    const avatarContent = avatarUrl
                        ? `<img src="${pmEscape(avatarUrl)}" alt="${pmEscape(s.viewedByDisplayName)}" style="width:100%;height:100%;object-fit:cover;" />`
                        : pmEscape(initials);
                    viewerCell = `<div class="pm-secret-viewer" title="${pmEscape(s.viewedUserAgent || '')}">
                        <div class="mud-avatar mud-avatar-small mud-avatar-filled mud-avatar-filled-primary pm-secret-viewer-avatar">${avatarContent}</div>
                        <span>${pmEscape(s.viewedByDisplayName)}</span>
                    </div>`;
                } else if (s.isAnonymousViewed) {
                    viewerCell = `<span title="${pmEscape(s.viewedUserAgent || '')}">Người ngoài</span>`;
                }
            }

            html += `<tr class="mud-table-row">
                <td class="mud-table-cell" data-label="Tạo lúc">${this._fmtDate(s.createdAt)}</td>
                <td class="mud-table-cell" data-label="Hết hạn">${this._fmtDate(s.expiresAt)}</td>
                <td class="mud-table-cell" data-label="Đã xem lúc">${s.viewedAt ? this._fmtDate(s.viewedAt) : '-'}</td>
                <td class="mud-table-cell" data-label="Người xem">${viewerCell}</td>
                <td class="mud-table-cell" data-label="Trạng thái"><div class="mud-chip mud-chip-filled mud-chip-color-${statusColor} mud-chip-size-small"><span class="mud-chip-content">${pmEscape(statusText)}</span></div></td>
                <td class="mud-table-cell">
                    <button type="button" onclick="pmSecrets.revoke(${s.id})" class="mud-button-root mud-button mud-button-text mud-button-text-error mud-button-size-small mud-ripple ${!isActive ? 'mud-disabled' : ''}" ${!isActive ? 'disabled' : ''}>
                        <span class="mud-button-label">Thu hồi</span>
                    </button>
                </td>
            </tr>`;
        });

        html += '</tbody></table></div></div>';
        list.innerHTML = html;
    },

    async create() {
        const text = document.getElementById('secret-text').value.trim();
        if (!text) { pmToast.error('Vui lòng nhập nội dung bí mật'); return; }
        const expiresIn = document.getElementById('secret-expires').value;
        const btn = document.getElementById('secret-create-btn');
        btn.disabled = true;
        btn.classList.add('mud-disabled');
        const r = await pmApi.post('/api/one-time-secrets', { secretText: text, expiresIn });
        btn.disabled = false;
        btn.classList.remove('mud-disabled');
        if (!r) return;

        if (r.shareUrl) {
            this._shareUrl = r.shareUrl;
            document.getElementById('secret-share-url').value = r.shareUrl;
            document.getElementById('secret-share-section').style.display = 'block';
        }
        document.getElementById('secret-text').value = '';
        document.getElementById('secret-char-count').textContent = '0';
        btn.disabled = true;
        btn.classList.add('mud-disabled');
        pmToast.success('Đã tạo bí mật');
        await this.load();
    },

    copyLink() {
        const url = document.getElementById('secret-share-url').value;
        if (url) {
            navigator.clipboard.writeText(url).then(() => pmToast.success('Đã copy link'));
        }
    },

    async revoke(id) {
        const r = await pmApi.post('/api/one-time-secrets/' + id + '/revoke', {});
        if (r !== null) {
            pmToast.success('Đã thu hồi bí mật');
            await this.load();
        }
    }
};
document.addEventListener('DOMContentLoaded', () => pmSecrets.init());
</script>
}
