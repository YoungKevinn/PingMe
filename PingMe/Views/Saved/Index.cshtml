@{
    ViewData["Title"] = "Tin nhắn đã lưu - PingMe";
}

<style>
    .pm-saved-page {
        min-height: calc(100vh - 64px);
        padding: 24px;
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-primary);
    }
    .pm-saved-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        max-width: 960px;
        margin: 0 auto 18px;
    }
    .pm-saved-header h1 { margin: 0 0 4px; font-size: 1.35rem; font-weight: 800; color: var(--mud-palette-text-primary); }
    .pm-saved-header p { margin: 0; color: var(--mud-palette-text-secondary); font-size: .9rem; }
    .pm-saved-loading, .pm-saved-empty {
        min-height: 320px; display: flex; align-items: center;
        justify-content: center; flex-direction: column; gap: 10px;
        color: var(--mud-palette-text-secondary); font-weight: 700;
    }
    .pm-saved-filter {
        display: inline-flex; align-items: center; padding: 3px;
        border-radius: 8px; border: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-surface);
    }
    .pm-saved-filter button {
        border: 0; border-radius: 6px; padding: 7px 12px; background: transparent;
        color: var(--mud-palette-text-secondary); font-weight: 800; cursor: pointer;
        transition: .15s;
    }
    .pm-saved-filter button.active { background: var(--mud-palette-primary); color: white; }
    .pm-saved-list { max-width: 960px; margin: 0 auto; display: flex; flex-direction: column; gap: 10px; }
    .pm-saved-card {
        display: grid; grid-template-columns: 42px minmax(0,1fr) auto;
        gap: 12px; padding: 14px; border-radius: 8px;
        background: var(--mud-palette-surface); border: 1px solid var(--mud-palette-divider);
        box-shadow: 0 1px 3px rgba(0,0,0,.07);
    }
    .pm-saved-avatar {
        width: 42px; height: 42px; border-radius: 50%; overflow: hidden;
        background: rgba(59,130,246,.14); color: var(--mud-palette-primary);
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; flex-shrink: 0;
    }
    .pm-saved-avatar img { width: 100%; height: 100%; object-fit: cover; }
    .pm-saved-body { min-width: 0; display: flex; flex-direction: column; gap: 6px; }
    .pm-saved-meta-row, .pm-saved-time-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 12px; }
    .pm-saved-sender { font-weight: 800; color: var(--mud-palette-text-primary); }
    .pm-saved-context { color: var(--mud-palette-text-secondary); font-size: .82rem; }
    .pm-saved-content { color: var(--mud-palette-text-primary); white-space: pre-wrap; overflow-wrap: anywhere; line-height: 1.45; }
    .pm-saved-file {
        display: inline-flex; align-items: center; gap: 6px; width: fit-content;
        max-width: 100%; color: var(--mud-palette-primary); font-weight: 700; text-decoration: none;
    }
    .pm-saved-file span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pm-saved-time-row { color: var(--mud-palette-text-secondary); font-size: .78rem; }
    .pm-saved-actions { display: flex; align-items: flex-start; gap: 2px; }
    @@media (max-width: 720px) {
        .pm-saved-page { padding: 16px; }
        .pm-saved-header { align-items: stretch; flex-direction: column; }
        .pm-saved-card { grid-template-columns: 38px minmax(0,1fr); }
        .pm-saved-actions { grid-column: 2; justify-content: flex-end; }
    }
</style>

<div class="pm-saved-page">
    <div class="pm-saved-header">
        <div>
            <h1>Tin nhắn đã lưu</h1>
            <p>Các tin nhắn bạn đã đánh dấu để xem lại</p>
        </div>
        <div class="pm-saved-filter" role="tablist">
            <button type="button" class="active" id="filter-all" onclick="pmSaved.setFilter('all')">Tất cả</button>
            <button type="button" id="filter-dm" onclick="pmSaved.setFilter('dm')">Tin nhắn riêng</button>
            <button type="button" id="filter-group" onclick="pmSaved.setFilter('group')">Nhóm</button>
        </div>
    </div>

    <div id="pm-saved-container"></div>
</div>

@section Scripts {
<script>
const pmSaved = {
    _filter: 'all',
    _items: [],
    _busyMessageIds: new Set(),

    async init() {
        await this.load();
    },

    setFilter(f) {
        this._filter = f;
        document.querySelectorAll('.pm-saved-filter button').forEach(b => b.classList.remove('active'));
        document.getElementById('filter-' + f)?.classList.add('active');
        this.load();
    },

    async load() {
        const container = document.getElementById('pm-saved-container');
        container.innerHTML = '<div class="pm-saved-loading"><div class="mud-progress-circular mud-progress-circular-indeterminate mud-progress-circular-color-primary mud-progress-circular-size-small" role="progressbar" aria-valuenow="0"><svg class="mud-progress-circular-svg" viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20" fill="none" stroke-width="3"></circle></svg></div></div>';

        try {
            const url = this._filter === 'all'
                ? '/api/saved-messages?page=1&pageSize=50'
                : `/api/saved-messages?type=${this._filter}&page=1&pageSize=50`;
            this._items = await pmApi.get(url) || [];
            this.render();
        } catch(e) {
            container.innerHTML = '<div class="pm-saved-empty"><p>Không thể tải dữ liệu.</p></div>';
        }
    },

    render() {
        const container = document.getElementById('pm-saved-container');
        if (!this._items.length) {
            container.innerHTML = `<div class="pm-saved-empty">
                <svg class="mud-icon-root mud-svg-icon" style="font-size:56px;opacity:.28;" viewBox="0 0 24 24"><path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2zm0 15l-5-2.18L7 18V5h10v13z"/></svg>
                <p>Không có tin nhắn đã lưu</p>
            </div>`;
            return;
        }

        let html = '<div class="pm-saved-list">';
        this._items.forEach(item => {
            const name = pmEscape(item.senderName || item.sender?.displayName || 'Người dùng');
            const initial = name[0]?.toUpperCase() || '?';
            const avatar = item.senderAvatarUrl
                ? `<img src="${pmApi.backendUrl}${item.senderAvatarUrl}" alt="${name}" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"><span style="display:none">${initial}</span>`
                : `<span>${initial}</span>`;

            const context = item.groupId || (item.conversationType && item.conversationType.toLowerCase() === 'group')
                ? `Group: ${pmEscape(item.groupName || '#' + item.groupId)}`
                : `DM: ${pmEscape(item.peerDisplayName || '#' + item.peerUserId)}`;

            const content = item.content
                ? pmEscape(item.content)
                : (item.messageType === 'Image' ? 'Hình ảnh' : 'Tệp đính kèm');

            const formatTime = (dateStr) => {
                if (!dateStr) return '';
                const d = new Date(dateStr);
                const day = String(d.getDate()).padStart(2, '0');
                const month = String(d.getMonth() + 1).padStart(2, '0');
                const year = d.getFullYear();
                const hours = String(d.getHours()).padStart(2, '0');
                const minutes = String(d.getMinutes()).padStart(2, '0');
                return `${day}/${month}/${year} ${hours}:${minutes}`;
            };
            const msgTime = formatTime(item.createdAt);
            const savedTime = formatTime(item.savedAt);

            const jumpUrl = item.groupId
                ? `/chat/group/${item.groupId}?messageId=${item.messageId}`
                : `/chat/${item.peerUserId}?messageId=${item.messageId}`;

            const fileLink = item.fileName
                ? `<a class="pm-saved-file" href="${pmApi.backendUrl}${item.fileUrl}" target="_blank" rel="noopener">
                    <svg class="mud-icon-root mud-svg-icon" style="font-size:16px;" viewBox="0 0 24 24"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/></svg>
                    <span>${pmEscape(item.fileName)}</span>
                </a>` : '';

            const disabledAttr = this._busyMessageIds.has(item.messageId) ? 'disabled' : '';

            html += `
            <article class="pm-saved-card">
                <div class="pm-saved-avatar">${avatar}</div>
                <div class="pm-saved-body">
                    <div class="pm-saved-meta-row">
                        <span class="pm-saved-sender">${name}</span>
                        <span class="pm-saved-context">${context}</span>
                    </div>
                    <div class="pm-saved-content">${content}</div>
                    ${fileLink}
                    <div class="pm-saved-time-row">
                        <span>Thời gian tin nhắn: ${msgTime}</span>
                        <span>Đã lưu lúc: ${savedTime}</span>
                    </div>
                </div>
                <div class="pm-saved-actions">
                    <button type="button" class="mud-button-root mud-icon-button mud-icon-button-color-primary mud-icon-button-size-small mud-ripple" title="Mở trong chat" onclick="window.location.href='${jumpUrl}'">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M19 19H5V5h7V3H5a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z"/></svg>
                        </span>
                    </button>
                    <button type="button" class="mud-button-root mud-icon-button mud-icon-button-color-error mud-icon-button-size-small mud-ripple" title="Bỏ lưu" ${disabledAttr}
                            onclick="pmSaved.unsave(${item.messageId})">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M17 3H7c-1.1 0-1.99.9-1.99 2L5 21l7-3 7 3V5c0-1.1-.9-2-2-2zm0 15l-5-2.18L7 18V5h10v13z"/></svg>
                        </span>
                    </button>
                </div>
            </article>`;
        });
        html += '</div>';
        container.innerHTML = html;
    },

    async unsave(messageId) {
        if (this._busyMessageIds.has(messageId)) return;
        this._busyMessageIds.add(messageId);
        this.render();

        const ok = await pmApi.delete(`/api/saved-messages/${messageId}`);
        this._busyMessageIds.delete(messageId);

        if (ok !== false) {
            this._items = this._items.filter(i => i.messageId !== messageId);
            this.render();
            if (window.pmToast) pmToast.success('Đã bỏ lưu tin nhắn');
        } else {
            this.render();
            if (window.pmToast) pmToast.warning('Không thể bỏ lưu tin nhắn');
        }
    }
};

document.addEventListener('DOMContentLoaded', () => pmSaved.init());
</script>
}
