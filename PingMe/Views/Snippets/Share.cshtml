@model string
@{
    Layout = null;
    var token = Model ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>PingMe — Code Snippet</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #0B1120; color: #E5E7EB; font-family: system-ui, -apple-system, sans-serif; min-height: 100vh; display: flex; flex-direction: column; }
        .pm-share-header { background: #0F172A; border-bottom: 1px solid rgba(148,163,184,.18); padding: 16px 24px; display: flex; align-items: center; gap: 12px; }
        .pm-share-logo { font-size: 1.2rem; font-weight: 800; color: #3B82F6; }
        .pm-share-badge { font-size: 0.7rem; background: rgba(59,130,246,.18); color: #60A5FA; border: 1px solid rgba(59,130,246,.28); border-radius: 999px; padding: 2px 8px; font-weight: 600; }
        .pm-share-main { flex: 1; padding: 32px 24px; max-width: 1100px; margin: 0 auto; width: 100%; }
        .pm-share-meta { margin-bottom: 20px; }
        .pm-share-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 6px; color: #F1F5F9; }
        .pm-share-info { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .pm-share-lang { display: inline-flex; align-items: center; padding: 3px 10px; background: rgba(59,130,246,.18); color: #60A5FA; border: 1px solid rgba(59,130,246,.28); border-radius: 999px; font-size: 0.78rem; font-weight: 700; }
        .pm-share-author { font-size: 0.82rem; color: #94A3B8; }
        .pm-share-date { font-size: 0.82rem; color: #64748B; }
        .pm-share-code-wrap { position: relative; }
        .pm-share-copy-btn { position: absolute; top: 14px; right: 14px; background: rgba(59,130,246,.18); color: #60A5FA; border: 1px solid rgba(59,130,246,.28); border-radius: 8px; padding: 6px 14px; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: background .15s; }
        .pm-share-copy-btn:hover { background: rgba(59,130,246,.35); }
        pre { background: #0B1120; border: 1px solid rgba(148,163,184,.18); border-radius: 14px; overflow: auto; padding: 24px; font-family: 'Fira Code', Consolas, monospace; font-size: 14px; line-height: 1.65; }
        pre code { background: transparent; }
        .pm-error { text-align: center; padding: 64px 24px; color: #94A3B8; }
        .pm-error h2 { font-size: 1.4rem; font-weight: 700; color: #F87171; margin-bottom: 8px; }
        .pm-loading { text-align: center; padding: 64px 24px; color: #94A3B8; }
        .pm-share-footer { text-align: center; padding: 16px; color: #475569; font-size: 0.78rem; border-top: 1px solid rgba(148,163,184,.1); }
        .pm-share-footer a { color: #3B82F6; text-decoration: none; }
    </style>
</head>
<body>
    <div class="pm-share-header">
        <span class="pm-share-logo">PingMe</span>
        <span class="pm-share-badge">Code Snippet</span>
    </div>

    <div class="pm-share-main">
        <div id="pm-loading" class="pm-loading">Đang tải snippet...</div>
        <div id="pm-error" class="pm-error" style="display:none;">
            <h2>Không tìm thấy</h2>
            <p>Snippet này không tồn tại, đã hết hạn hoặc đã bị thu hồi.</p>
        </div>
        <div id="pm-content" style="display:none;">
            <div class="pm-share-meta">
                <div class="pm-share-title" id="snip-title">Snippet</div>
                <div class="pm-share-info">
                    <span class="pm-share-lang" id="snip-lang"></span>
                    <span class="pm-share-author" id="snip-author"></span>
                    <span class="pm-share-date" id="snip-date"></span>
                </div>
            </div>
            <div class="pm-share-code-wrap">
                <button class="pm-share-copy-btn" onclick="copyCode()">Copy</button>
                <pre id="snip-pre"><code id="snip-code"></code></pre>
            </div>
        </div>
    </div>

    <div class="pm-share-footer">Chia sẻ bởi <a href="/">PingMe</a></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>
        const token = '@Html.Raw(token)';
        let _code = '';

        async function load() {
            try {
                const r = await fetch('/api/snippets/share/' + encodeURIComponent(token));
                if (!r.ok) { showError(); return; }
                const s = await r.json();
                _code = s.content || '';
                document.getElementById('snip-title').textContent = s.title || 'Snippet';
                document.getElementById('snip-lang').textContent = s.language || 'plaintext';
                document.getElementById('snip-author').textContent = 'Bởi ' + (s.creatorDisplayName || '');
                document.getElementById('snip-date').textContent = new Date(s.createdAt).toLocaleDateString('vi-VN');
                const codeEl = document.getElementById('snip-code');
                codeEl.textContent = _code;
                codeEl.className = 'language-' + (s.language || 'plaintext');
                document.getElementById('pm-loading').style.display = 'none';
                document.getElementById('pm-content').style.display = '';
                if (window.hljs) hljs.highlightElement(codeEl);
            } catch {
                showError();
            }
        }

        function showError() {
            document.getElementById('pm-loading').style.display = 'none';
            document.getElementById('pm-error').style.display = '';
        }

        function copyCode() {
            navigator.clipboard.writeText(_code).then(() => {
                const btn = document.querySelector('.pm-share-copy-btn');
                btn.textContent = 'Đã copy!';
                setTimeout(() => btn.textContent = 'Copy', 2000);
            });
        }

        load();
    </script>
</body>
</html>
