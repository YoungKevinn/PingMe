@{
    ViewData["Title"] = "Nhóm của tôi - PingMe";
}

<div class="mud-container mud-container-maxwidth-md mt-6">
    <div class="d-flex justify-space-between align-center mb-4">
        <h5 class="mud-typography mud-typography-h5 font-weight-bold">👥 Nhóm của tôi</h5>

        <button type="button" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple" onclick="pmGroups.openCreate()">
            <span class="mud-button-label">
                <span class="mud-icon-root mud-svg-icon mud-button-icon-start">
                    <svg viewBox="0 0 24 24"><path d="M22 9V7h-2v2h-2v2h2v2h2v-2h2V9h-2zM8 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4zm4.51-8.95C13.43 5.67 14 6.76 14 8s-.57 2.33-1.49 2.95C14.47 10.7 16 9.04 16 7s-1.53-3.7-3.49-3.95zM16.53 13.83C17.42 14.66 18 15.7 18 17v2h4v-2c0-1.55-2.54-2.82-5.47-3.17z"/></svg>
                </span>
                Tạo nhóm mới
            </span>
        </button>
    </div>

    <!-- Container for dynamic group rendering via JS -->
    <div id="pm-groups-list">
        <div class="mud-progress-circular mud-progress-circular-indeterminate mud-progress-circular-color-default">
            <svg class="mud-progress-circular-svg" viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle></svg>
        </div>
    </div>
</div>

<!-- Create Group Modal Backdrop -->
<div id="pm-create-group-overlay" class="pm-modal-backdrop" style="display:none;" onclick="pmGroups.closeCreate()">
    <!-- Create Group Modal -->
    <div class="pm-create-group-modal" onclick="event.stopPropagation()">
        <div class="pm-modal-header">
            <h6 class="mud-typography mud-typography-h6 font-weight-bold">Tạo nhóm mới</h6>
            <button type="button" class="pm-modal-close" onclick="pmGroups.closeCreate()">
                ×
            </button>
        </div>

        <div class="pm-modal-body">
            <!-- Group Name -->
            <div class="mud-input-control mud-input-control-full-width mb-3">
                <div class="mud-input-control-input-container">
                    <div class="mud-input mud-input-outlined">
                        <input type="text" id="new-group-name" placeholder=" " class="mud-input-slot mud-input-root mud-input-root-outlined" required />
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol">Tên nhóm *</label>
                        <div class="mud-input-outlined-border"></div>
                    </div>
                </div>
            </div>

            <!-- Group Description -->
            <div class="mud-input-control mud-input-control-full-width mb-3">
                <div class="mud-input-control-input-container">
                    <div class="mud-input mud-input-outlined">
                        <textarea id="new-group-desc" rows="2" placeholder=" " class="mud-input-slot mud-input-root mud-input-root-outlined"></textarea>
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol">Mô tả</label>
                        <div class="mud-input-outlined-border"></div>
                    </div>
                </div>
            </div>

            <hr class="mud-divider my-3" />
            
            <h6 class="mud-typography mud-typography-subtitle2 mb-2 font-weight-bold">Thêm thành viên</h6>

            <!-- Member Search -->
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; width:100%;">
                <div class="mud-input-control" style="flex:1; margin:0;">
                    <div class="mud-input-control-input-container">
                        <div class="mud-input mud-input-outlined mud-input-margin-dense mud-input-adorned-start">
                            <div class="mud-input-adornment mud-input-adornment-start" style="margin-top:0;">
                                <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                            </div>
                            <input type="text" id="member-search-input" placeholder=" " class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-margin-dense mud-input-root-adorned-start" />
                            <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol">Tìm theo tên hoặc username</label>
                            <div class="mud-input-outlined-border"></div>
                        </div>
                    </div>
                </div>
                
                <button type="button" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple" style="height:40px; margin:0;" onclick="pmGroups.searchMembers()">
                    <span class="mud-button-label">Tìm</span>
                </button>
            </div>

            <!-- Selected Members count -->
            <div id="pm-selected-members" style="display:none;" class="mud-paper mud-paper-outlined pa-2 mb-2">
                <span class="mud-typography mud-typography-caption mud-secondary-text mb-2 d-block">Đã chọn <span id="pm-selected-count">0</span> thành viên</span>
                <div id="pm-selected-members-list"></div>
            </div>

            <!-- Search Results -->
            <div id="pm-member-search-results" class="mud-paper mud-paper-outlined pa-2" style="display:none;">
                <!-- Filled by JS -->
            </div>
        </div>

        <div class="pm-modal-actions">
            <button type="button" class="mud-button-root mud-button mud-button-text mud-button-text-default mud-ripple" onclick="pmGroups.closeCreate()">
                <span class="mud-button-label">Hủy</span>
            </button>
            <button type="button" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple" onclick="pmGroups.createGroup()" id="pm-create-btn">
                <span class="mud-button-label">Tạo nhóm</span>
            </button>
        </div>
    </div>
</div>

<style>
    .pm-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, .55);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .pm-create-group-modal {
        width: min(430px, 100%);
        max-height: calc(100vh - 48px);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 14px;
        box-shadow: 0 24px 80px rgba(0, 0, 0, .45);
    }

    .pm-modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 18px 22px 10px;
        flex-shrink: 0;
    }

    .pm-modal-close {
        width: 34px;
        height: 34px;
        border: none;
        border-radius: 999px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        font-size: 28px;
        line-height: 1;
        cursor: pointer;
    }

        .pm-modal-close:hover {
            background: rgba(148, 163, 184, .16);
            color: var(--mud-palette-text-primary);
        }

    .pm-modal-body {
        padding: 8px 22px 16px;
        overflow-y: auto;
    }

    .pm-modal-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        padding: 14px 22px 18px;
        border-top: 1px solid var(--mud-palette-divider);
        flex-shrink: 0;
    }
</style>

@section Scripts {
<script src="/js/groups.js" asp-append-version="true"></script>
}
