@{
    ViewData["Title"] = "Phiên đăng nhập - PingMe";
}

<div style="height:100%;overflow-y:auto;padding:24px;background:var(--mud-palette-background);">
    <div style="max-width:680px;margin:0 auto;">
        <div style="margin-bottom:20px;display:flex;align-items:center;gap:16px;">
            <div style="flex:1;">
                <h1 class="pm-page-title">Phiên đăng nhập</h1>
                <p class="pm-page-subtitle">Quản lý các thiết bị đang đăng nhập</p>
            </div>
            <button type="button" onclick="revokeAll()" class="mud-button-root mud-button mud-button-outlined mud-button-outlined-error mud-ripple" style="height:40px;padding:0 16px;font-weight:600;font-size:.875rem;">
                <span class="mud-button-label">Đăng xuất tất cả</span>
            </button>
        </div>
        <div id="pm-sessions-list">
            <div style="text-align:center;padding:32px;"><div class="mud-progress-circular mud-progress-circular-indeterminate" style="width:32px;height:32px;margin:0 auto;"><svg viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle></svg></div></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function loadSessions() {
    const items = await pmApi.get('/api/sessions') || [];
    const list = document.getElementById('pm-sessions-list');
    if (!items.length) { list.innerHTML = '<div class="pm-empty"><p class="pm-empty-title">Không có phiên nào</p></div>'; return; }
    list.innerHTML = items.map(s => `
        <div class="pm-card" style="padding:14px 16px;margin-bottom:8px;display:flex;align-items:center;gap:12px;">
            <div style="flex:1;">
                <p style="margin:0;font-weight:700;font-size:.875rem;">${pmEscape(s.deviceInfo||'Thiết bị không xác định')}</p>
                <p style="margin:0;font-size:.75rem;color:var(--mud-palette-text-secondary);">IP: ${pmEscape(s.ipAddress||'')} · Hoạt động: ${pmFmt.time(s.lastActive)}</p>
                ${s.isCurrent ? '<span style="font-size:.7rem;background:rgba(34,197,94,.1);color:#16A34A;border-radius:999px;padding:2px 8px;font-weight:700;">Hiện tại</span>' : ''}
            </div>
            ${!s.isCurrent ? `<button type="button" onclick="revokeSession(${s.id})" class="mud-button-root mud-button mud-button-outlined mud-button-outlined-error mud-ripple" style="height:34px;padding:0 12px;font-size:.8rem;font-weight:600;"><span class="mud-button-label">Đăng xuất</span></button>` : ''}
        </div>
    `).join('');
}

async function revokeSession(id) {
    await pmApi.delete('/api/sessions/' + id);
    pmToast.success('Đã đăng xuất phiên');
    loadSessions();
}

async function revokeAll() {
    if (!confirm('Đăng xuất tất cả các thiết bị khác?')) return;
    await pmApi.delete('/api/sessions/others');
    pmToast.success('Đã đăng xuất tất cả phiên khác');
    loadSessions();
}

document.addEventListener('DOMContentLoaded', loadSessions);
</script>
}
