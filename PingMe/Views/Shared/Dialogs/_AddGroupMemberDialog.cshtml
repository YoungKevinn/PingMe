<!-- Add Group Member Dialog -->
<div id="pm-add-member-dialog" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center;">
    <div style="background:var(--mud-palette-surface);border-radius:12px;max-width:480px;width:90%;box-shadow:0 16px 48px rgba(0,0,0,.2);display:flex;flex-direction:column;max-height:min(90vh, 720px);">
        
        <!-- Header -->
        <div class="pm-dialog-title" style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 20px 10px;">
            <div>
                <h6 class="mud-typography mud-typography-h6" style="margin:0;font-size:1.25rem;font-weight:600;">Thêm thành viên</h6>
                <span class="mud-typography mud-typography-caption mud-secondary-text" id="pm-add-member-group-name" style="font-size:0.75rem;color:var(--mud-palette-text-secondary);display:none;"></span>
            </div>
            <button type="button" class="mud-button-root mud-icon-button mud-icon-button-size-small" onclick="pmDialogs.closeAddMember()" style="color:var(--mud-palette-text-secondary);">
                <span class="mud-icon-button-label">
                    <span class="mud-icon-root mud-svg-icon" style="font-size:20px;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                    </span>
                </span>
            </button>
        </div>

        <!-- Body -->
        <div class="pm-dialog-body" style="padding:8px 20px 16px;overflow:auto;">
            <!-- Loading state -->
            <div id="pm-add-member-loading" style="min-height:160px;display:flex;align-items:center;justify-content:center;">
                <div class="mud-progress-circular mud-progress-circular-indeterminate" style="width:32px;height:32px;margin:0 auto;color:var(--mud-palette-primary);">
                    <svg viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle></svg>
                </div>
            </div>

            <!-- Empty state -->
            <div id="pm-add-member-empty" style="display:none;">
                <div class="mud-alert mud-alert-filled-info mud-elevation-0" style="padding:6px 16px;border-radius:8px;background:rgba(59,130,246,0.1);color:#3B82F6;">
                    <div class="mud-alert-position">Không có bạn bè phù hợp để thêm vào nhóm.</div>
                </div>
            </div>

            <!-- Content state -->
            <div id="pm-add-member-content" style="display:none;">
                <div style="position:relative;margin-bottom:12px;">
                    <span style="position:absolute;left:12px;top:50%;transform:translateY(-50%);display:flex;align-items:center;pointer-events:none;color:var(--mud-palette-text-secondary);">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                    </span>
                    <input type="search" id="pm-add-member-search" placeholder="Tìm bạn bè..."
                           oninput="pmDialogs.filterAddMember(this.value)"
                           style="width:100%;padding:10px 12px 10px 38px;border:1px solid var(--mud-palette-divider);border-radius:999px;background:var(--mud-palette-background);color:var(--mud-palette-text-primary);font-size:.875rem;outline:none;font-family:inherit;" />
                </div>

                <div id="pm-add-member-list" style="max-height:320px;overflow:auto;display:flex;flex-direction:column;gap:6px;">
                    <!-- Injected by JS -->
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="pm-dialog-actions" style="display:flex;align-items:center;justify-content:flex-end;gap:8px;padding:8px 20px 16px;">
            <button type="button" class="mud-button-root mud-button mud-button-text mud-button-text-default mud-ripple" onclick="pmDialogs.closeAddMember()">
                <span class="mud-button-label">Đóng</span>
            </button>
            <button type="button" id="pm-add-member-btn" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple" onclick="pmDialogs.submitAddMember()" disabled>
                <span class="mud-button-label">Thêm</span>
            </button>
        </div>
    </div>
</div>

<style>
.pm-member-picker-row {
    width: 100%;
    border: 1px solid var(--mud-palette-divider);
    border-radius: 10px;
    background: var(--mud-palette-surface);
    color: var(--mud-palette-text-primary);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    cursor: pointer;
    text-align: left;
    transition: all 0.15s ease;
}
.pm-member-picker-row:hover, .pm-member-picker-row.selected {
    border-color: var(--mud-palette-primary);
    background: rgba(59, 130, 246, .10);
}
</style>
