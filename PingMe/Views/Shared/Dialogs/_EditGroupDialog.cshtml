<!-- Edit Group Dialog -->
<div id="pm-edit-group-dialog" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center;">
    <div style="background:var(--mud-palette-surface);border-radius:12px;max-width:400px;width:90%;box-shadow:0 16px 48px rgba(0,0,0,.2);display:flex;flex-direction:column;max-height:min(90vh, 720px);">
        
        <!-- Header -->
        <div class="pm-dialog-title" style="display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--mud-palette-divider);">
            <h6 class="mud-typography mud-typography-h6" style="margin:0;font-size:1.25rem;font-weight:700;">Đổi tên & ảnh nhóm</h6>
            <button type="button" class="mud-button-root mud-icon-button mud-icon-button-size-small" onclick="pmDialogs.closeEditGroup()" style="color:var(--mud-palette-text-secondary);">
                <span class="mud-icon-button-label">
                    <span class="mud-icon-root mud-svg-icon" style="font-size:20px;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                    </span>
                </span>
            </button>
        </div>

        <!-- Body -->
        <div class="pm-dialog-body" style="padding:24px;display:flex;flex-direction:column;gap:24px;overflow:auto;">
            <div style="display:flex;flex-direction:column;align-items:center;gap:16px;">
                <div class="mud-avatar mud-avatar-large mud-avatar-filled mud-avatar-filled-primary" style="width:100px;height:100px;font-size:3rem;position:relative;overflow:hidden;">
                    <span id="pm-edit-group-avatar-initial" style="font-weight:700;">?</span>
                    <img id="pm-edit-group-avatar-preview" src="" style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                </div>
                
                <input type="file" id="pm-edit-group-file" accept="image/*" style="display:none;" onchange="pmDialogs.handleEditGroupAvatar(this)" />
                <button type="button" class="mud-button-root mud-button mud-button-outlined mud-button-outlined-primary mud-ripple" onclick="document.getElementById('pm-edit-group-file').click()">
                    <span class="mud-button-label" style="display:flex;align-items:center;gap:8px;">
                        <span class="mud-icon-root mud-svg-icon" style="font-size:20px;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM14 13v4h-4v-4H7l5-5 5 5h-3z"/></svg>
                        </span>
                        Tải ảnh lên
                    </span>
                </button>
                <span class="mud-typography mud-typography-caption mud-secondary-text" id="pm-edit-group-filename" style="display:none;"></span>
            </div>

            <div class="mud-input-control mud-input-input-control">
                <div class="mud-input-control-input-container">
                    <div class="mud-input mud-input-outlined">
                        <input type="text" id="pm-edit-group-name" placeholder=" " class="mud-input-slot mud-input-root mud-input-root-outlined" maxlength="100" />
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol">Tên nhóm</label>
                        <div class="mud-input-outlined-border"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="pm-dialog-actions" style="border-top:1px solid var(--mud-palette-divider);padding:16px 24px;display:flex;align-items:center;justify-content:flex-end;gap:12px;">
            <button type="button" class="mud-button-root mud-button mud-button-text mud-button-text-default mud-ripple" onclick="pmDialogs.closeEditGroup()">
                <span class="mud-button-label">Hủy</span>
            </button>
            <button type="button" id="pm-edit-group-btn" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple" onclick="pmDialogs.submitEditGroup()">
                <span class="mud-button-label" id="pm-edit-group-btn-label" style="font-weight:600;">Lưu thay đổi</span>
                <span id="pm-edit-group-btn-loading" style="display:none;align-items:center;">
                    <div class="mud-progress-circular mud-progress-circular-indeterminate ms-n1 mud-progress-circular-small" style="width:20px;height:20px;"><svg viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle></svg></div>
                    <span class="ms-2">Đang lưu...</span>
                </span>
            </button>
        </div>
    </div>
</div>
