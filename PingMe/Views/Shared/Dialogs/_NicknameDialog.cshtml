<!-- Nickname Dialog -->
<div id="pm-nickname-dialog" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9000;align-items:center;justify-content:center;">
    <div style="background:var(--mud-palette-surface);border-radius:12px;max-width:400px;width:90%;box-shadow:0 16px 48px rgba(0,0,0,.2);display:flex;flex-direction:column;max-height:min(90vh, 720px);">
        
        <!-- Header -->
        <div class="pm-dialog-title" style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px 10px;">
            <h6 class="mud-typography mud-typography-h6" style="margin:0;font-size:1.25rem;font-weight:600;">Đặt biệt danh</h6>
            <button type="button" class="mud-button-root mud-icon-button mud-icon-button-size-small" onclick="pmDialogs.closeNickname()" style="color:var(--mud-palette-text-secondary);">
                <span class="mud-icon-button-label">
                    <span class="mud-icon-root mud-svg-icon" style="font-size:20px;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                    </span>
                </span>
            </button>
        </div>

        <!-- Body -->
        <div class="pm-dialog-body" style="padding:8px 20px 16px;overflow:auto;">
            <div class="mud-input-control mud-input-input-control">
                <div class="mud-input-control-input-container">
                    <div class="mud-input mud-input-outlined">
                        <input type="text" id="pm-nickname-input" placeholder=" " class="mud-input-slot mud-input-root mud-input-root-outlined" maxlength="100" />
                        <label class="mud-input-label mud-input-label-animated mud-input-label-outlined mud-input-label-inputcontrol">Biệt danh</label>
                        <div class="mud-input-outlined-border"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="pm-dialog-actions" style="display:flex;align-items:center;justify-content:flex-end;gap:8px;padding:8px 20px 16px;">
            <button type="button" class="mud-button-root mud-button mud-button-text mud-button-text-default mud-ripple" onclick="pmDialogs.closeNickname()">
                <span class="mud-button-label">Đóng</span>
            </button>
            <button type="button" id="pm-nickname-btn" class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple" onclick="pmDialogs.submitNickname()">
                <span class="mud-button-label">Lưu</span>
            </button>
        </div>
    </div>
</div>
