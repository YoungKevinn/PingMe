@{
    ViewData["Title"] = "Tin nhắn - PingMe";
}

<div style="display:flex;height:100%;overflow:hidden;background:var(--mud-palette-background);">

    <!-- ========== CONVERSATION SIDEBAR ========== -->
    <div id="pm-conv-sidebar"
         style="width:300px;min-width:260px;max-width:320px;border-right:1px solid rgba(0,0,0,.07);
                background:var(--mud-palette-surface);overflow:hidden;flex-shrink:0;display:flex;flex-direction:column;">

        <!-- Sidebar header -->
        <div style="height:56px;min-height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid rgba(0,0,0,.06);flex-shrink:0;">
            <h6 style="margin:0;font-size:1rem;font-weight:700;color:var(--mud-palette-text-primary);">Tin nhắn</h6>
            <button type="button" id="pm-new-dm-btn" title="Tin nhắn mới"
                    class="mud-button-root mud-icon-button mud-icon-button-color-primary mud-ripple mud-icon-button-size-small"
                    onclick="pmChat.openNewDm && pmChat.openNewDm()">
                <span class="mud-icon-button-label">
                    <svg class="mud-icon-root mud-svg-icon mud-icon-size-small" viewBox="0 0 24 24">
                        <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
                    </svg>
                </span>
            </button>
        </div>

        <!-- Conversation search -->
        <div style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,.04);">
            <div class="mud-input-control mud-input-input-control" style="margin:0;">
                <div class="mud-input-control-input-container">
                    <div class="mud-input mud-input-outlined mud-input-adorned-start mud-input-margin-dense" style="border-radius:20px;">
                        <div class="mud-input-adornment mud-input-adornment-start">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24" style="color:var(--mud-palette-text-secondary);"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                        </div>
                        <input type="search" id="pm-conv-search" placeholder="Tìm kiếm..."
                               oninput="pmChat.filterConvs(this.value)"
                               class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-adorned-start mud-input-root-margin-dense"
                               style="border-radius:20px;font-size:.875rem;" />
                        <div class="mud-input-outlined-border"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Conversation list -->
        <div id="pm-conv-list" class="mud-list mud-list-padding" style="flex:1;overflow-y:auto;padding:4px 0;">
            <div id="pm-conv-empty" style="display:none;padding:32px 16px;text-align:center;">
                <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24" style="font-size:48px;opacity:.2;color:var(--mud-palette-primary);margin:0 auto;display:block;">
                    <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/>
                </svg>
                <p class="mud-typography mud-typography-subtitle1" style="margin-top:16px;">Chưa có hội thoại nào</p>
                <p class="mud-typography mud-typography-body2" style="color:var(--mud-palette-text-secondary);">Bắt đầu cuộc trò chuyện mới</p>
            </div>
            <!-- Conversations injected by JS -->
        </div>
    </div>

    <!-- ========== CHAT AREA ========== -->
    <div id="pm-chat-area" style="flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;">

        <!-- Empty state (no conversation selected) -->
        <div id="pm-empty-state" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:32px;">
            <div style="width:80px;height:80px;background:linear-gradient(135deg,#2563EB,#60A5FA);border-radius:24px;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(37,99,235,.3);">
                <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24" style="font-size:40px;color:white;">
                    <path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
                </svg>
            </div>
            <div style="text-align:center;">
                <h5 class="mud-typography mud-typography-h5" style="margin:0 0 4px;font-weight:700;">
                    Chọn một cuộc trò chuyện
                </h5>
                <p class="mud-typography mud-typography-body2" style="margin:0;color:#94A3B8;max-width:280px;">
                    Chọn từ danh sách hoặc bắt đầu cuộc hội thoại mới
                </p>
            </div>
        </div>

        <!-- Active chat (hidden until a conv is selected) -->
        <div id="pm-chat-wrapper" style="display:none;flex:1;flex-direction:column;overflow:hidden;">

            <!-- Chat header -->
            <div class="mud-toolbar mud-toolbar-regular mud-elevation-1" id="pm-chat-header" style="background:var(--mud-palette-surface); z-index:10; border-bottom:1px solid rgba(0,0,0,.06);">
                <div id="pm-chat-avatar" style="flex-shrink:0; margin-right:12px;">
                </div>

                <div style="flex:1; min-width:0;">
                    <h6 class="mud-typography mud-typography-subtitle1" id="pm-chat-title" style="margin:0; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></h6>
                    <p class="mud-typography mud-typography-body2" id="pm-chat-subtitle" style="margin:0; color:var(--mud-palette-text-secondary); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"></p>
                </div>

                <!-- Call buttons (DM only) -->
                <div id="pm-call-btns" style="display:none;align-items:center;gap:4px;">
                    <button type="button" title="Gọi thoại"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            style="color:var(--mud-palette-text-secondary);"
                            onclick="pmChat.initiateCall(false)">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                        </span>
                    </button>
                    <button type="button" title="Gọi video"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            style="color:var(--mud-palette-text-secondary);"
                            onclick="pmChat.initiateCall(true)">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/></svg>
                        </span>
                    </button>
                </div>

                <!-- Pin panel toggle -->
                <div style="position:relative;display:inline-flex;">
                    <button type="button" id="pm-pin-toggle" title="Tin nhắn đã ghim"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            onclick="pmChat.togglePinPanel()"
                            style="color:var(--mud-palette-text-secondary);">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"/></svg>
                        </span>
                    </button>
                    <span id="pm-pin-count-badge" class="pm-pin-count-badge" style="display:none;"></span>
                </div>

                <!-- In-chat search -->
                <button type="button" title="Tìm trong đoạn chat"
                        class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                        onclick="pmChat.toggleMsgSearch()"
                        style="color:var(--mud-palette-text-secondary);">
                    <span class="mud-icon-button-label">
                        <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                    </span>
                </button>

                <!-- More menu -->
                <div class="pm-chat-more-menu" style="position:relative;">
                    <button type="button" id="pm-more-btn" title="Tùy chọn"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small pm-chat-more-btn"
                            onclick="pmChat.toggleMoreMenu(event)"
                            style="color:var(--mud-palette-text-secondary);">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
                        </span>
                    </button>

                    <div id="pm-more-dropdown" class="pm-chat-more-dropdown" style="display:none;">
                        <!-- Items injected by JS based on conv type (group/dm) -->
                    </div>
                </div>
            </div>

            <!-- In-chat search bar (hidden) -->
            <div id="pm-msg-search-bar" class="pm-chat-search-bar" style="display:none;">
                <div style="display:flex;gap:8px;align-items:center;flex:1;">
                    <div class="mud-input mud-input-outlined mud-input-adorned-start mud-input-margin-dense" style="flex:1;">
                        <div class="mud-input-adornment mud-input-adornment-start">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-medium" viewBox="0 0 24 24" style="color:var(--mud-palette-text-secondary);"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                        </div>
                        <input type="search" id="pm-msg-search-input" placeholder="Tìm kiếm trong đoạn chat..."
                               oninput="pmChat.searchMessages(this.value)"
                               class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-adorned-start mud-input-root-margin-dense"
                               style="font-size:.875rem;" />
                        <div class="mud-input-outlined-border"></div>
                    </div>
                    <span id="pm-msg-search-count" style="font-size:.8rem;color:var(--mud-palette-text-secondary);min-width:50px;text-align:center;"></span>
                    <button type="button" onclick="pmChat.searchMsgPrev && pmChat.searchMsgPrev()"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            style="color:var(--mud-palette-text-secondary);">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-small" viewBox="0 0 24 24"><path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"/></svg>
                        </span>
                    </button>
                    <button type="button" onclick="pmChat.searchMsgNext && pmChat.searchMsgNext()"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            style="color:var(--mud-palette-text-secondary);">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-small" viewBox="0 0 24 24"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"/></svg>
                        </span>
                    </button>
                    <button type="button" onclick="pmChat.toggleMsgSearch()"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            style="color:var(--mud-palette-text-secondary);">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon mud-icon-size-small" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                        </span>
                    </button>
                </div>
            </div>

            <!-- Messages + pin panel overlay container -->
            <div style="flex:1;overflow:hidden;position:relative;">

                <!-- Kicked from group banner -->
                <div id="pm-kicked-banner" class="mud-alert mud-alert-filled mud-alert-filled-error" style="display:none; border-radius:0;">
                    <div class="mud-alert-message">Bạn đã bị xóa khỏi nhóm này.</div>
                </div>

                <!-- Messages area -->
                <div id="msgScroll"
                     style="height:100%;overflow-y:auto;padding:12px 16px;display:flex;flex-direction:column;gap:2px;background:var(--mud-palette-background);">
                    <div id="pm-msgs-loading" style="display:none;text-align:center;padding:20px;">
                        <div class="mud-progress-circular mud-progress-circular-indeterminate mud-progress-circular-color-primary" style="width:32px;height:32px;margin:0 auto;">
                            <svg viewBox="22 22 44 44"><circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle></svg>
                        </div>
                    </div>
                    <!-- Messages injected by JS -->
                </div>

                <!-- Pin panel (overlay on right) -->
                <div id="pm-pin-panel" class="mud-paper mud-elevation-4" style="display:none; position:absolute; right:0; top:0; bottom:0; width:320px; z-index:50; background:var(--mud-palette-surface); border-left:1px solid var(--mud-palette-divider); display:flex; flex-direction:column;">
                    <div class="mud-toolbar mud-toolbar-dense" style="border-bottom:1px solid var(--mud-palette-divider);">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24" style="color:#F59E0B; margin-right:8px;"><path d="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z"/></svg>
                        <h6 class="mud-typography mud-typography-subtitle1" style="flex:1; margin:0;">Tin nhắn đã ghim</h6>
                        <button type="button" onclick="pmChat.togglePinPanel()" class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small">
                            <span class="mud-icon-button-label">
                                <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                            </span>
                        </button>
                    </div>
                    <div id="pm-pin-list" class="mud-list mud-list-padding" style="flex:1; overflow-y:auto;">
                        <!-- Pins injected by JS -->
                    </div>
                </div>
            </div>

            <!-- Typing indicator -->
            <div id="pm-typing-area" style="padding:0 16px 4px;flex-shrink:0;min-height:0;"></div>

            <!-- Reply-to preview -->
            <div id="pm-reply-preview" style="display:none;padding:8px 16px 0;background:var(--mud-palette-surface);">
                <div class="mud-paper mud-elevation-0" style="background:rgba(37,99,235,.06);border-left:3px solid #2563EB;border-radius:0 8px 8px 0;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;">
                    <div style="min-width:0;">
                        <p class="mud-typography mud-typography-subtitle2" id="pm-reply-author" style="margin:0 0 2px;color:#2563EB;"></p>
                        <p class="mud-typography mud-typography-body2" id="pm-reply-text" style="margin:0;color:var(--mud-palette-text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:300px;"></p>
                    </div>
                    <button type="button" onclick="pmChat.cancelReply()"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                            style="flex-shrink:0;">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                        </span>
                    </button>
                </div>
            </div>

            <!-- File preview -->
            <div id="pm-file-preview" style="display:none;padding:4px 16px;flex-shrink:0;"></div>

            <!-- Message input -->
            <div class="mud-paper mud-elevation-1" id="pm-input-area" style="padding:12px 16px; display:flex; align-items:center; gap:8px; background:var(--mud-palette-surface); z-index:10; border-top:1px solid rgba(0,0,0,.06);">
                <!-- Recording bar (shown only while recording) -->
                <div id="pm-recording-bar" style="display:none;align-items:center;gap:10px;flex:1;">
                    <span style="display:inline-flex;align-items:center;color:var(--mud-palette-error);font-weight:600;">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24" style="width:20px;height:20px;margin-right:8px;animation:pm-rec-pulse 1s infinite;fill:currentColor;"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5-3c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
                        <span>Đang ghi âm...</span>
                    </span>
                    <span id="pm-record-time" style="font-variant-numeric:tabular-nums;color:var(--mud-palette-text-secondary);font-weight:600;">00:00</span>
                    <button type="button" title="Hủy" onclick="pmChat.cancelRecording()"
                            class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small" style="color:var(--mud-palette-text-secondary);margin-left:auto;">
                        <span class="mud-icon-button-label"><svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg></span>
                    </button>
                </div>

                <!-- Normal input controls -->
                <div id="pm-input-normal" style="display:flex;align-items:center;gap:8px;flex:1;">
                <!-- TTL (self-destruct) button -->
                <div style="position:relative;">
                    <button type="button" id="pm-ttl-btn" class="mud-button-root mud-icon-button mud-ripple"
                            title="Tin nhắn tự xóa"
                            onclick="pmChat.toggleTtlMenu(event)"
                            style="color:var(--mud-palette-text-secondary);">
                        <span class="mud-icon-button-label">
                            <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M13 3a9 9 0 1 0 0 18A9 9 0 0 0 13 3zm0 16A7 7 0 1 1 13 5a7 7 0 0 1 0 14zm.5-11H12v6l5.25 3.15L18 15.65l-4.5-2.65V8z"/></svg>
                        </span>
                    </button>
                    <div id="pm-ttl-menu" style="display:none;position:absolute;bottom:calc(100% + 4px);left:0;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.2);z-index:6000;min-width:160px;padding:6px;">
                        <div style="padding:4px 12px 6px;font-size:.72rem;font-weight:700;color:var(--mud-palette-text-secondary);letter-spacing:.04em;">TỰ XÓA SAU</div>
                        <button type="button" onclick="pmChat.setTtl(300)" style="width:100%;text-align:left;padding:7px 12px;background:none;border:none;cursor:pointer;font-size:.87rem;border-radius:8px;color:var(--mud-palette-text-primary);" onmouseover="this.style.background='var(--mud-palette-action-hover)'" onmouseout="this.style.background='none'">5 phút</button>
                        <button type="button" onclick="pmChat.setTtl(3600)" style="width:100%;text-align:left;padding:7px 12px;background:none;border:none;cursor:pointer;font-size:.87rem;border-radius:8px;color:var(--mud-palette-text-primary);" onmouseover="this.style.background='var(--mud-palette-action-hover)'" onmouseout="this.style.background='none'">1 giờ</button>
                        <button type="button" onclick="pmChat.setTtl(86400)" style="width:100%;text-align:left;padding:7px 12px;background:none;border:none;cursor:pointer;font-size:.87rem;border-radius:8px;color:var(--mud-palette-text-primary);" onmouseover="this.style.background='var(--mud-palette-action-hover)'" onmouseout="this.style.background='none'">1 ngày</button>
                        <button type="button" onclick="pmChat.setTtl(604800)" style="width:100%;text-align:left;padding:7px 12px;background:none;border:none;cursor:pointer;font-size:.87rem;border-radius:8px;color:var(--mud-palette-text-primary);" onmouseover="this.style.background='var(--mud-palette-action-hover)'" onmouseout="this.style.background='none'">7 ngày</button>
                        <hr style="margin:4px 0;border:none;border-top:1px solid var(--mud-palette-divider);">
                        <button type="button" onclick="pmChat.setTtl(0)" style="width:100%;text-align:left;padding:7px 12px;background:none;border:none;cursor:pointer;font-size:.87rem;border-radius:8px;color:var(--mud-palette-error);" onmouseover="this.style.background='var(--mud-palette-action-hover)'" onmouseout="this.style.background='none'">Hủy tự xóa</button>
                    </div>
                </div>

                <!-- Emoji button -->
                <button type="button" class="mud-button-root mud-icon-button mud-ripple" title="Emoji"
                        onclick="pmChat.toggleEmoji(event)">
                    <span class="mud-icon-button-label">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/></svg>
                    </span>
                </button>

                <!-- Poll button -->
                <button type="button" class="mud-button-root mud-icon-button mud-ripple" title="Tạo bình chọn"
                        onclick="pmChat.openPollModal()" style="color:var(--mud-palette-text-secondary);">
                    <span class="mud-icon-button-label">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/></svg>
                    </span>
                </button>

                <!-- Attachment button -->
                <label for="pm-file-input" class="mud-button-root mud-icon-button mud-ripple" title="Đính kèm file" style="cursor:pointer; display:inline-flex;">
                    <span class="mud-icon-button-label">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/></svg>
                    </span>
                </label>

                <!-- Mic / voice record button -->
                <button type="button" id="pm-mic-btn" class="mud-button-root mud-icon-button mud-ripple" title="Ghi âm"
                        onclick="pmChat.startRecording()" style="color:var(--mud-palette-text-secondary);">
                    <span class="mud-icon-button-label">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3zm5-3c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z"/></svg>
                    </span>
                </button>

                <!-- Text input -->
                <div class="mud-input-control mud-input-input-control" style="flex:1; margin:0; position:relative;">
                    <div id="pm-mention-dropdown" style="display:none; position:absolute; bottom:100%; left:12px; margin-bottom:8px; width:240px; max-height:200px; overflow-y:auto; background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:10px; box-shadow:0 8px 30px rgba(0,0,0,0.3); z-index:1000; padding:4px 0;"></div>
                    <div class="mud-input-control-input-container">
                        <div class="mud-input mud-input-outlined mud-input-margin-dense" style="border-radius:20px; background:var(--mud-palette-background);">
                            <textarea id="pm-msg-input" rows="1" placeholder="Nhập tin nhắn..."
                                      onkeydown="pmChat.handleKeydown(event)"
                                      oninput="pmChat.handleInput(event)"
                                      class="mud-input-slot mud-input-root mud-input-root-outlined mud-input-root-margin-dense" style="border-radius:20px; padding:10px 14px; max-height:120px;"></textarea>
                            <div class="mud-input-outlined-border"></div>
                        </div>
                    </div>
                </div>

                </div><!-- /pm-input-normal -->

                <!-- Send button -->
                <button type="button" id="pm-send-btn" class="mud-button-root mud-icon-button mud-ripple mud-icon-button-color-primary"
                        onclick="pmChat.onSendClick()">
                    <span class="mud-icon-button-label">
                        <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                    </span>
                </button>

                <!-- File input (hidden) -->
                <input type="file" id="pm-file-input" multiple style="display:none;" onchange="pmChat.handleFileSelect(this)" />
            </div>
        </div>
    </div>
</div>

<!-- Emoji picker (simple) -->
<div id="pm-emoji-picker" style="display:none;position:fixed;z-index:5000;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:16px;padding:10px;box-shadow:0 18px 44px rgba(0,0,0,.35);width:248px;max-height:220px;overflow-y:auto;">
    <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:6px;">
        @foreach (var emoji in new[] { "😀", "😂", "😍", "🤩", "😎", "🥳", "😊", "🤔", "😮", "😢", "😡", "🤗", "👍", "👎", "❤️", "🔥", "✅", "⭐", "🎉", "💯", "🙏", "💪", "👋", "🤝" })
        {
            <button type="button" class="pm-emoji-btn"
                    onclick="pmChat.insertEmoji('@emoji')"
                    style="background:none;border:none;cursor:pointer;font-size:22px;line-height:1;padding:7px 0;border-radius:10px;"
                    onmouseover="this.style.background='rgba(59,130,246,.12)'" onmouseout="this.style.background='none'">@emoji</button>
        }
    </div>
</div>

<!-- Reaction picker -->
<div id="pm-reaction-picker" style="display:none;position:fixed;z-index:5000;background:var(--mud-palette-surface);border:1px solid var(--mud-palette-divider);border-radius:999px;padding:8px 12px;box-shadow:0 4px 20px rgba(0,0,0,.15);gap:8px;">
    @foreach (var emoji in new[] { "👍", "❤️", "😂", "😮", "😢", "🔥", "✅", "👎" })
    {
        <button type="button" class="pm-reaction-emoji-btn" data-emoji="@emoji"
                onclick="pmChat.addReactionActive('@emoji')"
                style="background:none;border:none;cursor:pointer;font-size:1.3rem;padding:2px;border-radius:4px;line-height:1;transition:.1s ease;"
                onmouseover="this.style.transform='scale(1.3)'" onmouseout="this.style.transform='scale(1)'">@emoji</button>
    }
</div>

<!-- Forward message dialog -->
<div id="pm-forward-modal" style="display:none;position:fixed;inset:0;background:rgba(2,6,23,.6);z-index:9000;align-items:center;justify-content:center;backdrop-filter:blur(3px);"
     onclick="if(event.target===this)pmChat.closeForwardModal()">
    <div class="mud-paper mud-elevation-24" style="width:100%;max-width:420px;border-radius:16px;overflow:hidden;background:var(--mud-palette-surface);">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--mud-palette-divider);">
            <h6 class="mud-typography mud-typography-h6" style="margin:0;font-weight:700;">Chuyển tiếp tin nhắn</h6>
            <button type="button" onclick="pmChat.closeForwardModal()"
                    class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                    style="color:var(--mud-palette-text-secondary);">
                <span class="mud-icon-button-label">
                    <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                </span>
            </button>
        </div>
        <div id="pm-forward-list" style="max-height:380px;overflow-y:auto;padding:8px;">
        </div>
    </div>
</div>

<!-- Confirm dialog -->
<div id="pm-confirm-overlay" style="display:none;position:fixed;inset:0;background:var(--mud-palette-overlay-dark);z-index:8000;align-items:center;justify-content:center;backdrop-filter:blur(2px);">
    <div class="mud-paper mud-elevation-24 mud-dialog" style="width:100%;max-width:400px;border-radius:12px;">
        <div class="mud-dialog-title" style="padding:16px 24px;">
            <h6 class="mud-typography mud-typography-h6" id="pm-confirm-title" style="margin:0;"></h6>
        </div>
        <div class="mud-dialog-content" style="padding:0 24px 20px;">
            <p class="mud-typography mud-typography-body1" id="pm-confirm-text" style="margin:0;color:var(--mud-palette-text-secondary);"></p>
        </div>
        <div class="mud-dialog-actions" style="padding:8px 24px 16px;">
            <button type="button" class="mud-button-root mud-button mud-button-text mud-button-text-default mud-ripple" onclick="pmChat.confirmCancel()">
                <span class="mud-button-label">Hủy</span>
            </button>
            <button type="button" id="pm-confirm-ok" class="mud-button-root mud-button mud-button-filled mud-button-filled-error mud-ripple" onclick="pmChat.confirmOk()" style="margin-left:8px;">
                <span class="mud-button-label" id="pm-confirm-ok-text">Xác nhận</span>
            </button>
        </div>
    </div>
</div>

<!-- Poll creation modal -->
<div id="pm-poll-modal" style="display:none;position:fixed;inset:0;background:rgba(2,6,23,.6);z-index:9000;align-items:center;justify-content:center;backdrop-filter:blur(3px);"
     onclick="if(event.target===this)pmChat.closePollModal()">
    <div style="width:100%;max-width:460px;border-radius:16px;overflow:hidden;background:var(--mud-palette-surface);box-shadow:0 24px 64px rgba(0,0,0,.4);">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:18px 20px;border-bottom:1px solid var(--mud-palette-divider);">
            <div style="display:flex;align-items:center;gap:10px;">
                <span style="font-size:1.3rem;">📊</span>
                <h6 style="margin:0;font-weight:700;font-size:1rem;color:var(--mud-palette-text-primary);">Tạo bình chọn</h6>
            </div>
            <button type="button" onclick="pmChat.closePollModal()"
                    class="mud-button-root mud-icon-button mud-ripple mud-icon-button-size-small"
                    style="color:var(--mud-palette-text-secondary);">
                <span class="mud-icon-button-label">
                    <svg class="mud-icon-root mud-svg-icon" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
                </span>
            </button>
        </div>

        <div style="padding:20px;">
            <div style="margin-bottom:16px;">
                <p style="margin:0 0 6px;font-size:.85rem;font-weight:600;color:var(--mud-palette-text-secondary);">Câu hỏi</p>
                <input type="text" id="pm-poll-question" placeholder="Nhập câu hỏi bình chọn..."
                       style="width:100%;padding:10px 14px;border:1.5px solid var(--mud-palette-lines-inputs);border-radius:10px;background:transparent;color:var(--mud-palette-text-primary);font-size:.9rem;outline:none;box-sizing:border-box;"
                       onfocus="this.style.borderColor='var(--mud-palette-primary)'" onblur="this.style.borderColor='var(--mud-palette-lines-inputs)'" />
            </div>

            <div style="margin-bottom:12px;">
                <p style="margin:0 0 8px;font-size:.85rem;font-weight:600;color:var(--mud-palette-text-secondary);">Các lựa chọn</p>
                <div id="pm-poll-options"></div>
                <button type="button" onclick="pmChat.addPollOption()"
                        style="background:none;border:1.5px dashed var(--mud-palette-divider);border-radius:8px;padding:8px 16px;cursor:pointer;font-size:.85rem;color:var(--mud-palette-text-secondary);width:100%;margin-top:4px;"
                        onmouseover="this.style.borderColor='var(--mud-palette-primary)';this.style.color='var(--mud-palette-primary)'"
                        onmouseout="this.style.borderColor='var(--mud-palette-divider)';this.style.color='var(--mud-palette-text-secondary)'">
                    + Thêm lựa chọn
                </button>
            </div>

            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;margin-bottom:20px;">
                <input type="checkbox" id="pm-poll-multiple" style="width:16px;height:16px;accent-color:var(--mud-palette-primary);">
                <span style="font-size:.875rem;color:var(--mud-palette-text-secondary);">Cho phép nhiều lựa chọn</span>
            </label>

            <div style="display:flex;gap:10px;justify-content:flex-end;">
                <button type="button" onclick="pmChat.closePollModal()"
                        class="mud-button-root mud-button mud-button-outlined mud-ripple"
                        style="height:40px;padding:0 20px;font-weight:600;">
                    <span class="mud-button-label">Hủy</span>
                </button>
                <button type="button" onclick="pmChat.submitPoll()"
                        class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-ripple"
                        style="height:40px;padding:0 20px;font-weight:600;">
                    <span class="mud-button-label">Tạo bình chọn</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="/js/chat.js" asp-append-version="true"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    pmChat.init({
        myId:    @ViewBag.MyId,
        myName:  '@Html.Raw((ViewBag.MyName as string ?? "").Replace("\\", "\\\\").Replace("'", "\\'"))',
        peerId:  @(ViewBag.PeerId  != null ? ViewBag.PeerId.ToString()  : "null"),
        groupId: @(ViewBag.GroupId != null ? ViewBag.GroupId.ToString() : "null"),
    });
});
// close more menu when clicking outside
document.addEventListener('click', function(e) {
    var dd = document.getElementById('pm-more-dropdown');
    if (dd && !e.target.closest('#pm-more-btn') && !e.target.closest('#pm-more-dropdown')) {
        dd.style.display = 'none';
    }
});
</script>
}
