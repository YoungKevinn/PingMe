@{
    Layout = "_EmptyLayout";
    ViewData["Title"] = "Đặt lại mật khẩu - PingMe";
    var token = ViewBag.Token as string ?? "";
}

@section Styles {
<style>
/* Strength segments */
.pm-strength-row {
    display: flex;
    gap: 5px;
    margin: 8px 0 4px;
}
.pm-strength-seg {
    flex: 1;
    height: 4px;
    border-radius: 2px;
    background: var(--mud-palette-divider);
    transition: background .25s;
}
.pm-strength-label {
    font-size: .75rem;
    font-weight: 500;
    min-height: 16px;
    margin-bottom: 12px;
    padding-left: 2px;
    transition: color .25s;
}
.pm-match-msg {
    font-size: .75rem;
    font-weight: 500;
    min-height: 16px;
    margin-top: 6px;
    padding-left: 2px;
}
</style>
}

<div class="pm-auth-wrapper">
    <div class="pm-auth-card">

        @if (ViewBag.Done == true)
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon" style="background:linear-gradient(135deg,#16a34a,#22c55e);">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="color:white;width:28px;height:28px;fill:currentColor;">
                        <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                    </svg>
                </div>
                <div class="pm-auth-heading">
                    <p class="pm-auth-title">Đặt lại thành công!</p>
                    <p class="pm-auth-subtitle">Bạn có thể đăng nhập bằng mật khẩu mới ngay bây giờ</p>
                </div>
            </div>
            <a href="/auth/login"
               class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-full-width mud-ripple"
               style="height:46px;font-size:.9375rem;font-weight:600;letter-spacing:.02em;width:100%;border-radius:8px;display:flex;align-items:center;justify-content:center;text-decoration:none;">
                <span class="mud-button-label">Đăng nhập ngay</span>
            </a>
        }
        else
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="color:white;width:28px;height:28px;fill:currentColor;">
                        <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
                    </svg>
                </div>
                <div class="pm-auth-heading">
                    <p class="pm-auth-title">Đặt mật khẩu mới</p>
                    <p class="pm-auth-subtitle">Nhập mật khẩu mới cho tài khoản của bạn</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error as string))
            {
                <div class="mud-alert mud-alert-filled mud-alert-filled-error"
                     style="margin-bottom:16px;border-radius:10px;padding:12px 16px;">
                    <div class="mud-alert-message">@ViewBag.Error</div>
                </div>
            }

            <form method="post" action="/auth/reset-password" onsubmit="return handleResetSubmit(event)">
                @Html.AntiForgeryToken()
                <input type="hidden" name="token" value="@token" />

                <!-- Mật khẩu mới -->
                <div class="pm-field mb-1">
                    <span class="pm-field-start-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                    </span>
                    <input type="password" id="rp-pw" name="newPassword" required
                           placeholder=" "
                           class="pm-field-input has-start-icon has-end-icon"
                           autocomplete="new-password"
                           oninput="onPwInput(this.value)" />
                    <label class="pm-field-label has-start-icon" for="rp-pw">Mật khẩu mới</label>
                    <button type="button" class="pm-field-end-btn" onclick="togglePw('rp-pw','eye1')" tabindex="-1" aria-label="Hiện/ẩn mật khẩu">
                        <span id="eye1"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg></span>
                    </button>
                </div>

                <!-- Strength indicator -->
                <div class="pm-strength-row">
                    <div class="pm-strength-seg" id="seg0"></div>
                    <div class="pm-strength-seg" id="seg1"></div>
                    <div class="pm-strength-seg" id="seg2"></div>
                    <div class="pm-strength-seg" id="seg3"></div>
                </div>
                <p class="pm-strength-label" id="rp-strength-label" style="color:var(--mud-palette-text-secondary);">Tối thiểu 8 ký tự</p>

                <!-- Xác nhận mật khẩu -->
                <div class="pm-field mb-1">
                    <span class="pm-field-start-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                    </span>
                    <input type="password" id="rp-pw2" name="confirmPassword" required
                           placeholder=" "
                           class="pm-field-input has-start-icon has-end-icon"
                           autocomplete="new-password"
                           oninput="checkMatch()" />
                    <label class="pm-field-label has-start-icon" for="rp-pw2">Xác nhận mật khẩu</label>
                    <button type="button" class="pm-field-end-btn" onclick="togglePw('rp-pw2','eye2')" tabindex="-1" aria-label="Hiện/ẩn mật khẩu">
                        <span id="eye2"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg></span>
                    </button>
                </div>
                <p class="pm-match-msg" id="rp-match-msg" style="display:none;margin-bottom:16px;"></p>
                <div id="rp-match-spacer" style="margin-bottom:20px;"></div>

                <button type="submit" id="rp-btn"
                        class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-full-width mud-ripple"
                        style="height:46px;font-size:.9375rem;font-weight:600;letter-spacing:.02em;width:100%;border-radius:8px;">
                    <span class="mud-button-label">
                        <span id="rp-btn-text">Đặt mật khẩu mới</span>
                        <span id="rp-spinner" style="display:none;margin-left:8px;vertical-align:middle;">
                            <svg class="mud-progress-circular mud-progress-circular-indeterminate" style="width:18px;height:18px;" viewBox="22 22 44 44">
                                <circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle>
                            </svg>
                        </span>
                    </span>
                </button>
            </form>

            <div style="text-align:center;margin-top:18px;">
                <a href="/auth/forgot-password"
                   style="font-size:.8125rem;font-weight:500;color:var(--mud-palette-text-secondary);text-decoration:none;opacity:.8;transition:opacity .15s;"
                   onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.8'">
                    ← Yêu cầu link mới
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
const EYE_OPEN = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>';
const EYE_OFF  = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>';

function togglePw(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    const isPassword = input.type === 'password';
    input.type    = isPassword ? 'text' : 'password';
    icon.innerHTML = isPassword ? EYE_OFF : EYE_OPEN;
}

const STRENGTH_LEVELS = [
    { segs: 0, color: '',        label: 'Tối thiểu 8 ký tự',  labelColor: 'var(--mud-palette-text-secondary)' },
    { segs: 1, color: '#ef4444', label: 'Rất yếu',             labelColor: '#ef4444' },
    { segs: 2, color: '#f97316', label: 'Yếu',                 labelColor: '#f97316' },
    { segs: 3, color: '#eab308', label: 'Trung bình',          labelColor: '#eab308' },
    { segs: 4, color: '#22c55e', label: 'Mạnh',                labelColor: '#22c55e' },
];

function calcScore(pw) {
    if (!pw) return 0;
    let s = 0;
    if (pw.length >= 8)  s++;
    if (pw.length >= 12) s++;
    if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) s++;
    if (/\d/.test(pw)) s++;
    if (/[^A-Za-z0-9]/.test(pw)) s++;
    // map 0-5 → 0-4 segments
    if (s === 0) return 0;
    if (s === 1) return 1;
    if (s === 2) return 2;
    if (s <= 3)  return 3;
    return 4;
}

function onPwInput(pw) {
    const idx = calcScore(pw);
    const lvl = STRENGTH_LEVELS[idx];
    for (let i = 0; i < 4; i++) {
        document.getElementById('seg' + i).style.background =
            i < lvl.segs ? lvl.color : 'var(--mud-palette-divider)';
    }
    const lbl = document.getElementById('rp-strength-label');
    lbl.textContent  = lvl.label;
    lbl.style.color  = lvl.labelColor;
    checkMatch();
}

function checkMatch() {
    const pw1 = document.getElementById('rp-pw').value;
    const pw2 = document.getElementById('rp-pw2').value;
    const msg    = document.getElementById('rp-match-msg');
    const spacer = document.getElementById('rp-match-spacer');
    if (!pw2) {
        msg.style.display    = 'none';
        spacer.style.display = 'block';
        return;
    }
    msg.style.display    = 'block';
    spacer.style.display = 'none';
    if (pw1 === pw2) {
        msg.textContent = '✓ Mật khẩu khớp';
        msg.style.color = '#22c55e';
    } else {
        msg.textContent = '✗ Mật khẩu chưa khớp';
        msg.style.color = '#ef4444';
    }
}

function handleResetSubmit(e) {
    const pw1 = document.getElementById('rp-pw').value;
    const pw2 = document.getElementById('rp-pw2').value;
    if (pw1 !== pw2) {
        e.preventDefault();
        const msg = document.getElementById('rp-match-msg');
        const spacer = document.getElementById('rp-match-spacer');
        msg.textContent  = '✗ Mật khẩu chưa khớp';
        msg.style.color  = '#ef4444';
        msg.style.display    = 'block';
        spacer.style.display = 'none';
        return false;
    }
    const btn  = document.getElementById('rp-btn');
    const txt  = document.getElementById('rp-btn-text');
    const spin = document.getElementById('rp-spinner');
    btn.disabled     = true;
    txt.textContent  = 'Đang lưu...';
    spin.style.display = 'inline-flex';
    return true;
}
</script>
}
