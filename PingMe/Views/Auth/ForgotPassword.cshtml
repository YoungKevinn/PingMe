@{
    Layout = "_EmptyLayout";
    ViewData["Title"] = "Quên mật khẩu - PingMe";
}


<div class="pm-auth-wrapper">
    <div class="pm-auth-card" id="pm-fp-card">

        @if (ViewBag.Sent != null)
        {
            <!-- Success state -->
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <span class="mud-icon-root mud-svg-icon" style="color:white;font-size:30px;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                    </span>
                </div>
                <div class="pm-auth-heading">
                    <p class="pm-auth-title">Kiểm tra email</p>
                    <p class="pm-auth-subtitle">Nếu email tồn tại, link đặt lại mật khẩu đã được gửi đến @ViewBag.SentEmail</p>
                </div>
            </div>

            <div class="mud-alert mud-alert-filled mud-alert-filled-info" style="margin-bottom:20px;border-radius:10px;padding:12px 16px;">
                <div class="mud-alert-message">Bấm vào link trong email để đặt mật khẩu mới. Link có hiệu lực trong 1 giờ.</div>
            </div>

            <a href="/auth/login"
               class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-full-width mud-ripple"
               style="height:46px;font-size:.9375rem;font-weight:600;letter-spacing:.02em;width:100%;border-radius:8px;display:flex;align-items:center;justify-content:center;text-decoration:none;">
                <span class="mud-button-label">Đến trang đăng nhập</span>
            </a>
        }
        else
        {
            <!-- Form state -->
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <span class="mud-icon-root mud-svg-icon" style="color:white;font-size:30px;">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>
                    </span>
                </div>
                <div class="pm-auth-heading">
                    <p class="pm-auth-title">Quên mật khẩu</p>
                    <p class="pm-auth-subtitle">Nhập email đã đăng ký để nhận link đặt lại mật khẩu</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Error as string))
            {
                <div class="mud-alert mud-alert-filled mud-alert-filled-error" style="margin-bottom:16px;border-radius:10px;padding:12px 16px;">
                    <div class="mud-alert-message">@ViewBag.Error</div>
                </div>
            }

            <form method="post" action="/auth/forgot-password" onsubmit="return handleFpSubmit(event)">
                @Html.AntiForgeryToken()

                <div class="pm-field mb-4">
                    <span class="pm-field-start-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                    </span>
                    <input type="email" name="Email" id="fp-email" required
                           placeholder=" "
                           class="pm-field-input has-start-icon"
                           autocomplete="email" autofocus />
                    <label class="pm-field-label has-start-icon" for="fp-email">Email</label>
                </div>

                <button type="submit" id="fp-btn"
                        class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-full-width mud-ripple"
                        style="height:46px;font-size:.9375rem;font-weight:600;letter-spacing:.02em;width:100%;border-radius:8px;">
                    <span class="mud-button-label">
                        <span id="fp-btn-text">Gửi link đặt lại</span>
                        <span id="fp-spinner" style="display:none;margin-left:8px;vertical-align:middle;">
                            <svg class="mud-progress-circular mud-progress-circular-indeterminate" style="width:20px;height:20px;" viewBox="22 22 44 44">
                                <circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle>
                            </svg>
                        </span>
                    </span>
                </button>
            </form>

            <div style="text-align:center;margin-top:18px;">
                <a href="/auth/login" style="font-size:.8125rem;font-weight:500;color:var(--mud-palette-text-secondary);text-decoration:none;opacity:.8;transition:opacity .15s;"
                   onmouseover="this.style.opacity=1" onmouseout="this.style.opacity='.8'">← Quay lại đăng nhập</a>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
function handleFpSubmit(e) {
    const btn = document.getElementById('fp-btn');
    const txt = document.getElementById('fp-btn-text');
    const spinner = document.getElementById('fp-spinner');
    setTimeout(() => { btn.disabled = true; }, 10);
    txt.textContent = 'Đang gửi...';
    spinner.style.display = 'inline-flex';
    return true;
}
</script>
}
