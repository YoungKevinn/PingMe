@{
    Layout = "_EmptyLayout";
    ViewData["Title"] = "Đăng ký - PingMe";
}


<div class="pm-auth-wrapper">
    <div class="pm-auth-card">
        <div class="pm-auth-logo">
            <div class="pm-auth-logo-icon">
                <span class="mud-icon-root mud-svg-icon" style="color:white;font-size:30px;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M15 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm-9-2V7H4v3H1v2h3v3h2v-3h3v-2H6zm9 4c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                </span>
            </div>
            <div class="pm-auth-heading">
                <p class="pm-auth-title">Tạo tài khoản</p>
                <p class="pm-auth-subtitle">Tham gia PingMe hôm nay</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(ViewBag.Error as string))
        {
            <div class="mud-alert mud-alert-filled mud-alert-filled-error" style="margin-bottom:16px;border-radius:10px;padding:12px 16px;">
                <div class="mud-alert-message">@ViewBag.Error</div>
            </div>
        }

        <form method="post" action="/auth/register" onsubmit="return handleRegisterSubmit(event)">
            @Html.AntiForgeryToken()

            <!-- Email field -->
            <div class="pm-field mb-3">
                <span class="pm-field-start-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                </span>
                <input type="email" name="Email" required
                       placeholder=" "
                       class="pm-field-input has-start-icon"
                       autocomplete="email" />
                <label class="pm-field-label has-start-icon">Email</label>
            </div>

            <!-- Username field -->
            <div class="pm-field" style="margin-bottom:4px;">
                <span class="pm-field-start-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                </span>
                <input type="text" name="Username" required
                       placeholder=" "
                       class="pm-field-input has-start-icon"
                       autocomplete="username" />
                <label class="pm-field-label has-start-icon">Tên người dùng</label>
            </div>
            <div class="pm-field-helper">Dùng để tìm kiếm và nhắn tin</div>

            <!-- Display Name field -->
            <div class="pm-field mb-3">
                <span class="pm-field-start-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                </span>
                <input type="text" name="DisplayName" required
                       placeholder=" "
                       class="pm-field-input has-start-icon"
                       autocomplete="name" />
                <label class="pm-field-label has-start-icon">Tên hiển thị</label>
            </div>

            <!-- Password field -->
            <div class="pm-field mb-3">
                <input type="password" name="Password" id="reg-password" required
                       placeholder=" "
                       class="pm-field-input has-end-icon"
                       autocomplete="new-password" />
                <label class="pm-field-label">Mật khẩu</label>
                <button type="button" class="pm-field-end-btn" onclick="togglePw('reg-password','reg-pw-eye')"
                        aria-label="Hiện/ẩn mật khẩu">
                    <span id="reg-pw-eye">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                    </span>
                </button>
            </div>

            <button type="submit" id="reg-btn"
                    class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-full-width mud-ripple mt-2"
                    style="height:46px;font-size:.9375rem;font-weight:600;letter-spacing:.02em;width:100%;border-radius:8px;">
                <span class="mud-button-label">
                    <span id="reg-btn-text">Đăng ký tài khoản</span>
                    <span id="reg-spinner" style="display:none;margin-left:8px;vertical-align:middle;">
                        <svg class="mud-progress-circular mud-progress-circular-indeterminate" style="width:20px;height:20px;" viewBox="22 22 44 44">
                            <circle class="mud-progress-circular-circle" cx="44" cy="44" r="20.2" fill="none" stroke-width="3.6"></circle>
                        </svg>
                    </span>
                </span>
            </button>
        </form>

        <div class="pm-auth-divider"><span>hoặc</span></div>

        <div style="text-align:center;font-size:.875rem;color:var(--mud-palette-text-secondary);">
            Đã có tài khoản?
            <a href="/auth/login" style="font-weight:700;color:var(--mud-palette-primary);text-decoration:none;margin-left:3px;">Đăng nhập ngay</a>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePw(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (input.type === 'password') {
        input.type = 'text';
        icon.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>';
    } else {
        input.type = 'password';
        icon.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>';
    }
}

function handleRegisterSubmit(e) {
    const btn = document.getElementById('reg-btn');
    const txt = document.getElementById('reg-btn-text');
    const spinner = document.getElementById('reg-spinner');
    setTimeout(() => { btn.disabled = true; }, 10);
    txt.textContent = 'Đang đăng ký...';
    spinner.style.display = 'inline-flex';
    return true; // allow normal form POST
}
</script>
}
