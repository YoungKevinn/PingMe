          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/webhooks/group/{{group_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Toggle Webhook",
