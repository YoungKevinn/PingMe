{
  "info": {
    "name": "PingMe API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "peer_id", "value": "" },
    { "key": "group_id", "value": "" },
    { "key": "message_id", "value": "" }
  ],
  "item": [
    {
      "name": "01. Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has token', () => pm.expect(r.token).to.be.a('string'));",
            "pm.collectionVariables.set('token', r.token);",
            "pm.collectionVariables.set('user_id', r.user.id);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"testuser1\",\"email\":\"test1@pingme.dev\",\"password\":\"Test123!\",\"displayName\":\"Test User 1\"}" }
          }
        },
        {
          "name": "Register User 2 (peer)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.collectionVariables.set('peer_id', r.user.id);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"testuser2\",\"email\":\"test2@pingme.dev\",\"password\":\"Test123!\",\"displayName\":\"Test User 2\"}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has token', () => pm.expect(r.token).to.be.a('string'));",
            "pm.collectionVariables.set('token', r.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"test1@pingme.dev\",\"password\":\"Test123!\"}" }
          }
        },
        {
          "name": "Get Me",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has username', () => pm.expect(r.username).to.eql('testuser1'));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Forgot Password",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"test1@pingme.dev\"}" }
          }
        }
      ]
    },
    {
      "name": "02. User Profile",
      "item": [
        {
          "name": "Get Profile by ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has displayName', () => pm.expect(pm.response.json().displayName).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/users/{{user_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Profile by Username",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/users/by-username/testuser1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Bio updated', () => pm.expect(pm.response.json().bio).to.eql('Hello PingMe!'));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"displayName\":\"Test User Updated\",\"bio\":\"Hello PingMe!\"}" }
          }
        }
      ]
    },
    {
      "name": "03. Messages (DM)",
      "item": [
        {
          "name": "Send DM Message",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has message id', () => pm.expect(r.id).to.be.a('number'));",
            "pm.collectionVariables.set('message_id', r.id);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/messages",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"receiverId\":{{peer_id}},\"content\":\"Hello from PingMe test!\",\"messageType\":\"Text\"}" }
          }
        },
        {
          "name": "Send DM with Reply",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has replyToMessageId', () => pm.expect(pm.response.json().replyToMessageId).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/messages",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"receiverId\":{{peer_id}},\"content\":\"This is a reply!\",\"messageType\":\"Text\",\"replyToMessageId\":{{message_id}}}" }
          }
        },
        {
          "name": "Get DM Messages",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
            "pm.test('Has messages', () => pm.expect(pm.response.json().length).to.be.greaterThan(0));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/messages/dm/{{peer_id}}?limit=30",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Edit Message",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{base_url}}/api/messages/{{message_id}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"content\":\"Edited message content\"}" }
          }
        },
        {
          "name": "Pin Message",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PATCH", "url": "{{base_url}}/api/messages/{{message_id}}/pin",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"isPinned\":true}" }
          }
        },
        {
          "name": "Get Pinned Messages",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has pinned', () => pm.expect(pm.response.json().length).to.be.greaterThan(0));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/messages/pinned?peerId={{peer_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "React to Message",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/messages/{{message_id}}/reactions",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"emoji\":\"❤️\"}" }
          }
        },
        {
          "name": "Remove Reaction",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/messages/{{message_id}}/reactions/❤️",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Mark Message as Read",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/messages/{{message_id}}/read",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Forward Message",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has forwardedFromMessageId', () => pm.expect(pm.response.json().forwardedFromMessageId).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/messages/{{message_id}}/forward?receiverId={{peer_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Message",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/messages/{{message_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
