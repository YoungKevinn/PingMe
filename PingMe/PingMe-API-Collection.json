          ]}}],
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/groups/{{group_id}}/members/{{peer_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
