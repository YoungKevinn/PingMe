    {
      "name": "08. Snippets",
      "item": [
        {
          "name": "Create Snippet",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.test('Has shareToken', () => pm.expect(r.shareToken).to.be.a('string'));",
            "pm.collectionVariables.set('snippet_token', r.shareToken);",
            "pm.collectionVariables.set('snippet_id', r.id);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/snippets",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"title\":\"Hello World\",\"content\":\"console.log('Hello PingMe!');\",\"language\":\"javascript\"}" }
          }
        },
        {
          "name": "Get My Snippets",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has snippet', () => pm.expect(pm.response.json().length).to.be.greaterThan(0));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/snippets",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Snippet by Share Token (public)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has content', () => pm.expect(pm.response.json().content).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{base_url}}/api/snippets/share/{{snippet_token}}"
          }
        },
        {
          "name": "Delete Snippet",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/snippets/{{snippet_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "09. Webhooks",
      "item": [
        {
          "name": "Create Webhook",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const r = pm.response.json();",
            "pm.collectionVariables.set('webhook_id', r.id);",
            "pm.collectionVariables.set('webhook_token', r.token);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{base_url}}/api/webhooks",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"groupId\":{{group_id}},\"name\":\"GitHub CI\"}" }
          }
        },
        {
          "name": "Get Group Webhooks",
          "event": [{ "listen": "test", "script": { "exec": [
