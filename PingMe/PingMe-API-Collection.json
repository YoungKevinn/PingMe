            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "PATCH", "url": "{{base_url}}/api/webhooks/{{webhook_id}}/toggle?active=false",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Delete Webhook",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 204', () => pm.response.to.have.status(204));"
          ]}}],
          "request": {
            "method": "DELETE", "url": "{{base_url}}/api/webhooks/{{webhook_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
