@using PingMe.Frontend.Services
@using PingMe.Frontend.Models
@inject WebRTCService WebRTC
@implements IDisposable

@if (WebRTC.CurrentState != CallState.Idle)
{
    <div class="pm-call-overlay" 
         style="left: @($"{_x}px"); top: @($"{_y}px");" 
         @onmousedown="OnMouseDown">
         
        <div class="pm-call-header" @onmousemove="OnMouseMove" @onmouseup="OnMouseUp" @onmouseleave="OnMouseUp">
            <MudIcon Icon="@(WebRTC.IsVideoCall ? Icons.Material.Filled.Videocam : Icons.Material.Filled.Phone)" Size="Size.Small" Class="mr-2" />
            <MudText Typo="Typo.subtitle2">
                @if (WebRTC.CurrentState == CallState.IncomingRinging)
                {
                    <text>Incoming call from @WebRTC.PartnerName...</text>
                }
                else if (WebRTC.CurrentState == CallState.OutgoingRinging)
                {
                    <text>Calling @WebRTC.PartnerName...</text>
                }
                else
                {
                    <text>In call with @WebRTC.PartnerName</text>
                }
            </MudText>
            <MudSpacer />
            @if (WebRTC.CurrentState == CallState.InCall)
            {
                <MudText Typo="Typo.caption" Class="mr-2">@_durationText</MudText>
            }
        </div>

        <div class="pm-call-body @(WebRTC.IsVideoCall ? "has-video" : "no-video")">
            
            <div class="pm-call-videos" style="@(WebRTC.IsVideoCall && WebRTC.CurrentState == CallState.InCall ? "" : "display: none;")">
                <video id="remote-video" autoplay playsinline></video>
                <video id="local-video" autoplay playsinline muted></video>
            </div>

            @if (!WebRTC.IsVideoCall || WebRTC.CurrentState != CallState.InCall)
            {
                <div class="pm-call-avatar-wrap">
                    <MudAvatar Style="height:80px; width:80px; font-size: 2rem;">
                        @if (!string.IsNullOrEmpty(WebRTC.PartnerAvatar))
                        {
                            <MudImage Src="@WebRTC.PartnerAvatar" />
                        }
                        else
                        {
                            @(WebRTC.PartnerName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                        }
                    </MudAvatar>
                </div>
            }
        </div>

        <div class="pm-call-controls" @onmousedown:stopPropagation>
            @if (WebRTC.CurrentState == CallState.IncomingRinging)
            {
                <MudFab Color="Color.Success" StartIcon="@Icons.Material.Filled.Call" Size="Size.Medium" OnClick="() => WebRTC.AnswerCallAsync(true)" />
                <MudFab Color="Color.Error" StartIcon="@Icons.Material.Filled.CallEnd" Size="Size.Medium" OnClick="() => WebRTC.AnswerCallAsync(false)" />
            }
            else
            {
                @if (WebRTC.CurrentState == CallState.InCall)
                {
                    <MudFab Color="@(WebRTC.IsMuted ? Color.Error : Color.Dark)" 
                            StartIcon="@(WebRTC.IsMuted ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)" 
                            Size="Size.Medium" 
                            OnClick="() => WebRTC.ToggleMuteAsync()" />

                    if (WebRTC.IsVideoCall)
                    {
                        <MudFab Color="@(WebRTC.IsVideoOff ? Color.Error : Color.Dark)" 
                                StartIcon="@(WebRTC.IsVideoOff ? Icons.Material.Filled.VideocamOff : Icons.Material.Filled.Videocam)" 
                                Size="Size.Medium" 
                                OnClick="() => WebRTC.ToggleVideoAsync()" />
                    }
                }
                
                <MudFab Color="Color.Error" StartIcon="@Icons.Material.Filled.CallEnd" Size="Size.Medium" OnClick="() => WebRTC.EndCallAsync()" />
            }
        </div>
    </div>
}

<style>
    .pm-call-overlay {
        position: fixed;
        width: 320px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        box-shadow: 0 12px 28px rgba(0,0,0,0.2);
        z-index: 300000;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        user-select: none;
    }
    .pm-call-header {
        display: flex;
        align-items: center;
        padding: 8px 12px;
        background: var(--mud-palette-primary);
        color: white;
        cursor: move;
    }
    .pm-call-body {
        position: relative;
        height: 240px;
        background: #111;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .pm-call-body.no-video {
        height: 160px;
        background: var(--mud-palette-background);
    }
    .pm-call-videos {
        position: relative;
        width: 100%;
        height: 100%;
    }
    #remote-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    #local-video {
        position: absolute;
        bottom: 8px;
        right: 8px;
        width: 80px;
        height: 120px;
        object-fit: cover;
        border-radius: 8px;
        border: 2px solid rgba(255,255,255,0.2);
        background: #000;
        transform: scaleX(-1);
    }
    .pm-call-controls {
        display: flex;
        justify-content: center;
        gap: 16px;
        padding: 16px;
        background: var(--mud-palette-surface);
        border-top: 1px solid var(--mud-palette-divider);
    }
</style>

@code {
    private double _x = 50;
    private double _y = 50;
    private bool _isDragging = false;
    private double _startX, _startY;
    private double _startLeft, _startTop;
    private string _durationText = "00:00";
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        WebRTC.OnCallStateChanged += StateHasChanged;
        WebRTC.OnCallStateChanged += HandleCallStateChanged;
    }

    private void HandleCallStateChanged()
    {
        if (WebRTC.CurrentState == CallState.InCall)
        {
            if (_timer == null)
            {
                _timer = new System.Threading.Timer(_ =>
                {
                    InvokeAsync(() =>
                    {
                        if (WebRTC.CallStartTime.HasValue)
                        {
                            var span = DateTime.UtcNow - WebRTC.CallStartTime.Value;
                            _durationText = $"{(int)span.TotalMinutes:D2}:{span.Seconds:D2}";
                            StateHasChanged();
                        }
                    });
                }, null, 0, 1000);
            }
        }
        else
        {
            _timer?.Dispose();
            _timer = null;
            _durationText = "00:00";
        }
    }

    private void OnMouseDown(MouseEventArgs e)
    {
        _isDragging = true;
        _startX = e.ClientX;
        _startY = e.ClientY;
        _startLeft = _x;
        _startTop = _y;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (_isDragging)
        {
            _x = _startLeft + (e.ClientX - _startX);
            _y = _startTop + (e.ClientY - _startY);
        }
    }

    private void OnMouseUp(MouseEventArgs e)
    {
        _isDragging = false;
    }

    public void Dispose()
    {
        WebRTC.OnCallStateChanged -= StateHasChanged;
        WebRTC.OnCallStateChanged -= HandleCallStateChanged;
        _timer?.Dispose();
    }
}
