    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (_slashPopupVisible && FilteredSlashCommandList.Any())
        {
            var list = FilteredSlashCommandList;

            if (e.Key == "ArrowDown")
            {
                _slashSelectedIndex = (_slashSelectedIndex + 1) % list.Count;
                StateHasChanged();
                return;
            }

            if (e.Key == "ArrowUp")
            {
                _slashSelectedIndex = (_slashSelectedIndex - 1 + list.Count) % list.Count;
                StateHasChanged();
                return;
            }

            if (e.Key == "Enter" || e.Key == "Tab")
            {
                InsertSlashCommand(list[Math.Clamp(_slashSelectedIndex, 0, list.Count - 1)]);
                return;
            }

            if (e.Key == "Escape")
            {
                _slashPopupVisible = false;
                _slashSelectedIndex = 0;
                StateHasChanged();
                return;
            }
        }

        if (_mentionPopupVisible && FilteredMentionSuggestionList.Any())
        {
            var list = FilteredMentionSuggestionList;

            if (e.Key == "ArrowDown")
            {
                _mentionSelectedIndex = (_mentionSelectedIndex + 1) % list.Count;
                StateHasChanged();
                return;
            }

            if (e.Key == "ArrowUp")
            {
                _mentionSelectedIndex = (_mentionSelectedIndex - 1 + list.Count) % list.Count;
                StateHasChanged();
                return;
            }

            if (e.Key == "Enter" || e.Key == "Tab")
            {
                InsertMention(list[Math.Clamp(_mentionSelectedIndex, 0, list.Count - 1)]);
                return;
            }

            if (e.Key == "Escape")
            {
                _mentionPopupVisible = false;
                _mentionSelectedIndex = 0;
                StateHasChanged();
                return;
            }
        }

        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
            return;
        }

        _typingTimer?.Stop();
        _typingTimer?.Dispose();

        if ((DateTime.UtcNow - _lastTypingStartedAt).TotalMilliseconds >= 400)
        {
            _lastTypingStartedAt = DateTime.UtcNow;

            if (PeerId.HasValue)
                await Hub.StartTypingAsync(PeerId.Value, null);
            else if (GroupId.HasValue)
                await Hub.StartTypingAsync(null, GroupId.Value);
        }

        _typingTimer = new Timer(2000);
        _typingTimer.AutoReset = false;

        _typingTimer.Elapsed += async (_, _) =>
        {
            _typingTimer?.Stop();
            _lastTypingStartedAt = DateTime.MinValue;

            if (PeerId.HasValue)
                await Hub.StopTypingAsync(PeerId.Value, null);
            else if (GroupId.HasValue)
                await Hub.StopTypingAsync(null, GroupId.Value);
        };

        _typingTimer.Start();
    }
