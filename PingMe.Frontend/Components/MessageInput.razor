        _ = InvokeAsync(StateHasChanged);
    }

    private sealed record SlashCommandItem(
        string Icon,
        string Command,
        string Title,
        string Description,
        string Template,
        string? ExampleText = null);

    private sealed record MentionSuggestion(
        string DisplayName,
        string Description,
        string InsertText,
        bool IsGroupMention,
        int? UserId = null,
        string? AvatarUrl = null);
}
