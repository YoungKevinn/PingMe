    private List<MentionSuggestion> FilteredMentionSuggestionList
    {
        get
        {
            if (!GroupId.HasValue)
                return new List<MentionSuggestion>();

            var suggestions = new List<MentionSuggestion>();

            if (string.IsNullOrWhiteSpace(_mentionFilter)
                || "@all".Contains(_mentionFilter, StringComparison.OrdinalIgnoreCase)
                || "all".Contains(_mentionFilter, StringComparison.OrdinalIgnoreCase))
            {
                suggestions.Add(new MentionSuggestion(
                    DisplayName: "@all",
                    Description: "Tag tất cả thành viên trong nhóm",
                    InsertText: "@all ",
                    IsGroupMention: true
                ));
            }

            var memberMentions = _allGroupMembers
                .Where(m => m.UserId != CurrentUserId)
                .Where(m => string.IsNullOrWhiteSpace(_mentionFilter)
                    || m.DisplayName.Contains(_mentionFilter, StringComparison.OrdinalIgnoreCase))
                .Take(8)
                .Select(m => new MentionSuggestion(
                    DisplayName: $"@{m.DisplayName}",
                    Description: m.IsOnline ? "Online" : "Offline",
                    InsertText: $"@{m.DisplayName} ",
                    IsGroupMention: false,
                    UserId: m.UserId,
                    AvatarUrl: m.AvatarUrl
                ));

            suggestions.AddRange(memberMentions);

            return suggestions.Take(9).ToList();
        }
    }
