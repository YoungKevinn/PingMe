@code {
    [Parameter] public int? PeerId { get; set; }
    [Parameter] public int? GroupId { get; set; }
    [Parameter] public MessageResponse? ReplyTo { get; set; }
    [Parameter] public EventCallback<MessageResponse?> ReplyToChanged { get; set; }
    [Parameter] public EventCallback<MessageResponse> OnSendMessage { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string DisabledReason { get; set; } = "Bạn không thể gửi tin nhắn trong hội thoại này.";
private const int MaxMessageLength = 4000;
private int CurrentUserId;
    private int _slashSelectedIndex;
    private int _mentionSelectedIndex;
    private string _message = "";
    private bool _sending;
    private bool _sendingSnippet;
    private bool _emojiOpen;
    private bool _isRecording;

    private async Task StartRecordingAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("audioRecorder.startRecording");
            _isRecording = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Không thể truy cập Microphone: {ex.Message}", Severity.Error);
        }
    }

    private async Task CancelRecordingAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("audioRecorder.stopRecording");
        }
        catch { }
        _isRecording = false;
    }

    private async Task StopAndSendRecordingAsync()
    {
        if (!_isRecording || _sending || Disabled) return;
        
        _sending = true;
        StateHasChanged();

        try
        {
            var audioBytes = await JS.InvokeAsync<byte[]>("audioRecorder.stopRecordingBytes");
            
            if (audioBytes != null && audioBytes.Length > 0)
            {
                MessageResponse? sent = null;
                if (PeerId.HasValue)
                    sent = await MsgService.UploadAudioAsync(audioBytes, "audio/webm", PeerId.Value, null, ReplyTo?.Id);
                else if (GroupId.HasValue)
                    sent = await MsgService.UploadAudioAsync(audioBytes, "audio/webm", null, GroupId.Value, ReplyTo?.Id);

                if (sent == null)
                {
                    Snackbar.Add(MsgService.LastError ?? "Gửi voice thất bại.", Severity.Error);
                }
                else
                {
                    await ClearReply();
                    await OnSendMessage.InvokeAsync(sent);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi khi gửi voice: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRecording = false;
            _sending = false;
            StateHasChanged();
        }
    }

