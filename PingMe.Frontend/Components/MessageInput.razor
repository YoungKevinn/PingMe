    private async Task UpdateSuggestionStateAsync()
    {
        var cursorPos = await GetCursorPositionAsync();
        var text = _message ?? "";

        _slashPopupVisible = false;
        _mentionPopupVisible = false;
        _triggerStartPos = -1;
        _slashFilter = "";
        _mentionFilter = "";

        if (string.IsNullOrEmpty(text))
            return;

        var token = GetCurrentToken(text, cursorPos, out var start);

        if (token.StartsWith("/", StringComparison.Ordinal))
        {
            _triggerStartPos = start;
            _slashFilter = token[1..];
            _slashSelectedIndex = 0;
            _slashPopupVisible = true;
            _mentionPopupVisible = false;
            _emojiOpen = false;
            StateHasChanged();
            return;
        }

        if (GroupId.HasValue && token.StartsWith("@", StringComparison.Ordinal))
        {
            if (!_allGroupMembers.Any())
                await LoadGroupMembersAsync();

            _triggerStartPos = start;
            _mentionFilter = token[1..];
            _mentionSelectedIndex = 0;
            _mentionPopupVisible = true;
            _slashPopupVisible = false;
            _emojiOpen = false;
            StateHasChanged();
        }
    }

    private static string GetCurrentToken(string text, int cursorPos, out int start)
    {
        cursorPos = Math.Clamp(cursorPos, 0, text.Length);
        start = cursorPos;

        while (start > 0 && !char.IsWhiteSpace(text[start - 1]))
            start--;

        return text[start..cursorPos];
    }

    private async Task<int> GetCursorPositionAsync()
    {
        try
        {
            return await JS.InvokeAsync<int>("pingmeChatScroll.getTextareaCursorPosition", InputSelector);
        }
        catch
        {
            return _message?.Length ?? 0;
        }
    }

    private void InsertSlashCommand(SlashCommandItem item)
    {
        if (item.Command.Equals("/snippet", StringComparison.OrdinalIgnoreCase))
        {
            _slashPopupVisible = false;
            _message = "";
            OpenSnippetDialog();
            return;
        }

        ReplaceCurrentToken(item.Template);
        _slashPopupVisible = false;
        StateHasChanged();
        _ = FocusInputAsync();
    }

    private void InsertMention(MentionSuggestion item)
    {
        ReplaceCurrentToken(item.InsertText);
        _mentionPopupVisible = false;
        StateHasChanged();
        _ = FocusInputAsync();
    }

    private void ReplaceCurrentToken(string replacement)
    {
        if (_triggerStartPos < 0)
            return;

        var cursorPos = _message.Length;
        var before = _message[.._triggerStartPos];

        var afterStart = cursorPos;

        for (var i = _triggerStartPos; i < _message.Length; i++)
        {
            if (char.IsWhiteSpace(_message[i]))
            {
                afterStart = i;
                break;
            }

            afterStart = i + 1;
        }

        var after = afterStart < _message.Length ? _message[afterStart..] : string.Empty;
        _message = before + replacement + after;
    }

