    private async Task SendAsync()
    {
        var content = _message.Trim();

        if (Disabled)
        {
            Snackbar.Add(DisabledReason, Severity.Warning);
            return;
        }

        if (string.IsNullOrEmpty(content))
            return;
        if (content.Length > MaxMessageLength)
        {
            Snackbar.Add($"Tin nhắn tối đa {MaxMessageLength} ký tự. Hãy rút ngắn hoặc gửi bằng file/snippet.", Severity.Warning);
            return;
        }

        if (_sending)
            return;

        if (content.Equals("/snippet", StringComparison.OrdinalIgnoreCase))
        {
            OpenSnippetDialog();
            _message = "";
            return;
        }

        if (IsVulnCommand(content) && !GroupId.HasValue)
        {
            Snackbar.Add("/vuln chỉ hỗ trợ group chat trong MVP.", Severity.Warning);
            return;
        }

        _sending = true;
        _message = "";
        _slashPopupVisible = false;
        _mentionPopupVisible = false;

        try
        {
            MessageResponse? sent = null;

            if (PeerId.HasValue)
                sent = await MsgService.SendDmAsync(PeerId.Value, content, ReplyTo?.Id);
            else if (GroupId.HasValue)
                sent = await MsgService.SendGroupAsync(GroupId.Value, content, ReplyTo?.Id);
            else
            {
                Snackbar.Add("Chưa chọn cuộc trò chuyện.", Severity.Warning);
                _message = content;
                return;
            }

            if (sent == null)
            {
                Snackbar.Add(MsgService.LastError ?? "Gửi thất bại: API không trả về tin nhắn.", Severity.Error);
                _message = content;
                return;
            }
            await ClearReply();
            if (IsIocCommand(content))
                _ = IocNavState.RefreshAsync();
            if (IsVulnCommand(content))
                Snackbar.Add(BuildVulnCreatedMessage(sent), Severity.Success);
            if (IsTaskCommand(content))
                Snackbar.Add(BuildTaskCreatedMessage(sent), Severity.Success);
            if (IsReminderCommand(content))
                Snackbar.Add(Loc.T("reminder.created"), Severity.Success);
            await OnSendMessage.InvokeAsync(sent);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Gửi thất bại: {ex.Message}", Severity.Error);
            _message = content;
        }
        finally
        {
            _sending = false;
        }
    }

    private static bool IsIocCommand(string content)
        => content.TrimStart().StartsWith("/ioc ", StringComparison.OrdinalIgnoreCase);

    private static bool IsVulnCommand(string content)
        => content.TrimStart().StartsWith("/vuln", StringComparison.OrdinalIgnoreCase);

    private static bool IsReminderCommand(string content)
        => content.TrimStart().StartsWith("/reminder", StringComparison.OrdinalIgnoreCase);

    private static bool IsTaskCommand(string content)
        => content.TrimStart().StartsWith("/task", StringComparison.OrdinalIgnoreCase);

    private static string BuildVulnCreatedMessage(MessageResponse sent)
    {
        var findingId = ExtractFindingId(sent.Content);
        return findingId.HasValue
            ? $"Đã tạo Finding #{findingId.Value} từ /vuln"
            : "Đã tạo Finding từ /vuln";
    }

    private static int? ExtractFindingId(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return null;

        try
        {
            using var document = JsonDocument.Parse(content);
            if (document.RootElement.TryGetProperty("findingId", out var idElement)
                && idElement.ValueKind == JsonValueKind.Number
                && idElement.TryGetInt32(out var id)
                && id > 0)
            {
                return id;
            }
        }
        catch
        {
        }

        return null;
    }

    private static string BuildTaskCreatedMessage(MessageResponse sent)
    {
        var taskId = ExtractIntProperty(sent.Content, "taskId");
        return taskId.HasValue
            ? $"Đã tạo Task #{taskId.Value} từ /task"
            : "Đã tạo Task từ /task";
    }

    private static int? ExtractIntProperty(string? content, string propertyName)
    {
        if (string.IsNullOrWhiteSpace(content))
            return null;

        try
        {
            using var document = JsonDocument.Parse(content);
            if (document.RootElement.TryGetProperty(propertyName, out var idElement)
                && idElement.ValueKind == JsonValueKind.Number
                && idElement.TryGetInt32(out var id)
                && id > 0)
            {
                return id;
            }
        }
        catch
        {
        }

        return null;
    }

