@using System.Timers
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using PingMe.Frontend.Models
@inject MessageService MsgService
@inject IocNavStateService IocNavState
@inject ChatHubService Hub
@inject SnippetService SnippetService
@inject PollService PollService
@inject ISnackbar Snackbar
@inject GroupService GroupService
@inject IJSRuntime JS
@inject LocalizationService Loc
@implements IDisposable
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@inject AuthenticationStateProvider AuthStateProvider
@if (ReplyTo != null)
{
    <div style="padding:8px 16px 0;background:var(--mud-palette-surface);">
        <div style="background:rgba(37,99,235,.06);border-left:3px solid #2563EB;border-radius:0 8px 8px 0;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;">
            <div style="min-width:0;">
                <p style="margin:0 0 2px;font-size:.75rem;font-weight:600;color:#2563EB;">
                    Trả lời @ReplyTo.SenderDisplayName
                </p>

                <p style="margin:0;font-size:.8rem;color:#64748B;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:300px;">
                    @ReplyTo.Content
                </p>
            </div>

            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="@ClearReply"
                           Style="flex-shrink:0;" />
        </div>
    </div>
}

<div class="pm-input-shell">
    @if (Disabled)
    {
        <div class="pm-input-disabled-note">@DisabledReason</div>
    }

    @if (_emojiOpen)
    {
        <div class="pm-emoji-panel">
            @foreach (var e in _emojis)
            {
                var emoji = e;

                <button type="button"
                        class="pm-emoji-btn"
                        @onclick="@(() => AppendEmoji(emoji))">
                    @emoji
                </button>
            }
        </div>
    }

    @if (_slashPopupVisible && FilteredSlashCommandList.Any())
    {
        <div class="pm-command-popup">
            @foreach (var entry in FilteredSlashCommandList.Select((item, index) => new { item, index }))
            {
                var item = entry.item;

                <button type="button"
                        class="@($"pm-command-item {(entry.index == _slashSelectedIndex ? "active" : "")}")"
                        @onclick="@(() => InsertSlashCommand(item))">
                    <span class="pm-command-icon">@item.Icon</span>

                    <span class="pm-command-content">
                        <span class="pm-command-title">@item.Title</span>
                        <span class="pm-command-desc">@item.Description</span>
                    </span>

                    <span class="pm-command-template">@(item.ExampleText ?? item.Template)</span>
                </button>
            }
        </div>
    }

    @if (_mentionPopupVisible && FilteredMentionSuggestionList.Any())
{
    <div class="pm-mention-popup">
        @foreach (var entry in FilteredMentionSuggestionList.Select((item, index) => new { item, index }))
        {
            var item = entry.item;

            <button type="button"
                    class="@($"pm-mention-item {(entry.index == _mentionSelectedIndex ? "active" : "")}")"
                    @onclick="@(() => InsertMention(item))">
                    <MudAvatar Size="Size.Small"
                               Color="@(item.IsGroupMention ? Color.Warning : Color.Primary)"
                               Style="width:28px;height:28px;font-size:0.8rem;">
                        @if (item.IsGroupMention)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Style="font-size:16px;" />
                        }
                        else
                        {
                            @GetInitial(item.DisplayName)
                        }
                    </MudAvatar>

                    <span class="pm-mention-content">
                        <span class="pm-mention-name">@item.DisplayName</span>
                        <span class="pm-mention-meta">@item.Description</span>
                    </span>
                </button>
            }
        </div>
    }

    <div class="pm-input-row">
        <button type="button"
                class="@($"pm-input-icon-btn {(Disabled ? "is-disabled" : "")}")"
                title="Emoji"
                @onclick="@ToggleEmojiPanel">
            <MudIcon Icon="@Icons.Material.Outlined.EmojiEmotions" Style="font-size:20px;" />
        </button>

        <InputFile id="pm-file-input"
                   OnChange="@OnFileSelected"
                   disabled="@Disabled"
                   style="display:none;" />

        <label for="pm-file-input"
               class="@($"pm-input-icon-btn {(Disabled ? "is-disabled" : "")}")"
               title="Đính kèm file">
            <MudIcon Icon="@Icons.Material.Outlined.AttachFile" Style="font-size:20px;" />
        </label>

        <button type="button"
                class="pm-input-icon-btn pm-code-btn"
                title="Gửi code snippet"
                @onclick="@OpenSnippetDialog"
                disabled="@(_sending || Disabled || _isRecording)">
            <MudIcon Icon="@Icons.Material.Filled.Code" Style="font-size:20px;" />
        </button>

        <button type="button"
                class="pm-input-icon-btn"
                title="Tạo bình chọn"
                @onclick="@OpenPollDialog"
                disabled="@(_sending || Disabled || _isRecording)">
            <MudIcon Icon="@Icons.Material.Outlined.HowToVote" Style="font-size:20px;" />
        </button>

        @if (_isRecording)
        {
            <div class="pm-recording-indicator" style="flex:1;display:flex;align-items:center;color:var(--mud-palette-error);font-weight:600;padding-left:10px; transform: translateY(-7px);">
                <MudIcon Icon="@Icons.Material.Filled.Mic" Style="font-size:20px;animation:pulse 1s infinite;margin-right:8px;" />
                <span>Đang ghi âm...</span>
            </div>
            
            <button type="button" class="pm-input-icon-btn" title="Hủy" @onclick="CancelRecordingAsync" style="color:var(--mud-palette-text-secondary);">
                <MudIcon Icon="@Icons.Material.Filled.Close" Style="font-size:20px;" />
            </button>
        }
        else
        {
            <button type="button"
                    class="pm-input-icon-btn"
                    title="Ghi âm"
                    @onclick="StartRecordingAsync"
                    disabled="@(_sending || Disabled)">
                <MudIcon Icon="@Icons.Material.Filled.Mic" Style="font-size:20px;" />
            </button>

            <textarea @ref="_inputRef"
                      id="@InputElementId"
                      @bind="_message"
                      @bind:event="oninput"
                      @bind:after="OnAfterInput"
                      @onkeydown="OnKeyDown"
                      placeholder="@InputPlaceholder"
                      rows="1"
                      class="pm-message-textarea"
                      disabled="@(_sending || Disabled)" />
        }

        <button type="button"
                class="pm-send-btn"
                @onclick="@( _isRecording ? StopAndSendRecordingAsync : SendAsync )"
                disabled="@( (!_isRecording && string.IsNullOrWhiteSpace(_message)) || (_message?.Length > MaxMessageLength) || _sending || Disabled)">
            @if (_sending)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.Send" Style="font-size:18px;" />
            }
        </button>
    </div>
</div>

@if (_snippetDialogOpen)
{
    <div class="pm-modal-backdrop" @onclick="@CloseSnippetDialog">
        <div class="pm-modal-card pm-snippet-modal" @onclick:stopPropagation="true">
            <div class="pm-modal-header">
                <div>
                    <MudText Typo="Typo.h6">Gửi Code Snippet</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Snippet sẽ được lưu vào kho code và gửi vào cuộc trò chuyện hiện tại.
                    </MudText>
                </div>

                <button type="button" class="pm-modal-x" @onclick="@CloseSnippetDialog">
                    ×
                </button>
            </div>

            <div class="pm-modal-body">
                <MudTextField @bind-Value="_snippetRequest.Title"
                              Label="Tiêu đề (tùy chọn)"
                              Variant="Variant.Outlined"
                              HelperText="Nếu bỏ trống, hệ thống sẽ tự tạo tiêu đề."
                              Immediate="true"
                              Class="mb-3" />

                <div class="pm-form-label">Ngôn ngữ</div>

                <div class="pm-custom-select pm-custom-select-full">
                    <button type="button"
                            class="pm-custom-select-button"
                            @onclick="@ToggleSnippetLanguageDropdown">
                        <span>@GetLanguageLabel(_snippetRequest.Language)</span>
                        <span class="pm-select-arrow">▾</span>
                    </button>

                    @if (_snippetLanguageOpen)
                    {
                        <div class="pm-custom-select-menu">
                            @foreach (var lang in _snippetLanguages)
                            {
                                var language = lang;

                                <button type="button"
                                        class="pm-custom-select-item @(string.Equals(_snippetRequest.Language, language, StringComparison.OrdinalIgnoreCase) ? "active" : "")"
                                        @onclick="@(() => SetChatSnippetLanguage(language))">
                                    @language
                                </button>
                            }
                        </div>
                    }
                </div>

                <MudTextField @bind-Value="_snippetRequest.Content"
                              Label="Code *"
                              Variant="Variant.Outlined"
                              Lines="12"
                              Immediate="true"
                              Style="font-family:'Fira Code',Consolas,monospace;"
                              Required="true"
                              Class="mt-3" />
            </div>

            <div class="pm-modal-actions">
                <MudButton ButtonType="ButtonType.Button" OnClick="@CloseSnippetDialog">
                    Hủy
                </MudButton>

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="@(string.IsNullOrWhiteSpace(_snippetRequest.Content) || _sendingSnippet)"
                           OnClick="@CreateAndSendSnippetAsync">
                    @if (_sendingSnippet)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                    }
                    else
                    {
                        <span>Gửi vào chat</span>
                    }
                </MudButton>
            </div>
        </div>
    </div>
}

@if (_pollDialogOpen)
{
    <div class="pm-modal-backdrop" @onclick="@ClosePollDialog">
        <div class="pm-modal-card" @onclick:stopPropagation="true" style="max-width:440px;width:96vw;">
            <div class="pm-modal-header">
                <div>
                    <MudText Typo="Typo.h6">📊 Tạo bình chọn</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Mọi người trong cuộc trò chuyện có thể tham gia bình chọn.
                    </MudText>
                </div>
                <button type="button" class="pm-modal-x" @onclick="@ClosePollDialog">✕</button>
            </div>

            <div class="pm-modal-body" style="display:flex;flex-direction:column;gap:12px;">
                <MudTextField @bind-Value="_pollQuestion"
                              Label="Câu hỏi bình chọn"
                              Placeholder="Hỏi điều gì đó..."
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              FullWidth="true"
                              MaxLength="300"
                              Counter="300"
                              AutoFocus="true" />

                <MudText Typo="Typo.subtitle2" Style="margin-bottom:-4px;">Các lựa chọn (tối thiểu 2)</MudText>
                @for (var i = 0; i < _pollOptions.Count; i++)
                {
                    var idx = i;
                    <div style="display:flex;gap:6px;align-items:center;">
                        <MudTextField Value="@_pollOptions[idx]"
                                      ValueChanged="@((string v) => _pollOptions[idx] = v)"
                                      Placeholder="@($"Lựa chọn {idx + 1}")"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      MaxLength="300" />
                        @if (_pollOptions.Count > 2)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RemovePollOption(idx))" />
                        }
                    </div>
                }

                @if (_pollOptions.Count < 10)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.Add"
                               Variant="Variant.Text"
                               Color="Color.Primary"
                               Size="Size.Small"
                               OnClick="@AddPollOption">
                        Thêm lựa chọn
                    </MudButton>
                }

                <div style="display:flex;gap:16px;flex-wrap:wrap;">
                    <MudCheckBox @bind-Value="_pollAllowMultiple" Label="Cho phép chọn nhiều đáp án" Color="Color.Primary" />
                </div>
            </div>

            <div class="pm-modal-actions">
                <MudButton ButtonType="ButtonType.Button" OnClick="@ClosePollDialog">Huỷ</MudButton>
                <MudButton ButtonType="ButtonType.Button"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="@(!CanSendPoll || _sendingPoll)"
                           OnClick="@SendPollAsync">
                    @if (_sendingPoll)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                    }
                    else
                    {
                        <span>Tạo bình chọn</span>
                    }
                </MudButton>
            </div>
        </div>
    </div>
}

