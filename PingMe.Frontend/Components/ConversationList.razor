@using PingMe.Frontend.Models
@using PingMe.Frontend.Helpers
@using System.Text.Json
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject ConversationService ConvService
@inject NavigationManager Nav
@inject SearchService SearchService
@inject AuthenticationStateProvider AuthStateProvider
@inject UnreadStateService UnreadState
@inject LocalizationService Loc
@implements IDisposable

<div class="pm-conversation-list-root" style="height:100%;display:flex;flex-direction:column;overflow:hidden;">

    <!-- Header -->
    <div style="padding:16px;border-bottom:1px solid rgba(0,0,0,.06);display:flex;align-items:center;justify-content:space-between;">
        <div>
            <p style="margin:0;font-size:1rem;font-weight:700;color:var(--mud-palette-text-primary);letter-spacing:-.01em;">
                @Loc.T("chat.messagesTitle")
            </p>
        </div>

        <MudTooltip Text="Tin nhắn mới">
            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                           Size="Size.Small"
                           Color="Color.Primary"
                           OnClick="@OpenNewChatDialog" />
        </MudTooltip>
    </div>

    <!-- Search -->
    <div style="padding:10px 12px;border-bottom:1px solid rgba(0,0,0,.04);">
        <MudTextField @bind-Value="_search"
                      Placeholder='@Loc.T("chat.searchPlaceholder")'
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Immediate="true"
                      Style="border-radius:20px;" />
    </div>

    <!-- Conversations -->
    <div style="flex:1;overflow-y:auto;">
        @if (_conversations == null)
        {
            <div style="display:flex;justify-content:center;padding:32px;">
                <MudProgressCircular Indeterminate Size="Size.Small" Color="Color.Primary" />
            </div>
        }
        else if (!FilteredConversations.Any())
        {
            <div class="pm-empty" style="padding:32px 16px;">
                <MudIcon Icon="@Icons.Material.Outlined.Forum"
                         Style="font-size:48px;opacity:.2;color:var(--mud-palette-primary);" />

                <p style="margin:8px 0 0;font-size:.875rem;color:#94A3B8;text-align:center;">
                    Chưa có hội thoại nào
                </p>
            </div>
        }
        else
        {
            @foreach (var conv in FilteredConversations)
            {
                var c = conv;
                var isSelected = (c.Type == "dm" && c.PeerId == SelectedPeerId)
                || (c.Type == "group" && c.GroupId == SelectedGroupId);

                var avatarUrl = c.Type == "dm"
                ? BuildAvatarUrl(c.PeerAvatarUrl)
                : BuildAvatarUrl(c.GroupAvatarUrl);

                <div @key="GetConversationKey(c)"
                     class="@($"pm-conv-item {(isSelected ? "active" : "")} {(c.UnreadCount > 0 ? "has-unread" : "")}")"
                     @onclick="() => SelectConversation(c)"
                     @onmouseenter="() => _hoveredConversationKey = GetConversationKey(c)"
                     @onmouseleave="() => _hoveredConversationKey = string.Empty"
                     style="padding:10px 14px;">

                    <!-- Avatar -->
                    <div class="pm-avatar-wrap" style="flex-shrink:0;">
                        <MudAvatar Color="@(isSelected? Color.Primary: Color.Default)"
                                   Style="@(isSelected ? "background:var(--mud-palette-primary);color:white;" : "background:#E2E8F0;color:#475569;")"
                                   Size="Size.Medium">
                            @if (c.Type == "group")
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Group" Style="font-size:18px;" />
                            }
                            else
                            {
                                @GetConversationDisplayName(c).FirstOrDefault()
                            }

                            @if (!string.IsNullOrWhiteSpace(avatarUrl))
                            {
                                <img src="@avatarUrl"
                                     alt="@GetConversationDisplayName(c)"
                                     class="pm-avatar-image"
                                     loading="lazy"
                                     decoding="async"
                                     referrerpolicy="no-referrer"
                                     onerror="this.style.display='none';this.parentElement.classList.add('pm-avatar-fallback-active');" />
                            }
                        </MudAvatar>

                        @if (c.IsOnline && c.Type == "dm")
                        {
                            <div class="pm-online-dot"></div>
                        }
                    </div>

                    <!-- Info -->
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:4px;">
                            <span class="@($"pm-conv-name {(c.UnreadCount > 0 ? "unread" : "")}")">
                                @if (c.IsPinned)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.PushPin"
                                             Style="font-size:13px;color:var(--mud-palette-primary);margin-right:3px;vertical-align:-2px;" />
                                }

                                @GetConversationDisplayName(c)
                            </span>

                            <span class="pm-conv-time">@FormatTime(c.LastMessageAt)</span>
                        </div>

                        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2px;">
                            <span class="@($"pm-conv-preview {(c.UnreadCount > 0 ? "unread" : "")}")">
                                @if (c.Mentioned)
                                {
                                    <span class="pm-mention-marker">@GetMentionPreview(c)</span>
                                }
                                else
                                {
                                    @c.LastMessage
                                }
                            </span>

                            <div style="display:flex;align-items:center;gap:4px;flex-shrink:0;min-width:52px;justify-content:flex-end;">
                                @if (_hoveredConversationKey == GetConversationKey(c))
                                {
                                    <div @onclick:stopPropagation="true">
                                        <MudTooltip Text="@(c.IsPinned ? "Bỏ ghim hội thoại" : "Ghim hội thoại")">
                                            <MudIconButton Icon="@Icons.Material.Filled.PushPin"
                                                           Size="Size.Small"
                                                           Color="@(c.IsPinned ? Color.Primary : Color.Default)"
                                                           OnClick="() => ToggleConversationPinAsync(c)"
                                                           Style="width:26px;height:26px;" />
                                        </MudTooltip>
                                    </div>
                                }
                                @if (c.UnreadCount > 0)
                                {
                                    <span class="pm-unread-badge">
                                        @(c.UnreadCount > 99 ? "99+" : c.UnreadCount.ToString())
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (_newChatOpen)
{
    <div class="pm-newchat-backdrop" @onclick="CloseNewChatDialog">
        <div class="pm-newchat-card" @onclick:stopPropagation="true">
            <div class="pm-newchat-header">
                <div>
                    <MudText Typo="Typo.h6">Tin nhắn mới</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Tìm người dùng để bắt đầu cuộc trò chuyện.
                    </MudText>
                </div>

                <button type="button"
                        class="pm-newchat-close"
                        @onclick="CloseNewChatDialog">
                    ×
                </button>
            </div>

            <div class="pm-newchat-body">
                <MudTextField T="string"
                              Value="@_searchUser"
                              ValueChanged="@OnSearchUserChanged"
                              Label="Tìm người dùng..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              FullWidth="true" />

                @if (_searchingUser)
                {
                    <div style="display:flex;justify-content:center;padding:16px;">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    </div>
                }
                else if (_searchResults.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:6px;margin-top:12px;max-height:360px;overflow:auto;">
                        @foreach (var u in _searchResults)
                        {
                            var user = u;
                            var userAvatarUrl = UrlHelper.BuildBackendUrl(user.AvatarUrl, _avatarVersion);

                            <button type="button"
                                    class="pm-newchat-user"
                                    @onclick="@(() => StartChat(user.Id))">
                                <MudAvatar Size="Size.Small" Color="Color.Primary">
                                    <span>@user.DisplayName.FirstOrDefault()</span>
                                    @if (!string.IsNullOrWhiteSpace(userAvatarUrl))
                                    {
                                        <img src="@userAvatarUrl"
                                             alt="@user.DisplayName"
                                             class="pm-avatar-image"
                                             loading="lazy"
                                             decoding="async"
                                             referrerpolicy="no-referrer"
                                             onerror="this.style.display='none';this.parentElement.classList.add('pm-avatar-fallback-active');" />
                                    }
                                </MudAvatar>

                                <div style="min-width:0;text-align:left;">
                                    <div style="font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @user.DisplayName
                                    </div>

                                    <div style="font-size:12px;color:var(--mud-palette-text-secondary);">
                                        @@@user.Username
                                    </div>
                                </div>
                            </button>
                        }
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_searchUser))
                {
                    <div style="padding:16px;text-align:center;color:var(--mud-palette-text-secondary);">
                        Không tìm thấy người dùng phù hợp.
                    </div>
                }
            </div>

            <div class="pm-newchat-actions">
                <button type="button"
                        class="pm-newchat-cancel"
                        @onclick="CloseNewChatDialog">
                    Hủy
                </button>
            </div>
        </div>
    </div>
}

