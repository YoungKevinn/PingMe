@code {
    [Parameter] public int? SelectedPeerId { get; set; }
    [Parameter] public int? SelectedGroupId { get; set; }
    [Parameter] public EventCallback<ConversationDto> OnConversationSelected { get; set; }

    private List<ConversationDto>? _conversations;
    private string _search = "";
    private bool _newChatOpen;
    private string _searchUser = "";
    private string _hoveredConversationKey = string.Empty;
    private bool _searchingUser;
    private List<UserSearchResult> _searchResults = new();
    private int CurrentUserId;
    private readonly Dictionary<string, int> _lastAppliedMessageIds = new();
    private readonly HashSet<int> _mentionMessageIds = new();
    private CancellationTokenSource? _searchUserDebounceCts;

    private long _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    public IEnumerable<ConversationDto> FilteredConversations =>
        (_conversations?.Where(c => string.IsNullOrWhiteSpace(_search)
            || GetConversationDisplayName(c).Contains(_search, StringComparison.OrdinalIgnoreCase)
            || c.LastMessage?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true)
            .OrderByDescending(c => c.IsPinned)
            .ThenByDescending(c => c.LastMessageAt ?? DateTime.MinValue))
        ?? Enumerable.Empty<ConversationDto>();

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += HandleLanguageChanged;
        await Loc.LoadAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                      ?? authState.User.FindFirst("sub")?.Value;

        CurrentUserId = int.TryParse(idClaim, out var id) ? id : 0;

        await RefreshAsync();
    }

    public async Task RefreshAsync()
    {
        _conversations = await ConvService.GetConversationsAsync();
        _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        PublishUnreadTotal();
        StateHasChanged();
    }

    public async Task ApplyIncomingMessageAsync(MessageResponse message, bool isCurrentConversation)
    {
        if (_conversations == null || CurrentUserId <= 0)
            return;

        var key = GetMessageConversationKey(message);

        if (key != null &&
            _lastAppliedMessageIds.TryGetValue(key, out var lastMessageId) &&
            lastMessageId == message.Id)
        {
            return;
        }

        var conversation = FindConversation(message);

        if (conversation == null)
        {
            await RefreshAsync();
            return;
        }

        conversation.LastMessage = BuildLastMessagePreview(message);
        conversation.LastMessageAt = message.CreatedAt;

        if (isCurrentConversation || message.SenderId == CurrentUserId)
        {
            conversation.UnreadCount = 0;
            conversation.Mentioned = false;
            conversation.MentionedByName = null;
            conversation.MentionPreview = null;
        }
        else
        {
            if (!_mentionMessageIds.Contains(message.Id))
                conversation.UnreadCount++;
        }

        if (key != null)
            _lastAppliedMessageIds[key] = message.Id;

        PublishUnreadTotal();
        StateHasChanged();
    }

    public Task MarkConversationReadAsync(int? peerId, int? groupId)
    {
        if (_conversations == null)
            return Task.CompletedTask;

        var conversation = _conversations.FirstOrDefault(c =>
            (groupId.HasValue && c.Type == "group" && c.GroupId == groupId) ||
            (peerId.HasValue && c.Type == "dm" && c.PeerId == peerId));

        if (conversation != null && (conversation.UnreadCount != 0 || conversation.Mentioned))
        {
            conversation.UnreadCount = 0;
            conversation.Mentioned = false;
            conversation.MentionedByName = null;
            conversation.MentionPreview = null;
            PublishUnreadTotal();
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    public async Task MarkGroupMentionedAsync(int groupId, int messageId, bool isCurrentConversation, string? senderDisplayName)
    {
        if (_conversations == null)
            await RefreshAsync();

        if (_conversations == null)
            return;

        var conversation = _conversations.FirstOrDefault(c =>
            c.Type == "group" && c.GroupId == groupId);

        if (conversation == null)
        {
            await RefreshAsync();
            conversation = _conversations?.FirstOrDefault(c =>
                c.Type == "group" && c.GroupId == groupId);
        }

        if (conversation == null)
            return;

        _mentionMessageIds.Add(messageId);

        if (isCurrentConversation)
        {
            conversation.UnreadCount = 0;
            conversation.Mentioned = false;
            conversation.MentionedByName = null;
            conversation.MentionPreview = null;
        }
        else
        {
            conversation.Mentioned = true;
            conversation.MentionedByName = senderDisplayName;
            conversation.MentionPreview = BuildMentionPreview(senderDisplayName);
            if (conversation.UnreadCount <= 0)
                conversation.UnreadCount = 1;
        }

        PublishUnreadTotal();
        StateHasChanged();
    }

    public Task UpdateConversationTitleAsync(int? peerId, int? groupId, string title, string? avatarUrl = null)
    {
        if (_conversations == null)
            return Task.CompletedTask;

        var conversation = _conversations.FirstOrDefault(c =>
            (groupId.HasValue && c.Type == "group" && c.GroupId == groupId) ||
            (peerId.HasValue && c.Type == "dm" && c.PeerId == peerId));

        if (conversation is null)
            return Task.CompletedTask;

        if (conversation.Type == "group")
        {
            conversation.GroupName = title;

            if (avatarUrl is not null)
                conversation.GroupAvatarUrl = avatarUrl;
        }
        else
        {
            conversation.PeerDisplayName = title;

            if (avatarUrl is not null)
                conversation.PeerAvatarUrl = avatarUrl;
        }

        _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        StateHasChanged();
        return Task.CompletedTask;
    }

    private ConversationDto? FindConversation(MessageResponse message)
    {
        if (message.GroupId.HasValue)
        {
            return _conversations?.FirstOrDefault(c =>
                c.Type == "group" &&
                c.GroupId == message.GroupId.Value);
        }

        var peerId = message.SenderId == CurrentUserId
            ? message.ReceiverId
            : message.SenderId;

        return _conversations?.FirstOrDefault(c =>
            c.Type == "dm" &&
            c.PeerId == peerId);
    }

    private string? GetMessageConversationKey(MessageResponse message)
    {
        if (message.GroupId.HasValue)
            return $"group:{message.GroupId.Value}";

        var peerId = message.SenderId == CurrentUserId
            ? message.ReceiverId
            : message.SenderId;

        return peerId.HasValue ? $"dm:{peerId.Value}" : null;
    }

    private static string BuildLastMessagePreview(MessageResponse message)
    {
        if (message.IsDeleted)
            return "Tin nhắn đã thu hồi";

        if (message.Attachments?.Any() == true)
        {
            var attachment = message.Attachments.First();
            return attachment.IsImage ? "Hình ảnh" : $"Tệp: {attachment.FileName}";
        }

        if (string.Equals(message.MessageType, "Image", StringComparison.OrdinalIgnoreCase))
            return "Hình ảnh";

        if (string.Equals(message.MessageType, "File", StringComparison.OrdinalIgnoreCase))
            return "Tệp đính kèm";

        if (string.Equals(message.MessageType, "Reminder", StringComparison.OrdinalIgnoreCase))
            return TruncatePreview(BuildCommandPreview(message.Content, "reminder") ?? "⏰ Nhắc việc");

        if (string.Equals(message.MessageType, "Task", StringComparison.OrdinalIgnoreCase))
            return TruncatePreview(BuildCommandPreview(message.Content, "task") ?? "✅ Task");

        if (string.Equals(message.MessageType, "Vulnerability", StringComparison.OrdinalIgnoreCase))
            return TruncatePreview(BuildCommandPreview(message.Content, "vulnerability") ?? "🐞 Finding");

        if (string.Equals(message.MessageType, "Cve", StringComparison.OrdinalIgnoreCase))
            return TruncatePreview(BuildCommandPreview(message.Content, "ioc") ?? "🛡 IOC");

        var commandPreview = BuildCommandPreview(message.Content, null);
        if (!string.IsNullOrWhiteSpace(commandPreview))
            return TruncatePreview(commandPreview);

        return string.IsNullOrWhiteSpace(message.Content)
            ? "(Tin nhắn trống)"
            : TruncatePreview(message.Content);
    }

    private static string? BuildCommandPreview(string? content, string? expectedType)
    {
        if (string.IsNullOrWhiteSpace(content))
            return null;

        var trimmed = content.Trim();

        if (trimmed.StartsWith("/ioc ", StringComparison.OrdinalIgnoreCase))
        {
            var parts = trimmed.Split(' ', 3, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 3)
                return $"🛡 IOC: {parts[2]}";
        }

        if (!trimmed.StartsWith('{'))
            return null;

        try
        {
            using var doc = JsonDocument.Parse(trimmed);
            var root = doc.RootElement;
            var type = GetString(root, "type");

            if (!string.IsNullOrWhiteSpace(expectedType) &&
                !string.Equals(type, expectedType, StringComparison.OrdinalIgnoreCase) &&
                !(string.Equals(expectedType, "vulnerability", StringComparison.OrdinalIgnoreCase) &&
                  string.Equals(type, "finding", StringComparison.OrdinalIgnoreCase)))
            {
                return null;
            }

            return type?.Trim().ToLowerInvariant() switch
            {
                "reminder" => $"⏰ Nhắc việc: {GetString(root, "text") ?? "nhắc việc"}",
                "task" => $"✅ Task: {GetString(root, "title") ?? "task"}",
                "vulnerability" or "finding" => $"🐞 Finding: {GetString(root, "title") ?? "finding"}",
                "ioc" => $"🛡 IOC: {GetString(root, "value") ?? GetString(root, "title") ?? "IOC"}",
                _ => null
            };
        }
        catch
        {
            return null;
        }
    }

    private static string? GetString(JsonElement element, string propertyName)
        => element.TryGetProperty(propertyName, out var value) && value.ValueKind == JsonValueKind.String
            ? value.GetString()
            : null;

    private static string TruncatePreview(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "(Tin nhắn trống)";

        var normalized = value.Replace("\r", " ").Replace("\n", " ").Trim();
        return normalized.Length <= 140 ? normalized : normalized[..137] + "...";
    }

    private static string GetMentionPreview(ConversationDto conversation)
        => !string.IsNullOrWhiteSpace(conversation.MentionPreview)
            ? conversation.MentionPreview
            : BuildMentionPreview(conversation.MentionedByName);

    private static string BuildMentionPreview(string? senderDisplayName)
        => string.IsNullOrWhiteSpace(senderDisplayName)
            ? "Có người đã nhắc đến bạn"
            : $"{senderDisplayName.Trim()} đã nhắc đến bạn";

    private void PublishUnreadTotal()
    {
        var total = _conversations?.Sum(c => Math.Max(0, c.UnreadCount)) ?? 0;
        UnreadState.SetTotal(total);
    }

    private string? BuildAvatarUrl(string? avatarUrl)
    {
        return UrlHelper.BuildBackendUrl(avatarUrl, _avatarVersion);
    }

    private static string GetConversationKey(ConversationDto c)
    {
        return c.Type == "group"
            ? $"group:{c.GroupId}"
            : $"dm:{c.PeerId}";
    }

    private async Task ToggleConversationPinAsync(ConversationDto c)
    {
        var ok = c.IsPinned
            ? await ConvService.UnpinConversationAsync(c.PeerId, c.GroupId)
            : await ConvService.PinConversationAsync(c.PeerId, c.GroupId);

        if (!ok)
            return;

        c.IsPinned = !c.IsPinned;
        StateHasChanged();
    }

    private void SelectConversation(ConversationDto c)
    {
        if (c.Type == "dm" && c.PeerId.HasValue)
            Nav.NavigateTo($"/chat/{c.PeerId}");
        else if (c.Type == "group" && c.GroupId.HasValue)
            Nav.NavigateTo($"/chat/group/{c.GroupId}");

        OnConversationSelected.InvokeAsync(c);
    }

    private void OpenNewChatDialog()
    {
        _newChatOpen = true;
        _searchUser = string.Empty;
        _searchResults.Clear();
    }

    private void CloseNewChatDialog()
    {
        _newChatOpen = false;
        _searchUser = string.Empty;
        _searchingUser = false;
        _searchResults.Clear();
        StateHasChanged();
    }

    private async Task OnSearchUserChanged(string value)
    {
        _searchUser = value;
        _searchUserDebounceCts?.Cancel();

        if (string.IsNullOrWhiteSpace(_searchUser))
        {
            _searchResults.Clear();
            _searchingUser = false;
            StateHasChanged();
            return;
        }

        if (_searchUser.Trim().Length < 2)
        {
            _searchResults.Clear();
            _searchingUser = false;
            StateHasChanged();
            return;
        }

        var cts = new CancellationTokenSource();
        _searchUserDebounceCts = cts;

        try
        {
            await Task.Delay(350, cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _searchingUser = true;
        StateHasChanged();

        try
        {
            var term = _searchUser.Trim();
            var result = await SearchService.SearchAsync(term, 10);
            if (cts.IsCancellationRequested || !string.Equals(term, _searchUser.Trim(), StringComparison.Ordinal))
                return;

            _searchResults = result?.Users ?? new List<UserSearchResult>();
        }
        finally
        {
            if (!cts.IsCancellationRequested)
            {
                _searchingUser = false;
                StateHasChanged();
            }
        }
    }

    private void StartChat(int userId)
    {
        CloseNewChatDialog();
        Nav.NavigateTo($"/chat/{userId}");
    }

    private string FormatTime(DateTime? dt)
    {
        if (!dt.HasValue)
            return "";

        var local = dt.Value.ToLocalTime();
        var now = DateTime.Now;

        if (local.Date == now.Date)
            return local.ToString("HH:mm");

        if (local.Date == now.Date.AddDays(-1))
            return Loc.T("time.yesterday");

        if ((now - local).TotalDays < 7)
            return local.ToString("ddd");

        return local.ToString("dd/MM");
    }

    private string GetConversationDisplayName(ConversationDto conversation)
    {
        if (conversation.Type.Equals("group", StringComparison.OrdinalIgnoreCase))
            return conversation.GroupName ?? Loc.T("chat.groupLabel");

        return conversation.PeerDisplayName ?? string.Empty;
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= HandleLanguageChanged;
        _searchUserDebounceCts?.Cancel();
        _searchUserDebounceCts?.Dispose();
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
