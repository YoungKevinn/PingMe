        flex-wrap: wrap;
    }

    .pm-gm-title-text {
        margin: 0;
        line-height: 1.2;
    }

    .pm-gm-group-name {
        display: block;
        line-height: 1.2;
    }

    .pm-gm-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 24px;
        padding: 3px 10px;
        border-radius: 999px;
        background: rgba(37, 99, 235, .12);
        color: var(--mud-palette-primary);
        font-size: .78rem;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
        transform: translateY(1px);
    }

    .pm-gm-loading {
        min-height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pm-gm-list {
        display: flex;
        flex-direction: column;
