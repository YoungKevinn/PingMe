</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthTask { get; set; }

    [Parameter] public int GroupId { get; set; }
    [Parameter] public string? GroupName { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private readonly List<GroupMemberResponse> _members = new();
    private bool _loading = true;
    private bool _loadFailed;
    private string _loadError = "Không tải được danh sách thành viên.";
    private int _currentUserId;
    private int? _actingUserId;

    private IEnumerable<GroupMemberResponse> SortedMembers =>
        _members
            .OrderBy(x => GetRoleSort(x.Role))
            .ThenBy(x => x.DisplayName);

    private string CurrentRole =>
        _members.FirstOrDefault(x => x.UserId == _currentUserId)?.Role ?? "";

    private bool IsCurrentAdmin => RoleEquals(CurrentRole, "Admin");
    private bool IsCurrentCoAdmin => RoleEquals(CurrentRole, "CoAdmin");

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
        await LoadMembersAsync();
    }

    private async Task LoadCurrentUserAsync()
    {
        if (AuthTask is null)
            return;

        var auth = await AuthTask;
        var idClaim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                      ?? auth.User.FindFirst("sub")?.Value;

        _currentUserId = int.TryParse(idClaim, out var id) ? id : 0;
    }

    private async Task LoadMembersAsync()
    {
        _loading = true;
        _loadFailed = false;
        _loadError = "Không tải được danh sách thành viên.";

        try
        {
            var members = await GroupService.GetGroupMembersAsync(GroupId);
            if (GroupService.LastError is not null)
            {
                _members.Clear();
                _loadFailed = true;
                _loadError = GroupService.LastError;
                Snackbar.Add(_loadError, Severity.Warning);
                return;
            }

            _members.Clear();
            _members.AddRange(members);
        }
        catch
        {
            _members.Clear();
            _loadFailed = true;
            Snackbar.Add("Không tải được danh sách thành viên nhóm.", Severity.Warning);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool CanPromote(GroupMemberResponse member) =>
        IsCurrentAdmin &&
        member.UserId != _currentUserId &&
        RoleEquals(member.Role, "Member");

    private bool CanDemote(GroupMemberResponse member) =>
        IsCurrentAdmin &&
        member.UserId != _currentUserId &&
        RoleEquals(member.Role, "CoAdmin");

    private bool CanKick(GroupMemberResponse member) =>
        (IsCurrentAdmin || IsCurrentCoAdmin) &&
        member.UserId != _currentUserId &&
        !RoleEquals(member.Role, "Admin") &&
        (IsCurrentAdmin || RoleEquals(member.Role, "Member"));

    private bool IsActing(int userId) => _actingUserId == userId;

    private Task PromoteAsync(int userId) => ChangeRoleAsync(userId, "CoAdmin");

    private Task DemoteAsync(int userId) => ChangeRoleAsync(userId, "Member");

    private async Task ChangeRoleAsync(int userId, string role)
    {
        _actingUserId = userId;

        try
        {
            var ok = await GroupService.UpdateMemberRoleAsync(GroupId, userId, role);

            if (!ok)
            {
                Snackbar.Add(GroupService.LastError ?? "Không cập nhật được quyền thành viên.", Severity.Warning);
                return;
            }

            Snackbar.Add("Đã cập nhật quyền thành viên.", Severity.Success);
            await LoadMembersAsync();
        }
        catch
        {
            Snackbar.Add("Không cập nhật được quyền thành viên.", Severity.Warning);
        }
        finally
        {
            _actingUserId = null;
        }
    }

    private async Task KickAsync(int userId)
    {
        _actingUserId = userId;

        try
        {
            var ok = await GroupService.KickMemberAsync(GroupId, userId);

            if (!ok)
            {
                Snackbar.Add(GroupService.LastError ?? "Không thể xóa thành viên khỏi nhóm.", Severity.Warning);
                return;
            }

            Snackbar.Add("Đã xóa thành viên khỏi nhóm.", Severity.Success);
            await LoadMembersAsync();
        }
        catch
        {
            Snackbar.Add("Không thể xóa thành viên khỏi nhóm.", Severity.Warning);
        }
        finally
        {
            _actingUserId = null;
        }
    }

    private Task CloseAsync() => OnClose.InvokeAsync();

    private static bool RoleEquals(string? role, string expected) =>
        string.Equals(role, expected, StringComparison.OrdinalIgnoreCase);

    private static int GetRoleSort(string? role)
    {
        if (RoleEquals(role, "Admin")) return 0;
        if (RoleEquals(role, "CoAdmin")) return 1;
        return 2;
    }

    private static string GetRoleLabel(string? role)
    {
        if (RoleEquals(role, "Admin")) return "Admin";
        if (RoleEquals(role, "CoAdmin")) return "CoAdmin";
        return "Member";
    }

    private static string GetRoleBadgeClass(string? role)
    {
        if (RoleEquals(role, "Admin")) return "pm-gm-role admin";
        if (RoleEquals(role, "CoAdmin")) return "pm-gm-role coadmin";
        return "pm-gm-role member";
    }

    private static char GetInitial(string? displayName) =>
        string.IsNullOrWhiteSpace(displayName) ? '?' : displayName.Trim()[0];

    private static string? BuildAvatarUrl(string? avatarUrl)
    {
        return UrlHelper.BuildBackendUrl(avatarUrl);
    }
}
