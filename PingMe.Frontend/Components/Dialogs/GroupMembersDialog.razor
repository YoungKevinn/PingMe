            padding-inline: 16px;
        }

        .pm-gm-title-row {
            gap: 8px;
        }

        .pm-gm-row {
            grid-template-columns: 44px minmax(0, 1fr);
        }

        .pm-gm-role-cell,
        .pm-gm-actions {
            grid-column: 2 / -1;
            justify-content: flex-start;
        }
