@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using PingMe.Frontend.Models
@using PingMe.Frontend.Helpers
@inject GroupService GroupService
@inject ISnackbar Snackbar

<div class="pm-group-members-dialog">
    <div class="pm-dialog-title-wrap">
        <div class="pm-gm-title">
            <div class="pm-gm-title-main">
                <div class="pm-gm-title-row">
                    <MudText Typo="Typo.h6" Class="pm-gm-title-text">Quản lý thành viên</MudText>

                    @if (!_loading)
                    {
                        <span class="pm-gm-count">@_members.Count thành viên</span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(GroupName))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pm-gm-group-name">@GroupName</MudText>
                }
            </div>

            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           ButtonType="ButtonType.Button"
                           OnClick="CloseAsync"
                           AriaLabel="Đóng" />
        </div>
    </div>

    <div class="pm-dialog-body-wrap">
        @if (_loading)
        {
            <div class="pm-gm-loading">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_loadFailed)
        {
            <MudAlert Severity="Severity.Warning" Dense="true">
                @_loadError
            </MudAlert>
        }
        else if (!_members.Any())
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                Nhóm chưa có thành viên.
            </MudAlert>
        }
        else
        {
            <div class="pm-gm-list">
                @foreach (var item in SortedMembers)
                {
                    var member = item;
                    var avatarUrl = BuildAvatarUrl(member.AvatarUrl);

                    <div class="pm-gm-row">
                        <MudAvatar Size="Size.Medium" Class="pm-gm-avatar">
                            <span>@GetInitial(member.DisplayName)</span>
                            @if (!string.IsNullOrWhiteSpace(avatarUrl))
                            {
                                <img src="@avatarUrl"
                                     alt="@member.DisplayName"
                                     class="pm-avatar-image"
                                     loading="lazy"
                                     decoding="async"
                                     referrerpolicy="no-referrer"
                                     onerror="this.style.display='none';this.parentElement.classList.add('pm-avatar-fallback-active');" />
                            }
                        </MudAvatar>

                        <div class="pm-gm-info">
                            <div class="pm-gm-name-line">
                                <span class="pm-gm-name">@member.DisplayName</span>
                                @if (member.UserId == _currentUserId)
                                {
                                    <span class="pm-gm-me">Bạn</span>
                                }
                            </div>
                            <div class="pm-gm-meta">
                                Tham gia @member.JoinedAt.ToLocalTime().ToString("dd/MM/yyyy")
                            </div>
                        </div>

                        <div class="pm-gm-role-cell">
                            <span class="@GetRoleBadgeClass(member.Role)">
                                @GetRoleLabel(member.Role)
                            </span>
                        </div>

                        <div class="pm-gm-actions">
                            @if (CanPromote(member))
                            {
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           Disabled="@IsActing(member.UserId)"
                                           ButtonType="ButtonType.Button"
                                           OnClick="() => PromoteAsync(member.UserId)">
                                    Lên CoAdmin
                                </MudButton>
                            }

                            @if (CanDemote(member))
                            {
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Color="Color.Warning"
                                           Disabled="@IsActing(member.UserId)"
                                           ButtonType="ButtonType.Button"
                                           OnClick="() => DemoteAsync(member.UserId)">
                                    Xuống Member
                                </MudButton>
                            }

                            @if (CanKick(member))
                            {
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Text"
                                           Color="Color.Error"
                                           Disabled="@IsActing(member.UserId)"
                                           ButtonType="ButtonType.Button"
                                           OnClick="() => KickAsync(member.UserId)">
                                    Kick
                                </MudButton>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="pm-dialog-actions-wrap">
        <MudButton Variant="Variant.Text" ButtonType="ButtonType.Button" OnClick="CloseAsync">Đóng</MudButton>
    </div>
</div>

<style>
    .pm-group-members-dialog {
        display: flex;
        flex-direction: column;
        max-height: min(90vh, 720px);
    }

    .pm-dialog-title-wrap {
        padding: 16px 20px 10px;
    }

    .pm-dialog-body-wrap {
        padding: 8px 20px 16px;
        overflow: auto;
    }

    .pm-dialog-actions-wrap {
        display: flex;
        justify-content: flex-end;
        padding: 8px 20px 16px;
    }

    .pm-gm-title {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        width: 100%;
    }

    .pm-gm-title-main {
        min-width: 0;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 4px;
        flex: 1;
    }

    .pm-gm-title-row {
        min-width: 0;
        display: flex;
        align-items: center;
