    .pm-gm-avatar {
        justify-self: center;
        background: linear-gradient(135deg, #2563EB, #60A5FA);
        color: white;
        font-weight: 800;
    }

    .pm-gm-info {
        min-width: 0;
    }

    .pm-gm-name-line {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
    }

    .pm-gm-name {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--mud-palette-text-primary);
        font-weight: 750;
    }

    .pm-gm-me {
        padding: 2px 7px;
        border-radius: 999px;
        background: rgba(16, 185, 129, .14);
        color: #047857;
        font-size: .68rem;
        font-weight: 800;
        white-space: nowrap;
    }

    .pm-gm-meta {
        margin-top: 2px;
        color: var(--mud-palette-text-secondary);
        font-size: .76rem;
    }

    .pm-gm-role-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
    }

    .pm-gm-role {
        display: inline-flex;
        align-items: center;
