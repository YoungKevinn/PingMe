@using PingMe.Frontend.Models
@inject MudBlazor.IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Lịch sử chỉnh sửa</MudText>
    </TitleContent>
    <DialogContent>
        @if (History == null || !History.Any())
        {
            <MudText>Không có lịch sử chỉnh sửa.</MudText>
        }
        else
        {
            @foreach (var entry in History.OrderByDescending(e => e.EditedAt))
            {
                <MudPaper Class="pa-3 mb-3" Elevation="0" Style="border-left: 3px solid #3B82F6;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @entry.EditedAt.ToLocalTime().ToString("HH:mm:ss dd/MM/yyyy")
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-1">
                        <strong>Cũ:</strong> @entry.OldContent
                    </MudText>
                    <MudText Typo="Typo.body2" Class="mt-1">
                        <strong>Mới:</strong> @entry.NewContent
                    </MudText>
                </MudPaper>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Text">Đóng</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudBlazor.MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<EditHistoryDto> History { get; set; } = new();

    private void Close() => MudDialog.Close();
}