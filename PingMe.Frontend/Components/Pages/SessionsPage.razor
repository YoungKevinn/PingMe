@page "/sessions"
@attribute [Authorize]
@implements IDisposable
@using PingMe.Frontend.Models
@using PingMe.Frontend.Services
@inject SessionService SessionService
@inject LocalizationService Loc
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h5" Class="font-weight-bold">@Loc.T("sessions.title")</MudText>
        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.Logout"
                   OnClick="RevokeOthersAsync">
            @Loc.T("sessions.logoutOthers")
        </MudButton>
    </div>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate />
    }
    else
    {
        <MudGrid>
            @foreach (var s in _sessions)
            {
                var session = s;
                <MudItem xs="12" sm="6">
                    <MudCard Outlined="true" Style="@(s.IsCurrent ? "border-color: #534AB7;" : "")">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Computer" Color="Color.Primary" />
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold">
                                    @(s.DeviceInfo?.Split('/').FirstOrDefault() ?? Loc.T("sessions.unknownDevice"))
                                </MudText>
                                @if (s.IsCurrent)
                                {
                                    <MudChip Size="Size.Small" Color="Color.Success">@Loc.T("sessions.current")</MudChip>
                                }
                            </div>

                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
                                @Loc.T("sessions.ip") @(s.IpAddress ?? Loc.T("sessions.unknownIp"))
                            </MudText>

                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
                                @Loc.T("sessions.active") @s.LastActive.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </MudText>

                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
                                @Loc.T("sessions.expires") @s.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy")
                            </MudText>
                        </MudCardContent>

                        @if (!s.IsCurrent)
                        {
                            <MudCardActions>
                                <MudButton Color="Color.Error" Size="Size.Small"
                                           OnClick="() => RevokeAsync(session.Id)">
                                    @Loc.T("sessions.revoke")
                                </MudButton>
                            </MudCardActions>
                        }
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@code {
    private List<SessionResponse> _sessions = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += StateHasChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= StateHasChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _sessions = await SessionService.GetSessionsAsync() ?? new();
        _loading = false;
    }

    private async Task RevokeAsync(int sessionId)
    {
        var ok = await SessionService.RevokeSessionAsync(sessionId);

        if (ok)
        {
            Snackbar.Add("Đã thu hồi phiên", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Thu hồi thất bại", Severity.Error);
        }
    }

    private async Task RevokeOthersAsync()
    {
        var ok = await SessionService.RevokeOtherSessionsAsync();

        if (ok)
        {
            Snackbar.Add("Đã đăng xuất tất cả thiết bị khác", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Thất bại", Severity.Error);
        }
    }
}