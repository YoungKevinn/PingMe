@page "/forgot-password"
@using PingMe.Frontend.Services
@inject ForgotPasswordService ForgotPasswordService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@attribute [AllowAnonymous]
@layout PingMe.Frontend.Components.Layout.EmptyLayout

<div class="pm-auth-wrapper">
    <div class="pm-auth-card">
        @if (!_sent)
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="color:white;font-size:30px;" />
                </div>
                <div>
                    <p class="pm-auth-title">Quên mật khẩu</p>
                    <p class="pm-auth-subtitle">Nhập email đã đăng ký để nhận mật khẩu mới</p>
                </div>
            </div>

            <MudForm @ref="_form">
                <MudTextField @bind-Value="_email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Email"
                              Required="true"
                              RequiredError="Vui lòng nhập email"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="SendNewPasswordAsync"
                           Disabled="@_loading"
                           Style="height:48px;font-size:1rem;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" /> }
                    Gửi mật khẩu mới
                </MudButton>
            </MudForm>

            <div style="text-align:center;margin-top:16px;">
                <MudLink Href="/login">← Quay lại đăng nhập</MudLink>
            </div>
        }
        else
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Style="color:white;font-size:30px;" />
                </div>
                <div>
                    <p class="pm-auth-title">Kiểm tra email</p>
                    <p class="pm-auth-subtitle">Nếu email tồn tại, mật khẩu mới đã được gửi đến @_email</p>
                </div>
            </div>

            <MudAlert Severity="Severity.Info" Class="mb-4">
                Hãy đăng nhập bằng mật khẩu mới trong email, sau đó vào phần cài đặt để đổi lại mật khẩu của bạn.
            </MudAlert>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="@(() => Nav.NavigateTo("/login"))"
                       Style="height:48px;font-size:1rem;font-weight:600;">
                Đến trang đăng nhập
            </MudButton>
        }
    </div>
</div>

@code {
    private MudForm? _form;
    private string _email = "";
    private bool _loading;
    private bool _sent;

    private async Task SendNewPasswordAsync()
    {
        if (_form == null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        _loading = true;
        try
        {
            var (success, error) = await ForgotPasswordService.SendNewPasswordAsync(_email);
            if (success)
            {
                Snackbar.Add("Nếu email tồn tại, mật khẩu mới đã được gửi. Kiểm tra hộp thư của bạn.", Severity.Success);
                _sent = true;
            }
            else
            {
                Snackbar.Add(error ?? "Không thể gửi yêu cầu.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
