@page "/forgot-password"
@using PingMe.Frontend.Services
@inject ForgotPasswordService ForgotPasswordService
@inject NavigationManager Nav
@implements IDisposable
@inject ISnackbar Snackbar
@attribute [AllowAnonymous]
@layout PingMe.Frontend.Components.Layout.EmptyLayout

<div class="pm-auth-wrapper">
    <div class="pm-auth-card">
        @if (_currentStep == 1)
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="color:white;font-size:30px;" />
                </div>
                <div>
                    <p class="pm-auth-title">Quên mật khẩu</p>
                    <p class="pm-auth-subtitle">Nhập email để nhận mã OTP</p>
                </div>
            </div>

            <MudForm @ref="_formStep1">
                <MudTextField @bind-Value="_email"
                              Label="Email"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Email"
                              Required="true"
                              RequiredError="Vui lòng nhập email"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="RequestOtpAsync"
                           Disabled="@_loading"
                           Style="height:48px;font-size:1rem;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" /> }
                    Gửi mã OTP
                </MudButton>
            </MudForm>

            <div style="text-align:center;margin-top:16px;">
                <MudLink Href="/login">← Quay lại đăng nhập</MudLink>
            </div>
        }
        else if (_currentStep == 2)
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Style="color:white;font-size:30px;" />
                </div>
                <div>
                    <p class="pm-auth-title">Nhập mã xác nhận</p>
                    <p class="pm-auth-subtitle">Mã OTP đã gửi đến @_email</p>
                </div>
            </div>

            <MudForm @ref="_formStep2">
                <MudTextField @bind-Value="_otpCode"
                              Label="Mã OTP (6 số)"
                              Variant="Variant.Outlined"
                              MaxLength="6"
                              Required="true"
                              RequiredError="Vui lòng nhập mã OTP"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="VerifyOtpAsync"
                           Disabled="@_loading"
                           Style="height:48px;font-size:1rem;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" /> }
                    Xác nhận
                </MudButton>
            </MudForm>

            <div style="text-align:center;margin-top:16px;">
                <MudText Typo="Typo.body2">Không nhận được mã?</MudText>
                <MudButton Variant="Variant.Text" 
                           Color="Color.Primary" 
                           Disabled="@(_countdown > 0)" 
                           OnClick="ResendOtpAsync">
                    Gửi lại @(_countdown > 0 ? $"({_countdown}s)" : "")
                </MudButton>
            </div>
        }
        else if (_currentStep == 3)
        {
            <div class="pm-auth-logo">
                <div class="pm-auth-logo-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Style="color:white;font-size:30px;" />
                </div>
                <div>
                    <p class="pm-auth-title">Đặt mật khẩu mới</p>
                </div>
            </div>

            <MudForm @ref="_formStep3">
                <MudTextField @bind-Value="_newPassword"
                              Label="Mật khẩu mới (tối thiểu 8 ký tự)"
                              Variant="Variant.Outlined"
                              InputType="@(_showPw ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPw ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="() => _showPw = !_showPw"
                              Required="true"
                              RequiredError="Vui lòng nhập mật khẩu"
                              Class="mb-4" />

                <MudTextField @bind-Value="_confirmPassword"
                              Label="Xác nhận mật khẩu mới"
                              Variant="Variant.Outlined"
                              InputType="@(_showConfirmPw ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showConfirmPw ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="() => _showConfirmPw = !_showConfirmPw"
                              Required="true"
                              RequiredError="Vui lòng xác nhận mật khẩu"
                              Validation="@(new Func<string, string?>(ValidatePasswordsMatch))"
                              Class="mb-4" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           OnClick="ResetPasswordAsync"
                           Disabled="@_loading"
                           Style="height:48px;font-size:1rem;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" /> }
                    Đặt lại mật khẩu
                </MudButton>
            </MudForm>
        }
    </div>
</div>

@code {
    private int _currentStep = 1;
    private bool _loading;
    
    // Step 1
    private MudForm? _formStep1;
    private string _email = "";
    
    // Step 2
    private MudForm? _formStep2;
    private string _otpCode = "";
    private int _countdown = 0;
    private System.Timers.Timer? _timer;
    
    // Step 3
    private MudForm? _formStep3;
    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _showPw;
    private bool _showConfirmPw;

    private async Task RequestOtpAsync()
    {
        if (_formStep1 == null) return;
        await _formStep1.Validate();
        if (!_formStep1.IsValid) return;

        _loading = true;
        try
        {
            var success = await ForgotPasswordService.RequestOtpAsync(_email);
            if (success)
            {
                Snackbar.Add("Nếu email tồn tại, mã OTP đã được gửi. Kiểm tra hộp thư của bạn.", Severity.Info);
                _currentStep = 2;
                StartCountdown();
            }
            else
            {
                Snackbar.Add("Không thể gửi yêu cầu.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResendOtpAsync()
    {
        if (_countdown > 0) return;
        _loading = true;
        try
        {
            var success = await ForgotPasswordService.RequestOtpAsync(_email);
            if (success)
            {
                Snackbar.Add("Mã OTP mới đã được gửi.", Severity.Info);
                StartCountdown();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void StartCountdown()
    {
        _countdown = 60;
        _timer?.Stop();
        _timer?.Dispose();
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (sender, e) =>
        {
            if (_countdown > 0)
            {
                _countdown--;
                InvokeAsync(StateHasChanged);
            }
            else
            {
                _timer.Stop();
            }
        };
        _timer.Start();
    }

    private async Task VerifyOtpAsync()
    {
        if (_formStep2 == null) return;
        await _formStep2.Validate();
        if (!_formStep2.IsValid) return;

        _loading = true;
        try
        {
            var valid = await ForgotPasswordService.VerifyOtpAsync(_email, _otpCode);
            if (valid)
            {
                _currentStep = 3;
            }
            else
            {
                Snackbar.Add("Mã OTP không đúng hoặc đã hết hạn.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Có lỗi xảy ra khi xác thực.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private string? ValidatePasswordsMatch(string value)
    {
        if (value != _newPassword)
            return "Mật khẩu không khớp";
        return null;
    }

    private async Task ResetPasswordAsync()
    {
        if (_formStep3 == null) return;
        await _formStep3.Validate();
        if (!_formStep3.IsValid) return;

        if (_newPassword.Length < 8)
        {
            Snackbar.Add("Mật khẩu mới phải có tối thiểu 8 ký tự.", Severity.Error);
            return;
        }

        _loading = true;
        try
        {
            var (success, error) = await ForgotPasswordService.ResetPasswordAsync(_email, _otpCode, _newPassword);
            if (success)
            {
                Snackbar.Add("Mật khẩu đã được đặt lại. Đang chuyển hướng...", Severity.Success);
                await Task.Delay(2000);
                Nav.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(error ?? "Có lỗi xảy ra", Severity.Error);
            }
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}
