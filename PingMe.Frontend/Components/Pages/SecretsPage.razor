@page "/secrets"
@attribute [Authorize]
@inject OneTimeSecretService SecretService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject LocalizationService Loc
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h5" Class="font-weight-bold">@Loc.T("secrets.title")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @Loc.T("secrets.subtitle")
            </MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="LoadAsync">
            @Loc.T("secrets.refresh")
        </MudButton>
    </div>

    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-3">@Loc.T("secrets.createTitle")</MudText>

                <MudTextField @bind-Value="_secretText"
                              Label="@Loc.T("secrets.secretLabel")"
                              Lines="8"
                              MaxLines="12"
                              Variant="Variant.Outlined"
                              Counter="8000"
                              MaxLength="8000"
                              Immediate="true" />

                <div class="pm-secret-field mt-3">
                    <label>@Loc.T("secrets.expiresLabel")</label>
                    <select @bind="_expiresIn" class="pm-secret-select">
                        <option value="5m">@Loc.T("secrets.expires5m")</option>
                        <option value="1h">@Loc.T("secrets.expires1h")</option>
                        <option value="1d">@Loc.T("secrets.expires1d")</option>
                    </select>
                </div>

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           StartIcon="@Icons.Material.Filled.Key"
                           Disabled="@(_creating || string.IsNullOrWhiteSpace(_secretText))"
                           OnClick="CreateAsync"
                           Class="mt-4">
                    @Loc.T("secrets.createButton")
                </MudButton>

                @if (!string.IsNullOrWhiteSpace(_shareUrl))
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="pm-secret-share-alert mt-4">
                        @Loc.T("secrets.shareOnce")
                    </MudAlert>

                    <MudPaper Outlined="true" Class="pm-secret-share-card pa-3 mt-2">
                        <MudText Typo="Typo.caption" Class="pm-secret-share-label">@Loc.T("secrets.shareLink")</MudText>
                        <textarea class="pm-secret-share-link" readonly rows="3">@_shareUrl</textarea>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ContentCopy"
                                   OnClick="CopyLinkAsync"
                                   Class="mt-2">
                            @Loc.T("secrets.copyLink")
                        </MudButton>
                    </MudPaper>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Outlined="true" Class="pa-4">
                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-3">@Loc.T("secrets.createdList")</MudText>

                @if (_loading)
                {
                    <MudProgressCircular Indeterminate />
                }
                else if (_items.Count == 0)
                {
                    <MudText Color="Color.Secondary">@Loc.T("secrets.empty")</MudText>
                }
                else
                {
                    <MudTable Items="_items" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>@Loc.T("secrets.createdAt")</MudTh>
                            <MudTh>@Loc.T("secrets.expiresAt")</MudTh>
                            <MudTh>@Loc.T("secrets.viewedAt")</MudTh>
                            <MudTh>@Loc.T("secrets.viewer")</MudTh>
                            <MudTh>@Loc.T("secrets.status")</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Loc.T("secrets.createdAt")">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                            <MudTd DataLabel="@Loc.T("secrets.expiresAt")">@context.ExpiresAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
                            <MudTd DataLabel="@Loc.T("secrets.viewedAt")">@(context.ViewedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
                            <MudTd DataLabel="@Loc.T("secrets.viewer")">
                                @if (!context.ViewedAt.HasValue)
                                {
                                    <span>-</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(context.ViewedByDisplayName))
                                {
                                    <MudTooltip Text="@GetViewerTooltip(context)">
                                        <div class="pm-secret-viewer">
                                            @{
                                                var avatarUrl = UrlHelper.BuildBackendUrl(context.ViewedByAvatarUrl);
                                            }
                                            <MudAvatar Size="Size.Small" Class="pm-secret-viewer-avatar">
                                                @if (!string.IsNullOrWhiteSpace(avatarUrl))
                                                {
                                                    <img src="@avatarUrl"
                                                         alt="@context.ViewedByDisplayName"
                                                         style="width:100%;height:100%;object-fit:cover;" />
                                                }
                                                else
                                                {
                                                    @GetInitials(context.ViewedByDisplayName)
                                                }
                                            </MudAvatar>
                                            <span>@context.ViewedByDisplayName</span>
                                        </div>
                                    </MudTooltip>
                                }
                                else if (context.IsAnonymousViewed)
                                {
                                    <MudTooltip Text="@GetViewerTooltip(context)">
                                        <span>@Loc.T("secrets.externalViewer")</span>
                                    </MudTooltip>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </MudTd>
                            <MudTd DataLabel="@Loc.T("secrets.status")">
                                <MudChip Size="Size.Small" Color="@GetStatusColor(context)">
                                    @GetStatusText(context)
                                </MudChip>
                            </MudTd>
                            <MudTd>
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Text"
                                           Color="Color.Error"
                                           Disabled="@(!IsActive(context))"
                                           OnClick="@(() => RevokeAsync(context.Id))">
                                    @Loc.T("secrets.revoke")
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>
<style>
    .pm-secret-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .pm-secret-field label {
            font-size: .78rem;
            font-weight: 700;
            color: var(--mud-palette-text-secondary);
        }

    .pm-secret-select {
        width: 100%;
        height: 44px;
        border-radius: 8px;
        border: 1px solid var(--mud-palette-lines-inputs);
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        padding: 0 12px;
        outline: none;
        font-weight: 600;
    }

        .pm-secret-select:focus {
            border-color: var(--mud-palette-primary);
            box-shadow: 0 0 0 2px rgba(37, 99, 235, .18);
        }

    .pm-secret-share-alert {
        font-weight: 700;
    }

    .pm-secret-share-card {
        border-color: var(--mud-palette-warning);
        background: var(--mud-palette-surface);
    }

    .pm-secret-share-label {
        display: block;
        color: var(--mud-palette-text-secondary);
        font-weight: 700;
        margin-bottom: 6px;
    }

    .pm-secret-share-link {
        width: 100%;
        min-height: 78px;
        border: 1px solid var(--mud-palette-lines-inputs);
        border-radius: 8px;
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-primary);
        font: 600 .875rem/1.45 ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
        padding: 10px 12px;
        resize: vertical;
        word-break: break-all;
        overflow-wrap: anywhere;
    }

    .pm-secret-viewer {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-width: 0;
        max-width: 220px;
    }

        .pm-secret-viewer span {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .pm-secret-viewer-avatar {
        flex: 0 0 auto;
        font-size: .72rem;
        font-weight: 700;
    }
</style>
@code {
    private List<OneTimeSecretListItemDto> _items = new();
    private string _secretText = string.Empty;
    private string _expiresIn = "5m";
    private string? _shareUrl;
    private bool _loading = true;
    private bool _creating;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += HandleLanguageChanged;
        await Loc.LoadAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _items = await SecretService.GetMineAsync();
        _loading = false;
    }

    private async Task CreateAsync()
    {
        _creating = true;
        var result = await SecretService.CreateAsync(new CreateOneTimeSecretRequest
        {
            SecretText = _secretText,
            ExpiresIn = _expiresIn
        });
        _creating = false;

        if (result.Secret is null)
        {
            Snackbar.Add(result.Error ?? Loc.T("secrets.createFailed"), Severity.Error);
            return;
        }

        _shareUrl = result.Secret.ShareUrl;
        _secretText = string.Empty;
        Snackbar.Add(Loc.T("secrets.created"), Severity.Success);
        await LoadAsync();
    }

    private async Task CopyLinkAsync()
    {
        if (string.IsNullOrWhiteSpace(_shareUrl))
            return;

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _shareUrl);
        Snackbar.Add(Loc.T("secrets.copyDone"), Severity.Success);
    }

    private async Task RevokeAsync(int id)
    {
        var result = await SecretService.RevokeAsync(id);

        if (!result.Success)
        {
            Snackbar.Add(result.Error ?? Loc.T("secrets.revokeFailed"), Severity.Error);
            return;
        }

        Snackbar.Add(Loc.T("secrets.revokeDone"), Severity.Success);
        await LoadAsync();
    }

    private static bool IsActive(OneTimeSecretListItemDto item)
        => !item.IsViewed && !item.IsRevoked && item.ExpiresAt > DateTime.UtcNow;

    private string GetStatusText(OneTimeSecretListItemDto item)
    {
        if (item.IsRevoked)
            return Loc.T("secrets.statusRevoked");

        if (item.IsViewed)
            return Loc.T("secrets.statusViewed");

        if (item.ExpiresAt <= DateTime.UtcNow)
            return Loc.T("secrets.statusExpired");

        return Loc.T("secrets.statusActive");
    }

    private static Color GetStatusColor(OneTimeSecretListItemDto item)
    {
        if (item.IsRevoked)
            return Color.Error;

        if (item.IsViewed)
            return Color.Info;

        if (item.ExpiresAt <= DateTime.UtcNow)
            return Color.Warning;

        return Color.Success;
    }

    private static string GetViewerTooltip(OneTimeSecretListItemDto item)
        => string.IsNullOrWhiteSpace(item.ViewedUserAgent)
            ? string.Empty
            : item.ViewedUserAgent;

    private static string GetInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
            return "?";

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0)
            return "?";

        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpperInvariant();

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= HandleLanguageChanged;
    }
}
