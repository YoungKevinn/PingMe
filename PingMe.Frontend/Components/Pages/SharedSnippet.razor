@page "/snippets/share/{Token}"
@attribute [AllowAnonymous]
@using PingMe.Frontend.Models
@inject SnippetService SnippetService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @if (_loading)
    {
        <div style="display:flex;justify-content:center;padding:48px;">
            <MudProgressCircular Indeterminate Color="Color.Primary" />
        </div>
    }
    else if (_notFound)
    {
        <MudPaper Class="pa-6 text-center" Outlined="true">
            <MudIcon Icon="@Icons.Material.Filled.LinkOff"
                     Style="font-size:64px;opacity:.3;color:var(--mud-palette-error);" />

            <MudText Typo="Typo.h5" Class="font-weight-bold mt-3">
                Snippet không khả dụng
            </MudText>

            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1">
                @_notFoundReason
            </MudText>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Class="mt-4"
                       OnClick="@GoHome">
                Về trang chủ
            </MudButton>
        </MudPaper>
    }
    else if (_snippet != null)
    {
        <MudPaper Class="pa-0" Outlined="true" Style="border-radius:16px;overflow:hidden;">

            <!-- Header bar -->
            <div style="padding:18px 24px;background:var(--mud-palette-surface);border-bottom:1px solid var(--mud-palette-divider);display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;">
                <div style="min-width:0;">
                    <div class="d-flex align-center gap-2 flex-wrap">
                        <MudText Typo="Typo.h6" Class="font-weight-bold" Style="margin:0;">
                            @(string.IsNullOrWhiteSpace(_snippet.Title) ? "Code Snippet" : _snippet.Title)
                        </MudText>

                        <MudChip Size="Size.Small" Color="Color.Primary" Style="margin:0;">
                            @_snippet.Language
                        </MudChip>
                    </div>

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-top:4px;display:block;">
                        Chia sẻ bởi @_snippet.CreatorDisplayName via PingMe •
                        @_snippet.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        @if (_snippet.AccessCount > 0)
                        {
                            <span> · 👁 @_snippet.AccessCount lượt xem</span>
                        }
                        @if (_snippet.ExpiresAt.HasValue)
                        {
                            <span> · ⏳ @_snippet.ExpiryLabel</span>
                        }
                    </MudText>
                </div>

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.OpenInFull"
                               OnClick="@OpenFullscreen">
                        Toàn màn hình
                    </MudButton>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="@CopyCode">
                        @(_copied ? "Đã copy!" : "Copy code")
                    </MudButton>
                </div>
            </div>

            <!-- Code area with syntax highlight -->
            <div style="background:#020617;overflow:auto;min-height:400px;max-height:calc(100vh - 260px);">
    <pre class="pm-shared-code-block">
                <code class="@($"language-{NormalizeHighlightLanguage(_snippet.Language)}")" id="shared-snippet-code">@_snippet.Content</code>
    </pre>
            </div>
        </MudPaper>
    }
</MudContainer>
<style>
    .pm-shared-code-block {
        position: relative;
        margin: 0;
        padding: 0;
        background: #0B1120;
        color: #E5E7EB;
        font-family: 'Fira Code', Consolas, monospace;
        font-size: 14px;
        line-height: 1.65;
        overflow: auto;
    }

        .pm-shared-code-block code {
            display: block;
            min-width: max-content;
            padding: 24px;
            background: transparent;
            white-space: pre;
        }
</style>
@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    private bool _loading = true;
    private bool _notFound;
    private string _notFoundReason = "Link chia sẻ không tồn tại, đã hết hạn hoặc đã bị thu hồi.";
    private SnippetResponse? _snippet;
    private bool _copied;

    protected override async Task OnInitializedAsync()
    {
        _snippet = await SnippetService.GetSharedSnippetAsync(Token);
        _loading = false;

        if (_snippet is null)
        {
            _notFound = true;
            // Try to give a slightly more informative message — we can't know the exact
            // reason from a 404, but we cover the common cases.
            _notFoundReason = "Link chia sẻ này không còn khả dụng. " +
                              "Có thể snippet đã bị xóa, link đã hết hạn, hoặc người tạo đã thu hồi.";
        }
    }
    private static string NormalizeHighlightLanguage(string? language)
    {
        if (string.IsNullOrWhiteSpace(language))
            return "plaintext";

        return language.Trim().ToLowerInvariant() switch
        {
            "c#" => "csharp",
            "cs" => "csharp",
            "js" => "javascript",
            "ts" => "typescript",
            "py" => "python",
            "sh" => "bash",
            "shell" => "bash",
            "ps" => "powershell",
            "ps1" => "powershell",
            "md" => "markdown",
            "yml" => "yaml",
            "html" => "xml",
            "plain" => "plaintext",
            "text" => "plaintext",
            var value => value
        };
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_snippet is not null)
        {
            try { await JS.InvokeVoidAsync("pingmeHighlight"); } catch { }
        }
    }

    private async Task CopyCode()
    {
        if (_snippet is null || string.IsNullOrWhiteSpace(_snippet.Content)) return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _snippet.Content);
            _copied = true;
            StateHasChanged();
            await Task.Delay(1500);
            _copied = false;
            StateHasChanged();
        }
        catch
        {
            Snackbar.Add("Không thể copy vào clipboard.", Severity.Warning);
        }
    }

    private async Task OpenFullscreen()
    {
        if (_snippet is null) return;

        await JS.InvokeVoidAsync(
            "pingmeSnippetFullscreen.open",
            _snippet.Title ?? "Code Snippet",
            _snippet.Language ?? "plaintext",
            _snippet.Content ?? string.Empty
        );
    }

    private void GoHome() => Nav.NavigateTo("/");
}
