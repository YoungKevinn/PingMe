@page "/timeline"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Authorization
@using PingMe.Frontend.Models
@using PingMe.Frontend.Helpers
@using PingMe.Frontend.Services
@inject TimelineService TimelineService
@inject GroupService GroupService
@inject ChatHubService ChatHubService
@inject LocalizationService Loc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 h-100" Style="overflow: hidden;">
    <MudGrid Spacing="3" Class="h-100">
        <!-- Sidebar: Group List (Desktop only) -->
        <MudItem xs="12" md="3" Class="d-none d-md-flex flex-column h-100">
            <MudPaper Elevation="1" Class="d-flex flex-column h-100 rounded-lg overflow-hidden">
                <MudToolBar Dense="true" Class="border-b mud-border-lines-default">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">@Loc.T("timeline.myGroups")</MudText>
                </MudToolBar>
                
                <div class="flex-grow-1 overflow-auto pa-2">
                    @if (_groupsLoading)
                    {
                        <div class="d-flex justify-center pa-4">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        </div>
                    }
                    else if (!_groups.Any())
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="pa-4">
                            @Loc.T("timeline.noGroups")
                        </MudText>
                    }
                    else
                    {
                        <MudList T="int" SelectedValue="GroupId">
                            @foreach (var g in _groups)
                            {
                                <MudListItem T="int" Value="@g.Id" Class="rounded-lg mb-1" OnClick="() => OnGroupSelected(g.Id)">
                                    <div class="d-flex align-center gap-3">
                                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                                            @if (!string.IsNullOrEmpty(g.AvatarUrl))
                                            {
                                                <img src="@GetAbsoluteUrl(g.AvatarUrl)" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';" style="width:100%; height:100%; object-fit:cover;" />
                                                <span style="display:none;">@g.Name?.FirstOrDefault()</span>
                                            }
                                            else
                                            {
                                                <span>@g.Name?.FirstOrDefault()</span>
                                            }
                                        </MudAvatar>
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;" Class="text-truncate">
                                            @g.Name
                                        </MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </div>
            </MudPaper>
        </MudItem>

        <!-- Main Content: Feed -->
        <MudItem xs="12" md="9" Class="d-flex flex-column h-100">
            <MudPaper Elevation="1" Class="d-flex flex-column h-100 rounded-lg overflow-hidden">
                <!-- Header -->
                <div class="pa-4 pa-sm-6 border-b mud-border-lines-default">
                    <div class="d-flex align-center justify-space-between flex-wrap gap-4">
                        <div>
                            <MudText Typo="Typo.h5" Style="font-weight: 800;" Color="Color.Default" Class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Timeline" Size="Size.Large" />
                                @Loc.T("timeline.title")
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @Loc.T("timeline.subtitle")
                            </MudText>
                        </div>
                        
                        <!-- Mobile Group Select -->
                        <div class="d-md-none" style="min-width: 200px;">
                            <MudSelect T="int" Value="GroupId" ValueChanged="@(EventCallback.Factory.Create<int>(this, OnGroupSelected))" Label="@Loc.T("timeline.selectGroup")" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense">
                                @foreach (var g in _groups)
                                {
                                    <MudSelectItem T="int" Value="@g.Id">@g.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="px-4 py-2 border-b mud-border-lines-default d-flex align-center flex-wrap gap-4" style="background: rgba(var(--mud-palette-surface-rgb), 0.8); backdrop-filter: blur(8px);">
                    <div class="d-flex flex-nowrap overflow-x-auto gap-2">
                        <MudChip T="string" Variant="@(CurrentFilter == null ? Variant.Filled : Variant.Text)" Color="Color.Primary" OnClick="@(() => OnFilterChanged("all"))">@Loc.T("timeline.all")</MudChip>
                        <MudChip T="string" Variant="@(CurrentFilter == "finding" ? Variant.Filled : Variant.Text)" Color="Color.Error" OnClick="@(() => OnFilterChanged("finding"))">Findings</MudChip>
                        <MudChip T="string" Variant="@(CurrentFilter == "ioc" ? Variant.Filled : Variant.Text)" Color="Color.Warning" OnClick="@(() => OnFilterChanged("ioc"))">IOCs</MudChip>
                        <MudChip T="string" Variant="@(CurrentFilter == "task" ? Variant.Filled : Variant.Text)" Color="Color.Success" OnClick="@(() => OnFilterChanged("task"))">Tasks</MudChip>
                        <MudChip T="string" Variant="@(CurrentFilter == "file" ? Variant.Filled : Variant.Text)" Color="Color.Secondary" OnClick="@(() => OnFilterChanged("file"))">Files</MudChip>
                    </div>
                    <MudSpacer />
                    <MudTextField T="string" Placeholder="@Loc.T("search")" Value="@SearchTerm" ValueChanged="OnSearchTermChanged" Immediate="true" Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Style="min-width: 250px; max-width: 350px;" />
                </div>

                <!-- Feed Area -->
                <div class="flex-grow-1 overflow-auto pa-4 pa-sm-6" id="timeline-scroll-area">
                    @if (GroupId == 0)
                    {
                        <div class="d-flex flex-column align-center justify-center h-100 text-center">
                            <MudIcon Icon="@Icons.Material.Outlined.Groups" Style="font-size: 80px; opacity: 0.3;" Color="Color.Primary" Class="mb-4" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">@Loc.T("timeline.noGroupSelected")</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.T("timeline.selectGroupFirst")</MudText>
                        </div>
                    }
                    else if (IsLoading && !Events.Any())
                    {
                        <div class="d-flex flex-column align-center justify-center h-100">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-4">@Loc.T("timeline.loading")</MudText>
                        </div>
                    }
                    else if (!Events.Any())
                    {
                        <div class="d-flex flex-column align-center justify-center h-100 text-center">
                            <MudIcon Icon="@Icons.Material.Outlined.History" Style="font-size: 80px; opacity: 0.3;" Color="Color.Primary" Class="mb-4" />
                            <MudText Typo="Typo.h6" Color="Color.Primary">@Loc.T("timeline.empty")</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.T("timeline.emptyDesc")</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTimeline TimelinePosition="TimelinePosition.Start" Modifiers="true" DisableModifiers="false" Class="pa-0">
                            @foreach (var ev in Events)
                            {
                                <MudTimelineItem Size="Size.Medium" Color="@GetEventColor(ev.EventType)" Elevation="1" TimelineAlign="TimelineAlign.End">
                                    <ItemOpposite>
                                    </ItemOpposite>
                                    <ItemContent>
                                        <MudCard Elevation="0" Class="border mud-border-lines-default pa-0 overflow-hidden" Style="transition: transform 0.2s, box-shadow 0.2s; border-radius: 12px;">
                                            <MudCardHeader Class="pa-3 border-b mud-border-lines-default" Style="background: rgba(var(--mud-palette-surface-rgb), 0.5);">
                                                <CardHeaderAvatar>
                                                    <MudAvatar Size="Size.Small" Color="Color.Primary">
                                                        @if (!string.IsNullOrEmpty(ev.ActorAvatar))
                                                        {
                                                            <img src="@GetAbsoluteUrl(ev.ActorAvatar)" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';" style="width:100%; height:100%; object-fit:cover;" />
                                                            <span style="display:none;">@ev.ActorDisplayName?.FirstOrDefault()</span>
                                                        }
                                                        else
                                                        {
                                                            <span>@ev.ActorDisplayName?.FirstOrDefault()</span>
                                                        }
                                                    </MudAvatar>
                                                </CardHeaderAvatar>
                                                <CardHeaderContent>
                                                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@ev.ActorDisplayName</MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @GetEventActionText(ev.EventType)
                                                    </MudText>
                                                </CardHeaderContent>
                                                <CardHeaderActions>
                                                    <MudText Typo="Typo.caption" Color="Color.Default" Style="font-weight: 600; padding: 12px 8px; display: inline-block;">
                                                        @FormatTimestamp(ev.Timestamp)
                                                    </MudText>
                                                </CardHeaderActions>
                                            </MudCardHeader>
                                            
                                            <MudCardContent Class="pa-4">
                                                @if (ev.EventType == "finding")
                                                {
                                                    <div class="d-flex gap-2 mb-2">
                                                        @if(!string.IsNullOrEmpty(ev.Severity))
                                                        { 
                                                            <MudChip T="string" Size="Size.Small" Color="@GetSeverityColor(ev.Severity)" Class="rounded-pill px-2">@ev.Severity.ToUpper()</MudChip> 
                                                        }
                                                        @if(!string.IsNullOrEmpty(ev.Status))
                                                        { 
                                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="rounded-pill px-2">@ev.Status</MudChip> 
                                                        }
                                                    </div>
                                                    <MudText Typo="Typo.body1" Style="font-weight: 600;" Class="mb-2">@ev.Title</MudText>
                                                    @if (!string.IsNullOrEmpty(ev.Endpoint))
                                                    {
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="d-flex align-center gap-1">
                                                            <MudIcon Icon="@Icons.Material.Filled.Api" Size="Size.Small" /> @ev.Endpoint
                                                        </MudText>
                                                    }
                                                }
                                                else if (ev.EventType == "ioc")
                                                {
                                                    <div class="d-flex gap-2 mb-2">
                                                        @if(!string.IsNullOrEmpty(ev.IocType))
                                                        { 
                                                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="rounded-pill px-2">@ev.IocType.ToUpper()</MudChip> 
                                                        }
                                                    </div>
                                                    <MudText Typo="Typo.body1" Style="font-weight: 600;" Class="mb-1">@ev.Title</MudText>
                                                }
                                                else if (ev.EventType == "task")
                                                {
                                                    <div class="d-flex gap-2 mb-2">
                                                        @if(!string.IsNullOrEmpty(ev.Priority))
                                                        { 
                                                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(ev.Priority)" Class="rounded-pill px-2">@ev.Priority.ToUpper()</MudChip> 
                                                        }
                                                        @if(!string.IsNullOrEmpty(ev.Status))
                                                        { 
                                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="rounded-pill px-2">@ev.Status</MudChip> 
                                                        }
                                                    </div>
                                                    <MudText Typo="Typo.body1" Style="font-weight: 600;" Class="mb-2">@ev.Title</MudText>
                                                    <div class="d-flex flex-wrap gap-4">
                                                        @if(!string.IsNullOrEmpty(ev.AssignedTo))
                                                        {
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-flex align-center gap-1">
                                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" /> @ev.AssignedTo
                                                            </MudText>
                                                        }
                                                        @if(ev.DueDate.HasValue)
                                                        {
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-flex align-center gap-1">
                                                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" /> @ev.DueDate.Value.ToString("dd/MM/yyyy")
                                                            </MudText>
                                                        }
                                                    </div>
                                                }
                                                else if (ev.EventType == "file")
                                                {
                                                    <div class="d-flex align-center gap-3">
                                                        <MudAvatar Color="Color.Secondary" Variant="Variant.Filled" Size="Size.Medium">
                                                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                                                        </MudAvatar>
                                                        <div class="overflow-hidden">
                                                            <MudText Typo="Typo.body2" Style="font-weight: 600;" Class="text-truncate">@ev.FileName</MudText>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <MudText Typo="Typo.body2" Style="font-style: italic; border-left: 3px solid var(--mud-palette-primary); padding-left: 12px;">
                                                        "@ev.Title"
                                                    </MudText>
                                                }
                                            </MudCardContent>

                                            @if (!string.IsNullOrWhiteSpace(ev.ActionUrl))
                                            {
                                                <MudCardActions Class="pa-2 px-4" Style="background: rgba(var(--mud-palette-primary-rgb), 0.03);">
                                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" EndIcon="@Icons.Material.Filled.ArrowForward" Class="text-none" OnClick="@(() => NavigateToAction(ev.ActionUrl))">
                                                        @(string.IsNullOrWhiteSpace(ev.ActionText) ? "Xem" : ev.ActionText)
                                                    </MudButton>
                                                    @if (ev.MessageId.HasValue && ev.GroupId.HasValue)
                                                    {
                                                        <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Chat" Class="text-none" OnClick="@(() => OpenInChat(ev.GroupId.Value, ev.MessageId.Value))">
                                                            Mở trong chat
                                                        </MudButton>
                                                    }
                                                </MudCardActions>
                                            }
                                        </MudCard>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>

                        @if (HasMore)
                        {
                            <div class="d-flex justify-center mt-6">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LoadMore" Disabled="@IsLoading" Class="rounded-pill px-6 text-none">
                                    @(IsLoading ? Loc.T("timeline.loadingMore") : Loc.T("timeline.loadMore"))
                                </MudButton>
                            </div>
                        }
                        else if (Events.Any())
                        {
                            <div class="d-flex justify-center mt-8 mb-4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Loc.T("timeline.endOfTimeline")</MudText>
                            </div>
                        }
                    }
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<GroupResponse> _groups = new();
    private bool _groupsLoading = true;

    private int GroupId = 0;
    private List<TimelineEventDto> Events = new();
    private string? CurrentFilter = null;
    private string? SearchTerm = null;
    private int CurrentPage = 1;
    private int PageSize = 50;
    private bool IsLoading = false;
    private bool HasMore = true;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += StateHasChanged;
        ChatHubService.OnMessageReceived += HandleNewMessage;
        await LoadGroupsAsync();
        if (_groups.Any())
        {
            await OnGroupSelected(_groups.First().Id);
        }
    }

    public ValueTask DisposeAsync()
    {
        Loc.OnLanguageChanged -= StateHasChanged;
        ChatHubService.OnMessageReceived -= HandleNewMessage;
        _searchDebounceTimer?.Dispose();
        return ValueTask.CompletedTask;
    }

    private async Task LoadGroupsAsync()
    {
        _groupsLoading = true;
        try
        {
            var res = await GroupService.GetMyGroupsAsync();
            if (res != null) _groups = res;
        }
        catch { }
        finally
        {
            _groupsLoading = false;
        }
    }

    private async Task OnGroupSelected(int groupId)
    {
        if (GroupId == groupId) return;
        GroupId = groupId;
        await LoadEvents(reset: true);
    }

    private async Task OnFilterChanged(string filterVal)
    {
        var newFilter = filterVal == "all" ? null : filterVal;
        if (CurrentFilter == newFilter) return;
        CurrentFilter = newFilter;
        await LoadEvents(reset: true);
    }

    private System.Threading.Timer? _searchDebounceTimer;

    private Task OnSearchTermChanged(string? term)
    {
        _searchDebounceTimer?.Dispose();
        var localTerm = term;
        _searchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (SearchTerm == localTerm) return;
                SearchTerm = localTerm;
                await LoadEvents(reset: true);
            });
        }, null, 400, System.Threading.Timeout.Infinite);
        return Task.CompletedTask;
    }

    private async Task LoadMore()
    {
        await LoadEvents(reset: false);
    }

    private async Task LoadEvents(bool reset)
    {
        if (GroupId == 0 || IsLoading) return;
        IsLoading = true;
        StateHasChanged();

        if (reset)
        {
            CurrentPage = 1;
            Events.Clear();
            HasMore = true;
        }

        try
        {
            var query = new TimelineQueryDto
            {
                Page = CurrentPage,
                PageSize = PageSize,
                EventType = CurrentFilter,
                SearchTerm = SearchTerm
            };
            var result = await TimelineService.GetGroupTimelineAsync(GroupId, query);
            
            if (result.Count < PageSize)
            {
                HasMore = false;
            }
            Events.AddRange(result);
            CurrentPage++;
        }
        catch { }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void HandleNewMessage(MessageResponse msg)
    {
        if (!msg.GroupId.HasValue || msg.GroupId.Value != GroupId) return;

        string? evtType = null;
        if (msg.MessageType == "Image" || msg.MessageType == "File") evtType = "file";
        else if (msg.MessageType == "Vulnerability") evtType = "finding";
        else if (msg.MessageType == "Cve") evtType = "ioc";
        else if (msg.MessageType == "Task") evtType = "task";
        else if (!string.IsNullOrWhiteSpace(msg.Content) &&
            (msg.Content.TrimStart().StartsWith("/ioc", StringComparison.OrdinalIgnoreCase) ||
             msg.Content.TrimStart().StartsWith("/vuln", StringComparison.OrdinalIgnoreCase) ||
             msg.Content.TrimStart().StartsWith("/task", StringComparison.OrdinalIgnoreCase)))
            return;

        if (evtType == null) return;

        if (!string.IsNullOrEmpty(CurrentFilter) && CurrentFilter != evtType) return;

        var preview = msg.Content ?? "";
        if (preview.Length > 100) preview = preview.Substring(0, 100) + "...";

        var attachment = msg.Attachments?.FirstOrDefault();

        var ev = new TimelineEventDto
        {
            EventType = evtType,
            Timestamp = msg.CreatedAt,
            ActorUserId = msg.SenderId,
            ActorDisplayName = msg.SenderDisplayName ?? "Unknown",
            ActorAvatar = msg.SenderAvatarUrl,
            SourceId = msg.Id,
            RelatedId = null,
            MessageId = msg.Id,
            GroupId = msg.GroupId,
            Title = string.IsNullOrEmpty(preview) && evtType == "file" && attachment != null ? attachment.FileName : preview,
            FileName = evtType == "file" && attachment != null ? attachment.FileName : null,
            FileUrl = evtType == "file" && attachment != null ? attachment.FileUrl : null,
            ActionText = evtType switch
            {
                "finding" => "Xem Finding",
                "ioc" => "Xem IOC",
                "task" => "Xem Task",
                "file" => "Xem File",
                _ => null
            },
            ActionUrl = evtType switch
            {
                "finding" => "/pentest",
                "ioc" => "/iocs",
                "task" => "/tasks",
                "file" => attachment?.FileUrl,
                _ => null
            }
        };

        if (evtType == "finding" || evtType == "ioc" || evtType == "task") {
            try {
                using var doc = System.Text.Json.JsonDocument.Parse(msg.Content ?? "{}");
                if (evtType == "finding") {
                    if (doc.RootElement.TryGetProperty("severity", out var sevProp)) ev.Severity = sevProp.GetString();
                    if (doc.RootElement.TryGetProperty("status", out var statProp)) ev.Status = statProp.GetString();
                    if (doc.RootElement.TryGetProperty("title", out var titleProp)) ev.Title = titleProp.GetString() ?? ev.Title;
                    if (doc.RootElement.TryGetProperty("findingId", out var idProp) && idProp.TryGetInt32(out var findingId)) ev.ActionUrl = $"/pentest?findingId={findingId}";
                } else if (evtType == "ioc") {
                    if (doc.RootElement.TryGetProperty("value", out var valProp)) ev.Title = valProp.GetString() ?? ev.Title;
                    if (doc.RootElement.TryGetProperty("type", out var typeProp)) ev.IocType = typeProp.GetString();
                    if (doc.RootElement.TryGetProperty("iocId", out var idProp) && idProp.TryGetInt32(out var iocId)) ev.ActionUrl = $"/iocs?highlightId={iocId}";
                } else if (evtType == "task") {
                    if (doc.RootElement.TryGetProperty("title", out var titleProp)) ev.Title = titleProp.GetString() ?? ev.Title;
                    if (doc.RootElement.TryGetProperty("priority", out var prioProp)) ev.Priority = prioProp.GetString();
                    if (doc.RootElement.TryGetProperty("status", out var statProp)) ev.Status = statProp.GetString();
                    if (doc.RootElement.TryGetProperty("assignedTo", out var assignProp)) ev.AssignedTo = assignProp.GetString();
                    if (doc.RootElement.TryGetProperty("taskId", out var idProp) && idProp.TryGetInt32(out var taskId)) ev.ActionUrl = $"/tasks?taskId={taskId}";
                }
            } catch {}
        }

        InvokeAsync(() =>
        {
            Events.Insert(0, ev);
            StateHasChanged();
        });
    }

    private Color GetEventColor(string eventType)
    {
        return eventType switch
        {
            "finding" => Color.Error,
            "ioc" => Color.Warning,
            "task" => Color.Success,
            "file" => Color.Secondary,
            _ => Color.Primary
        };
    }

    private string GetEventActionText(string eventType)
    {
        return eventType switch
        {
            "finding" => "đã báo cáo một lỗ hổng",
            "ioc" => "đã chia sẻ một IOC",
            "task" => "đã giao một công việc mới",
            "file" => "đã đính kèm một tệp",
            _ => "đã cập nhật timeline"
        };
    }

    private void NavigateToAction(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url))
            NavManager.NavigateTo(url);
    }

    private void OpenInChat(int groupId, int messageId)
    {
        NavManager.NavigateTo($"/chat/group/{groupId}?messageId={messageId}");
    }

    private Color GetSeverityColor(string? severity)
    {
        if (string.IsNullOrEmpty(severity)) return Color.Default;
        var s = severity.ToLower();
        if (s.Contains("crit") || s.Contains("high")) return Color.Error;
        if (s.Contains("med")) return Color.Warning;
        return Color.Info;
    }
    
    private Color GetPriorityColor(string? priority)
    {
        if (string.IsNullOrEmpty(priority)) return Color.Default;
        var s = priority.ToLower();
        if (s.Contains("high") || s.Contains("urgent")) return Color.Error;
        if (s.Contains("med")) return Color.Warning;
        return Color.Info;
    }

    private string FormatTimestamp(DateTime dt)
    {
        return dt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss");
    }

    private string GetAbsoluteUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return string.Empty;
        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return url;
        return $"http://localhost:5000{url}";
    }
}
