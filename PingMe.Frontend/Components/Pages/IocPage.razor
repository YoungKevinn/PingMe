@page "/iocs"
@attribute [Authorize]
@implements IDisposable
@using Microsoft.AspNetCore.Authorization
@using PingMe.Frontend.Models
@using PingMe.Frontend.Services
@inject IocService IocService
@inject GroupService GroupService
@inject IocNavStateService IocNavState
@inject LocalizationService Loc
@inject ISnackbar Snackbar

<div class="pm-ioc-page">
    <div class="pm-ioc-header">
        <div>
            <h2>@Loc.T("ioc.title")</h2>
            <p>@Loc.T("ioc.subtitle")</p>
        </div>

        <button type="button" class="pm-ioc-primary-btn" @onclick="OpenCreateDialog">
            <span>＋</span>
            @Loc.T("ioc.addIoc")
        </button>
    </div>

    <div class="pm-ioc-filter-card">
        <div class="pm-ioc-filter-grid">
            <div class="pm-ioc-field pm-ioc-field-search">
                <label>@Loc.T("search.title")</label>
                <input @bind="_keyword"
                       @bind:event="oninput"
                       placeholder="@Loc.T("ioc.searchPlaceholder")" />
            </div>

            <div class="pm-ioc-field">
                <label>@Loc.T("ioc.type")</label>
                <select @bind="_type">
                    <option value="">@Loc.T("ioc.allTypes")</option>
                    @foreach (var t in _types)
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>

            <div class="pm-ioc-field">
                <label>@Loc.T("ioc.severity")</label>
                <select @bind="_severity">
                    <option value="">@Loc.T("ioc.allSeverities")</option>
                    @foreach (var s in _severities)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="pm-ioc-field">
                <label>Status</label>
                <select @bind="_status">
                    <option value="">Tất cả</option>
                    @foreach (var s in _statuses)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>

            <div class="pm-ioc-filter-actions">
                <button type="button" class="pm-ioc-filter-btn" @onclick="LoadAsync">
                    Lọc
                </button>

                <button type="button" class="pm-ioc-reset-btn" @onclick="ResetFilterAsync">
                    Reset
                </button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="pm-ioc-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <span>Đang tải IOC...</span>
        </div>
    }
    else if (!_iocs.Any())
    {
        <div class="pm-ioc-empty">
            <div class="pm-ioc-empty-icon">🛡️</div>
            <h3>@Loc.T("ioc.empty")</h3>
            <p>Bạn có thể tạo thủ công tại đây hoặc gửi trong chat bằng cú pháp <b>/ioc</b>.</p>
            <code>/ioc cve 2025-70149 high ghi chú kiểm thử</code>
        </div>
    }
    else
    {
        <div class="pm-ioc-list">
            @foreach (var ioc in _iocs)
            {
                <div class="pm-ioc-item">
                    <div class="pm-ioc-item-top">
                        <div class="pm-ioc-badges">
                            <span class="@($"pm-ioc-badge type-{CssKey(ioc.Type)}")">@ioc.Type</span>
                            <span class="@($"pm-ioc-badge severity-{CssKey(ioc.Severity)}")">@ioc.Severity</span>
                            <span class="@($"pm-ioc-badge status-{CssKey(ioc.Status)}")">@StatusLabel(ioc.Status)</span>
                        </div>

                        <span class="pm-ioc-time">
                            @ioc.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>

                    <div class="pm-ioc-value">@ioc.Value</div>

                    @if (!string.IsNullOrWhiteSpace(ioc.Description))
                    {
                        <div class="pm-ioc-description">
                            @ioc.Description
                        </div>
                    }

                    <div class="pm-ioc-meta">
                        <span>Source: @ioc.Source</span>

                        @if (ioc.GroupId.HasValue)
                        {
                            <span>Group: @GetGroupDisplay(ioc)</span>
                        }

                        @if (ioc.PeerUserId.HasValue)
                        {
                            <span>Peer: @GetPeerDisplay(ioc)</span>
                        }

                        @if (ioc.MessageId.HasValue)
                        {
                            <span>Msg: @ioc.MessageId</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(ioc.Tags))
                    {
                        <div class="pm-ioc-tags">
                            @foreach (var tag in SplitTags(ioc.Tags))
                            {
                                <span>@tag</span>
                            }
                        </div>
                    }

                    <div class="pm-ioc-actions">
                        @if (!string.IsNullOrWhiteSpace(ioc.ExternalUrl))
                        {
                            <a class="pm-ioc-action-link"
                               href="@ioc.ExternalUrl"
                               target="_blank"
                               rel="noopener">
                                Tra cứu
                            </a>
                        }

                        <button type="button"
                                class="pm-ioc-action-btn"
                                @onclick="() => OpenEditDialog(ioc)">
                            @Loc.T("ioc.edit")
                        </button>

                        @if (!string.Equals(ioc.Status, "Resolved", StringComparison.OrdinalIgnoreCase))
                        {
                            <button type="button"
                                    class="pm-ioc-action-btn success"
                                    @onclick="() => MarkResolvedAsync(ioc.Id)">
                                Resolved
                            </button>
                        }

                        <button type="button"
                                class="pm-ioc-action-btn danger"
                                @onclick="() => DeleteAsync(ioc.Id)">
                            @Loc.T("ioc.delete")
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_dialogOpen)
{
    <div class="pm-ioc-modal-backdrop" @onclick="CloseDialog">
        <div class="pm-ioc-modal-card" @onclick:stopPropagation="true">
            <div class="pm-ioc-modal-header">
                <div>
                    <h3>@(_editingId.HasValue ? Loc.T("ioc.edit") : Loc.T("ioc.addIoc"))</h3>
                    <p>Quản lý type, severity, status và mô tả IOC.</p>
                </div>

                <button type="button" class="pm-ioc-modal-close" @onclick="CloseDialog">
                    ×
                </button>
            </div>

            <div class="pm-ioc-modal-body">
                <div class="pm-ioc-form-grid">
                    <div class="pm-ioc-field">
                        <label>@Loc.T("ioc.type")</label>
                        <select @bind="_form.Type">
                            @foreach (var t in _types)
                            {
                                <option value="@t">@t</option>
                            }
                        </select>
                    </div>

                    <div class="pm-ioc-field">
                        <label>@Loc.T("ioc.group")</label>
                        <select @bind="_form.GroupId">
                            <option value="">-- Cá nhân (Personal) --</option>
                            @foreach (var g in _myGroups)
                            {
                                <option value="@g.Id">@g.Name</option>
                            }
                        </select>
                    </div>

                    <div class="pm-ioc-field">
                        <label>@Loc.T("ioc.severity")</label>
                        <select @bind="_form.Severity">
                            @foreach (var s in _severities)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>

                    <div class="pm-ioc-field">
                        <label>Status</label>
                        <select @bind="_form.Status">
                            @foreach (var s in _statuses)
                            {
                                <option value="@s">@StatusLabel(s)</option>
                            }
                        </select>
                    </div>

                    <div class="pm-ioc-field pm-ioc-field-full">
                        <label>@Loc.T("ioc.value") *</label>
                        <input @bind="_form.Value"
                               @bind:event="oninput"
                               placeholder="VD: CVE-2025-70149, 8.8.8.8, domain.com..." />
                    </div>

                    <div class="pm-ioc-field pm-ioc-field-full">
                        <label>@Loc.T("ioc.note")</label>
                        <textarea @bind="_form.Description"
                                  @bind:event="oninput"
                                  rows="4"
                                  placeholder="Ghi chú phân tích, nguồn log, tình trạng xử lý..."></textarea>
                    </div>

                    <div class="pm-ioc-field">
                        <label>Source</label>
                        <input @bind="_form.Source"
                               @bind:event="oninput"
                               placeholder="Manual, ChatCommand, Wazuh..." />
                    </div>

                    <div class="pm-ioc-field">
                        <label>Tags</label>
                        <input @bind="_form.Tags"
                               @bind:event="oninput"
                               placeholder="malware, brute-force, phishing" />
                    </div>
                </div>
            </div>

            <div class="pm-ioc-modal-actions">
                <button type="button" class="pm-ioc-reset-btn" @onclick="CloseDialog">
                    @Loc.T("ioc.cancel")
                </button>

                <button type="button"
                        class="pm-ioc-primary-btn"
                        disabled="@string.IsNullOrWhiteSpace(_form.Value)"
                        @onclick="SaveAsync">
                    @Loc.T("ioc.save")
                </button>
            </div>
        </div>
    </div>
}

<style>
    .pm-ioc-page {
        min-height: 100%;
        padding: 26px 28px 40px;
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-primary);
    }

    .pm-ioc-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 18px;
        margin-bottom: 18px;
    }

        .pm-ioc-header h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 900;
            letter-spacing: -0.03em;
            color: var(--mud-palette-text-primary) !important;
        }

        .pm-ioc-header p {
            margin: 6px 0 0;
            color: var(--mud-palette-text-secondary) !important;
            font-size: 14px;
        }

    .pm-ioc-primary-btn,
    .pm-ioc-filter-btn,
    .pm-ioc-reset-btn,
    .pm-ioc-action-btn,
    .pm-ioc-action-link {
        border: 0;
        border-radius: 12px;
        min-height: 38px;
        padding: 0 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 7px;
        font-size: 13px;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        transition: .15s ease;
        white-space: nowrap;
    }

    .pm-ioc-primary-btn,
    .pm-ioc-filter-btn {
        background: var(--mud-palette-primary);
        color: white;
    }

        .pm-ioc-primary-btn:hover,
        .pm-ioc-filter-btn:hover {
            filter: brightness(1.05);
            transform: translateY(-1px);
        }

        .pm-ioc-primary-btn:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
        }

    .pm-ioc-reset-btn {
        background: rgba(148, 163, 184, .14);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
    }

    .pm-ioc-filter-card {
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, .08);
        margin-bottom: 18px;
    }

    .pm-ioc-filter-grid {
        display: grid;
        grid-template-columns: minmax(260px, 2fr) minmax(130px, .8fr) minmax(150px, .9fr) minmax(170px, .9fr) auto;
        gap: 12px;
        align-items: end;
    }

    .pm-ioc-form-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .pm-ioc-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 0;
    }

    .pm-ioc-field-full {
        grid-column: 1 / -1;
    }

    .pm-ioc-field label {
        color: var(--mud-palette-text-secondary) !important;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .02em;
    }

    .pm-ioc-field input,
    .pm-ioc-field select,
    .pm-ioc-field textarea {
        width: 100%;
        min-height: 42px;
        border-radius: 12px;
        border: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-background);
        color: var(--mud-palette-text-primary) !important;
        padding: 0 12px;
        outline: none;
        font-size: 14px;
        box-sizing: border-box;
    }

    .pm-ioc-field textarea {
        padding: 10px 12px;
        resize: vertical;
        line-height: 1.5;
    }

        .pm-ioc-field input::placeholder,
        .pm-ioc-field textarea::placeholder {
            color: var(--mud-palette-text-secondary);
            opacity: .8;
        }

        .pm-ioc-field input:focus,
        .pm-ioc-field select:focus,
        .pm-ioc-field textarea:focus {
            border-color: var(--mud-palette-primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, .14);
        }

    .pm-ioc-filter-actions {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .pm-ioc-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 58px;
        color: var(--mud-palette-text-secondary);
    }

    .pm-ioc-empty {
        border: 1px dashed var(--mud-palette-divider);
        border-radius: 18px;
        padding: 40px 20px;
        text-align: center;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
    }

    .pm-ioc-empty-icon {
        font-size: 42px;
        margin-bottom: 8px;
    }

    .pm-ioc-empty h3 {
        margin: 0 0 8px;
        font-size: 20px;
        color: var(--mud-palette-text-primary) !important;
    }

    .pm-ioc-empty p {
        margin: 0 0 12px;
        color: var(--mud-palette-text-secondary);
    }

    .pm-ioc-empty code {
        display: inline-block;
        padding: 8px 12px;
        border-radius: 10px;
        background: rgba(59, 130, 246, .12);
        color: var(--mud-palette-primary);
        font-weight: 800;
    }

    .pm-ioc-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .pm-ioc-item {
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 18px;
        padding: 16px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, .08);
        overflow: hidden;
    }

    .pm-ioc-item-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
    }

    .pm-ioc-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .pm-ioc-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 24px;
        padding: 0 9px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .04em;
        text-transform: uppercase;
        border: 1px solid transparent;
    }

    .type-cve,
    .severity-critical {
        background: rgba(239, 68, 68, .16);
        color: #EF4444;
        border-color: rgba(239, 68, 68, .25);
    }

    .type-ip,
    .type-domain,
    .severity-medium,
    .status-investigating {
        background: rgba(59, 130, 246, .16);
        color: #2563EB;
        border-color: rgba(59, 130, 246, .25);
    }

    .type-url,
    .status-resolved {
        background: rgba(16, 185, 129, .16);
        color: #059669;
        border-color: rgba(16, 185, 129, .25);
    }

    .type-md5,
    .type-sha256 {
        background: rgba(168, 85, 247, .16);
        color: #7C3AED;
        border-color: rgba(168, 85, 247, .25);
    }

    .severity-high,
    .status-open {
        background: rgba(245, 158, 11, .16);
        color: #B45309;
        border-color: rgba(245, 158, 11, .25);
    }

    .severity-low,
    .severity-info,
    .status-falsepositive {
        background: rgba(148, 163, 184, .14);
        color: var(--mud-palette-text-secondary);
        border-color: rgba(148, 163, 184, .24);
    }

    .pm-ioc-time {
        color: var(--mud-palette-text-secondary) !important;
        font-size: 12px;
        white-space: nowrap;
    }

    .pm-ioc-value {
        font-family: 'Fira Code', Consolas, monospace;
        font-weight: 900;
        font-size: 15px;
        line-height: 1.55;
        word-break: break-all;
        color: var(--mud-palette-text-primary) !important;
    }

    .pm-ioc-description {
        margin-top: 10px;
        color: var(--mud-palette-text-primary) !important;
        line-height: 1.5;
        font-size: 14px;
    }

    .pm-ioc-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        margin-top: 12px;
    }

        .pm-ioc-meta span {
            padding: 4px 8px;
            border-radius: 999px;
            background: rgba(148, 163, 184, .12);
            color: var(--mud-palette-text-secondary) !important;
            font-size: 12px;
            font-weight: 700;
        }

    .pm-ioc-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 10px;
    }

        .pm-ioc-tags span {
            padding: 4px 8px;
            border-radius: 999px;
            background: rgba(59, 130, 246, .12);
            color: var(--mud-palette-primary) !important;
            font-size: 12px;
            font-weight: 800;
        }

    .pm-ioc-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid var(--mud-palette-divider);
    }

    .pm-ioc-action-link,
    .pm-ioc-action-btn {
        background: rgba(148, 163, 184, .12);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
    }

        .pm-ioc-action-link:hover,
        .pm-ioc-action-btn:hover {
            background: rgba(59, 130, 246, .12);
            color: var(--mud-palette-primary);
        }

        .pm-ioc-action-btn.success {
            color: #059669;
        }

        .pm-ioc-action-btn.danger {
            color: #EF4444;
        }

    .pm-ioc-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 250000;
        background: rgba(2, 6, 23, .58);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .pm-ioc-modal-card {
        width: min(860px, 100%);
        max-height: calc(100vh - 48px);
        overflow: hidden;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        box-shadow: 0 24px 80px rgba(0, 0, 0, .45);
    }

    .pm-ioc-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        padding: 20px 24px 12px;
        border-bottom: 1px solid var(--mud-palette-divider);
    }

        .pm-ioc-modal-header h3 {
            margin: 0;
            font-size: 20px;
            font-weight: 900;
            color: var(--mud-palette-text-primary) !important;
        }

        .pm-ioc-modal-header p {
            margin: 5px 0 0;
            color: var(--mud-palette-text-secondary) !important;
            font-size: 13px;
        }

    .pm-ioc-modal-close {
        width: 36px;
        height: 36px;
        border: 0;
        border-radius: 999px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        font-size: 30px;
        line-height: 1;
        cursor: pointer;
    }

        .pm-ioc-modal-close:hover {
            background: rgba(148, 163, 184, .16);
            color: var(--mud-palette-text-primary);
        }

    .pm-ioc-modal-body {
        padding: 18px 24px;
        overflow: auto;
        max-height: calc(100vh - 190px);
    }

    .pm-ioc-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 14px 24px 20px;
        border-top: 1px solid var(--mud-palette-divider);
    }

    @@media (max-width: 1100px) {
        .pm-ioc-filter-grid {
            grid-template-columns: 1fr 1fr;
        }

        .pm-ioc-filter-actions {
            grid-column: 1 / -1;
        }

        .pm-ioc-list {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 720px) {
        .pm-ioc-page {
            padding: 18px 14px 30px;
        }

        .pm-ioc-header {
            flex-direction: column;
        }

        .pm-ioc-filter-grid,
        .pm-ioc-form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private readonly string[] _types = { "CVE", "IP", "MD5", "SHA256", "URL", "DOMAIN" };
    private readonly string[] _severities = { "Info", "Low", "Medium", "High", "Critical" };
    private readonly string[] _statuses = { "Open", "Investigating", "Resolved", "FalsePositive" };

    private List<IocResponse> _iocs = new();
    private bool _loading = true;

    private string _keyword = "";
    private string _type = "";
    private string _severity = "";
    private string _status = "";

    private bool _dialogOpen;
    private int? _editingId;
    private List<GroupResponse> _myGroups = new();

    private CreateIocRequest _form = new()
    {
        Type = "IP",
        Severity = "Medium",
        Status = "Open",
        Source = "Manual"
    };

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += StateHasChanged;
        _myGroups = await GroupService.GetMyGroupsAsync() ?? new();
        await LoadAsync();
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= StateHasChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _iocs = await IocService.SearchAsync(new IocSearchRequest
            {
                Keyword = _keyword,
                Type = _type,
                Severity = _severity,
                Status = _status
            });
            await IocNavState.RefreshAsync();
        }
        catch
        {
            _iocs = new();
            Snackbar.Add("Không thể tải IOC. Kiểm tra API /api/iocs hoặc migration database.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResetFilterAsync()
    {
        _keyword = "";
        _type = "";
        _severity = "";
        _status = "";

        await LoadAsync();
    }

    private void OpenCreateDialog()
    {
        _editingId = null;

        _form = new CreateIocRequest
        {
            Type = "IP",
            Severity = "Medium",
            Status = "Open",
            Source = "Manual"
        };

        _dialogOpen = true;
    }

    private void OpenEditDialog(IocResponse ioc)
    {
        _editingId = ioc.Id;

        _form = new CreateIocRequest
        {
            Type = ioc.Type,
            Value = ioc.Value,
            Description = ioc.Description,
            Severity = ioc.Severity,
            Status = ioc.Status,
            Source = ioc.Source,
            Tags = ioc.Tags,
            GroupId = ioc.GroupId
        };

        _dialogOpen = true;
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
        _editingId = null;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Value))
        {
            Snackbar.Add("Vui lòng nhập value IOC.", Severity.Warning);
            return;
        }

        if (_editingId.HasValue)
        {
            var updated = await IocService.UpdateAsync(_editingId.Value, new UpdateIocRequest
            {
                Type = _form.Type,
                Value = _form.Value,
                Description = _form.Description,
                Severity = _form.Severity,
                Status = _form.Status,
                Source = _form.Source,
                Tags = _form.Tags
            });

            if (updated is null)
            {
                Snackbar.Add("Cập nhật IOC thất bại.", Severity.Error);
                return;
            }

            Snackbar.Add("Đã cập nhật IOC.", Severity.Success);
        }
        else
        {
            var created = await IocService.CreateAsync(_form);

            if (created is null)
            {
                Snackbar.Add("Tạo IOC thất bại. IOC có thể đã tồn tại hoặc bạn không có quyền tạo trong phạm vi này.", Severity.Error);
                return;
            }

            Snackbar.Add("Đã tạo IOC.", Severity.Success);
        }

        CloseDialog();
        await LoadAsync();
    }

    private async Task MarkResolvedAsync(int id)
    {
        await SetStatusAsync(id, "Resolved");
    }

    private async Task SetStatusAsync(int id, string status)
    {
        var updated = await IocService.UpdateStatusAsync(id, status);

        if (updated is null)
        {
            Snackbar.Add("Cập nhật trạng thái thất bại.", Severity.Error);
            return;
        }

        Snackbar.Add($"Đã chuyển IOC sang {StatusLabel(status)}.", Severity.Success);
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        var ok = await IocService.DeleteAsync(id);

        if (ok)
        {
            Snackbar.Add("Đã xóa IOC.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Xóa IOC thất bại. Bạn có thể không có quyền xóa IOC này.", Severity.Error);
        }
    }

    private static string GetGroupDisplay(IocResponse ioc)
    {
        return !string.IsNullOrWhiteSpace(ioc.GroupName)
            ? ioc.GroupName
            : $"#{ioc.GroupId}";
    }

    private static string GetPeerDisplay(IocResponse ioc)
    {
        return !string.IsNullOrWhiteSpace(ioc.PeerDisplayName)
            ? ioc.PeerDisplayName
            : $"#{ioc.PeerUserId}";
    }

    private static string StatusLabel(string? status)
    {
        return status switch
        {
            "FalsePositive" => "False Positive",
            _ => status ?? string.Empty
        };
    }

    private static string CssKey(string? value)
    {
        return (value ?? string.Empty)
            .Trim()
            .Replace("_", "")
            .Replace("-", "")
            .Replace(" ", "")
            .ToLowerInvariant();
    }

    private static IEnumerable<string> SplitTags(string tags)
    {
        return tags
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x));
    }
}
