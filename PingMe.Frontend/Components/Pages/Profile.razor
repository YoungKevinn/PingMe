    }

        .pm-profile-chips span {
            padding: 6px 11px;
            border-radius: 999px;
            background: rgba(59,130,246,.14);
            color: var(--mud-palette-primary);
            font-size: .78rem;
            font-weight: 800;
        }

    .pm-profile-info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .pm-profile-info-item {
        padding: 14px;
        border-radius: 16px;
        border: 1px solid var(--mud-palette-divider);
        background: rgba(148,163,184,.06);
    }

        .pm-profile-info-item .label,
        .pm-profile-bio .label {
            font-size: 13px;
            font-weight: 800;
            color: var(--mud-palette-text-secondary);
            margin-bottom: 6px;
