        background: rgba(2,6,23,.58);
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 82px 18px 18px 18px;
    }

        .pm-profile-modal-backdrop.confirm {
            z-index: 270000;
        }

    .pm-profile-modal-card {
        width: min(760px, 100%);
        max-height: calc(100vh - 42px);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 20px;
        box-shadow: 0 24px 80px rgba(0,0,0,.48);
    }

    .pm-profile-modal-header {
        padding: 18px 22px 12px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        flex-shrink: 0;
    }

    .pm-profile-modal-close {
        width: 36px;
        height: 36px;
        border: none;
        border-radius: 999px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        font-size: 30px;
        line-height: 1;
        cursor: pointer;
    }

        .pm-profile-modal-close:hover {
            background: rgba(148,163,184,.16);
            color: var(--mud-palette-text-primary);
        }

    .pm-profile-modal-body {
        padding: 8px 22px 18px;
        overflow: auto;
    }

    .pm-profile-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 14px 22px 20px;
        border-top: 1px solid var(--mud-palette-divider);
        flex-shrink: 0;
    }

    .pm-edit-avatar-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px;
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px;
        margin-bottom: 16px;
        background: rgba(148,163,184,.06);
    }

    .pm-edit-avatar {
        width: 72px !important;
        height: 72px !important;
        font-size: 30px !important;
        background: #2563EB;
        color: white;
        flex-shrink: 0;
    }

    .pm-avatar-upload-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(59,130,246,.14);
        color: var(--mud-palette-primary);
        font-weight: 900;
        cursor: pointer;
        border: 1px solid rgba(59,130,246,.24);
    }

        .pm-avatar-upload-btn:hover {
            background: rgba(59,130,246,.22);
