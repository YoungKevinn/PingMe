    }

    .pm-confirm-actions {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 22px;
    }

    @@media (max-width: 720px) {
        .pm-profile-view-top {
            grid-template-columns: 1fr;
            margin-top: -58px;
            gap: 10px;
        }

        .pm-profile-title-block {
            padding-bottom: 0;
            padding-left: 0;
        }

        .pm-profile-info-grid,
        .pm-edit-grid {
            grid-template-columns: 1fr;
        }

        .pm-profile-edit-float span {
            display: none;
        }
    }
</style>

@code {
    private UserProfileResponse? _profile;
    private MudForm? _form;

    private bool _loading = true;
    private bool _saving;
    private bool _editOpen;
    private bool _confirmOpen;

    private UpdateProfileRequest _edit = new();
    private string _dateOfBirthText = string.Empty;

    private IBrowserFile? _selectedAvatarFile;
    private string? _selectedAvatarFileName;
    private string? _avatarPreviewUrl;
    private long _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        _loading = true;

        try
        {
            _profile = await UserService.GetProfileAsync();

            if (_profile == null)
                Snackbar.Add("Không tải được hồ sơ. Vui lòng đăng nhập lại.", Severity.Error);
        }
        catch
        {
            Snackbar.Add("Lỗi khi tải hồ sơ.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenEditProfile()
    {
        if (_profile == null)
            return;

        _edit = new UpdateProfileRequest
        {
            DisplayName = _profile.DisplayName,
            Bio = _profile.Bio,
            JobTitle = _profile.JobTitle,
            Department = _profile.Department,
            WorkLocation = _profile.WorkLocation,
            PhoneNumber = _profile.PhoneNumber,
            DateOfBirth = _profile.DateOfBirth
        };

        _dateOfBirthText = _profile.DateOfBirth.HasValue
            ? _profile.DateOfBirth.Value.ToString("yyyy-MM-dd")
            : string.Empty;

        _selectedAvatarFile = null;
        _selectedAvatarFileName = null;
        _avatarPreviewUrl = null;

        _editOpen = true;
    }

    private void CloseEditProfile()
    {
        if (_saving)
            return;

        _editOpen = false;
        _confirmOpen = false;
        _selectedAvatarFile = null;
        _selectedAvatarFileName = null;
        _avatarPreviewUrl = null;
    }
    private async Task OpenConfirmSaveAsync()
    {
        if (_form == null)
            return;

        await _form.Validate();

        if (!_form.IsValid)
            return;

        _confirmOpen = true;
    }

    private void CloseConfirmSave()
    {
        if (_saving)
            return;

        _confirmOpen = false;
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
            return;

        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Vui lòng chọn file ảnh.", Severity.Warning);
            return;
        }

        const long maxFileSize = 3 * 1024 * 1024;

        if (file.Size > maxFileSize)
        {
            Snackbar.Add("Ảnh đại diện tối đa 3MB.", Severity.Warning);
            return;
        }

        _selectedAvatarFile = file;
        _selectedAvatarFileName = file.Name;

        try
        {
            await using var stream = file.OpenReadStream(maxFileSize);
            using var memoryStream = new MemoryStream();

            await stream.CopyToAsync(memoryStream);

            var base64 = Convert.ToBase64String(memoryStream.ToArray());
            _avatarPreviewUrl = $"data:{file.ContentType};base64,{base64}";

            StateHasChanged();
        }
        catch
        {
            _avatarPreviewUrl = null;
            Snackbar.Add("Không đọc được file ảnh.", Severity.Error);
        }
    }
    private void OnDateOfBirthChanged(ChangeEventArgs e)
    {
        _dateOfBirthText = e.Value?.ToString() ?? string.Empty;
    }

    private async Task SaveAsync()
    {
        if (_profile == null || _saving)
            return;

        _saving = true;

        try
        {
            var parsedDateOfBirth = ParseDateOfBirth(_dateOfBirthText);

            if (_selectedAvatarFile != null)
            {
                var avatarOk = await UserService.UploadAvatarAsync(_selectedAvatarFile);

                if (!avatarOk)
                {
                    Snackbar.Add(
                        UserService.LastAvatarUploadError ?? "Upload ảnh đại diện thất bại.",
                        Severity.Error
                    );
                    return;
                }
            }

            var ok = await UserService.UpdateProfileAsync(new UpdateProfileRequest
            {
                DisplayName = _edit.DisplayName?.Trim(),
                Bio = _edit.Bio?.Trim(),
                JobTitle = _edit.JobTitle?.Trim(),
                Department = _edit.Department?.Trim(),
                WorkLocation = _edit.WorkLocation?.Trim(),
                PhoneNumber = _edit.PhoneNumber?.Trim(),
                DateOfBirth = parsedDateOfBirth
            });

            if (ok)
            {
                Snackbar.Add("Đã cập nhật hồ sơ.", Severity.Success);

                _confirmOpen = false;
                _editOpen = false;
                _selectedAvatarFile = null;
                _selectedAvatarFileName = null;

                _profile = await UserService.GetProfileAsync();
            }
            else
            {
                Snackbar.Add("Cập nhật hồ sơ thất bại.", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("Lỗi khi cập nhật hồ sơ.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private string? GetAvatarUrl()
    {
        if (!string.IsNullOrWhiteSpace(_avatarPreviewUrl))
            return _avatarPreviewUrl;

        if (string.IsNullOrWhiteSpace(_profile?.AvatarUrl))
            return null;

        var url = _profile.AvatarUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase)
            ? _profile.AvatarUrl
            : $"http://localhost:5000{_profile.AvatarUrl}";

        var separator = url.Contains('?') ? "&" : "?";

        return $"{url}{separator}v={_avatarVersion}";
    }
    private static DateTime? ParseDateOfBirth(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        return DateTime.TryParse(value, out var date)
            ? date
            : null;
    }

    private static string FormatDateOfBirth(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToString("dd/MM/yyyy")
            : "Chưa cập nhật";
    }

    private static string DisplayValue(string? value, string fallback = "Chưa cập nhật")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }
}