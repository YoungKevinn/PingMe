@page "/profile"
@attribute [Authorize]
@using PingMe.Frontend.Models
@using Microsoft.AspNetCore.Components.Forms
@inject UserService UserService
@inject ISnackbar Snackbar
@using System.IO
<MudContainer MaxWidth="MaxWidth.Medium" Class="pa-4">
    <div class="pm-profile-page-title">
        <p class="pm-page-title">Hồ sơ cá nhân</p>
        <p class="pm-page-subtitle">Xem thông tin tài khoản nội bộ của bạn</p>
    </div>

    @if (_loading)
    {
        <div style="display:flex;justify-content:center;padding:40px;">
            <MudProgressCircular Indeterminate Color="Color.Primary" />
        </div>
    }
    else if (_profile == null)
    {
        <MudAlert Severity="Severity.Error">
            Không tải được hồ sơ. Vui lòng đăng nhập lại.
        </MudAlert>
    }
    else
    {
        <div class="pm-profile-view-card">
            <div class="pm-profile-cover">
                <MudTooltip Text="Chỉnh sửa hồ sơ">
                    <button type="button"
                            class="pm-profile-edit-float"
                            @onclick="OpenEditProfile">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Style="font-size:20px;" />
                        <span>Chỉnh sửa</span>
                    </button>
                </MudTooltip>
            </div>

            <div class="pm-profile-view-body">
                <div class="pm-profile-view-top">
                    <div class="pm-profile-avatar-wrap">
                        <MudTooltip Text="Bấm để chỉnh sửa ảnh đại diện">
                            <button type="button"
                                    class="pm-profile-avatar-button"
                                    @onclick="OpenEditProfile">
                                <MudAvatar Class="pm-profile-avatar">
                                    @{
                                        var avatarUrl = GetAvatarUrl();
                                    }

                                    @if (!string.IsNullOrEmpty(avatarUrl))
                                    {
                                        <MudImage Src="@avatarUrl" />
                                    }
                                    else
                                    {
                                        @_profile.DisplayName?.FirstOrDefault()
                                    }
                                </MudAvatar>

                                <span class="pm-profile-avatar-camera">
                                    <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Style="font-size:16px;" />
                                </span>
                            </button>
                        </MudTooltip>
                    </div>
                    <div class="pm-profile-title-block">
                        <div class="pm-profile-name">@_profile.DisplayName</div>
                        <div class="pm-profile-email">@_profile.Email</div>

                        <div class="pm-profile-chips">
                            <span>@DisplayValue(_profile.JobTitle, "Chưa có chức vụ")</span>
                            <span>@DisplayValue(_profile.Department, "Chưa có bộ phận")</span>
                        </div>
                    </div>
                </div>

                <MudDivider Class="my-4" />

                <div class="pm-profile-info-grid">
                    <div class="pm-profile-info-item">
                        <div class="label">Username</div>
                        <div class="value">@DisplayValue(_profile.Username)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Email</div>
                        <div class="value">@DisplayValue(_profile.Email)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Chức vụ</div>
                        <div class="value">@DisplayValue(_profile.JobTitle)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Bộ phận / Team</div>
                        <div class="value">@DisplayValue(_profile.Department)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Vị trí làm việc</div>
                        <div class="value">@DisplayValue(_profile.WorkLocation)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Số điện thoại</div>
                        <div class="value">@DisplayValue(_profile.PhoneNumber)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Ngày sinh</div>
                        <div class="value">@FormatDateOfBirth(_profile.DateOfBirth)</div>
                    </div>

                    <div class="pm-profile-info-item">
                        <div class="label">Trạng thái</div>
                        <div class="value">
                            @if (_profile.IsOnline)
                            {
                                <span class="pm-status-online">● Đang online</span>
                            }
                            else
                            {
                                <span>@(_profile.LastSeen?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Không rõ")</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="pm-profile-bio">
                    <div class="label">Giới thiệu</div>
                    <p>@DisplayValue(_profile.Bio, "Chưa có giới thiệu.")</p>
                </div>
            </div>
        </div>
    }
</MudContainer>

@if (_editOpen && _profile != null)
{
    <div class="pm-profile-modal-backdrop" @onclick="CloseEditProfile">
        <div class="pm-profile-modal-card" @onclick:stopPropagation="true">
            <div class="pm-profile-modal-header">
                <div>
                    <MudText Typo="Typo.h6">Chỉnh sửa hồ sơ</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Cập nhật thông tin hiển thị trong PingMe.
                    </MudText>
                </div>

                <button type="button"
                        class="pm-profile-modal-close"
                        @onclick="CloseEditProfile">
                    ×
                </button>
            </div>

            <div class="pm-profile-modal-body">
                <MudForm @ref="_form">
                    <div class="pm-edit-avatar-row">
                        <label for="avatarUpload" class="pm-edit-avatar-button">
                            <MudAvatar Class="pm-edit-avatar">
                                @if (!string.IsNullOrEmpty(GetAvatarUrl()))
                                {
                                    <MudImage Src="@GetAvatarUrl()" />
                                }
                                else
                                {
                                    @_profile.DisplayName?.FirstOrDefault()
                                }
                            </MudAvatar>

                            <span class="pm-edit-avatar-camera">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Style="font-size:15px;" />
                            </span>
                        </label>

                        <div>
                            <label for="avatarUpload" class="pm-avatar-upload-btn">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Style="font-size:17px;" />
                                Đổi ảnh đại diện
                            </label>

                            <InputFile id="avatarUpload"
                                       OnChange="OnAvatarSelected"
                                       accept="image/png,image/jpeg,image/jpg,image/webp"
                                       style="display:none;" />

                            @if (!string.IsNullOrWhiteSpace(_selectedAvatarFileName))
                            {
                                <div class="pm-avatar-selected">
                                    Đã chọn: @_selectedAvatarFileName
                                </div>
                            }
                        </div>
                    </div>

                    <div class="pm-edit-grid">
                        <MudTextField @bind-Value="_edit.DisplayName"
                                      Label="Tên hiển thị"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      RequiredError="Tên hiển thị không được trống"
                                      Class="mb-3" />

                        <MudTextField Value="@_profile.Email"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_edit.JobTitle"
                                      Label="Chức vụ"
                                      Variant="Variant.Outlined"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_edit.Department"
                                      Label="Bộ phận / Team"
                                      Variant="Variant.Outlined"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_edit.WorkLocation"
                                      Label="Vị trí làm việc"
                                      Variant="Variant.Outlined"
                                      Class="mb-3" />

                        <MudTextField @bind-Value="_edit.PhoneNumber"
                                      Label="Số điện thoại"
                                      Variant="Variant.Outlined"
                                      Class="mb-3" />

                        <div class="pm-native-date-field mb-3">
                            <label>Ngày sinh</label>
                            <input type="date"
                                   class="pm-native-date-input"
                                   value="@_dateOfBirthText"
                                   @onchange="OnDateOfBirthChanged" />
                        </div>

                        <MudTextField Value="@_profile.Username"
                                      Label="Username"
                                      Variant="Variant.Outlined"
                                      ReadOnly="true"
                                      Class="mb-3" />
                    </div>

                    <MudTextField @bind-Value="_edit.Bio"
                                  Label="Giới thiệu"
                                  Variant="Variant.Outlined"
                                  Lines="4"
                                  Placeholder="Giới thiệu về bản thân..."
                                  Class="mb-2"
                                  FullWidth="true" />
                </MudForm>
            </div>

            <div class="pm-profile-modal-actions">
                <MudButton ButtonType="ButtonType.Button"
                           Variant="Variant.Text"
                           OnClick="CloseEditProfile"
                           Disabled="@_saving">
                    Hủy
                </MudButton>

                <MudButton ButtonType="ButtonType.Button"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="OpenConfirmSaveAsync"
                           Disabled="@_saving">
                    Tiếp tục
                </MudButton>
            </div>
        </div>
    </div>
}

@if (_confirmOpen)
{
    <div class="pm-profile-modal-backdrop confirm" @onclick="CloseConfirmSave">
        <div class="pm-confirm-card" @onclick:stopPropagation="true">
            <div class="pm-confirm-icon">
                <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Style="font-size:34px;" />
            </div>

            <MudText Typo="Typo.h6" Class="font-weight-bold">
                Xác nhận cập nhật hồ sơ?
            </MudText>

            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                Các thay đổi của bạn sẽ được lưu vào tài khoản PingMe.
            </MudText>

            <div class="pm-confirm-actions">
                <MudButton Variant="Variant.Text"
                           OnClick="CloseConfirmSave"
                           Disabled="@_saving">
                    Quay lại
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="SaveAsync"
                           Disabled="@_saving">
                    @if (_saving)
                    {
                        <MudProgressCircular Size="Size.Small"
                                             Indeterminate="true"
                                             Color="Color.Inherit"
                                             Class="mr-2" />
                        <span>Đang lưu...</span>
                    }
                    else
                    {
                        <span>Xác nhận lưu</span>
                    }
                </MudButton>
            </div>
        </div>
    </div>
}

<style>
    .pm-edit-avatar-button {
        position: relative;
        display: inline-flex;
        cursor: pointer;
        border-radius: 999px;
    }

        .pm-edit-avatar-button:hover .pm-edit-avatar {
            filter: brightness(.85);
        }

    .pm-edit-avatar-camera {
        position: absolute;
        right: 2px;
        bottom: 2px;
        width: 26px;
        height: 26px;
        border-radius: 999px;
        background: rgba(15, 23, 42, .88);
        color: white;
        border: 2px solid var(--mud-palette-surface);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .pm-profile-page-title {
        max-width: 860px;
        margin: 0 auto 24px;
    }

    .pm-profile-avatar-button {
        position: relative;
        border: none;
        background: transparent;
        padding: 0;
        margin: 0;
        border-radius: 999px;
        cursor: pointer;
    }

        .pm-profile-avatar-button:hover .pm-profile-avatar {
            filter: brightness(.88);
        }

    .pm-profile-avatar-camera {
        position: absolute;
        right: 8px;
        bottom: 8px;
        width: 32px;
        height: 32px;
        border-radius: 999px;
        background: rgba(15, 23, 42, .86);
        color: white;
        border: 2px solid var(--mud-palette-surface);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .pm-page-title {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 900;
        color: var(--mud-palette-text-primary);
    }

    .pm-page-subtitle {
        margin: 4px 0 0;
        color: var(--mud-palette-text-secondary);
    }

    .pm-profile-view-card {
        max-width: 860px;
        margin: 0 auto;
        overflow: hidden;
        border-radius: 22px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        box-shadow: 0 18px 50px rgba(0,0,0,.22);
    }

    .pm-profile-cover {
        height: 160px;
        position: relative;
        background: linear-gradient(135deg,#1D4ED8,#60A5FA,#38BDF8);
    }

    .pm-profile-edit-float {
        position: absolute;
        right: 18px;
        bottom: 18px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 38px;
        border: 1px solid rgba(255,255,255,.24);
        border-radius: 999px;
        padding: 0 14px;
        background: rgba(15,23,42,.72);
        color: white;
        font-weight: 800;
        cursor: pointer;
        backdrop-filter: blur(8px);
        z-index: 10;
    }

        .pm-profile-edit-float:hover {
            background: rgba(15,23,42,.9);
        }

    .pm-profile-view-body {
        padding: 0 28px 28px;
    }

    .pm-profile-view-top {
        display: grid;
        grid-template-columns: 132px minmax(0, 1fr);
        align-items: end;
        gap: 18px;
        margin-top: -68px;
        position: relative;
        z-index: 2;
    }

    .pm-profile-avatar-wrap {
        flex-shrink: 0;
        position: relative;
        z-index: 3;
    }

    .pm-profile-avatar {
        width: 118px !important;
        height: 118px !important;
        font-size: 44px !important;
        border: 6px solid var(--mud-palette-surface);
        background: #2563EB;
        color: white;
        box-shadow: 0 14px 34px rgba(0,0,0,.32);
