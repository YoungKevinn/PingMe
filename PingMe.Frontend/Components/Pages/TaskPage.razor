@page "/tasks"
@attribute [Authorize]
@implements IDisposable
@using PingMe.Frontend.Models
@using PingMe.Frontend.Services
@inject GroupTaskService TaskService
@inject LocalizationService Loc
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="mt-4 pm-task-shell">
    <div class="pm-task-header">
        <div>
            <MudText Typo="Typo.h5" Class="font-weight-bold">@Loc.T("task.title")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@Loc.T("task.subtitle")</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync" Disabled="_loading">
            @Loc.T("task.refresh")
        </MudButton>
    </div>

    <div class="pm-task-filters">
        <input type="search" placeholder="@Loc.T("task.search")" @bind="_keyword" @bind:event="oninput" />
        <input type="number" min="1" placeholder="@Loc.T("task.groupId")" @bind="_groupIdText" @bind:event="oninput" />
        <select @bind="_status">
            <option value="">@Loc.T("task.allStatus")</option>
            <option value="Open">Open</option>
            <option value="InProgress">In Progress</option>
            <option value="Done">Done</option>
            <option value="Cancelled">Cancelled</option>
        </select>
        <select @bind="_priority">
            <option value="">@Loc.T("task.allPriority")</option>
            <option value="Low">Low</option>
            <option value="Medium">Medium</option>
            <option value="High">High</option>
            <option value="Critical">Critical</option>
        </select>
        <label class="pm-task-check"><input type="checkbox" @bind="_assignedToMe" /> @Loc.T("task.assignedToMe")</label>
        <label class="pm-task-check"><input type="checkbox" @bind="_overdue" /> @Loc.T("task.overdue")</label>
        <button type="button" class="pm-task-primary" @onclick="LoadAsync">@Loc.T("task.apply")</button>
    </div>

    @if (_loading)
    {
        <div class="pm-task-empty"><MudProgressCircular Indeterminate Color="Color.Primary" /> <span>@Loc.T("task.loading")</span></div>
    }
    else if (!_tasks.Any())
    {
        <div class="pm-task-empty">
            <MudIcon Icon="@Icons.Material.Filled.TaskAlt" Size="Size.Large" />
            <span>@Loc.T("task.empty")</span>
            <code>/task Review auth flow @@alice due:tomorrow priority:high</code>
        </div>
    }
    else
    {
        <div class="pm-task-list">
            @foreach (var task in _tasks)
            {
                <article class="@($"pm-task-card priority-{CssKey(task.Priority)} {(task.Id == TaskId ? "highlight" : "")}")">
                    <div class="pm-task-topline">
                        <span class="pm-task-priority">@task.Priority</span>
                        <span class="@($"pm-task-status {CssKey(task.Status)}")">@task.Status</span>
                        @if (IsOverdue(task))
                        {
                            <span class="pm-task-overdue">@Loc.T("task.overdue")</span>
                        }
                    </div>
                    <h3>@task.Title</h3>
                    @if (!string.IsNullOrWhiteSpace(task.Description))
                    {
                        <p>@task.Description</p>
                    }
                    <div class="pm-task-meta">
                        <span>@Loc.T("task.group"): @task.GroupName</span>
                        <span>@Loc.T("task.creator"): @task.CreatedByDisplayName</span>
                        <span>@Loc.T("task.assignee"): @(task.AssignedToDisplayName ?? Loc.T("task.unassigned"))</span>
                        @if (task.DueAtUtc.HasValue)
                        {
                            <span>@Loc.T("task.due"): @task.DueAtUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        }
                    </div>
                    <div class="pm-task-actions">
                        @if (!IsCompleted(task))
                        {
                            <button type="button" @onclick="() => CompleteAsync(task.Id, true)">@Loc.T("task.complete")</button>
                        }
                        else
                        {
                            <button type="button" @onclick="() => CompleteAsync(task.Id, false)">@Loc.T("task.reopen")</button>
                        }
                        <button type="button" class="danger" @onclick="() => DeleteAsync(task.Id)">@Loc.T("task.delete")</button>
                    </div>
                </article>
            }
        </div>
    }
</MudContainer>

<style>
    .pm-task-shell { padding: 8px 24px 32px; }
    .pm-task-header { display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:16px; }
    .pm-task-filters { display:grid; grid-template-columns: minmax(180px, 1.5fr) 120px repeat(2, 150px) auto auto auto; gap:10px; align-items:center; margin-bottom:16px; }
    .pm-task-filters input,
    .pm-task-filters select { height:38px; border:1px solid var(--mud-palette-divider); border-radius:8px; padding:0 10px; background:var(--mud-palette-surface); color:var(--mud-palette-text-primary); }
    .pm-task-check { display:flex; align-items:center; gap:6px; color:var(--mud-palette-text-secondary); font-size:.86rem; white-space:nowrap; }
    .pm-task-primary,
    .pm-task-actions button { border:0; border-radius:8px; min-height:36px; padding:0 14px; font-weight:700; background:#2563EB; color:white; cursor:pointer; }
    .pm-task-list { display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:12px; }
    .pm-task-card { border:1px solid var(--mud-palette-divider); border-left:4px solid #2563EB; border-radius:8px; padding:14px; background:var(--mud-palette-surface); box-shadow:0 8px 20px rgba(15,23,42,.06); }
    .pm-task-card.highlight { outline:2px solid #2563EB; }
    .pm-task-card.priority-critical { border-left-color:#DC2626; }
    .pm-task-card.priority-high { border-left-color:#F97316; }
    .pm-task-card.priority-medium { border-left-color:#2563EB; }
    .pm-task-card.priority-low { border-left-color:#16A34A; }
    .pm-task-topline,
    .pm-task-meta,
    .pm-task-actions { display:flex; align-items:center; flex-wrap:wrap; gap:8px; }
    .pm-task-card h3 { margin:10px 0 6px; font-size:1rem; line-height:1.35; color:var(--mud-palette-text-primary); }
    .pm-task-card p { margin:0 0 10px; color:var(--mud-palette-text-secondary); white-space:pre-wrap; overflow-wrap:anywhere; }
    .pm-task-priority,
    .pm-task-status,
    .pm-task-overdue { border-radius:999px; padding:3px 8px; font-size:.72rem; font-weight:800; border:1px solid var(--mud-palette-divider); }
    .pm-task-priority { background:#EFF6FF; color:#1D4ED8; }
    .pm-task-status.open { background:#F8FAFC; color:#334155; border-color:#CBD5E1; }
    .pm-task-status.inprogress { background:#DBEAFE; color:#1D4ED8; border-color:#93C5FD; }
    .pm-task-status.done { background:#DCFCE7; color:#166534; border-color:#86EFAC; }
    .pm-task-status.completed { background:#DCFCE7; color:#166534; border-color:#86EFAC; }
    .pm-task-status.cancelled { background:#F3F4F6; color:#6B7280; border-color:#D1D5DB; }
    .pm-task-overdue { background:#FEE2E2; color:#991B1B; border-color:#FCA5A5; }
    .pm-task-meta { margin-top:10px; color:var(--mud-palette-text-secondary); font-size:.8rem; }
    .pm-task-actions { margin-top:12px; }
    .pm-task-actions .danger { background:#DC2626; }
    .pm-task-empty { min-height:260px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; color:var(--mud-palette-text-secondary); text-align:center; }
    .pm-task-empty code { background:var(--mud-palette-surface); border:1px solid var(--mud-palette-divider); border-radius:8px; padding:8px 10px; color:var(--mud-palette-text-primary); }
    @@media (max-width: 920px) {
        .pm-task-filters { grid-template-columns:1fr; }
        .pm-task-header { align-items:flex-start; flex-direction:column; }
    }
</style>

@code {
    [SupplyParameterFromQuery(Name = "taskId")]
    public int? TaskId { get; set; }

    private List<GroupTaskResponse> _tasks = new();
    private bool _loading;
    private string _keyword = string.Empty;
    private string _groupIdText = string.Empty;
    private string _status = string.Empty;
    private string _priority = string.Empty;
    private bool _assignedToMe;
    private bool _overdue;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += StateHasChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= StateHasChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var response = await TaskService.GetAsync(new GroupTaskQuery
            {
                Keyword = string.IsNullOrWhiteSpace(_keyword) ? null : _keyword,
                GroupId = int.TryParse(_groupIdText, out var groupId) && groupId > 0 ? groupId : null,
                Status = string.IsNullOrWhiteSpace(_status) ? null : _status,
                Priority = string.IsNullOrWhiteSpace(_priority) ? null : _priority,
                AssignedToMe = _assignedToMe,
                Overdue = _overdue,
                Page = 1,
                PageSize = 50
            });
            _tasks = response?.Items ?? new List<GroupTaskResponse>();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CompleteAsync(int id, bool isCompleted)
    {
        var updated = await TaskService.CompleteAsync(id, isCompleted);
        if (updated is null)
        {
            Snackbar.Add(TaskService.LastError ?? "Không cập nhật được task.", Severity.Error);
            return;
        }
        await LoadAsync();
    }

    private async Task DeleteAsync(int id)
    {
        if (!await TaskService.DeleteAsync(id))
        {
            Snackbar.Add(TaskService.LastError ?? "Không xóa được task.", Severity.Error);
            return;
        }
        await LoadAsync();
    }

    private static bool IsCompleted(GroupTaskResponse task)
        => string.Equals(task.Status, "Done", StringComparison.OrdinalIgnoreCase)
        || string.Equals(task.Status, "Completed", StringComparison.OrdinalIgnoreCase); // backward compat

    private static bool IsCancelled(GroupTaskResponse task)
        => string.Equals(task.Status, "Cancelled", StringComparison.OrdinalIgnoreCase);

    private static bool IsOverdue(GroupTaskResponse task)
        => task.DueAtUtc.HasValue
        && task.DueAtUtc.Value < DateTime.UtcNow
        && !IsCompleted(task)
        && !IsCancelled(task);

    private static string CssKey(string? value)
        => string.IsNullOrWhiteSpace(value) ? "none" : value.Trim().ToLowerInvariant().Replace(" ", "-");
}
