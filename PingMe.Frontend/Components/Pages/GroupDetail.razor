@page "/groups/{GroupId:int}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@using PingMe.Frontend.Models
@inject GroupService GroupService
@inject MessageService MessageService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject SearchService SearchService

<MudContainer MaxWidth="MaxWidth.Large" Class="pm-group-page">
    @if (_loading)
    {
        <div class="pm-center-loading">
            <MudProgressCircular Indeterminate Color="Color.Primary" />
        </div>
    }
    else if (_group == null)
    {
        <MudAlert Severity="Severity.Error">Không tìm thấy nhóm</MudAlert>
    }
    else
    {
        <div class="pm-group-hero">
            <div class="pm-hero-gradient"></div>

            <div class="pm-hero-content">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                               OnClick="GoBack"
                               Class="pm-back-btn" />

                <div class="pm-group-avatar-wrap">
                    <MudAvatar Class="pm-group-avatar">
                        @if (!string.IsNullOrWhiteSpace(_group.AvatarUrl))
                        {
                            <MudImage Src="@GetAbsoluteUrl(_group.AvatarUrl)" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Style="font-size:36px;" />
                        }
                    </MudAvatar>
                </div>

                <div class="pm-group-title-block">
                    @if (_editing)
                    {
                        <MudTextField @bind-Value="_editName"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Label="Tên nhóm"
                                      Class="pm-edit-name" />
                    }
                    else
                    {
                        <h1>@_group.Name</h1>
                    }

                    <div class="pm-group-subtitle">
                        <span>@_group.Members.Count thành viên</span>
                        <span>•</span>
                        <span>Tạo ngày @_group.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    </div>
                </div>

                <div class="pm-hero-actions">
                    <MudButton StartIcon="@Icons.Material.Filled.Chat"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="GoToChat">
                        Nhắn tin
                    </MudButton>

                    @if (IsAdmin)
                    {
                        @if (_editing)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Save"
                                           OnClick="SaveAsync"
                                           Color="Color.Success"
                                           Title="Lưu" />

                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           OnClick="CancelEdit"
                                           Title="Hủy" />
                        }
                        else
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           OnClick="StartEdit"
                                           Title="Chỉnh sửa nhóm" />
                        }
                    }
                </div>
            </div>
        </div>

        <div class="pm-tabs">
            <button type="button"
                    class="@GetTabClass("overview")"
                    @onclick="@(() => SetTabAsync("overview"))">
                Tổng quan
            </button>

            <button type="button"
                    class="@GetTabClass("members")"
                    @onclick="@(() => SetTabAsync("members"))">
                Thành viên
            </button>

            <button type="button"
                    class="@GetTabClass("media")"
                    @onclick="@(() => SetTabAsync("media"))">
                Ảnh & tệp
            </button>

            <button type="button"
                    class="@GetTabClass("danger")"
                    @onclick="@(() => SetTabAsync("danger"))">
                Vùng nguy hiểm
            </button>
        </div>

        @if (_activeTab == "overview")
        {
            <div class="pm-content-grid">
                <MudCard Outlined="true" Class="pm-panel">
                    <MudCardContent>
                        <div class="pm-panel-title">
                            <MudIcon Icon="@Icons.Material.Filled.Info" />
                            <span>Thông tin nhóm</span>
                        </div>

                        @if (_editing)
                        {
                            <MudTextField @bind-Value="_editDesc"
                                          Label="Mô tả"
                                          Variant="Variant.Outlined"
                                          Lines="4"
                                          Placeholder="Nhập mô tả nhóm..."
                                          Class="mt-3" />
                        }
                        else
                        {
                            <p class="pm-description">
                                @(string.IsNullOrWhiteSpace(_group.Description)
                                                    ? "Nhóm này chưa có mô tả."
                                                    : _group.Description)
                </p>
                                }
                    </MudCardContent>
                </MudCard>

                <MudCard Outlined="true" Class="pm-panel">
                    <MudCardContent>
                        <div class="pm-panel-title">
                            <MudIcon Icon="@Icons.Material.Filled.Analytics" />
                            <span>Tổng quan nhanh</span>
                        </div>

                        <div class="pm-stats-grid">
                            <div class="pm-stat-card">
                                <div class="pm-stat-number">@_group.Members.Count</div>
                                <div class="pm-stat-label">Thành viên</div>
                            </div>

                            <div class="pm-stat-card">
                                <div class="pm-stat-number">@_group.Members.Count(x => x.IsOnline)</div>
                                <div class="pm-stat-label">Đang online</div>
                            </div>

                            <div class="pm-stat-card">
                                <div class="pm-stat-number">@_group.Members.Count(x => x.Role == "Admin" || x.Role == "CoAdmin")</div>
                                <div class="pm-stat-label">Quản trị</div>
                            </div>
                        </div>
                    </MudCardContent>
                </MudCard>
            </div>
        }
        else if (_activeTab == "members")
        {
            <MudCard Outlined="true" Class="pm-panel">
                <MudCardContent>
                    <div class="pm-panel-title">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" />
                        <span>Thêm thành viên</span>
                    </div>

                    @if (IsAdmin)
                    {
                        <div class="pm-add-member-box">
                            <MudTextField @bind-Value="_addMemberSearchTerm"
                                          Label="Tìm theo tên, username hoặc để trống để xem danh bạ"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Search"
                                          Immediate="true"
                                          Style="flex:1;" />

                            <MudButton StartIcon="@Icons.Material.Filled.Search"
                                       Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_addMemberSearchLoading"
                                       OnClick="SearchAddMembersAsync">
                                @if (_addMemberSearchLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate Color="Color.Inherit" />
                                }
                                else
                                {
                                    <span>Tìm</span>
                                }
                            </MudButton>
                        </div>

                        @if (_addMemberSearchResults.Any())
                        {
                            <div class="pm-search-results">
                                @foreach (var user in _addMemberSearchResults)
                                {
                                    var foundUser = user;

                                    <div class="pm-user-row">
                                        <MudAvatar Size="Size.Small" Color="Color.Secondary">
                                            @if (!string.IsNullOrWhiteSpace(foundUser.AvatarUrl))
                                            {
                                                <MudImage Src="@GetAbsoluteUrl(foundUser.AvatarUrl)" />
                                            }
                                            else
                                            {
                                                @foundUser.DisplayName.FirstOrDefault()
                                            }
                                        </MudAvatar>

                                        <div class="pm-user-main">
                                            <div class="pm-user-name">@foundUser.DisplayName</div>
                                            <div class="pm-user-meta">
                                                @@@foundUser.Username
                                                @if (!string.IsNullOrWhiteSpace(foundUser.JobTitle))
                                                {
                                                    <span> • @foundUser.JobTitle</span>
                                                }
                                            </div>
                                        </div>

                                        <MudButton StartIcon="@Icons.Material.Filled.PersonAdd"
                                                   Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   OnClick="() => AddMemberByUserAsync(foundUser.Id)">
                                            Thêm
                                        </MudButton>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Class="mt-2">
                            Chỉ Admin hoặc Co-Admin mới có thể thêm thành viên.
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>

            <div class="pm-section-heading">
                <span>Danh sách thành viên</span>
                <small>@_group.Members.Count người</small>
            </div>

            <div class="pm-member-list">
                @foreach (var m in _group.Members
                        .OrderByDescending(x => x.Role == "Admin")
                        .ThenByDescending(x => x.Role == "CoAdmin")
                        .ThenBy(x => x.DisplayName))
                {
                    var member = m;

                    <div class="pm-member-card">
                        <MudAvatar Size="Size.Medium" Color="Color.Secondary">
                            @if (!string.IsNullOrWhiteSpace(member.AvatarUrl))
                            {
                                <img src="@GetAbsoluteUrl(member.AvatarUrl)" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';" style="width:100%; height:100%; object-fit:cover;" />
                                <span style="display:none;">@member.DisplayName.FirstOrDefault()</span>
                            }
                            else
                            {
                                <span>@member.DisplayName.FirstOrDefault()</span>
                            }
                        </MudAvatar>

                        <div class="pm-member-info">
                            <div class="pm-member-name">@member.DisplayName</div>

                            <div class="pm-member-meta">
                                <span>@GetRoleVietnamese(member.Role)</span>

                                @if (member.IsOnline)
                                {
                                    <span class="pm-online-dot">● Online</span>
                                }
                                else
                                {
                                    <span class="pm-offline-dot">● Ngoại tuyến</span>
                                }
                            </div>
                        </div>

                        @if (IsRealAdmin && member.Role != "Admin")
                        {
                            <select value="@member.Role"
                                    @onchange="@(async (ChangeEventArgs e) => await UpdateRoleAsync(member.UserId, e.Value?.ToString() ?? "Member"))"
                                    class="pm-role-select">
                                <option value="Member">Member</option>
                                <option value="CoAdmin">CoAdmin</option>
                            </select>

                            <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="() => KickAsync(member.UserId)" />
                        }
                    </div>
                }
            </div>
        }
        else if (_activeTab == "media")
        {
            <MudCard Outlined="true" Class="pm-panel">
                <MudCardContent>
                    <div class="pm-media-header">
                        <div class="pm-panel-title">
                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" />
                            <span>Ảnh & tệp đã upload</span>
                        </div>

                        <div class="pm-media-filter">
                            <button type="button"
                                    class="@GetMediaFilterClass("all")"
                                    @onclick="@(() => SetMediaFilterAsync("all"))">
                                Tất cả
                            </button>

                            <button type="button"
                                    class="@GetMediaFilterClass("images")"
                                    @onclick="@(() => SetMediaFilterAsync("images"))">
                                Ảnh
                            </button>

                            <button type="button"
                                    class="@GetMediaFilterClass("files")"
                                    @onclick="@(() => SetMediaFilterAsync("files"))">
                                Tệp
                            </button>
                        </div>
                    </div>

                    @if (_mediaLoading)
                    {
                        <div class="pm-center-loading small">
                            <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Small" />
                        </div>
                    }
                    else if (!_attachments.Any())
                    {
                        <div class="pm-empty-media">
                            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" />
                            <p>Chưa có ảnh hoặc tệp nào trong nhóm.</p>
                            <small>Các file gửi trong chat nhóm sẽ xuất hiện ở đây.</small>
                        </div>
                    }
                    else
                    {
                        @if (_attachments.Any(a => a.IsImage) && (_mediaFilter == "all" || _mediaFilter == "images"))
                        {
                            <div class="pm-section-heading">
                                <span>Ảnh</span>
                                <small>@_attachments.Count(a => a.IsImage) ảnh</small>
                            </div>

                            <div class="pm-image-grid">
                                @foreach (var img in _attachments.Where(a => a.IsImage))
                                {
                                    <a href="@img.FileUrl"
                                       target="_blank"
                                       rel="noopener"
                                       class="pm-image-tile">
                                        <img src="@img.FileUrl" alt="@img.FileName" />

                                        <div class="pm-image-overlay">
                                            <span>@img.FileName</span>
                                        </div>
                                    </a>
                                }
                            </div>
                        }

                        @if (_attachments.Any(a => !a.IsImage) && (_mediaFilter == "all" || _mediaFilter == "files"))
                        {
                            <div class="pm-section-heading">
                                <span>Tệp</span>
                                <small>@_attachments.Count(a => !a.IsImage) tệp</small>
                            </div>

                            <div class="pm-file-list">
                                @foreach (var file in _attachments.Where(a => !a.IsImage))
                                {
                                    <div class="pm-file-row">
                                        <div class="pm-file-icon">
                                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" />
                                        </div>

                                        <div class="pm-file-main">
                                            <div class="pm-file-name">@file.FileName</div>
                                            <div class="pm-file-meta">
                                                @file.DisplaySize • @file.MimeType • @file.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                            <div class="pm-file-sender">
                                                Gửi bởi @file.SenderDisplayName
                                            </div>
                                        </div>

                                        <div class="pm-file-actions">
                                            <a href="@file.FileUrl" target="_blank" rel="noopener" class="pm-link-btn">
                                                Xem
                                            </a>

                                            <a href="@GetDownloadUrl(file)" class="pm-link-btn primary">
                                                Tải xuống
                                            </a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </MudCardContent>
            </MudCard>
        }
        else if (_activeTab == "danger")
        {
            <MudCard Outlined="true" Class="pm-danger-panel">
                <MudCardContent>
                    <div class="pm-panel-title danger">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" />
                        <span>Vùng nguy hiểm</span>
                    </div>

                    <p class="pm-danger-desc">
                        Các thao tác bên dưới có thể ảnh hưởng trực tiếp đến quyền truy cập nhóm.
                    </p>

                    <div class="pm-danger-actions">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.ExitToApp"
                                   OnClick="LeaveAsync">
                            Rời nhóm
                        </MudButton>

                        @if (IsCreator)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="DeleteAsync">
                                Giải tán nhóm
                            </MudButton>
                        }
                    </div>
                </MudCardContent>
            </MudCard>
        }
    }
</MudContainer>

<style>
    .pm-group-page {
        padding-top: 24px;
        padding-bottom: 40px;
    }

    .pm-center-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px;
    }

        .pm-center-loading.small {
            padding: 28px;
        }

    .pm-group-hero {
        position: relative;
        overflow: hidden;
        border-radius: 22px;
        border: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-surface);
        box-shadow: 0 16px 42px rgba(0,0,0,.20);
        margin-bottom: 18px;
    }

    .pm-hero-gradient {
        height: 92px;
        background: linear-gradient(135deg, #1D4ED8, #2563EB, #38BDF8);
    }

    .pm-hero-content {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 0 22px 22px;
        margin-top: -42px;
    }

    .pm-back-btn {
        margin-bottom: 10px;
    }

    .pm-group-avatar-wrap {
        flex-shrink: 0;
    }

    .pm-group-avatar {
        width: 88px !important;
        height: 88px !important;
        border: 4px solid var(--mud-palette-surface);
        background: #2563EB;
        color: white;
        box-shadow: 0 10px 24px rgba(0,0,0,.28);
    }

    .pm-group-title-block {
        min-width: 0;
        flex: 1;
        padding-bottom: 7px;
    }

        .pm-group-title-block h1 {
            margin: 0;
            font-size: 1.55rem;
            font-weight: 900;
            color: var(--mud-palette-text-primary);
            line-height: 1.2;
            overflow-wrap: break-word;
            word-break: break-word;
            max-width: 100%;
        }

    .pm-group-subtitle {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 4px;
        color: var(--mud-palette-text-secondary);
        font-size: .86rem;
    }

    .pm-hero-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        padding-bottom: 8px;
        flex-shrink: 0;
    }

    .pm-edit-name {
        max-width: 420px;
    }

    .pm-tabs {
        display: flex;
        gap: 8px;
        padding: 8px;
        background: rgba(148, 163, 184, .08);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 16px;
        margin-bottom: 16px;
        overflow-x: auto;
    }

    .pm-tab-btn {
        border: none;
        border-radius: 12px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        padding: 9px 14px;
        font-weight: 800;
        cursor: pointer;
        white-space: nowrap;
    }

        .pm-tab-btn.active {
            color: white;
            background: var(--mud-palette-primary);
            box-shadow: 0 6px 16px rgba(37,99,235,.25);
        }

    .pm-content-grid {
        display: grid;
        grid-template-columns: 1.3fr .9fr;
        gap: 16px;
    }

    .pm-panel {
        border-radius: 18px;
        background: var(--mud-palette-surface);
    }

    .pm-panel-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
        color: var(--mud-palette-text-primary);
        margin-bottom: 12px;
    }

        .pm-panel-title.danger {
            color: var(--mud-palette-error);
        }

    .pm-description {
        margin: 0;
        color: var(--mud-palette-text-primary);
        line-height: 1.7;
        white-space: pre-wrap;
    }

    .pm-stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .pm-stat-card {
        border-radius: 14px;
        padding: 14px 10px;
        background: rgba(59,130,246,.10);
        border: 1px solid rgba(59,130,246,.18);
        text-align: center;
    }

    .pm-stat-number {
        font-size: 1.45rem;
        font-weight: 900;
        color: var(--mud-palette-primary);
    }

    .pm-stat-label {
        font-size: .78rem;
        color: var(--mud-palette-text-secondary);
        margin-top: 2px;
    }

    .pm-add-member-box {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

    .pm-search-results {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-top: 14px;
    }

    .pm-user-row,
    .pm-member-card,
    .pm-file-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border-radius: 14px;
        border: 1px solid var(--mud-palette-divider);
        background: rgba(148, 163, 184, .06);
    }

    .pm-user-main,
    .pm-member-info,
    .pm-file-main {
        min-width: 0;
        flex: 1;
    }

    .pm-user-name,
    .pm-member-name,
    .pm-file-name {
        font-weight: 900;
        color: var(--mud-palette-text-primary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pm-user-meta,
    .pm-member-meta,
    .pm-file-meta,
    .pm-file-sender {
        font-size: .8rem;
        color: var(--mud-palette-text-secondary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pm-member-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .pm-member-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 2px;
    }

    .pm-online-dot {
        color: #22C55E;
    }

    .pm-offline-dot {
        color: #94A3B8;
    }

    .pm-role-select {
        padding: 4px 8px;
        border: 1px solid var(--mud-palette-divider);
        border-radius: 6px;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        font-size: 0.85rem;
        cursor: pointer;
        width: 120px;
        outline: none;
    }
    
    .pm-role-select:focus {
        border-color: var(--mud-palette-primary);
    }

    .pm-section-heading {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin: 18px 0 10px;
        font-weight: 900;
        color: var(--mud-palette-text-primary);
    }

        .pm-section-heading small {
            color: var(--mud-palette-text-secondary);
            font-weight: 600;
        }

    .pm-media-header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
    }

    .pm-media-filter {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px;
        background: rgba(148, 163, 184, .08);
        border-radius: 999px;
        border: 1px solid var(--mud-palette-divider);
    }

    .pm-filter-btn {
        border: none;
        border-radius: 999px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        padding: 6px 11px;
        font-weight: 800;
        font-size: .8rem;
        cursor: pointer;
    }

        .pm-filter-btn.active {
            color: white;
            background: var(--mud-palette-primary);
        }

    .pm-empty-media {
        text-align: center;
        padding: 44px 16px;
        color: var(--mud-palette-text-secondary);
    }

        .pm-empty-media .mud-icon-root {
            font-size: 54px;
            opacity: .35;
            margin-bottom: 8px;
        }

        .pm-empty-media p {
            margin: 0;
            font-weight: 800;
            color: var(--mud-palette-text-primary);
        }

        .pm-empty-media small {
            display: block;
            margin-top: 4px;
        }

    .pm-image-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 10px;
    }

    .pm-image-tile {
        position: relative;
        overflow: hidden;
        border-radius: 14px;
        border: 1px solid var(--mud-palette-divider);
        aspect-ratio: 1 / 1;
        display: block;
        background: rgba(148,163,184,.10);
    }

        .pm-image-tile img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .pm-image-overlay {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
