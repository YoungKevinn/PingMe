@code {
    [Parameter] public int GroupId { get; set; }

    private GroupResponse? _group;
    private bool _loading = true;

    private string _activeTab = "overview";

    private bool _editing;
    private string _editName = "";
    private string _editDesc = "";

    private string _addMemberSearchTerm = "";
    private bool _addMemberSearchLoading;
    private List<UserSearchResult> _addMemberSearchResults = new();

    private string _mediaFilter = "all";
    private bool _mediaLoading;
    private List<ConversationAttachmentResponse> _attachments = new();

    [CascadingParameter] private Task<AuthenticationState>? AuthTask { get; set; }

    private int CurrentUserId;

    private bool IsAdmin =>
        _group?.Members.Any(m =>
            m.UserId == CurrentUserId &&
            (m.Role == "Admin" || m.Role == "CoAdmin")) == true;

    private bool IsRealAdmin =>
        _group?.Members.Any(m =>
            m.UserId == CurrentUserId &&
            m.Role == "Admin") == true;

    private bool IsCreator => _group?.CreatedByUserId == CurrentUserId;

    protected override async Task OnInitializedAsync()
    {
        if (AuthTask != null)
        {
            var auth = await AuthTask;
            var uid = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            CurrentUserId = int.TryParse(uid, out var id) ? id : 0;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _group = await GroupService.GetGroupAsync(GroupId);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SetTabAsync(string tab)
    {
        _activeTab = tab;

        if (tab == "media")
            await LoadAttachmentsAsync();
    }

    private string GetTabClass(string tab)
    {
        return _activeTab == tab ? "pm-tab-btn active" : "pm-tab-btn";
    }

    private string GetMediaFilterClass(string filter)
    {
        return _mediaFilter == filter ? "pm-filter-btn active" : "pm-filter-btn";
    }

    private async Task SetMediaFilterAsync(string filter)
    {
        _mediaFilter = filter;
        await LoadAttachmentsAsync();
    }

    private async Task LoadAttachmentsAsync()
    {
        _mediaLoading = true;

        try
        {
            _attachments = await MessageService.GetConversationAttachmentsAsync(
                groupId: GroupId,
                peerId: null,
                type: _mediaFilter,
                limit: 120
            ) ?? new List<ConversationAttachmentResponse>();
        }
        catch
        {
            Snackbar.Add("Không tải được danh sách ảnh/tệp đã upload.", Severity.Warning);
            _attachments = new List<ConversationAttachmentResponse>();
        }
        finally
        {
            _mediaLoading = false;
        }
    }

    private void StartEdit()
    {
        _editName = _group?.Name ?? "";
        _editDesc = _group?.Description ?? "";
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
        _editName = "";
        _editDesc = "";
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_editName))
        {
            Snackbar.Add("Tên nhóm không được rỗng.", Severity.Warning);
            return;
        }

        var ok = await GroupService.UpdateGroupAsync(GroupId, new UpdateGroupRequest
        {
            Name = _editName.Trim(),
            Description = _editDesc?.Trim()
        });

        if (ok)
        {
            Snackbar.Add("Cập nhật nhóm thành công!", Severity.Success);
            _editing = false;
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Cập nhật nhóm thất bại.", Severity.Error);
        }
    }

    private async Task SearchAddMembersAsync()
    {
        _addMemberSearchLoading = true;

        try
        {
            var result = await SearchService.SearchAsync(_addMemberSearchTerm ?? string.Empty, 50);

            var currentMemberIds = _group?.Members
                .Select(x => x.UserId)
                .ToHashSet() ?? new HashSet<int>();

            _addMemberSearchResults = (result?.Users ?? new List<UserSearchResult>())
                .Where(u => !currentMemberIds.Contains(u.Id))
                .ToList();
        }
        finally
        {
            _addMemberSearchLoading = false;
        }
    }

    private async Task AddMemberByUserAsync(int userId)
    {
        var ok = await GroupService.AddMemberAsync(GroupId, userId);

        if (ok)
        {
            Snackbar.Add("Thêm thành viên thành công!", Severity.Success);

            _addMemberSearchTerm = string.Empty;
            _addMemberSearchResults.Clear();

            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Thêm thành viên thất bại.", Severity.Error);
        }
    }

    private async Task KickAsync(int userId)
    {
        var ok = await GroupService.KickMemberAsync(GroupId, userId);

        if (ok)
        {
            Snackbar.Add("Đã xóa thành viên khỏi nhóm.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Xóa thành viên thất bại.", Severity.Error);
        }
    }

    private async Task UpdateRoleAsync(int userId, string role)
    {
        var ok = await GroupService.UpdateMemberRoleAsync(GroupId, userId, role);

        if (ok)
        {
            Snackbar.Add("Đã cập nhật quyền thành viên.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Cập nhật quyền thất bại.", Severity.Error);
        }
    }

    private async Task LeaveAsync()
    {
        var ok = await GroupService.LeaveGroupAsync(GroupId);

        if (ok)
        {
            Snackbar.Add("Đã rời nhóm.", Severity.Success);
            Nav.NavigateTo("/groups");
        }
        else
        {
            Snackbar.Add("Rời nhóm thất bại.", Severity.Error);
        }
    }

    private async Task DeleteAsync()
    {
        var ok = await GroupService.DeleteGroupAsync(GroupId);

        if (ok)
        {
            Snackbar.Add("Đã giải tán nhóm.", Severity.Success);
            Nav.NavigateTo("/groups");
        }
        else
        {
            Snackbar.Add("Giải tán nhóm thất bại.", Severity.Error);
        }
    }

    private void GoToChat()
    {
        Nav.NavigateTo($"/chat/group/{GroupId}");
    }

    private void GoBack()
    {
        Nav.NavigateTo("/groups");
    }

    private string GetRoleVietnamese(string role) => role switch
    {
        "Admin" => "👑 Admin",
        "CoAdmin" => "⭐ Co-Admin",
        _ => "Thành viên"
    };

    private string GetAbsoluteUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
            return string.Empty;

        if (url.StartsWith("http", StringComparison.OrdinalIgnoreCase))
            return url;

        return $"http://localhost:5000/{url.TrimStart('/')}";
    }

    private string GetDownloadUrl(ConversationAttachmentResponse file)
    {
        if (!Uri.TryCreate(file.FileUrl, UriKind.Absolute, out var uri))
            return file.FileUrl;

        var parts = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);

        var messagesIndex = Array.FindIndex(
            parts,
            p => string.Equals(p, "messages", StringComparison.OrdinalIgnoreCase)
        );

        if (messagesIndex < 0 || parts.Length <= messagesIndex + 2)
            return file.FileUrl;

        var date = parts[messagesIndex + 1];
        var fileName = Uri.UnescapeDataString(parts[messagesIndex + 2]);

        return $"{uri.Scheme}://{uri.Authority}/api/files/download/messages/{date}/{Uri.EscapeDataString(fileName)}";
    }
}