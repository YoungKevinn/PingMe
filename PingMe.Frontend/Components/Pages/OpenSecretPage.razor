@page "/secret/{Token}"
@inject OneTimeSecretService SecretService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject LocalizationService Loc
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Outlined="true" Class="pa-5">
        <div class="d-flex align-center gap-2 mb-3">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" />
            <MudText Typo="Typo.h5" Class="font-weight-bold">@Loc.T("openSecret.title")</MudText>
        </div>

        @if (_opened && _secret is not null)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                @Loc.T("openSecret.openedNotice")
            </MudAlert>

            <MudPaper Outlined="true" Class="pa-3" Style="white-space:pre-wrap;word-break:break-word;">
                @_secret.SecretText
            </MudPaper>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ContentCopy"
                       OnClick="CopySecretAsync"
                       Class="mt-3">
                @Loc.T("openSecret.copySecret")
            </MudButton>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @_error
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
                @Loc.T("openSecret.warning")
            </MudAlert>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Visibility"
                       Disabled="_opening"
                       OnClick="OpenAsync">
                @Loc.T("openSecret.openButton")
            </MudButton>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private ViewOneTimeSecretResponse? _secret;
    private string? _error;
    private bool _opening;
    private bool _opened;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += HandleLanguageChanged;
        await Loc.LoadAsync();
    }

    private async Task OpenAsync()
    {
        _opening = true;
        _error = null;

        var result = await SecretService.OpenAsync(Token);
        _opening = false;

        if (result.Secret is null)
        {
            _error = result.Error ?? Loc.T("openSecret.expiredOrViewed");
            Snackbar.Add(Loc.T("openSecret.expiredOrViewed"), Severity.Warning);
            return;
        }

        _secret = result.Secret;
        _opened = true;
    }

    private async Task CopySecretAsync()
    {
        if (_secret is null)
            return;

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _secret.SecretText);
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= HandleLanguageChanged;
    }
}
