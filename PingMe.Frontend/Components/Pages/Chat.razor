        if (!string.IsNullOrWhiteSpace(editResult.AvatarUrl))
        {
            _chatAvatarUrl = editResult.AvatarUrl;
            _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        }

        if (_convList != null)
            await _convList.UpdateConversationTitleAsync(null, GroupId, _chatTitle, _chatAvatarUrl);

        await LoadChatInfoAsync(PeerId, GroupId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleNicknameSavedAsync(string nickname)
    {
        if (!PeerId.HasValue)
            return;

        _showNicknameDialog = false;

        if (!string.IsNullOrWhiteSpace(nickname))
        {
            _chatTitle = nickname;
            _peerTitleOverrides[PeerId.Value] = nickname;

            if (_convList != null)
                await _convList.UpdateConversationTitleAsync(PeerId, null, nickname);

            StateHasChanged();
        }
        else
        {
            _peerTitleOverrides.Remove(PeerId.Value);
            await LoadChatInfoAsync(PeerId, GroupId);

            if (_convList != null)
                await _convList.RefreshAsync();
        }
    }

    private async Task ToggleBlockPeerAsync()
    {
        _moreMenuOpen = false;

        if (!PeerId.HasValue)
            return;

        if (_isPeerBlockedByMe)
            _showUnblockConfirm = true;
        else
            _showBlockConfirm = true;

        await InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmBlockPeerAsync()
    {
        if (!PeerId.HasValue || _blockActionBusy)
            return;

        _blockActionBusy = true;

        try
        {
            var ok = await BlockService.BlockUserAsync(PeerId.Value);
            Snackbar.Add(ok ? "Đã chặn người dùng." : "Không thể chặn người dùng.", ok ? Severity.Success : Severity.Warning);

            if (ok)
            {
                _isPeerBlockedByMe = true;
                _showBlockConfirm = false;
                await ClearReplyAfterBlockAsync();
            }
        }
        catch
        {
            Snackbar.Add("Không thể chặn người dùng.", Severity.Warning);
        }
        finally
        {
            _blockActionBusy = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmUnblockPeerAsync()
    {
        if (!PeerId.HasValue || _blockActionBusy)
            return;

        _blockActionBusy = true;

        try
        {
            var ok = await BlockService.UnblockUserAsync(PeerId.Value);
            Snackbar.Add(ok ? "Đã bỏ chặn người dùng." : "Không thể bỏ chặn người dùng.", ok ? Severity.Success : Severity.Warning);

            if (ok)
            {
                _isPeerBlockedByMe = false;
                _showUnblockConfirm = false;
                await RefreshBlockStatusAsync(PeerId.Value);
            }
        }
        catch
        {
            Snackbar.Add("Không thể bỏ chặn người dùng.", Severity.Warning);
        }
        finally
        {
            _blockActionBusy = false;
            StateHasChanged();
        }
    }

