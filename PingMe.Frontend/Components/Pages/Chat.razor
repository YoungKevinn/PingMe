    private string? CurrentConversationKey()
    {
        if (GroupId.HasValue)
            return $"group:{GroupId.Value}";

        if (PeerId.HasValue)
            return $"dm:{PeerId.Value}";

        return null;
    }

    private void RestorePinnedFromCache()
    {
        var key = CurrentConversationKey();

        if (key != null && _pinnedCache.TryGetValue(key, out var cached))
            _pinnedMessages = cached.ToList();
        else
            _pinnedMessages = new();
    }

    private void InvalidateCurrentPinnedCache()
    {
        var key = CurrentConversationKey();

        if (key != null)
            _pinnedCache.Remove(key);
    }

    private async Task LoadPinnedAsync(bool force = false)
    {
        var key = CurrentConversationKey();

        if (!PeerId.HasValue && !GroupId.HasValue)
        {
            _pinnedMessages.Clear();
            return;
        }

        if (!force && key != null && _pinnedCache.TryGetValue(key, out var cached))
        {
            _pinnedMessages = cached.ToList();
            StateHasChanged();
            return;
        }

        _pinLoading = true;

        try
        {
            var pins = await MsgService.GetPinnedMessagesAsync(GroupId, PeerId);
            _pinnedMessages = pins ?? new List<MessageResponse>();

            if (key != null)
                _pinnedCache[key] = _pinnedMessages.ToList();
        }
        catch
        {
            _pinnedMessages = new();
        }
        finally
        {
            _pinLoading = false;
            StateHasChanged();
        }
    }

    private async Task TogglePinPanelAsync()
    {
        _pinPanelOpen = !_pinPanelOpen;

        if (_pinPanelOpen)
        {
            _moreMenuOpen = false;
            _searchOpen = false;
        }

        StateHasChanged();

        if (_pinPanelOpen)
            await LoadPinnedAsync();
    }

    private async Task JumpToPinAsync(int messageId)
    {
        _pinPanelOpen = false;
        StateHasChanged();
        await Task.Delay(80);

        if (_msgList != null)
            await _msgList.ScrollToMessageAsync(messageId);
    }

    private async Task UnpinAsync(int messageId)
    {
        var ok = await MsgService.PinMessageAsync(messageId, false);

        if (!ok)
        {
            Snackbar.Add("Không thể bỏ ghim. Bạn có thể thiếu quyền.", Severity.Warning);
            return;
        }

        Snackbar.Add("Đã bỏ ghim tin nhắn.", Severity.Success);
        InvalidateCurrentPinnedCache();
        await LoadPinnedAsync(force: true);
    }

    private async Task HandlePinChangedAsync(MessagePinnedEvent _)
    {
        InvalidateCurrentPinnedCache();

        if (_pinPanelOpen)
            await LoadPinnedAsync(force: true);
        else
        {
            _pinnedMessages.Clear();
            StateHasChanged();
        }
    }

    private static string PinPreview(MessageResponse msg)
    {
        if (msg.IsDeleted)
            return "Tin nhắn đã thu hồi";

        if (!string.IsNullOrWhiteSpace(msg.Content))
        {
            var content = msg.Content.Replace("\n", " ").Trim();
            return content.Length > 120 ? content[..120] + "…" : content;
        }

        if (msg.Attachments?.Any() == true)
        {
            var att = msg.Attachments.First();
            return att.IsImage ? $"🖼 {att.FileName}" : $"📎 {att.FileName}";
        }

        return "(Tin nhắn trống)";
    }

    private async Task RefreshBlockStatusAsync(int peerId)
    {
        var status = await BlockService.GetBlockStatusAsync(peerId);
        _isPeerBlockedByMe = status?.IsBlockedByMe == true;
        _hasBlockedMe = status?.HasBlockedMe == true;
    }

