@page "/chat"
@page "/chat/{PeerId:int}"
@page "/chat/group/{GroupId:int}"
@attribute [Authorize]
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.AspNetCore.Components.Authorization
@using System.Text.Json
@using PingMe.Frontend.Models
@using PingMe.Frontend.Helpers
@using PingMe.Frontend.Components
@using PingMe.Frontend.Components.Dialogs
@inject ConversationService ConvService
@inject MessageService MsgService
@inject GroupService GroupService
@inject SearchService SearchService
@inject BlockService BlockService
@inject ChatHubService Hub
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject LocalizationService Loc
@inject WebRTCService WebRTC
@implements IAsyncDisposable

<div style="display:flex;height:calc(100vh - 64px);overflow:hidden;background:var(--mud-palette-background);">

    <!-- Conversation Sidebar -->
    <div style="width:300px;min-width:260px;max-width:320px;border-right:1px solid rgba(0,0,0,.07);background:var(--mud-palette-surface);overflow:hidden;flex-shrink:0;">
        <ConversationList @ref="_convList"
                          SelectedPeerId="PeerId"
                          SelectedGroupId="GroupId"
                          OnConversationSelected="OnConversationSelected" />
    </div>

    <!-- Chat Area -->
    <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;">
        @if (PeerId.HasValue || GroupId.HasValue)
        {
            var headerAvatarUrl = BuildAvatarUrl(_chatAvatarUrl);

            <!-- Header -->
            <div class="pm-chat-header">
                <MudAvatar Color="Color.Primary"
                           Size="Size.Medium"
                           Style="flex-shrink:0;">
                    @if (!string.IsNullOrWhiteSpace(_chatTitle))
                    {
                        <span class="pm-chat-avatar-fallback">@_chatTitle.FirstOrDefault()</span>
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Person" />
                    }

                    @if (!string.IsNullOrWhiteSpace(headerAvatarUrl))
                    {
                        <img src="@headerAvatarUrl"
                             alt="@_chatTitle"
                             class="pm-avatar-image"
                             loading="lazy"
                             decoding="async"
                             referrerpolicy="no-referrer"
                             onerror="this.style.display='none';this.parentElement.classList.add('pm-avatar-fallback-active');" />
                    }
                </MudAvatar>

                <div class="pm-chat-header-info">
                    <p class="pm-chat-title">
                        @_chatTitle
                    </p>

                    @if (_onlineStatus.HasValue)
                    {
                        <p class="pm-chat-subtitle" style="color:@(_onlineStatus.Value ? "#16A34A" : "#94A3B8");">
                            ● @(_onlineStatus.Value ? "Đang hoạt động" : "Ngoại tuyến")
                        </p>
                    }
                    else if (GroupId.HasValue)
                    {
                        <p class="pm-chat-subtitle">
                            @Loc.T("chat.groupLabel")
                        </p>
                    }
                </div>

                @if (PeerId.HasValue)
                {
                    <MudTooltip Text="Gọi thoại">
                        <MudIconButton Icon="@Icons.Material.Filled.Phone"
                                       OnClick="() => WebRTC.InitiateCallAsync(PeerId.Value, _chatTitle, _chatAvatarUrl, false)"
                                       Size="Size.Small" />
                    </MudTooltip>
                    
                    <MudTooltip Text="Gọi video">
                        <MudIconButton Icon="@Icons.Material.Filled.Videocam"
                                       OnClick="() => WebRTC.InitiateCallAsync(PeerId.Value, _chatTitle, _chatAvatarUrl, true)"
                                       Size="Size.Small" />
                    </MudTooltip>
                }

                <!-- Toggle pin panel -->
                <MudTooltip Text="@(_pinPanelOpen ? "Đóng tin nhắn đã ghim" : _pinnedMessages.Any() ? $"Tin nhắn đã ghim ({_pinnedMessages.Count})" : "Tin nhắn đã ghim")">
                    <div style="position:relative;display:inline-flex;">
                        <MudIconButton Icon="@(_pinPanelOpen? Icons.Material.Filled.PushPin : Icons.Material.Outlined.PushPin)"
                                       Color="@(_pinPanelOpen ? Color.Warning : (_pinnedMessages.Any() ? Color.Warning : Color.Default))"
                                       Size="Size.Small"
                                       OnClick="TogglePinPanelAsync" />

                        @if (_pinnedMessages.Count > 0 && !_pinPanelOpen)
                        {
                            <span class="pm-pin-count-badge">
                                @(_pinnedMessages.Count > 9 ? "9+" : _pinnedMessages.Count.ToString())
                            </span>
                        }
                    </div>
                </MudTooltip>

                <MudTooltip Text="Tìm trong đoạn chat">
                    <MudIconButton Icon="@Icons.Material.Filled.Search"
                                   OnClick="ToggleSearch"
                                   Size="Size.Small" />
                </MudTooltip>

                <!-- More menu: dùng HTML riêng thay MudMenu để tránh lỗi overlay không mở -->
                <div class="pm-chat-more-menu">
                    <button type="button"
                            class="@($"pm-chat-more-btn {(_moreMenuOpen ? "active" : "")}")"
                            title="Tùy chọn"
                            @onclick="ToggleMoreMenu">
                        <MudIcon Icon="@Icons.Material.Filled.MoreVert" />
                    </button>

                    @if (_moreMenuOpen)
                    {
                        <div class="pm-chat-more-dropdown" @onclick:stopPropagation="true">
                            @if (GroupId.HasValue)
                            {
                                <button type="button"
                                        class="pm-chat-more-item"
                                        @onclick="OpenGroupMemberManagerAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.Groups" />
                                    <span>Quản lý thành viên</span>
                                </button>

                                <button type="button"
                                        class="@($"pm-chat-more-item {(!CanManageCurrentGroup ? "is-disabled" : "")}")"
                                        @onclick="OpenAddGroupMemberDialogAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.PersonAddAlt1" />
                                    <span>Thêm thành viên</span>
                                </button>

                                <button type="button"
                                        class="pm-chat-more-item"
                                        @onclick="OpenSharedFilesDialogAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderShared" />
                                    <span>Tệp đã chia sẻ</span>
                                </button>

                                <button type="button"
                                        class="@($"pm-chat-more-item {(!CanManageCurrentGroup ? "is-disabled" : "")}")"
                                        @onclick="OpenEditGroupDialogAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.Edit" />
                                    <span>Đổi tên / đổi ảnh nhóm</span>
                                </button>
                                
                                <button type="button"
                                        class="pm-chat-more-item danger"
                                        @onclick="ClearHistoryAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" />
                                    <span>Xóa đoạn chat</span>
                                </button>
                                
                                @if (CanManageCurrentGroup && string.Equals(_currentGroupRole, "Admin", StringComparison.OrdinalIgnoreCase))
                                {
                                    <button type="button"
                                            class="pm-chat-more-item danger"
                                            @onclick="DissolveGroupAsync">
                                        <MudIcon Icon="@Icons.Material.Filled.DeleteForever" />
                                        <span>Giải tán nhóm</span>
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="pm-chat-more-item danger"
                                            @onclick="LeaveGroupAsync">
                                        <MudIcon Icon="@Icons.Material.Filled.ExitToApp" />
                                        <span>Rời nhóm</span>
                                    </button>
                                }
                            }
                            else if (PeerId.HasValue)
                            {
                                <button type="button"
                                        class="pm-chat-more-item"
                                        @onclick="OpenNicknameDialogAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.Badge" />
                                    <span>Đặt biệt danh</span>
                                </button>

                                <button type="button"
                                        class="pm-chat-more-item"
                                        @onclick="OpenSharedFilesDialogAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.FolderShared" />
                                    <span>Tệp đã chia sẻ</span>
                                </button>

                                <button type="button"
                                        class="pm-chat-more-item danger"
                                        @onclick="ToggleBlockPeerAsync">
                                    <MudIcon Icon="@(_isPeerBlockedByMe ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Block)" />
                                    <span>@(_isPeerBlockedByMe ? "Bỏ chặn" : "Chặn người dùng")</span>
                                </button>
                                
                                <button type="button"
                                        class="pm-chat-more-item danger"
                                        @onclick="ClearHistoryAsync">
                                    <MudIcon Icon="@Icons.Material.Filled.DeleteSweep" />
                                    <span>Xóa đoạn chat</span>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Search bar -->
            @if (_searchOpen)
            {
                <div class="pm-chat-search-bar">
                    <MudTextField @bind-Value="_searchTerm"
                                  Placeholder="Tìm kiếm trong đoạn chat..."
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  OnKeyDown="OnSearchKeyDown"
                                  Style="flex:1;" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="@(_searching || string.IsNullOrWhiteSpace(_searchTerm))"
                               OnClick="SearchInCurrentChatAsync">
                        @if (_searching)
                        {
                            <MudProgressCircular Size="Size.Small"
                                                 Indeterminate="true"
                                                 Color="Color.Inherit" />
                        }
                        else
                        {
                            <span>Tìm</span>
                        }
                    </MudButton>

                    @if (_searchResults.Any())
                    {
                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp"
                                       Size="Size.Small"
                                       Disabled="@(_searchResults.Count <= 1)"
                                       OnClick="PreviousSearchResultAsync" />

                        <span style="font-size:.8rem;color:var(--mud-palette-text-secondary);min-width:50px;text-align:center;">
                            @(_searchIndex + 1)/@_searchResults.Count
                        </span>

                        <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown"
                                       Size="Size.Small"
                                       Disabled="@(_searchResults.Count <= 1)"
                                       OnClick="NextSearchResultAsync" />
                    }

                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   OnClick="CloseSearch" />
                </div>
            }


                <!-- Messages + inline pin panel overlay -->
                <div style="flex:1;overflow:hidden;position:relative;">
                    @if (_groupAccessRevoked)
                    {
                        <div class="pm-group-kicked-banner">
                            Bạn đã bị xóa khỏi nhóm này.
                        </div>
                    }

                <MessageList @ref="_msgList"
                             PeerId="PeerId"
                             GroupId="GroupId"
                             TargetMessageId="MessageId"
                             PeerDisplayNameOverride="@_chatTitle"
                             OnReply="(msg) => { _replyTo = msg; StateHasChanged(); }"
                             OnPinChanged="HandlePinChangedAsync"
                             OnReadStateChanged="HandleReadStateChangedAsync" />

                @if (_pinPanelOpen)
                {
                    <div style="position:absolute;inset:0;z-index:100;"
                         @onclick="() => _pinPanelOpen = false" />

                    <div class="pm-pin-panel"
                         @onclick:stopPropagation="true">
                        <div class="pm-pin-panel-header">
                            <MudIcon Icon="@Icons.Material.Filled.PushPin"
                                     Style="color:#F59E0B;font-size:18px;flex-shrink:0;" />
                            <div style="flex:1;">
                                <span class="pm-pin-panel-title">Tin nhắn đã ghim</span>
                                @if (_pinnedMessages.Count > 0)
                                {
                                    <span class="pm-pin-panel-count">@_pinnedMessages.Count</span>
                                }
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           OnClick="() => _pinPanelOpen = false"
                                           Style="width:28px;height:28px;" />
                        </div>

                        <div class="pm-pin-panel-body">
                            @if (_pinLoading)
                            {
                                <div style="display:flex;justify-content:center;padding:28px;">
                                    <MudProgressCircular Indeterminate="true"
                                                         Size="Size.Small"
                                                         Color="Color.Primary" />
                                </div>
                            }
                            else if (!_pinnedMessages.Any())
                            {
                                <div class="pm-pin-panel-empty">
                                    <MudIcon Icon="@Icons.Material.Outlined.PushPin"
                                             Style="font-size:40px;opacity:.28;" />
                                    <p>Chưa có tin nhắn nào được ghim</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var pin in _pinnedMessages)
                                {
                                    var pinMsg = pin;

                                    <div class="pm-pin-panel-item">
                                        <button type="button"
                                                class="pm-pin-panel-jump"
                                                @onclick="() => JumpToPinAsync(pinMsg.Id)">
                                            <div class="pm-pin-panel-avatar">
                                                @pinMsg.SenderDisplayName?.FirstOrDefault()
                                            </div>

                                            <div class="pm-pin-panel-info">
                                                <div class="pm-pin-panel-row">
                                                    <span class="pm-pin-panel-author">@pinMsg.SenderDisplayName</span>
                                                    <span class="pm-pin-panel-time">
                                                        @pinMsg.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")
                                                    </span>
                                                </div>

                                                <div class="pm-pin-panel-preview">
                                                    @PinPreview(pinMsg)
                                                </div>
                                            </div>
                                        </button>

                                        <MudTooltip Text="Bỏ ghim">
                                            <MudIconButton Icon="@Icons.Material.Filled.PushPin"
                                                           Size="Size.Small"
                                                           Color="Color.Warning"
                                                           Style="flex-shrink:0;"
                                                           OnClick="() => UnpinAsync(pinMsg.Id)" />
                                        </MudTooltip>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Typing indicator -->
            @if (_typingUsers.Any())
            {
                <div style="padding:4px 16px 0;">
                    <TypingIndicator Users="_typingUsers" />
                </div>
            }

            <!-- Input -->
            <MessageInput PeerId="PeerId"
                          GroupId="GroupId"
                          @bind-ReplyTo="_replyTo"
                          OnSendMessage="OnSent"
                          Disabled="@IsInputDisabled"
                          DisabledReason="@InputDisabledReason" />
        }
        else
        {
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:32px;">
                <div style="width:80px;height:80px;background:linear-gradient(135deg,#2563EB,#60A5FA);border-radius:24px;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(37,99,235,.3);">
                    <MudIcon Icon="@Icons.Material.Filled.Forum"
                             Style="font-size:40px;color:white;" />
                </div>

                <div style="text-align:center;">
                    <p style="margin:0 0 4px;font-size:1.25rem;font-weight:700;color:var(--mud-palette-text-primary);">
                        @Loc.T("chat.emptyTitle")
                    </p>

                    <p style="margin:0;font-size:.875rem;color:#94A3B8;max-width:280px;">
                        @Loc.T("chat.emptySubtitle")
                    </p>
                </div>
            </div>
        }
    </div>
</div>

@if (_showGroupMembersDialog && GroupId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseGroupMembersDialogAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-md" @onclick:stopPropagation="true">
            <GroupMembersDialog GroupId="GroupId.Value"
                                GroupName="@_chatTitle"
                                OnClose="CloseGroupMembersDialogAsync" />
        </div>
    </div>
}

@if (_showAddMemberDialog && GroupId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseAddMemberDialogAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-sm" @onclick:stopPropagation="true">
            <AddGroupMemberDialog GroupId="GroupId.Value"
                                  GroupName="@_chatTitle"
                                  OnSaved="HandleAddMemberSavedAsync"
                                  OnClose="CloseAddMemberDialogAsync" />
        </div>
    </div>
}

@if (_showEditGroupDialog && GroupId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseEditGroupDialogAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-sm" @onclick:stopPropagation="true">
            <EditGroupDialog GroupId="GroupId.Value"
                             GroupName="@_chatTitle"
                             OnSaved="HandleEditGroupSavedAsync"
                             OnClose="CloseEditGroupDialogAsync" />
        </div>
    </div>
}

@if (_showNicknameDialog && PeerId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseNicknameDialogAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-xs" @onclick:stopPropagation="true">
            <NicknameDialog PeerId="PeerId.Value"
                            InitialNickname="@GetInitialNickname()"
                            OnSaved="HandleNicknameSavedAsync"
                            OnClose="CloseNicknameDialogAsync" />
        </div>
    </div>
}

@if (_showSharedFilesDialog)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseSharedFilesDialogAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-md" @onclick:stopPropagation="true">
            <SharedFilesDialog PeerId="PeerId"
                               GroupId="GroupId"
                               ConversationTitle="@_chatTitle"
                               OnClose="CloseSharedFilesDialogAsync" />
        </div>
    </div>
}

@if (_activeReminderAlarm is not null)
{
    <div class="pm-reminder-alarm-backdrop"
         @ref="_reminderAlarmBackdrop"
         tabindex="0"
         @onkeydown="HandleReminderAlarmKeyDown">
        <div class="pm-reminder-alarm-modal" @onclick:stopPropagation="true">
            <div class="pm-reminder-alarm-icon">⏰</div>
            <div class="pm-reminder-alarm-kicker">Nhắc việc đến hạn</div>
            <h2>@_activeReminderAlarm.Text</h2>
            <p>
                @if (_activeReminderAlarm.DueAt.HasValue)
                {
                    <span>Nhắc lúc: @_activeReminderAlarm.DueAt.Value.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</span>
                }
                else if (!string.IsNullOrWhiteSpace(_activeReminderAlarm.ConversationTitle))
                {
                    <span>Nhắc việc trong @_activeReminderAlarm.ConversationTitle</span>
                }
                else
                {
                    <span>Nhắc việc đã đến hạn.</span>
                }
            </p>
            <div class="pm-reminder-alarm-actions">
                <button type="button"
                        class="pm-reminder-alarm-btn primary"
                        @onclick="OpenReminderConversationAsync">
                    Mở đoạn chat
                </button>
                <button type="button"
                        class="pm-reminder-alarm-btn secondary"
                        @onclick="DismissReminderAlarmAsync">
                    Đã hiểu
                </button>
            </div>
        </div>
    </div>
}

@if (_showBlockConfirm && PeerId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseBlockConfirmAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-xs" @onclick:stopPropagation="true">
            <div class="pm-confirm-panel">
                <div class="pm-confirm-title">Chặn người dùng?</div>
                <div class="pm-confirm-text">Bạn sẽ không nhận/gửi tin nhắn với người này cho đến khi bỏ chặn.</div>
                <div class="pm-confirm-actions">
                    <button type="button" class="pm-confirm-btn secondary" disabled="@_blockActionBusy" @onclick="CloseBlockConfirmAsync">Hủy</button>
                    <button type="button" class="pm-confirm-btn danger" disabled="@_blockActionBusy" @onclick="ConfirmBlockPeerAsync">Chặn</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showUnblockConfirm && PeerId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseUnblockConfirmAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-xs" @onclick:stopPropagation="true">
            <div class="pm-confirm-panel">
                <div class="pm-confirm-title">Bỏ chặn người dùng?</div>
                <div class="pm-confirm-text">Bạn có thể gửi tin nhắn lại cho người này sau khi bỏ chặn.</div>
                <div class="pm-confirm-actions">
                    <button type="button" class="pm-confirm-btn secondary" disabled="@_blockActionBusy" @onclick="CloseUnblockConfirmAsync">Hủy</button>
                    <button type="button" class="pm-confirm-btn primary" disabled="@_blockActionBusy" @onclick="ConfirmUnblockPeerAsync">Bỏ chặn</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showClearHistoryConfirm)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseClearHistoryConfirmAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-xs" @onclick:stopPropagation="true">
            <div class="pm-confirm-panel">
                <div class="pm-confirm-title">Xóa đoạn chat?</div>
                <div class="pm-confirm-text">
                    @(GroupId.HasValue 
                        ? "Bạn có chắc chắn muốn xóa đoạn chat nhóm này không? Lịch sử sẽ chỉ bị xóa khỏi thiết bị của bạn." 
                        : "Bạn có chắc chắn muốn xóa cuộc trò chuyện này không? Toàn bộ tin nhắn sẽ bị xóa vĩnh viễn ở cả 2 bên.")
                </div>
                <div class="pm-confirm-actions">
                    <button type="button" class="pm-confirm-btn secondary" disabled="@_clearHistoryBusy" @onclick="CloseClearHistoryConfirmAsync">Hủy</button>
                    <button type="button" class="pm-confirm-btn danger" disabled="@_clearHistoryBusy" @onclick="ConfirmClearHistoryAsync">Xóa</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showLeaveGroupConfirm && GroupId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseLeaveGroupConfirmAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-xs" @onclick:stopPropagation="true">
            <div class="pm-confirm-panel">
                <div class="pm-confirm-title">Rời nhóm?</div>
                <div class="pm-confirm-text">Bạn có chắc chắn muốn rời nhóm này không?</div>
                <div class="pm-confirm-actions">
                    <button type="button" class="pm-confirm-btn secondary" disabled="@_leaveGroupBusy" @onclick="CloseLeaveGroupConfirmAsync">Hủy bỏ</button>
                    <button type="button" class="pm-confirm-btn danger" disabled="@_leaveGroupBusy" @onclick="ConfirmLeaveGroupAsync">Rời nhóm</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDissolveGroupConfirm && GroupId.HasValue)
{
    <div class="pm-chat-dialog-backdrop" @onclick="CloseDissolveGroupConfirmAsync">
        <div class="pm-chat-dialog-shell pm-chat-dialog-xs" @onclick:stopPropagation="true">
            <div class="pm-confirm-panel">
                <div class="pm-confirm-title">Giải tán nhóm?</div>
                <div class="pm-confirm-text">Bạn có chắc chắn muốn giải tán nhóm này không? Hành động này không thể hoàn tác.</div>
                <div class="pm-confirm-actions">
                    <button type="button" class="pm-confirm-btn secondary" disabled="@_dissolveGroupBusy" @onclick="CloseDissolveGroupConfirmAsync">Hủy bỏ</button>
                    <button type="button" class="pm-confirm-btn danger" disabled="@_dissolveGroupBusy" @onclick="ConfirmDissolveGroupAsync">Giải tán</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .pm-chat-dialog-backdrop {
        position: fixed;
        inset: 0;
        z-index: 7000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(15, 23, 42, .48);
    }

    .pm-chat-dialog-shell {
        width: min(100%, 560px);
        max-height: min(90vh, 720px);
        overflow: hidden;
        border-radius: 14px;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
