    private void ResetSearchState()
    {
        _searchResults.Clear();
        _searchIndex = -1;
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SearchInCurrentChatAsync();
    }

    private async Task SearchInCurrentChatAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
            return;

        _searching = true;

        try
        {
            var results = await SearchService.SearchMessagesInConversationAsync(
                _searchTerm, PeerId, GroupId, 50);

            _searchResults = results ?? new List<MessageSearchResult>();

            if (!_searchResults.Any())
            {
                _searchIndex = -1;
                Snackbar.Add("Không tìm thấy tin nhắn phù hợp.", Severity.Info);
                return;
            }

            _searchIndex = 0;
            await JumpToCurrentSearchResultAsync();
        }
        finally
        {
            _searching = false;
        }
    }

    private async Task NextSearchResultAsync()
    {
        if (!_searchResults.Any())
            return;

        _searchIndex = (_searchIndex + 1) % _searchResults.Count;
        await JumpToCurrentSearchResultAsync();
    }

    private async Task PreviousSearchResultAsync()
    {
        if (!_searchResults.Any())
            return;

        _searchIndex = _searchIndex <= 0 ? _searchResults.Count - 1 : _searchIndex - 1;
        await JumpToCurrentSearchResultAsync();
    }

    private async Task JumpToCurrentSearchResultAsync()
    {
        if (_msgList == null || _searchIndex < 0 || _searchIndex >= _searchResults.Count)
            return;

        await _msgList.ScrollToMessageAsync(_searchResults[_searchIndex].Id);
    }

    private async Task LoadChatInfoAsync(int? expectedPeerId = null, int? expectedGroupId = null)
    {
        expectedPeerId ??= PeerId;
        expectedGroupId ??= GroupId;

        if (expectedPeerId.HasValue)
        {
            var user = await ConvService.GetUserAsync(expectedPeerId.Value);
            if (PeerId != expectedPeerId || GroupId != expectedGroupId)
                return;

            _chatTitle = _peerTitleOverrides.TryGetValue(expectedPeerId.Value, out var titleOverride)
                ? titleOverride
                : user?.DisplayName ?? "Người dùng";
            _chatAvatarUrl = user?.AvatarUrl;
            _onlineStatus = user?.IsOnline;
            await RefreshBlockStatusAsync(expectedPeerId.Value);
            _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        }
        else if (expectedGroupId.HasValue)
        {
            var group = await ConvService.GetGroupAsync(expectedGroupId.Value);
            if (PeerId != expectedPeerId || GroupId != expectedGroupId)
                return;

            _chatTitle = group?.Name ?? Loc.T("chat.groupLabel");
            _chatAvatarUrl = group?.AvatarUrl;
            _onlineStatus = null;
            _currentGroupRole = group?.Members
                .FirstOrDefault(m => m.UserId == CurrentUserId)
                ?.Role;
            _groupAccessRevoked = group is null || string.IsNullOrWhiteSpace(_currentGroupRole);
            _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        }

        StateHasChanged();
    }

