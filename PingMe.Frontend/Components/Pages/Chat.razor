    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += HandleLanguageChanged;
        await Loc.LoadAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                      ?? authState.User.FindFirst("sub")?.Value;

        CurrentUserId = int.TryParse(idClaim, out var id) ? id : 0;

        await Hub.StartAsync();

        Hub.OnMessageReceived += HandleIncomingMessage;
        Hub.OnUserTyping += HandleTyping;
        Hub.OnUserStatusChanged += HandleStatusChanged;
        Hub.OnGroupMemberAdded += HandleGroupMemberAdded;
        Hub.OnGroupMemberKicked += HandleGroupMemberKicked;
        Hub.OnUserMentioned += HandleUserMentionedAsync;
    }

    protected override Task OnParametersSetAsync()
    {
        if (_lastPeerId == PeerId && _lastGroupId == GroupId)
            return Task.CompletedTask;

        _lastPeerId = PeerId;
        _lastGroupId = GroupId;

        ResetSearchState();
        _searchOpen = false;
        _pinPanelOpen = false;
        _moreMenuOpen = false;
        CloseHeaderDialogs();
        _currentGroupRole = null;
        _isPeerBlockedByMe = false;
