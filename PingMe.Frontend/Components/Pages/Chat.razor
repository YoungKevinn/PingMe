    private void HandleIncomingMessage(MessageResponse message)
    {
        var isDueReminder = TryGetDueReminderAlarm(message, out var reminderAlarm);

        if (message.SenderId == CurrentUserId && !isDueReminder)
            return;

        var isCurrentConversation = IsCurrentConversation(message);

        _ = InvokeAsync(async () =>
        {
            if (isDueReminder && _reminderAlarmMessageIds.Add(message.Id))
            {
                EnqueueReminderAlarm(reminderAlarm);
                Snackbar.Add($"⏰ Nhắc việc: {reminderAlarm.Text}", Severity.Warning);
                await PlayReminderSoundAsync();
                await SetReminderTitleAlertAsync(true);
            }

            if (_convList != null)
                await _convList.ApplyIncomingMessageAsync(message, isCurrentConversation);
        });
    }

    private Task HandleUserMentionedAsync(System.Text.Json.JsonElement data)
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                if (!data.TryGetProperty("mentionedUserId", out var mentionedUserElement) ||
                    mentionedUserElement.ValueKind != System.Text.Json.JsonValueKind.Number ||
                    mentionedUserElement.GetInt32() != CurrentUserId)
                {
                    return;
                }

                if (!data.TryGetProperty("groupId", out var groupElement) ||
                    groupElement.ValueKind != System.Text.Json.JsonValueKind.Number ||
                    !data.TryGetProperty("messageId", out var messageElement) ||
                    messageElement.ValueKind != System.Text.Json.JsonValueKind.Number)
                {
                    return;
                }

                var groupId = groupElement.GetInt32();
                var messageId = messageElement.GetInt32();
                var isCurrentConversation = GroupId == groupId;
                string? senderDisplayName = null;

                if (data.TryGetProperty("senderDisplayName", out var senderNameElement) &&
                    senderNameElement.ValueKind == System.Text.Json.JsonValueKind.String)
                {
                    senderDisplayName = senderNameElement.GetString();
                }

                if (_convList != null)
                    await _convList.MarkGroupMentionedAsync(groupId, messageId, isCurrentConversation, senderDisplayName);
            }
            catch
            {
            }
        });

        return Task.CompletedTask;
    }

    private void HandleGroupMemberAdded(GroupMemberAddedEvent data)
    {
        _ = InvokeAsync(async () =>
        {
            if (data.UserId == CurrentUserId)
            {
                await Hub.JoinGroupRoomAsync(data.GroupId);
                Snackbar.Add("Bạn đã được thêm vào nhóm.", Severity.Info);
            }

            if (GroupId == data.GroupId)
                await LoadChatInfoAsync(PeerId, GroupId);

            if (_convList != null)
                await _convList.RefreshAsync();

            StateHasChanged();
        });
    }

    private void HandleGroupMemberKicked(GroupMemberKickedEvent data)
    {
        if (data.UserId != CurrentUserId)
            return;

        _ = InvokeAsync(async () =>
        {
            await Hub.LeaveGroupRoomAsync(data.GroupId);

            if (GroupId == data.GroupId)
            {
                _groupAccessRevoked = true;
                _replyTo = null;
                _showGroupMembersDialog = false;
                _showAddMemberDialog = false;
                _showEditGroupDialog = false;
                if (_msgList != null)
                    await _msgList.ClearCurrentCacheAsync();
                Snackbar.Add(data.Message ?? "Bạn đã bị xóa khỏi nhóm này.", Severity.Warning);
                StateHasChanged();
            }

            if (_convList != null)
                await _convList.RefreshAsync();
        });
    }

    private bool IsCurrentConversation(MessageResponse message)
    {
        return (GroupId.HasValue && message.GroupId == GroupId.Value) ||
               (PeerId.HasValue &&
                message.GroupId == null &&
                ((message.SenderId == CurrentUserId && message.ReceiverId == PeerId.Value) ||
                 (message.SenderId == PeerId.Value && message.ReceiverId == CurrentUserId)));
    }

    private bool TryGetDueReminderAlarm(MessageResponse message, out ReminderAlarmModel alarm)
    {
        alarm = new ReminderAlarmModel();

        if (!string.Equals(message.MessageType, "Reminder", StringComparison.OrdinalIgnoreCase) ||
            string.IsNullOrWhiteSpace(message.Content))
        {
            return false;
        }

        try
        {
            using var doc = JsonDocument.Parse(message.Content);
            var root = doc.RootElement;

            if (!TryGetStringProperty(root, "status", out var status) ||
                !string.Equals(status, "Sent", StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }

            var groupId = GetIntProperty(root, "groupId") ?? message.GroupId;
            var peerUserId = GetIntProperty(root, "peerUserId");

            if (!groupId.HasValue)
            {
                peerUserId = message.SenderId == CurrentUserId
                    ? message.ReceiverId ?? peerUserId
                    : message.SenderId;
            }

            alarm = new ReminderAlarmModel
            {
                MessageId = message.Id,
                Text = TryGetStringProperty(root, "text", out var text) && !string.IsNullOrWhiteSpace(text)
                    ? text!
                    : "nhắc việc",
                DueAt = GetDateTimeProperty(root, "remindAtUtc"),
                GroupId = groupId,
                PeerUserId = peerUserId
            };

            alarm.ConversationTitle = ResolveReminderConversationTitle(alarm);

            return true;
        }
        catch
        {
            return false;
        }
    }

    private void EnqueueReminderAlarm(ReminderAlarmModel alarm)
    {
        alarm.ConversationTitle ??= ResolveReminderConversationTitle(alarm);
        _reminderAlarmQueue.Enqueue(alarm);

        if (_activeReminderAlarm is null)
            ShowNextReminderAlarm();

        StateHasChanged();
    }

    private void ShowNextReminderAlarm()
    {
        _activeReminderAlarm = _reminderAlarmQueue.TryDequeue(out var next)
            ? next
            : null;
        _shouldFocusReminderAlarm = _activeReminderAlarm is not null;
    }

    private async Task DismissReminderAlarmAsync()
    {
        ShowNextReminderAlarm();

        if (_activeReminderAlarm is null)
            await SetReminderTitleAlertAsync(false);

        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenReminderConversationAsync()
    {
        var alarm = _activeReminderAlarm;
        if (alarm is null)
            return;

        var isCurrentConversation =
            (alarm.GroupId.HasValue && GroupId == alarm.GroupId.Value) ||
            (alarm.PeerUserId.HasValue && PeerId == alarm.PeerUserId.Value);

        await DismissReminderAlarmAsync();

        if (isCurrentConversation)
            return;

        if (alarm.GroupId.HasValue)
            Nav.NavigateTo($"/chat/group/{alarm.GroupId.Value}");
        else if (alarm.PeerUserId.HasValue && alarm.PeerUserId.Value != CurrentUserId)
            Nav.NavigateTo($"/chat/{alarm.PeerUserId.Value}");
    }

