    {
        public int MessageId { get; set; }
        public string Text { get; set; } = string.Empty;
        public DateTime? DueAt { get; set; }
        public int? GroupId { get; set; }
        public int? PeerUserId { get; set; }
        public string? ConversationTitle { get; set; }
    }
