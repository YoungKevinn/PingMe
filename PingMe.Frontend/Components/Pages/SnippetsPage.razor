@code {
    private const string AllLanguagesValue = "all";

    private List<SnippetResponse> _snippets = new();
    private bool _loading = true;

    private bool _createOpen;
    private bool _editOpen;
    private bool _viewOpen;
    private bool _fullScreenOpen;

    private bool _filterLanguageOpen;
    private bool _createLanguageOpen;
    private bool _editLanguageOpen;

    private string _snippetSearch = "";
    private string _languageFilter = AllLanguagesValue;

    private CreateSnippetRequest _newSnippet = new()
    {
        Language = "csharp",
        ExpirationOption = "never"
    };

    private UpdateSnippetRequest _editSnippet = new()
    {
        Language = "plaintext"
    };

    private int? _editingSnippetId;
    private SnippetResponse? _viewingSnippet;
    private SnippetResponse? _fullScreenSnippet;

    private readonly string[] _languages =
    {
        "csharp", "javascript", "typescript", "python", "java",
        "cpp", "go", "rust", "sql", "html", "css", "bash", "powershell",
        "yaml", "json", "markdown", "plaintext"
    };

    private readonly (string Value, string Label)[] _expirationOptions =
    {
        ("never", "♾ Không hết hạn"),
        ("1h",    "⏱ 1 giờ"),
        ("1d",    "📅 1 ngày"),
        ("7d",    "🗓 7 ngày"),
        ("30d",   "📆 30 ngày"),
    };

    private IEnumerable<SnippetResponse> FilteredSnippets =>
        _snippets
            .Where(s =>
                string.IsNullOrWhiteSpace(_snippetSearch)
                || (s.Title?.Contains(_snippetSearch, StringComparison.OrdinalIgnoreCase) == true)
                || (s.Content?.Contains(_snippetSearch, StringComparison.OrdinalIgnoreCase) == true)
                || (s.Language?.Contains(_snippetSearch, StringComparison.OrdinalIgnoreCase) == true))
            .Where(s =>
                _languageFilter == AllLanguagesValue
                || string.Equals(s.Language, _languageFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += StateHasChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        Loc.OnLanguageChanged -= StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await JS.InvokeVoidAsync("pingmeHighlight");
        }
        catch
        {
            // Ignore JS errors during initial loading/hot reload.
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;

        try
        {
            _snippets = await SnippetService.GetMySnippetsAsync() ?? new();
        }
        catch
        {
            _snippets = new();
            Snackbar.Add("Không thể tải danh sách snippet.", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenCreateDialog()
    {
        _newSnippet = new CreateSnippetRequest
        {
            Language = "csharp",
            ExpirationOption = "never"
        };

        CloseAllDropdowns();
        _createOpen = true;
    }

    private void CloseCreateDialog()
    {
        _createOpen = false;
        _createLanguageOpen = false;

        _newSnippet = new CreateSnippetRequest
        {
            Language = "csharp",
            ExpirationOption = "never"
        };

        StateHasChanged();
    }

    private void OpenEditDialog(SnippetResponse snippet)
    {
        _editingSnippetId = snippet.Id;

        _editSnippet = new UpdateSnippetRequest
        {
            Title = snippet.Title,
            Language = NormalizeLanguage(snippet.Language),
            Content = GetDisplayCode(snippet.Content),
            ExpirationOption = null
        };

        CloseAllDropdowns();
        _editOpen = true;
    }

    private void CloseEditDialog()
    {
        _editOpen = false;
        _editLanguageOpen = false;
        _editingSnippetId = null;

        _editSnippet = new UpdateSnippetRequest
        {
            Language = "plaintext"
        };

        StateHasChanged();
    }

    private void ViewSnippet(SnippetResponse snippet)
    {
        _viewingSnippet = snippet;
        CloseAllDropdowns();
        _viewOpen = true;
    }

    private void CloseViewDialog()
    {
        _viewOpen = false;
        _viewingSnippet = null;
        StateHasChanged();
    }

    private async Task OpenFullScreen(SnippetResponse snippet)
    {
        _fullScreenSnippet = snippet;
        _fullScreenOpen = false;

        CloseAllDropdowns();

        try
        {
            await JS.InvokeVoidAsync(
                "pingmeSnippetFullscreen.open",
                snippet.Title ?? "Code snippet",
                snippet.Language ?? "plaintext",
                snippet.Content ?? string.Empty);
        }
        catch (JSException)
        {
            _fullScreenOpen = true;
            StateHasChanged();
        }
    }

    private async Task CloseFullScreen()
    {
        _fullScreenOpen = false;
        _fullScreenSnippet = null;

        await JS.InvokeVoidAsync("pingmeSnippetFullscreen.close");
        StateHasChanged();
    }

    private void ToggleFilterLanguageDropdown()
    {
        _filterLanguageOpen = !_filterLanguageOpen;
        _createLanguageOpen = false;
        _editLanguageOpen = false;
    }

    private void SetLanguageFilter(string language)
    {
        _languageFilter = language;
        _filterLanguageOpen = false;
    }

    private void ToggleCreateLanguageDropdown()
    {
        _createLanguageOpen = !_createLanguageOpen;
        _filterLanguageOpen = false;
        _editLanguageOpen = false;
    }

    private void SetNewSnippetLanguage(string language)
    {
        _newSnippet.Language = language;
        _createLanguageOpen = false;
    }

    private void ToggleEditLanguageDropdown()
    {
        _editLanguageOpen = !_editLanguageOpen;
        _filterLanguageOpen = false;
        _createLanguageOpen = false;
    }

    private void SetEditSnippetLanguage(string language)
    {
        _editSnippet.Language = language;
        _editLanguageOpen = false;
    }

    private void SetNewSnippetExpiration(string option)
    {
        _newSnippet.ExpirationOption = option;
    }

    private void CloseAllDropdowns()
    {
        _filterLanguageOpen = false;
        _createLanguageOpen = false;
        _editLanguageOpen = false;
    }

    private string GetLanguageLabel(string? language)
    {
        if (string.IsNullOrWhiteSpace(language) || language == AllLanguagesValue)
            return "Tất cả ngôn ngữ";

        return language;
    }

    private string GetLanguageFilterItemClass(string language)
    {
        return string.Equals(_languageFilter, language, StringComparison.OrdinalIgnoreCase)
            ? "pm-custom-select-item active"
            : "pm-custom-select-item";
    }

    private string GetCreateLanguageItemClass(string language)
    {
        return string.Equals(_newSnippet.Language, language, StringComparison.OrdinalIgnoreCase)
            ? "pm-custom-select-item active"
            : "pm-custom-select-item";
    }

    private string GetEditLanguageItemClass(string language)
    {
        return string.Equals(_editSnippet.Language, language, StringComparison.OrdinalIgnoreCase)
            ? "pm-custom-select-item active"
            : "pm-custom-select-item";
    }

    private string GetExpirationButtonClass(string option)
    {
        return string.Equals(_newSnippet.ExpirationOption, option, StringComparison.OrdinalIgnoreCase)
            ? "pm-expiry-btn active"
            : "pm-expiry-btn";
    }

    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newSnippet.Content))
        {
            Snackbar.Add("Vui lòng nhập code.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newSnippet.Language))
        {
            _newSnippet.Language = "plaintext";
        }

        if (string.IsNullOrWhiteSpace(_newSnippet.Title))
        {
            _newSnippet.Title = $"{_newSnippet.Language} snippet - {DateTime.Now:HH:mm dd/MM}";
        }

        var clean = StripMarkdownCodeFence(_newSnippet.Content);

        if (!string.IsNullOrWhiteSpace(clean.Language))
        {
            _newSnippet.Language = NormalizeLanguage(clean.Language);
        }

        _newSnippet.Content = clean.Content;

        var result = await SnippetService.CreateSnippetAsync(_newSnippet);

        if (result != null)
        {
            Snackbar.Add("Tạo snippet thành công.", Severity.Success);
            CloseCreateDialog();
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Tạo snippet thất bại.", Severity.Error);
        }
    }

    private async Task UpdateAsync()
    {
        if (!_editingSnippetId.HasValue)
        {
            Snackbar.Add("Không xác định được snippet cần sửa.", Severity.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editSnippet.Content))
        {
            Snackbar.Add("Vui lòng nhập code.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_editSnippet.Language))
        {
            _editSnippet.Language = "plaintext";
        }

        var clean = StripMarkdownCodeFence(_editSnippet.Content);

        if (!string.IsNullOrWhiteSpace(clean.Language))
        {
            _editSnippet.Language = NormalizeLanguage(clean.Language);
        }

        _editSnippet.Content = clean.Content;

        var result = await SnippetService.UpdateSnippetAsync(_editingSnippetId.Value, _editSnippet);

        if (result.Snippet != null)
        {
            Snackbar.Add("Đã cập nhật snippet.", Severity.Success);
            CloseEditDialog();
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error ?? "Cập nhật snippet thất bại.", Severity.Error);
        }
    }

    private async Task DeleteAsync(int id)
    {
        var ok = await SnippetService.DeleteSnippetAsync(id);

        if (ok)
        {
            Snackbar.Add("Đã xóa snippet.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add("Xóa snippet thất bại.", Severity.Error);
        }
    }

    private async Task RevokeAsync(int id)
    {
        var result = await SnippetService.RevokeSnippetAsync(id);

        if (result.Success)
        {
            Snackbar.Add("Đã thu hồi link chia sẻ. Snippet vẫn còn trong kho của bạn.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error ?? "Không thể thu hồi snippet.", Severity.Error);
        }
    }

    private async Task RestoreAsync(int id)
    {
        var result = await SnippetService.RestoreSnippetAsync(id);

        if (result.Success)
        {
            Snackbar.Add("Đã khôi phục link chia sẻ.", Severity.Success);
            await LoadAsync();
        }
        else
        {
            Snackbar.Add(result.Error ?? "Không thể khôi phục link chia sẻ.", Severity.Error);
        }
    }

    private async Task CopyViewingSnippetCode()
    {
        if (_viewingSnippet == null)
            return;

        await CopyCode(_viewingSnippet.Content);
    }

    private async Task CopyCode(string? code)
    {
        var cleanCode = GetDisplayCode(code);

        if (string.IsNullOrWhiteSpace(cleanCode))
        {
            Snackbar.Add("Không có code để copy.", Severity.Warning);
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", cleanCode);
        Snackbar.Add("Đã copy code.", Severity.Success);
    }

    private async Task CopyShareLink(SnippetResponse snippet)
    {
        if (string.IsNullOrWhiteSpace(snippet.ShareToken))
        {
            Snackbar.Add("Snippet này chưa có link chia sẻ.", Severity.Warning);
            return;
        }

        var url = $"{Nav.BaseUri}snippets/share/{snippet.ShareToken}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);

        Snackbar.Add("Đã copy link chia sẻ.", Severity.Success);
    }

    private static string PreviewCode(string? code)
    {
        var clean = GetDisplayCode(code);

        if (string.IsNullOrWhiteSpace(clean))
            return string.Empty;

        return clean.Length > 300 ? clean[..300] + "..." : clean;
    }

    private static string GetDisplayCode(string? code)
    {
        return StripMarkdownCodeFence(code).Content;
    }

    private static (string Content, string? Language) StripMarkdownCodeFence(string? input)
    {
        var content = input?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(content))
            return (string.Empty, null);

        var match = System.Text.RegularExpressions.Regex.Match(
            content,
            @"^\s*```(?<lang>[a-zA-Z0-9#+\-.]*)\s*\r?\n(?<code>[\s\S]*?)\r?\n?```\s*$",
            System.Text.RegularExpressions.RegexOptions.Multiline);

        if (!match.Success)
            return (content, null);

        var language = match.Groups["lang"].Value.Trim();
        var code = match.Groups["code"].Value.Trim('\r', '\n');

        return (code, string.IsNullOrWhiteSpace(language) ? null : language);
    }

    private static string NormalizeLanguage(string? language)
    {
        if (string.IsNullOrWhiteSpace(language))
            return "plaintext";

        return language.Trim().ToLowerInvariant() switch
        {
            "c#" => "csharp",
            "cs" => "csharp",
            "js" => "javascript",
            "ts" => "typescript",
            "py" => "python",
            "sh" => "bash",
            "shell" => "bash",
            "ps" => "powershell",
            "ps1" => "powershell",
            "md" => "markdown",
            "yml" => "yaml",
            "html" => "html",
            "plain" => "plaintext",
            "text" => "plaintext",
            var value => value
        };
    }

    private static string NormalizeHighlightLanguage(string? language)
    {
        return NormalizeLanguage(language) switch
        {
            "html" => "xml",
            var value => value
        };
    }
}
