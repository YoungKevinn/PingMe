@page "/snippets"
@attribute [Authorize]
@implements IDisposable
@using PingMe.Frontend.Models
@using PingMe.Frontend.Services
@inject SnippetService SnippetService
@inject LocalizationService Loc
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h5" Class="font-weight-bold">💻 @Loc.T("snippets.title")</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @Loc.T("snippets.subtitle")
            </MudText>
        </div>

        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="@OpenCreateDialog">
            @Loc.T("snippets.createBtn")
        </MudButton>
    </div>

    <MudPaper Class="pa-3 mb-4" Outlined="true">
        <div class="pm-snippet-filter-row">
            <MudTextField @bind-Value="_snippetSearch"
                          Placeholder="@Loc.T("snippets.searchPlaceholder")"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Margin="Margin.Dense"
                          Style="flex:1;" />

            <div class="pm-custom-select">
                <button type="button"
                        class="pm-custom-select-button"
                        @onclick="@ToggleFilterLanguageDropdown">
                    <span>@GetLanguageLabel(_languageFilter)</span>
                    <span class="pm-select-arrow">▾</span>
                </button>

                @if (_filterLanguageOpen)
                {
                    <div class="pm-custom-select-menu">
                        <button type="button"
                                class="@GetLanguageFilterItemClass(AllLanguagesValue)"
                                @onclick="@(() => SetLanguageFilter(AllLanguagesValue))">
                            @Loc.T("snippets.allLanguages")
                        </button>

                        @foreach (var lang in _languages)
                        {
                            var language = lang;

                            <button type="button"
                                    class="@GetLanguageFilterItemClass(language)"
                                    @onclick="@(() => SetLanguageFilter(language))">
                                @language
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </MudPaper>

    @if (_loading)
    {
        <div style="display:flex;justify-content:center;padding:48px;">
            <MudProgressCircular Indeterminate Color="Color.Primary" />
        </div>
    }
    else if (!_snippets.Any())
    {
        <MudAlert Severity="Severity.Info">
            @Loc.T("snippets.empty")
        </MudAlert>
    }
    else if (!FilteredSnippets.Any())
    {
        <MudAlert Severity="Severity.Warning">
            @Loc.T("snippets.noFilterResults")
        </MudAlert>
    }
    else
    {
        <MudGrid>
            @foreach (var s in FilteredSnippets)
            {
                var snippet = s;

                <MudItem xs="12" md="6">
                    <MudCard @key="snippet.Id" Outlined="true" Class="pm-snippet-card">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <div class="d-flex align-center gap-2 flex-wrap">
                                    <MudChip Size="Size.Small" Color="Color.Primary">
                                        @snippet.Language
                                    </MudChip>

                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">
                                        @(string.IsNullOrWhiteSpace(snippet.Title) ? Loc.T("snippets.noTitle") : snippet.Title)
                                    </MudText>

                                    @if (snippet.IsRevoked)
                                    {
                                        <span class="pm-snippet-badge revoked">🔒 @Loc.T("snippets.revoked")</span>
                                    }
                                    else if (snippet.IsExpired)
                                    {
                                        <span class="pm-snippet-badge expired">⏰ @Loc.T("snippets.expired")</span>
                                    }
                                    else if (snippet.ExpiresAt.HasValue)
                                    {
                                        <span class="pm-snippet-badge expiring">⏳ @snippet.ExpiryLabel</span>
                                    }
                                    else
                                    {
                                        <span class="pm-snippet-badge active">♾ @Loc.T("snippets.noExpiry")</span>
                                    }
                                </div>

                                <div class="d-flex align-center gap-2 mt-1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @snippet.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </MudText>

                                    @if (snippet.AccessCount > 0)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            · 👁 @string.Format(Loc.T("snippets.views"), snippet.AccessCount)
                                        </MudText>
                                    }
                                </div>
                            </CardHeaderContent>
                        </MudCardHeader>

                        <MudCardContent Style="max-height:170px;overflow:hidden;">
                            <pre class="pm-code-preview"><code class="@($"language-{NormalizeHighlightLanguage(snippet.Language)}")">@PreviewCode(snippet.Content)</code></pre>
                        </MudCardContent>

                        <MudCardActions>
                            <MudTooltip Text="@Loc.T("snippets.copyLink")">
                                <MudIconButton Icon="@Icons.Material.Filled.Share"
                                               Color="Color.Primary"
                                               OnClick="@(() => CopyShareLink(snippet))" />
                            </MudTooltip>

                            <MudTooltip Text="@Loc.T("snippets.copyCode")">
                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                               Color="Color.Primary"
                                               OnClick="@(() => CopyCode(snippet.Content))" />
                            </MudTooltip>

                            <MudTooltip Text="@Loc.T("snippets.edit")">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Color="Color.Info"
                                               OnClick="@(() => OpenEditDialog(snippet))" />
                            </MudTooltip>

                            <MudTooltip Text="@Loc.T("snippets.viewFull")">
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                               Color="Color.Primary"
                                               OnClick="@(() => ViewSnippet(snippet))" />
                            </MudTooltip>

                            <MudTooltip Text="@Loc.T("snippets.fullscreen")">
                                <MudIconButton Icon="@Icons.Material.Filled.OpenInFull"
                                               Color="Color.Primary"
                                               OnClick="@(() => OpenFullScreen(snippet))" />
                            </MudTooltip>

                            <MudSpacer />

                            @if (snippet.IsRevoked)
                            {
                                <MudTooltip Text="@Loc.T("snippets.restoreLink")">
                                    <MudIconButton Icon="@Icons.Material.Filled.Restore"
                                                   Color="Color.Success"
                                                   OnClick="@(() => RestoreAsync(snippet.Id))" />
                                </MudTooltip>
                            }
                            else if (snippet.IsActive)
                            {
                                <MudTooltip Text="@Loc.T("snippets.revokeLink")">
                                    <MudIconButton Icon="@Icons.Material.Filled.LinkOff"
                                                   Color="Color.Warning"
                                                   OnClick="@(() => RevokeAsync(snippet.Id))" />
                                </MudTooltip>
                            }

                            <MudTooltip Text="@Loc.T("snippets.delete")">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteAsync(snippet.Id))" />
                            </MudTooltip>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>

@if (_createOpen)
{
    <div class="pm-modal-backdrop" @onclick="@CloseCreateDialog">
        <div class="pm-modal-card pm-snippet-modal" @onclick:stopPropagation="true">
            <div class="pm-modal-header">
                <div>
                    <MudText Typo="Typo.h6">@Loc.T("snippets.createTitleModal")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @Loc.T("snippets.createSubtitleModal")
                    </MudText>
                </div>

                <button type="button" class="pm-modal-x" @onclick="@CloseCreateDialog">
                    ×
                </button>
            </div>

            <div class="pm-modal-body">
                <MudTextField @bind-Value="_newSnippet.Title"
                              Label="@Loc.T("snippets.titleLabel")"
                              Variant="Variant.Outlined"
                              HelperText="@Loc.T("snippets.titleHelper")"
                              Immediate="true"
                              Class="mb-3" />

                <div class="pm-form-label">@Loc.T("snippets.languageLabel")</div>

                <div class="pm-custom-select pm-custom-select-full">
                    <button type="button"
                            class="pm-custom-select-button"
                            @onclick="@ToggleCreateLanguageDropdown">
                        <span>@GetLanguageLabel(_newSnippet.Language)</span>
                        <span class="pm-select-arrow">▾</span>
                    </button>

                    @if (_createLanguageOpen)
                    {
                        <div class="pm-custom-select-menu">
                            @foreach (var lang in _languages)
                            {
                                var language = lang;

                                <button type="button"
                                        class="@GetCreateLanguageItemClass(language)"
                                        @onclick="@(() => SetNewSnippetLanguage(language))">
                                    @language
                                </button>
                            }
                        </div>
                    }
                </div>

                <MudTextField @bind-Value="_newSnippet.Content"
                              Label="@Loc.T("snippets.codeLabel")"
                              Variant="Variant.Outlined"
                              Lines="12"
                              Immediate="true"
                              Style="font-family:'Fira Code',Consolas,monospace;"
                              Required="true"
                              Class="mt-3"
                              HelperText="@Loc.T("snippets.codeHelper")" />

                <div class="pm-form-label mt-3">@Loc.T("snippets.expiryLabel")</div>

                <div class="pm-expiry-options">
                    @foreach (var opt in _expirationOptions)
                    {
                        var optVal = opt.Value;

                        <button type="button"
                                class="@GetExpirationButtonClass(optVal)"
                                @onclick="@(() => SetNewSnippetExpiration(optVal))">
                            @opt.Label
                        </button>
                    }
                </div>
            </div>

            <div class="pm-modal-actions">
                <MudButton ButtonType="ButtonType.Button" OnClick="@CloseCreateDialog">
                    @Loc.T("snippets.cancel")
                </MudButton>

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="@CreateAsync"
                           Disabled="@string.IsNullOrWhiteSpace(_newSnippet.Content)">
                    @Loc.T("snippets.create")
                </MudButton>
            </div>
        </div>
    </div>
}

@if (_editOpen)
{
    <div class="pm-modal-backdrop" @onclick="@CloseEditDialog">
        <div class="pm-modal-card pm-snippet-modal" @onclick:stopPropagation="true">
            <div class="pm-modal-header">
                <div>
                    <MudText Typo="Typo.h6">@Loc.T("snippets.editTitleModal")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @Loc.T("snippets.editSubtitleModal")
                    </MudText>
                </div>

                <button type="button" class="pm-modal-x" @onclick="@CloseEditDialog">
                    ×
                </button>
            </div>

            <div class="pm-modal-body">
                <MudTextField @bind-Value="_editSnippet.Title"
                              Label="@Loc.T("snippets.titleLabel")"
                              Variant="Variant.Outlined"
                              Immediate="true"
                              Class="mb-3" />

                <div class="pm-form-label">@Loc.T("snippets.languageLabel")</div>

                <div class="pm-custom-select pm-custom-select-full">
                    <button type="button"
                            class="pm-custom-select-button"
                            @onclick="@ToggleEditLanguageDropdown">
                        <span>@GetLanguageLabel(_editSnippet.Language)</span>
                        <span class="pm-select-arrow">▾</span>
                    </button>

                    @if (_editLanguageOpen)
                    {
                        <div class="pm-custom-select-menu">
                            @foreach (var lang in _languages)
                            {
                                var language = lang;

                                <button type="button"
                                        class="@GetEditLanguageItemClass(language)"
                                        @onclick="@(() => SetEditSnippetLanguage(language))">
                                    @language
                                </button>
                            }
                        </div>
                    }
                </div>

                <MudTextField @bind-Value="_editSnippet.Content"
                              Label="@Loc.T("snippets.codeLabel")"
                              Variant="Variant.Outlined"
                              Lines="15"
                              Immediate="true"
                              Style="font-family:'Fira Code',Consolas,monospace;"
                              Required="true"
                              Class="mt-3"
                              HelperText="@Loc.T("snippets.codeHelper")" />
            </div>

            <div class="pm-modal-actions">
                <MudButton ButtonType="ButtonType.Button" OnClick="@CloseEditDialog">
                    @Loc.T("snippets.cancel")
                </MudButton>

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           OnClick="@UpdateAsync"
                           Disabled="@string.IsNullOrWhiteSpace(_editSnippet.Content)">
                    @Loc.T("snippets.saveChanges")
                </MudButton>
            </div>
        </div>
    </div>
}

@if (_viewOpen)
{
    <div class="pm-modal-backdrop" @onclick="@CloseViewDialog">
        <div class="pm-modal-card pm-view-modal" @onclick:stopPropagation="true">
            <div class="pm-modal-header">
                <div>
                    <MudText Typo="Typo.h6">@(_viewingSnippet?.Title ?? "Snippet")</MudText>

                    @if (_viewingSnippet != null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_viewingSnippet.Language
                        </MudText>
                    }
                </div>

                <button type="button" class="pm-modal-x" @onclick="@CloseViewDialog">
                    ×
                </button>
            </div>

            <div class="pm-modal-body">
                @if (_viewingSnippet != null)
                {
                    <MudChip Color="Color.Primary" Size="Size.Small">
                        @_viewingSnippet.Language
                    </MudChip>

                    <pre @key="_viewingSnippet.Id" class="pm-code-view"><code class="@($"language-{NormalizeHighlightLanguage(_viewingSnippet.Language)}")">@GetDisplayCode(_viewingSnippet.Content)</code></pre>
                }
            </div>

            <div class="pm-modal-actions">
                <MudButton ButtonType="ButtonType.Button" OnClick="@CloseViewDialog">
                    @Loc.T("snippets.close")
                </MudButton>

                <MudButton Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="@(_viewingSnippet == null)"
                           OnClick="@CopyViewingSnippetCode">
                    @Loc.T("snippets.copyCode")
                </MudButton>
            </div>
        </div>
    </div>
}

@if (_fullScreenOpen && _fullScreenSnippet != null)
{
    <div class="pm-modal-backdrop pm-fullscreen-backdrop pm-snippet-fullscreen-overlay" @onclick="@CloseFullScreen">
        <div class="pm-modal-card pm-fullscreen-modal" @onclick:stopPropagation="true">
            <div class="pm-fullscreen-header">
                <div class="pm-fullscreen-title-wrap">
                    <MudText Typo="Typo.h6" Class="font-weight-bold">
                        @(_fullScreenSnippet.Title ?? "Code snippet")
                    </MudText>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_fullScreenSnippet.Language
                    </MudText>
                </div>

                <div class="pm-fullscreen-actions">
                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               OnClick="@(() => CopyCode(_fullScreenSnippet.Content))">
                        @Loc.T("snippets.copyCode")
                    </MudButton>

                    <button type="button" class="pm-modal-x" @onclick="@CloseFullScreen">
                        ×
                    </button>
                </div>
            </div>

            <div class="pm-fullscreen-body">
                <pre @key="_fullScreenSnippet.Id" class="pm-code-fullscreen"><code class="@($"language-{NormalizeHighlightLanguage(_fullScreenSnippet.Language)}")">@GetDisplayCode(_fullScreenSnippet.Content)</code></pre>
            </div>
        </div>
    </div>
}

<style>
    .pm-snippet-filter-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .pm-snippet-card {
        height: 100%;
        border-radius: 16px;
        overflow: hidden;
    }

    .pm-snippet-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        line-height: 1;
    }

        .pm-snippet-badge.revoked {
            background: rgba(239, 68, 68, .14);
            color: #F87171;
            border: 1px solid rgba(239, 68, 68, .28);
        }

        .pm-snippet-badge.expired {
            background: rgba(245, 158, 11, .14);
            color: #FBBF24;
            border: 1px solid rgba(245, 158, 11, .28);
        }

        .pm-snippet-badge.expiring {
            background: rgba(59, 130, 246, .14);
            color: #60A5FA;
            border: 1px solid rgba(59, 130, 246, .28);
        }

        .pm-snippet-badge.active {
            background: rgba(34, 197, 94, .14);
            color: #4ADE80;
            border: 1px solid rgba(34, 197, 94, .28);
        }

    .pm-code-preview {
        position: relative;
        font-size: 12px;
        line-height: 1.55;
        margin: 0;
        overflow: hidden;
        background: #0B1120;
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 12px;
        font-family: 'Fira Code', Consolas, monospace;
    }

        .pm-code-preview code {
            display: block;
            padding: 14px;
            overflow-x: auto;
            white-space: pre;
            word-break: normal;
            background: transparent;
            min-height: 52px;
        }

    .pm-code-view {
        position: relative;
        font-family: 'Fira Code', Consolas, monospace;
        font-size: 13px;
        line-height: 1.65;
        margin-top: 12px;
        max-height: 420px;
        overflow: auto;
        background: #0B1120;
        color: #E5E7EB;
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 12px;
    }

        .pm-code-view code {
            display: block;
            padding: 14px;
            min-width: max-content;
            white-space: pre;
            word-break: normal;
            background: transparent;
        }

    .pm-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 200000;
        background: rgba(0, 0, 0, .58);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 82px 24px 24px 24px;
    }

    .pm-modal-card {
        width: min(960px, 100%);
        max-height: calc(100vh - 48px);
        overflow: hidden;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 18px;
        box-shadow: 0 24px 80px rgba(0,0,0,.45);
    }

    .pm-snippet-modal {
        max-width: 960px;
    }

    .pm-view-modal {
        max-width: 920px;
    }

    .pm-modal-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 24px 12px;
        flex-shrink: 0;
    }

    .pm-modal-x {
        width: 36px;
        height: 36px;
        border: none;
        border-radius: 999px;
        background: transparent;
        color: var(--mud-palette-text-secondary);
        font-size: 30px;
        line-height: 1;
        cursor: pointer;
        pointer-events: auto;
    }

        .pm-modal-x:hover {
            background: rgba(148, 163, 184, .16);
            color: var(--mud-palette-text-primary);
        }

    .pm-modal-body {
        padding: 8px 24px 16px;
        overflow: auto;
        max-height: calc(100vh - 180px);
    }

    .pm-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        padding: 12px 24px 20px;
        border-top: 1px solid var(--mud-palette-divider);
        flex-shrink: 0;
    }

    .pm-fullscreen-backdrop,
    .pm-snippet-fullscreen-overlay,
    .pm-code-fullscreen-overlay,
    .pm-fullscreen-code-viewer {
        position: fixed !important;
        inset: 0 !important;
        z-index: 30000 !important;
        width: 100vw !important;
        height: 100vh !important;
        max-width: none !important;
        max-height: none !important;
        margin: 0 !important;
        padding: 24px !important;
        background: var(--mud-palette-background) !important;
        overflow: auto !important;
    }

    .pm-fullscreen-modal {
        width: calc(100vw - 48px);
        height: calc(100vh - 48px);
        max-width: none !important;
        max-height: none !important;
        display: flex;
        flex-direction: column;
        background: #020617;
        color: #E5E7EB;
    }

    .pm-fullscreen-header {
        height: 68px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 0 22px;
        background: #0F172A;
        border-bottom: 1px solid rgba(148, 163, 184, .22);
    }

    .pm-fullscreen-title-wrap {
        min-width: 0;
    }

    .pm-fullscreen-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

        .pm-fullscreen-actions .pm-modal-x {
            position: fixed;
            top: 16px;
            right: 16px;
            z-index: 30001;
        }

    .pm-fullscreen-body {
        flex: 1;
        min-height: 0;
        padding: 18px;
        overflow: hidden;
        background: #020617;
    }

    .pm-code-fullscreen {
        position: relative;
        width: 100%;
        height: 100%;
        margin: 0;
        overflow: auto;
        background: #0B1120;
        color: #E5E7EB;
        border: 1px solid rgba(148, 163, 184, .18);
        border-radius: 16px;
        font-family: 'Fira Code', Consolas, monospace;
        font-size: 14px;
        line-height: 1.65;
    }

        .pm-code-fullscreen code {
            display: block;
            min-width: max-content;
            padding: 24px;
            background: transparent;
            white-space: pre;
            word-break: normal;
        }

    .pm-form-label {
        color: var(--mud-palette-text-secondary);
        font-size: 13px;
        margin: 4px 0 6px;
    }

    .pm-custom-select {
        position: relative;
        width: 220px;
        z-index: 20;
    }

    .pm-custom-select-full {
        width: 100%;
    }

    .pm-custom-select-button {
        width: 100%;
        min-height: 40px;
        padding: 0 12px;
        border-radius: 10px;
        border: 1px solid var(--mud-palette-lines-inputs);
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        font-size: 14px;
        text-align: left;
    }

        .pm-custom-select-button:hover {
            border-color: var(--mud-palette-primary);
        }

    .pm-select-arrow {
        opacity: .7;
        margin-left: 8px;
    }

    .pm-custom-select-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        z-index: 30;
        background: var(--mud-palette-surface);
        color: var(--mud-palette-text-primary);
        border: 1px solid var(--mud-palette-divider);
        border-radius: 12px;
        box-shadow: 0 18px 40px rgba(0,0,0,.35);
        padding: 6px;
        max-height: 260px;
        overflow-y: auto;
    }

    .pm-custom-select-item {
        width: 100%;
        border: none;
        background: transparent;
        color: var(--mud-palette-text-primary);
        text-align: left;
        padding: 9px 10px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 14px;
    }

        .pm-custom-select-item:hover {
            background: rgba(59, 130, 246, .14);
            color: var(--mud-palette-primary);
        }

        .pm-custom-select-item.active {
            background: var(--mud-palette-primary);
            color: white;
            font-weight: 700;
        }

    .pm-expiry-options {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
