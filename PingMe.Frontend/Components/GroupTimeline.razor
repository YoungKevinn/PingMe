@using PingMe.Frontend.Models
@using PingMe.Frontend.Services
@inject TimelineService TimelineService
@inject ChatHubService ChatHubService
@inject NavigationManager Nav
@implements IDisposable

<div class="pm-timeline-container">
    <div class="pm-timeline-filters">
        <button class="@(CurrentFilter == null ? "active" : "")" @onclick="() => SetFilter(null)">All</button>
        <button class="@(CurrentFilter == "finding" ? "active" : "")" @onclick='() => SetFilter("finding")'>Findings</button>
        <button class="@(CurrentFilter == "ioc" ? "active" : "")" @onclick='() => SetFilter("ioc")'>IOCs</button>
        <button class="@(CurrentFilter == "task" ? "active" : "")" @onclick='() => SetFilter("task")'>Tasks</button>
        <button class="@(CurrentFilter == "file" ? "active" : "")" @onclick='() => SetFilter("file")'>Files</button>
    </div>

    <div class="pm-timeline-feed">
        <div class="pm-timeline-header">
            🕐 Threat Timeline
        </div>
        
        @if (IsLoading && Events.Count == 0)
        {
            <div class="loading-state">Đang tải...</div>
        }
        else if (Events.Count == 0)
        {
            <div class="empty-state">Chưa có hoạt động nào. Dùng /vuln, /ioc, /task trong group chat để bắt đầu timeline.</div>
        }
        else
        {
            <div class="timeline-list">
                @foreach (var ev in Events)
                {
                    <div class="timeline-item" data-type="@ev.EventType">
                        <div class="timeline-line"></div>
                        <div class="timeline-dot" style="background-color: @GetDotColor(ev.EventType, ev.Severity, ev.Priority)"></div>
                        <div class="timeline-content">
                            <div class="timeline-meta">
                                <span class="timeline-time">[@FormatTime(ev.Timestamp)]</span>
                                <span class="timeline-user">@ev.ActorDisplayName</span>
                            </div>
                            
                            @if (ev.EventType == "finding")
                            {
                                <div class="timeline-body">
                                    <div class="timeline-title">🐛 Pentest Finding — <span class="badge @ev.Severity?.ToLower()">@ev.Severity</span></div>
                                    <div class="timeline-text">@ev.Title</div>
                                    @if (!string.IsNullOrEmpty(ev.Endpoint))
                                    {
                                        <div class="timeline-detail">Endpoint: @ev.Endpoint</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(ev.ActionUrl))
                                    {
                                        <button type="button" class="timeline-link" @onclick="() => OpenAction(ev.ActionUrl)">@(ev.ActionText ?? "Xem Finding")</button>
                                    }
                                </div>
                            }
                            else if (ev.EventType == "ioc")
                            {
                                <div class="timeline-body">
                                    <div class="timeline-title">🔍 IOC — [@ev.IocType]</div>
                                    <div class="timeline-text">@ev.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(ev.ActionUrl))
                                    {
                                        <button type="button" class="timeline-link" @onclick="() => OpenAction(ev.ActionUrl)">@(ev.ActionText ?? "Xem IOC")</button>
                                    }
                                </div>
                            }
                            else if (ev.EventType == "task")
                            {
                                <div class="timeline-body">
                                    <div class="timeline-title">📋 Task — <span class="badge @ev.Priority?.ToLower()">@ev.Priority</span></div>
                                    <div class="timeline-text">@ev.Title → @@ev.AssignedTo</div>
                                    @if (ev.DueDate.HasValue)
                                    {
                                        <div class="timeline-detail">📅 @ev.DueDate.Value.ToString("dd/MM/yyyy")</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(ev.ActionUrl))
                                    {
                                        <button type="button" class="timeline-link" @onclick="() => OpenAction(ev.ActionUrl)">@(ev.ActionText ?? "Xem Task")</button>
                                    }
                                </div>
                            }
                            else if (ev.EventType == "file")
                            {
                                <div class="timeline-body">
                                    <div class="timeline-title">📎 @ev.FileName</div>
                                    @if (!string.IsNullOrWhiteSpace(ev.ActionUrl))
                                    {
                                        <button type="button" class="timeline-link" @onclick="() => OpenAction(ev.ActionUrl)">@(ev.ActionText ?? "Xem File")</button>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
            @if (HasMore)
            {
                <button class="load-more-btn" @onclick="LoadMore" disabled="@IsLoading">
                    @(IsLoading ? "Đang tải..." : "Tải thêm")
                </button>
            }
        }
    </div>
</div>

@code {
    [Parameter] public int GroupId { get; set; }

    private List<TimelineEventDto> Events = new();
    private string? CurrentFilter = null;
    private int CurrentPage = 1;
    private int PageSize = 50;
    private bool IsLoading = false;
    private bool HasMore = true;

    protected override async Task OnInitializedAsync()
    {
        ChatHubService.OnMessageReceived += HandleNewMessage;
        await LoadEvents(reset: true);
    }

    private int _lastGroupId;
    protected override async Task OnParametersSetAsync()
    {
        if (_lastGroupId != GroupId)
        {
            _lastGroupId = GroupId;
            await LoadEvents(reset: true);
        }
    }

    public void Dispose()
    {
        ChatHubService.OnMessageReceived -= HandleNewMessage;
    }

    private async Task SetFilter(string? filter)
    {
        if (CurrentFilter == filter) return;
        CurrentFilter = filter;
        await LoadEvents(reset: true);
    }

    private async Task LoadMore()
    {
        await LoadEvents(reset: false);
    }

    private async Task LoadEvents(bool reset)
    {
        if (IsLoading) return;
        IsLoading = true;
        StateHasChanged();

        if (reset)
        {
            CurrentPage = 1;
            HasMore = true;
            Events.Clear();
        }

        try
        {
            var query = new TimelineQueryDto
            {
                EventType = CurrentFilter,
                Page = CurrentPage,
                PageSize = PageSize
            };
            
            var newEvents = await TimelineService.GetGroupTimelineAsync(GroupId, query);
            
            if (newEvents.Count < PageSize)
            {
                HasMore = false;
            }

            if (reset)
            {
                Events = newEvents;
            }
            else
            {
                Events.AddRange(newEvents);
            }
            
            CurrentPage++;
        }
        catch
        {
            // Handle error
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void HandleNewMessage(MessageResponse msg)
    {
        if (msg.GroupId != GroupId) return;

        string? evtType = null;
        if (msg.MessageType == "Image" || msg.MessageType == "File") evtType = "file";
        else if (msg.MessageType == "Vulnerability") evtType = "finding";
        else if (msg.MessageType == "Cve") evtType = "ioc";
        else if (msg.MessageType == "Task") evtType = "task";
        else if (!string.IsNullOrWhiteSpace(msg.Content) &&
            (msg.Content.TrimStart().StartsWith("/ioc", StringComparison.OrdinalIgnoreCase) ||
             msg.Content.TrimStart().StartsWith("/vuln", StringComparison.OrdinalIgnoreCase) ||
             msg.Content.TrimStart().StartsWith("/task", StringComparison.OrdinalIgnoreCase)))
            return;

        if (evtType == null) return;

        if (!string.IsNullOrEmpty(CurrentFilter) && CurrentFilter != evtType) return;

        var preview = msg.Content ?? "";
        if (preview.Length > 100) preview = preview.Substring(0, 100) + "...";

        var attachment = msg.Attachments?.FirstOrDefault();

        var newEvent = new TimelineEventDto
        {
            EventType = evtType,
            Timestamp = msg.CreatedAt,
            ActorUserId = msg.SenderId,
            ActorDisplayName = msg.SenderDisplayName,
            ActorAvatar = msg.SenderAvatarUrl,
            SourceId = msg.Id,
            MessageId = msg.Id,
            GroupId = GroupId,
            Title = string.IsNullOrEmpty(preview) && evtType == "file" && attachment != null ? attachment.FileName : preview,
            FileName = evtType == "file" && attachment != null ? attachment.FileName : null,
            FileUrl = evtType == "file" && attachment != null ? attachment.FileUrl : null,
            ActionText = evtType switch
            {
                "finding" => "Xem Finding",
                "ioc" => "Xem IOC",
                "task" => "Xem Task",
                "file" => "Xem File",
                _ => null
            },
            ActionUrl = evtType switch
            {
                "finding" => "/pentest",
                "ioc" => "/iocs",
                "task" => "/tasks",
                "file" => attachment?.FileUrl,
                _ => null
            }
        };

        InvokeAsync(() =>
        {
            Events.Insert(0, newEvent);
            StateHasChanged();
        });
    }

    private string GetDotColor(string eventType, string? severity, string? priority)
    {
        if (eventType == "finding")
        {
            var sev = severity?.ToLower() ?? "";
            if (sev == "critical" || sev == "high") return "#ef4444";
            if (sev == "medium") return "#f97316";
            return "#3b82f6";
        }
        if (eventType == "task")
        {
            var pri = priority?.ToLower() ?? "";
            if (pri == "critical" || pri == "high") return "#ef4444";
            if (pri == "medium") return "#f97316";
            return "#3b82f6";
        }
        if (eventType == "ioc") return "#eab308";
        
        return "#9ca3af"; // file
    }

    private void OpenAction(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url))
            Nav.NavigateTo(url);
    }

    private string FormatTime(DateTime ts)
    {
        var localTime = ts.ToLocalTime();
        var now = DateTime.Now;
        if (localTime.Date == now.Date) return localTime.ToString("HH:mm");
        if (localTime.Date == now.Date.AddDays(-1)) return "Hôm qua " + localTime.ToString("HH:mm");
        return localTime.ToString("dd/MM HH:mm");
    }
}
