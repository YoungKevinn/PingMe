@inherits LayoutComponentBase
@implements IAsyncDisposable
@using System.Security.Claims
@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject CustomAuthStateProvider AuthStateProvider
@inject AuthService AuthService
@inject ChatHubService ChatHub
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject FriendService FriendService
@inject UnreadStateService UnreadState
@inject IocNavStateService IocNavState
@inject PentestFindingService PentestFindingService
@inject GroupTaskService GroupTaskService
@inject ConversationService ConvService
@inject LocalizationService Loc
@inject WebRTCService WebRTC
@implements IDisposable

<MudThemeProvider @ref="_themeProvider"
                  Theme="_blueTheme"
                  @bind-IsDarkMode="_isDarkMode" />

<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div style="width:100vw;height:100vh;overflow:hidden;background:var(--mud-palette-background);color:var(--mud-palette-text-primary);">

    <!-- TOPBAR -->
    <div style="position:fixed;top:0;left:0;right:0;height:64px;z-index:3000;
                display:flex;align-items:center;justify-content:space-between;
                padding:0 18px;
                background:linear-gradient(135deg,#1D4ED8,#2563EB);
                color:white;
                border-bottom:1px solid rgba(255,255,255,.12);
                box-shadow:0 6px 18px rgba(15,23,42,.18);">

        <div style="display:flex;align-items:center;gap:12px;height:100%;min-width:0;white-space:nowrap;">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           OnClick="@ToggleDrawerAsync" />

            <div style="display:flex;align-items:center;gap:10px;height:40px;cursor:pointer;white-space:nowrap;"
                 @onclick="GoChat">
                <div style="width:34px;height:34px;min-width:34px;border-radius:10px;
                            background:rgba(255,255,255,.18);
                            display:flex;align-items:center;justify-content:center;">
                    <MudIcon Icon="@Icons.Material.Filled.Forum"
                             Color="Color.Inherit"
                             Style="font-size:18px;" />
                </div>

                <span style="display:inline-block;font-size:1.22rem;font-weight:800;line-height:1;
                             letter-spacing:-.01em;font-family:'Inter',system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;white-space:nowrap;">
                    PingMe
                </span>
            </div>
        </div>

        <div style="display:flex;align-items:center;gap:4px;height:100%;flex-shrink:0;">
            <MudTooltip Text="@(_isDarkMode ? "Chuyển sang chế độ sáng" : "Chuyển sang chế độ tối")">
                <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               OnClick="@ToggleDarkModeAsync" />
            </MudTooltip>

            <AuthorizeView>
                <Authorized>
                    <MudTooltip Text="@GetLanguageTooltip()">
                        <MudIconButton Icon="@Icons.Material.Filled.Language"
                                       Color="Color.Inherit"
                                       OnClick="@ToggleLanguageAsync" />
                    </MudTooltip>

                    <MudTooltip Text="@Loc.T("account.profile")">
                        <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                                       Color="Color.Inherit"
                                       OnClick="@GoProfile" />
                    </MudTooltip>

                    <MudTooltip Text="@Loc.T("account.logout")">
                        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                                       Color="Color.Inherit"
                                       OnClick="@LogoutAsync" />
                    </MudTooltip>
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <!-- LEFT NAV -->
    <div id="pm-left-sidebar" class="@($"pm-side-nav-shell {(_drawerOpen ? "expanded" : "collapsed")}")" style="@SideNavStyle">
        <MudNavMenu Class="pm-nav-menu" Style="padding-top:18px;">
            <MudNavLink Href="/chat"
                        Icon="@Icons.Material.Filled.Chat"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="@($"pm-nav-item {(_totalUnread > 0 ? "pm-nav-has-badge" : "")}")">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-content">
                        <span class="@($"pm-nav-label {(_totalUnread > 0 ? "pm-nav-label-unread" : "")}")">@Loc.T("nav.messages")</span>
                        <span class="@($"pm-nav-badge-slot {(_totalUnread > 0 ? "has-badge" : "")}")">
                            @if (_totalUnread > 0)
                            {
                                <span class="pm-nav-badge">@FormatUnread(_totalUnread)</span>
                            }
                        </span>
                    </span>
                }
                else if (_totalUnread > 0)
                {
                    <span class="pm-nav-badge">@FormatUnread(_totalUnread)</span>
                }
            </MudNavLink>

            <MudNavLink Href="/groups"
                        Icon="@Icons.Material.Filled.Group"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.groups")</span>
                }
            </MudNavLink>

            <MudNavLink Href="/search"
                        Icon="@Icons.Material.Filled.Search"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.search")</span>
                }
            </MudNavLink>
            <MudNavLink Href="/saved"
                        Icon="@Icons.Material.Filled.Bookmark"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.saved")</span>
                }
            </MudNavLink>
            <MudNavLink Href="/friends"
                        Icon="@Icons.Material.Filled.People"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="@($"pm-nav-item {(pendingRequestsCount > 0 ? "pm-nav-has-badge" : "")}")">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-content">
                        <span class="@($"pm-nav-label {(pendingRequestsCount > 0 ? "pm-nav-label-unread" : "")}")">@Loc.T("nav.friends")</span>
                        <span class="@($"pm-nav-badge-slot {(pendingRequestsCount > 0 ? "has-badge" : "")}")">
                            @if (pendingRequestsCount > 0)
                            {
                                <span class="pm-nav-badge">@FormatUnread(pendingRequestsCount)</span>
                            }
                        </span>
                    </span>
                }
                else if (pendingRequestsCount > 0)
                {
                    <span class="pm-nav-badge">@FormatUnread(pendingRequestsCount)</span>
                }
            </MudNavLink>
            <MudNavLink Href="/snippets"
                        Icon="@Icons.Material.Filled.Code"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.code")</span>
                }

            </MudNavLink>
            <MudNavLink Href="/iocs"
                        Icon="@Icons.Material.Filled.Security"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="@($"pm-nav-item {(_iocBadgeCount > 0 ? "pm-nav-has-badge" : "")}")">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-content">
                        <span class="@($"pm-nav-label {(_iocBadgeCount > 0 ? "pm-nav-label-unread" : "")}")">@Loc.T("nav.ioc")</span>
                        <span class="@($"pm-nav-badge-slot {(_iocBadgeCount > 0 ? "has-badge" : "")}")">
                            @if (_iocBadgeCount > 0)
                            {
                                <span class="pm-nav-badge">@FormatUnread(_iocBadgeCount)</span>
                            }
                        </span>
                    </span>
                }
                else if ((_iocBadgeCount - _lastSeenIocCount) > 0)
                {
                    <span class="pm-nav-badge">@FormatUnread(_iocBadgeCount - _lastSeenIocCount)</span>
                }
            </MudNavLink>
            <MudNavLink Href="/pentest"
                        Icon="@Icons.Material.Filled.BugReport"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="@($"pm-nav-item {((_pentestBadgeCount - _lastSeenPentestCount) > 0 ? "pm-nav-has-badge" : "")}")">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-content">
                        <span class="@($"pm-nav-label {((_pentestBadgeCount - _lastSeenPentestCount) > 0 ? "pm-nav-label-unread" : "")}")">@Loc.T("nav.pentest")</span>
                        <span class="@($"pm-nav-badge-slot {((_pentestBadgeCount - _lastSeenPentestCount) > 0 ? "has-badge" : "")}")">
                            @if ((_pentestBadgeCount - _lastSeenPentestCount) > 0)
                            {
                                <span class="pm-nav-badge">@FormatUnread(_pentestBadgeCount - _lastSeenPentestCount)</span>
                            }
                        </span>
                    </span>
                }
                else if ((_pentestBadgeCount - _lastSeenPentestCount) > 0)
                {
                    <span class="pm-nav-badge">@FormatUnread(_pentestBadgeCount - _lastSeenPentestCount)</span>
                }
            </MudNavLink>
            <MudNavLink Href="/timeline"
                        Icon="@Icons.Material.Filled.Timeline"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">Timeline</span>
                }
            </MudNavLink>
            <MudNavLink Href="/tasks"
                        Icon="@Icons.Material.Filled.TaskAlt"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="@($"pm-nav-item {(_taskBadgeCount > 0 ? "pm-nav-has-badge" : "")}")">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-content">
                        <span class="@($"pm-nav-label {(_taskBadgeCount > 0 ? "pm-nav-label-unread" : "")}")">Tasks</span>
                        <span class="@($"pm-nav-badge-slot {(_taskBadgeCount > 0 ? "has-badge" : "")}")">
                            @if (_taskBadgeCount > 0)
                            {
                                <span class="pm-nav-badge">@FormatUnread(_taskBadgeCount)</span>
                            }
                        </span>
                    </span>
                }
                else if (_taskBadgeCount > 0)
                {
                    <span class="pm-nav-badge">@FormatUnread(_taskBadgeCount)</span>
                }
            </MudNavLink>
            <MudNavLink Href="/secrets"
                        Icon="@Icons.Material.Filled.VpnKey"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.secrets")</span>
                }
            </MudNavLink>
            <MudDivider Class="my-3 mx-3" />

            <MudNavLink Href="/blocked"
                        Icon="@Icons.Material.Filled.Block"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.blocked")</span>
                }
            </MudNavLink>

            <MudNavLink Href="/sessions"
                        Icon="@Icons.Material.Filled.Devices"
                        Match="NavLinkMatch.Prefix"
                        Style="@NavLinkStyle"
                        Class="pm-nav-item">
                @if (_drawerOpen)
                {
                    <span class="pm-nav-label">@Loc.T("nav.sessions")</span>
                }
            </MudNavLink>
        </MudNavMenu>

        @if (_drawerOpen)
        {
            <div @onmousedown="StartSidebarResizeAsync"
                 @onmousedown:preventDefault="true"
                 @onmousedown:stopPropagation="true"
                 title="Kéo để chỉnh độ rộng"
                 style="
                        position:absolute;
                        top:0;
                        right:0;
                        width:14px;
                        height:100%;
                        cursor:col-resize;
                        z-index:5000;
                        background:transparent;
                     ">
                <div style="
                        position:absolute;
                        top:0;
                        right:0;
                        width:3px;
                        height:100%;
                        background:rgba(59,130,246,.0);
                        transition:background .15s ease;">
                </div>
            </div>
        }
    </div>

    <!-- MAIN CONTENT -->
    <div id="pm-main-content" style="@MainContentStyle">
        @Body
    </div>

    <CallOverlay />
</div>

@code {
    private MudThemeProvider _themeProvider = null!;

    private bool _isDarkMode = false;
    private bool _drawerOpen = true;
    private int _sidebarWidth = 264;

    private DotNetObjectReference<MainLayout>? _layoutRef;

    private string SideWidth => _drawerOpen ? $"{_sidebarWidth}px" : "72px";

    private int pendingRequestsCount = 0;
    private int _totalUnread;
    private int _iocBadgeCount;
    private int _pentestBadgeCount;
    private int _taskBadgeCount;
    private int _currentUserId;
    private int _lastSeenIocCount;
    private int _lastSeenPentestCount;
    private System.Timers.Timer? friendRequestTimer;

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += HandleLanguageChanged;
        await Loc.LoadAsync();
        _totalUnread = UnreadState.TotalUnread;
        _iocBadgeCount = IocNavState.TotalIocBadgeCount;
        UnreadState.OnChanged += HandleUnreadChanged;
        IocNavState.OnChanged += HandleIocNavChanged;
        ChatHub.OnMessageReceived += HandleLayoutMessageReceived;
        ChatHub.OnTaskAssigned += HandleTaskAssigned;
        await LoadCurrentUserIdAsync();
        await LoadUnreadTotalAsync();
        await LoadPendingRequestsCount();
        await LoadLastSeenCountsAsync();
        Navigation.LocationChanged += HandleLocationChanged;
        _ = IocNavState.RefreshAsync();
        _ = LoadPentestBadgeCountAsync();
        _ = LoadTaskBadgeCountAsync();
        friendRequestTimer = new System.Timers.Timer(30000);
        friendRequestTimer.Elapsed += async (sender, e) => await LoadPendingRequestsCount();
        friendRequestTimer.Start();
    }

    private async Task LoadLastSeenCountsAsync()
    {
        try
        {
            var iocStr = await JS.InvokeAsync<string>("localStorage.getItem", "pm_last_seen_ioc");
            if (int.TryParse(iocStr, out var iocVal)) _lastSeenIocCount = iocVal;

            var pentestStr = await JS.InvokeAsync<string>("localStorage.getItem", "pm_last_seen_pentest");
            if (int.TryParse(pentestStr, out var pentestVal)) _lastSeenPentestCount = pentestVal;
        }
        catch { }
    }

    private async void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var relativePath = Navigation.ToBaseRelativePath(e.Location);
        bool changed = false;

        if (relativePath.StartsWith("messages", StringComparison.OrdinalIgnoreCase))
        {
            // Do message stuff
        }
        else if (relativePath.StartsWith("iocs", StringComparison.OrdinalIgnoreCase) && _iocBadgeCount > _lastSeenIocCount)
        {
            _lastSeenIocCount = _iocBadgeCount;
            await JS.InvokeVoidAsync("localStorage.setItem", "pm_last_seen_ioc", _lastSeenIocCount.ToString());
            changed = true;
        }
        else if (relativePath.StartsWith("pentest", StringComparison.OrdinalIgnoreCase) && _pentestBadgeCount > _lastSeenPentestCount)
        {
            _lastSeenPentestCount = _pentestBadgeCount;
            await JS.InvokeVoidAsync("localStorage.setItem", "pm_last_seen_pentest", _lastSeenPentestCount.ToString());
            changed = true;
        }

        if (changed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadPendingRequestsCount()
    {
        var requests = await FriendService.GetPendingRequestsAsync();
        pendingRequestsCount = requests.Count;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        UnreadState.OnChanged -= HandleUnreadChanged;
        IocNavState.OnChanged -= HandleIocNavChanged;
        ChatHub.OnMessageReceived -= HandleLayoutMessageReceived;
        ChatHub.OnTaskAssigned -= HandleTaskAssigned;
        Loc.OnLanguageChanged -= HandleLanguageChanged;
        Navigation.LocationChanged -= HandleLocationChanged;
        friendRequestTimer?.Stop();
        friendRequestTimer?.Dispose();
    }

    private string SideNavStyle =>
        $"position:fixed;" +
        $"left:0;" +
        $"top:64px;" +
        $"bottom:0;" +
        $"width:{SideWidth};" +
        $"z-index:2000;" +
        $"overflow-x:hidden;" +
        $"overflow-y:auto;" +
        $"background:var(--mud-palette-surface);" +
        $"color:var(--mud-palette-drawer-text);" +
        $"border-right:1px solid var(--mud-palette-divider);" +
        $"box-sizing:border-box;" +
        $"transition:none;";

    private string MainContentStyle =>
        $"position:fixed;" +
        $"top:64px;" +
        $"left:{SideWidth};" +
        $"right:0;" +
        $"bottom:0;" +
        $"overflow:auto;" +
        $"background:var(--mud-palette-background);" +
        $"color:var(--mud-palette-text-primary);" +
        $"transition:none;";

    private string NavLinkStyle =>
        $"margin:4px 12px;" +
        $"border-radius:13px;" +
        $"min-height:46px;" +
        $"color:var(--mud-palette-drawer-text);" +
        $"display:flex;" +
        $"align-items:center;" +
        $"position:relative;";

    private static string FormatUnread(int totalUnread) => totalUnread > 99 ? "99+" : totalUnread.ToString();

    private async Task LoadCurrentUserIdAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                          ?? authState.User.FindFirst("sub")?.Value;

            _currentUserId = int.TryParse(idClaim, out var id) ? id : 0;
        }
        catch
        {
            _currentUserId = 0;
        }
    }

    private async Task LoadUnreadTotalAsync()
    {
        try
        {
            var conversations = await ConvService.GetConversationsAsync();
            UnreadState.SetTotal(conversations.Sum(c => Math.Max(0, c.UnreadCount)));
        }
        catch
        {
        }
    }

    private async Task LoadPentestBadgeCountAsync()
    {
        try
        {
            _pentestBadgeCount = await PentestFindingService.GetOpenCountAsync();
        }
        catch
        {
            _pentestBadgeCount = 0;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadTaskBadgeCountAsync()
    {
        try
        {
            _taskBadgeCount = await GroupTaskService.GetOverdueCountAsync();
        }
        catch
        {
            _taskBadgeCount = 0;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void HandleTaskAssigned(TaskAssignedEvent data)
    {
        if (_currentUserId > 0 && data.AssignedToUserId == _currentUserId)
        {
            var title = string.IsNullOrWhiteSpace(data.Task?.Title) ? "task mới" : data.Task.Title;
            Snackbar.Add($"Bạn được assign task: {title}", Severity.Info);
        }

        _ = LoadTaskBadgeCountAsync();
    }

    private void HandleLayoutMessageReceived(MessageResponse message)
    {
        if (_currentUserId > 0 && message.SenderId == _currentUserId)
            return;

        if (Navigation.ToBaseRelativePath(Navigation.Uri).StartsWith("chat", StringComparison.OrdinalIgnoreCase))
            return;

        UnreadState.Increment();
    }

    private void HandleUnreadChanged()
    {
        _totalUnread = UnreadState.TotalUnread;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleIocNavChanged()
    {
        _iocBadgeCount = IocNavState.TotalIocBadgeCount;
        _ = InvokeAsync(StateHasChanged);
    }

    private readonly MudTheme _blueTheme = new MudTheme
    {
        Palette = new Palette
        {
            Primary = "#2563EB",
            PrimaryDarken = "#1D4ED8",
            PrimaryLighten = "#60A5FA",
            Secondary = "#38BDF8",
            AppbarBackground = "#1D4ED8",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#1E293B",
            ActionDefault = "#475569",
            TextPrimary = "#0F172A",
            TextSecondary = "#475569",
            Divider = "rgba(0,0,0,0.07)",
            Error = "#DC2626",
            Success = "#16A34A",
            Warning = "#D97706",
            Info = "#0EA5E9",
            GrayDefault = "#94A3B8",
            OverlayLight = "rgba(15,23,42,0.4)",
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#3B82F6",
            PrimaryDarken = "#2563EB",
            PrimaryLighten = "#93C5FD",
            Secondary = "#38BDF8",
            AppbarBackground = "#0F172A",
            Background = "#0F172A",
            Surface = "#1E293B",
            DrawerBackground = "#1E293B",
            DrawerText = "#E2E8F0",
            ActionDefault = "#94A3B8",
            TextPrimary = "#F1F5F9",
            TextSecondary = "#94A3B8",
            Divider = "rgba(255,255,255,0.07)",
            Error = "#F87171",
            Success = "#4ADE80",
            Warning = "#FBBF24",
            Info = "#38BDF8",
            GrayDefault = "#475569",
        },
        Typography = new Typography
        {
            Default = new Default
            {
                FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }
            },
            H1 = new H1 { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }, FontWeight = 700 },
            H2 = new H2 { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }, FontWeight = 700 },
            H3 = new H3 { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }, FontWeight = 700 },
            H4 = new H4 { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }, FontWeight = 700 },
            H5 = new H5 { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }, FontWeight = 600 },
            H6 = new H6 { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" }, FontWeight = 600 },
            Button = new Button
            {
                FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" },
                FontWeight = 600,
                TextTransform = "none"
            },
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px",
            AppbarHeight = "64px",
        },
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadThemePreferenceAsync();
        await LoadSidebarWidthAsync();

        _layoutRef = DotNetObjectReference.Create(this);

        await EnsureSidebarResizeScriptAsync();
        await JS.InvokeVoidAsync("pmMainLayout.init", _layoutRef, _sidebarWidth, _drawerOpen);

        // Initialize WebRTC logic
        await WebRTC.InitializeAsync();

        // Start chat hub and listen for mention events
        try
        {
            await ChatHub.StartAsync();
            ChatHub.OnUserMentioned += async data =>
            {
                try
                {
                    int currentUserId = -1;
                    try
                    {
                        var user = await AuthService.GetCurrentUserAsync();
                        if (user != null) currentUserId = user.Id;
                    }
                    catch { }

                    if (currentUserId > 0 && data.TryGetProperty("mentionedUserId", out var v) && v.ValueKind == System.Text.Json.JsonValueKind.Number)
                    {
                        if (v.GetInt32() == currentUserId)
                        {
                            Snackbar.Add("Bạn được mention trong nhóm", Severity.Info);
                        }
                    }
                }
                catch { }
            };
        }
        catch { }

        StateHasChanged();
    }

    private async Task LoadThemePreferenceAsync()
    {
        try
        {
            var savedMode = await JS.InvokeAsync<string>("localStorage.getItem", "pm_dark_mode");

            if (savedMode == "1")
                _isDarkMode = true;
            else if (savedMode == "0")
                _isDarkMode = false;
            else
                _isDarkMode = await _themeProvider.GetSystemPreference();
        }
        catch
        {
            _isDarkMode = false;
        }
    }

    private async Task LoadSidebarWidthAsync()
    {
        try
        {
            var savedWidth = await JS.InvokeAsync<string>("localStorage.getItem", "pm_sidebar_width");

            if (int.TryParse(savedWidth, out var width))
                _sidebarWidth = Math.Clamp(width, 220, 420);
            else
                _sidebarWidth = 264;
        }
        catch
        {
            _sidebarWidth = 264;
        }
    }

    private async Task EnsureSidebarResizeScriptAsync()
    {
        var exists = false;

        try
        {
            exists = await JS.InvokeAsync<bool>("eval", "!!window.pmMainLayout");
        }
        catch
        {
            exists = false;
        }

        if (exists)
            return;

        await JS.InvokeVoidAsync("eval", @"
window.pmMainLayout = {
    dotnet: null,
    lastWidth: 264,
    isOpen: true,

    clamp: function(width) {
        width = Number(width) || 264;
        return Math.max(220, Math.min(420, width));
    },

    getElements: function() {
        return {
            sidebar: document.getElementById('pm-left-sidebar'),
            main: document.getElementById('pm-main-content')
        };
    },

    init: function(dotnetRef, width, isOpen) {
        this.dotnet = dotnetRef;
        this.lastWidth = this.clamp(width);
        this.isOpen = !!isOpen;

        if (this.isOpen) {
            this.apply(this.lastWidth, true, false);
        } else {
            this.apply(72, false, false);
        }
    },

    apply: function(width, isOpen, save) {
        const els = this.getElements();

        if (!els.sidebar || !els.main) return;

        const finalWidth = isOpen ? this.clamp(width) : 72;

        els.sidebar.style.width = finalWidth + 'px';
        els.main.style.left = finalWidth + 'px';

        if (isOpen && save) {
            localStorage.setItem('pm_sidebar_width', finalWidth.toString());
        }
    },

    setOpen: function(isOpen, width) {
        this.isOpen = !!isOpen;

        if (this.isOpen) {
            this.lastWidth = this.clamp(width || localStorage.getItem('pm_sidebar_width') || this.lastWidth);
            this.apply(this.lastWidth, true, false);
        } else {
            this.apply(72, false, false);
        }
    },

    start: function() {
        const els = this.getElements();

        if (!els.sidebar || !els.main) return;

        this.isOpen = true;

        let currentWidth = els.sidebar.getBoundingClientRect().width;

        if (!currentWidth || currentWidth < 220) {
            currentWidth = Number(localStorage.getItem('pm_sidebar_width')) || this.lastWidth || 264;
        }

        this.lastWidth = this.clamp(currentWidth);

        document.body.style.userSelect = 'none';
        document.body.style.cursor = 'col-resize';

        const move = (e) => {
            const width = this.clamp(e.clientX);
            this.lastWidth = width;
            this.apply(width, true, true);
        };

        const up = () => {
            document.body.style.userSelect = '';
            document.body.style.cursor = '';

            document.removeEventListener('mousemove', move);
            document.removeEventListener('mouseup', up);

            localStorage.setItem('pm_sidebar_width', this.lastWidth.toString());

            if (this.dotnet) {
                this.dotnet.invokeMethodAsync('CommitSidebarWidth', this.lastWidth)
                    .catch(() => {});
            }
        };

        document.addEventListener('mousemove', move);
        document.addEventListener('mouseup', up);
    },

    dispose: function() {
        this.dotnet = null;
    }
};
");
    }

    private async Task ToggleDrawerAsync()
    {
        _drawerOpen = !_drawerOpen;

        if (_drawerOpen)
            await LoadSidebarWidthAsync();

        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("pmMainLayout.setOpen", _drawerOpen, _sidebarWidth);
        }
        catch
        {
        }
    }

    private async Task StartSidebarResizeAsync()
    {
        if (!_drawerOpen)
            return;

        try
        {
            await JS.InvokeVoidAsync("pmMainLayout.start");
        }
        catch
        {
            await EnsureSidebarResizeScriptAsync();
            await JS.InvokeVoidAsync("pmMainLayout.init", _layoutRef, _sidebarWidth, _drawerOpen);
            await JS.InvokeVoidAsync("pmMainLayout.start");
        }
    }

    [JSInvokable]
    public async Task CommitSidebarWidth(double width)
    {
        _sidebarWidth = Math.Clamp((int)Math.Round(width), 220, 420);

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "pm_sidebar_width", _sidebarWidth.ToString());
        }
        catch
        {
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleDarkModeAsync()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "pm_dark_mode", _isDarkMode ? "1" : "0");
    }

    private Task ToggleLanguageAsync()
        => Loc.ToggleLanguageAsync();

    private string GetLanguageTooltip()
        => Loc.CurrentLanguage == "vi"
            ? Loc.T("account.switchToEnglish")
            : Loc.T("account.switchToVietnamese");

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void GoChat()
    {
        Navigation.NavigateTo("/chat");
    }

    private void GoProfile()
    {
        Navigation.NavigateTo("/profile");
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        AuthStateProvider.NotifyUserLoggedOut();
        Snackbar.Add("Đã đăng xuất thành công", Severity.Success);
        Navigation.NavigateTo("/login");
    }

    public async ValueTask DisposeAsync()
    {
        UnreadState.OnChanged -= HandleUnreadChanged;
        IocNavState.OnChanged -= HandleIocNavChanged;
        ChatHub.OnMessageReceived -= HandleLayoutMessageReceived;
        Loc.OnLanguageChanged -= HandleLanguageChanged;

        try
        {
            await JS.InvokeVoidAsync("pmMainLayout.dispose");
        }
        catch
        {
        }

        _layoutRef?.Dispose();
    }
}
