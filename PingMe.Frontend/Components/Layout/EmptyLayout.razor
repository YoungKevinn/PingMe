@inherits LayoutComponentBase
<MudThemeProvider Theme="_blueTheme" />
@Body

@code {
    private readonly MudTheme _blueTheme = new MudTheme
    {
        Palette = new Palette{

            Primary       = "#2563EB",
            PrimaryDarken = "#1D4ED8",
        },
        Typography = new Typography
        {
            Default = new Default { FontFamily = new[] { "Inter", "system-ui", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "sans-serif" } },
        },
        LayoutProperties = new LayoutProperties { DefaultBorderRadius = "10px" }
    };
}
