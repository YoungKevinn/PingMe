    private async Task ReactAsync(int msgId, string emoji)
    {
        var msg = messages.FirstOrDefault(m => m.Id == msgId);

        var alreadyReacted = msg?.Reactions?
            .Any(r => r.Emoji == emoji && r.UserIds.Contains(CurrentUserId)) == true;

        bool ok;

        if (alreadyReacted)
            ok = await ReactionService.RemoveReactionAsync(msgId, emoji);
        else
            ok = await ReactionService.AddReactionAsync(msgId, emoji);

        if (!ok)
        {
            Snackbar.Add("Không thể cập nhật reaction.", Severity.Warning);
            return;
        }

        ApplyReactionLocal(msgId, emoji, !alreadyReacted);
        StateHasChanged();
    }

