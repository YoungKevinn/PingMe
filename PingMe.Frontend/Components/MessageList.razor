        UpdateCachedMessage(msg.Id, cached => cached.IsSaved = msg.IsSaved, CurrentConversationKey());
        StateHasChanged();

        var ok = msg.IsSaved
            ? await SavedMessageService.SaveAsync(msg.Id)
            : await SavedMessageService.UnsaveAsync(msg.Id);

        if (ok)
        {
            Snackbar.Add(msg.IsSaved ? Loc.T("message.saved") : Loc.T("message.unsaved"), Severity.Success);
            return;
        }

        msg.IsSaved = original;
        UpdateCachedMessage(msg.Id, cached => cached.IsSaved = original, CurrentConversationKey());
        Snackbar.Add(Loc.T("message.saveFailed"), Severity.Warning);
        StateHasChanged();
    }
