    private List<MessageResponse> messages = new();
    private int CurrentUserId;
    private bool _showImageViewer;
    private AttachmentResponse? _currentImage;

    private void OpenImageViewer(AttachmentResponse image)
    {
        _currentImage = image;
        _showImageViewer = true;
    }

    private void CloseImageViewer()
    {
        _showImageViewer = false;
        _currentImage = null;
    }
    private bool _loading = true;
    private bool _hasMore;
    private bool _canModerateCurrentGroup;
    private bool _editOpen;
    private string _editContent = "";
    private int _editId;
    private int? _reactionPickerMessageId;
    private readonly Dictionary<int, (string Content, MarkupString Html)> _markdownCache = new();
    private readonly Dictionary<string, List<MessageResponse>> _firstPageCache = new();

    private bool _forwardOpen;
    private bool _forwardLoading;
    private int _forwardMessageId;
    private string _forwardSearch = "";
    private List<ConversationDto> _forwardConversations = new();
    private const int FirstPageSize = 30;
    private const int CacheMessagesLimit = 50;
    private const int RenderWindowSize = 100;
    private int _windowStartIndex;
    private long _avatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();

    private static readonly string[] ReactionEmojis = { "👍", "❤️", "😂", "😮", "😢", "🔥" };

    private IEnumerable<ConversationDto> FilteredForwardConversations =>
        _forwardConversations
            .Where(c => string.IsNullOrWhiteSpace(_forwardSearch)
                || GetForwardConversationDisplayName(c).Contains(_forwardSearch, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(c => c.IsPinned)
            .ThenByDescending(c => c.LastMessageAt ?? DateTime.MinValue);

    private int? _highlightMessageId;
    private int? _lastPeerId;
    private int? _lastGroupId;
    private int? _lastTargetMessageId;
    private int _loadVersion;
    private CancellationTokenSource? _markReadCts;
    private bool _scrollToBottomAfterRender;

    private IReadOnlyList<MessageResponse> VisibleMessages
    {
        get
        {
            if (messages.Count <= RenderWindowSize)
                return messages;

            var start = Math.Clamp(_windowStartIndex, 0, Math.Max(0, messages.Count - RenderWindowSize));
            return messages.Skip(start).Take(RenderWindowSize).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Loc.OnLanguageChanged += HandleLanguageChanged;
        await Loc.LoadAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        CurrentUserId = int.TryParse(idClaim, out var id) ? id : 0;

        Hub.OnMessageReceived += HandleNewMessage;
        Hub.OnMessageEdited += HandleEdited;
        Hub.OnMessageDeleted += HandleDeleted;
        Hub.OnMessageReactionUpdated += HandleReaction;
        Hub.OnMessageRead += HandleRead;
        Hub.OnMessagePinned += HandlePinned;
        Hub.OnPollVoteUpdated += HandlePollVoteUpdated;
    }

    protected override async Task OnParametersSetAsync()
    {
        var targetChanged = TargetMessageId.HasValue && TargetMessageId != _lastTargetMessageId;

        if (_lastPeerId == PeerId && _lastGroupId == GroupId && !targetChanged)
            return;

        _lastPeerId = PeerId;
        _lastGroupId = GroupId;
        _lastTargetMessageId = TargetMessageId;

        if (!targetChanged || !messages.Any())
            await LoadAsync();

        if (TargetMessageId.HasValue)
        {
            await Task.Delay(120);
            await ScrollToMessageAsync(TargetMessageId.Value);
        }
    }

    private async Task LoadAsync()
    {
        var loadVersion = ++_loadVersion;
        var expectedPeerId = PeerId;
        var expectedGroupId = GroupId;
        var cacheKey = ConversationKey(expectedPeerId, expectedGroupId);

        _loading = true;
        _canModerateCurrentGroup = false;
        messages = new List<MessageResponse>();
        _hasMore = false;
        _markdownCache.Clear();
        SetWindowToLatest();
        StateHasChanged();

        if (cacheKey != null && _firstPageCache.TryGetValue(cacheKey, out var cached))
        {
            messages = cached.ToList();
            _hasMore = messages.Count >= FirstPageSize;
            SetWindowToLatest();
        }
        else
        {
            var indexedCache = cacheKey is null
                ? null
                : await MessageCache.GetCachedMessagesAsync(cacheKey);

            messages = indexedCache?.ToList() ?? new();
            _hasMore = false;
            SetWindowToLatest();
        }

        _scrollToBottomAfterRender = true;
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            List<MessageResponse>? result = null;

            if (expectedPeerId.HasValue)
            {
                result = await MsgService.GetDmMessagesAsync(expectedPeerId.Value, null, FirstPageSize);
            }
            else if (expectedGroupId.HasValue)
            {
                result = await MsgService.GetGroupMessagesAsync(expectedGroupId.Value, null, FirstPageSize);
                if (result is null && string.Equals(MsgService.LastError, "Bạn không còn là thành viên của nhóm này.", StringComparison.Ordinal))
                {
                    Snackbar.Add(MsgService.LastError, Severity.Warning);
                    result = new List<MessageResponse>
                    {
                        CreateLocalSystemMessage(expectedGroupId.Value, "Bạn đã bị xóa khỏi nhóm này")
                    };
                }
                _ = LoadGroupModerationPermissionAsync(expectedGroupId.Value);
            }

            if (loadVersion != _loadVersion || PeerId != expectedPeerId || GroupId != expectedGroupId)
                return;

            messages = result ?? new List<MessageResponse>();
            await ApplySavedStatesAsync(messages);
            _hasMore = messages.Count >= FirstPageSize;
            UpdateFirstPageCache(cacheKey, messages);
            SetWindowToLatest();
        }
        finally
        {
            if (loadVersion == _loadVersion)
            {
                _loading = false;
                StateHasChanged();

                await ScrollToBottomAsync();
                ScheduleMarkCurrentConversationAsRead();
            }
        }
    }

    private async Task LoadMoreAsync()
    {
        if (!messages.Any())
            return;

        var beforeId = messages.First().Id;
        List<MessageResponse>? older = null;
        var oldScrollHeight = await JS.InvokeAsync<double>("pingmeChatScroll.getScrollHeight", "msgScroll");

        if (PeerId.HasValue)
            older = await MsgService.GetDmMessagesAsync(PeerId.Value, beforeId, FirstPageSize);
        else if (GroupId.HasValue)
            older = await MsgService.GetGroupMessagesAsync(GroupId.Value, beforeId, FirstPageSize);

        if (older?.Any() == true)
        {
            await ApplySavedStatesAsync(older);
            var uniqueOlder = older.Where(o => messages.All(m => m.Id != o.Id)).ToList();
            messages.InsertRange(0, uniqueOlder);
            _hasMore = older.Count >= FirstPageSize;
            _windowStartIndex = 0;
            UpdateFirstPageCache(CurrentConversationKey(), messages);
        }
        else
        {
            _hasMore = false;
        }

        StateHasChanged();
        await JS.InvokeVoidAsync("pingmeChatScroll.restoreScrollAfterPrepend", "msgScroll", oldScrollHeight);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_scrollToBottomAfterRender)
            return;

        _scrollToBottomAfterRender = false;
        await ScrollToBottomAsync();
    }

    public async Task RefreshAsync()
    {
        await LoadAsync();
    }

    public async Task AppendMessageAsync(MessageResponse msg)
    {
        if (!BelongsToCurrentConversation(msg))
            return;

        if (messages.Any(m => m.Id == msg.Id))
            return;

        var nearBottom = await IsNearBottomAsync();
        messages.Add(msg);
        if (msg.SenderId == CurrentUserId || nearBottom)
            SetWindowToLatest();
        UpsertMessageInCache(msg);

        StateHasChanged();
        if (msg.SenderId == CurrentUserId || nearBottom)
            await ScrollToBottomAsync();

        if (msg.SenderId != CurrentUserId)
        {
            ScheduleMarkMessageRead(msg.Id);
        }
    }

    public async Task ScrollToMessageAsync(int messageId)
    {
        if (messages.All(m => m.Id != messageId))
        {
            var context = await MsgService.GetMessageContextAsync(messageId, 20, 20);

            if (context?.Any() == true)
            {
                await ApplySavedStatesAsync(context);
                messages = context;
                _hasMore = true;
                UpdateFirstPageCache(CurrentConversationKey(), messages);
                SetWindowToLatest();

                StateHasChanged();
                await Task.Delay(120);
            }
            else
            {
                Snackbar.Add("Không tải được vị trí tin nhắn cần tìm.", Severity.Warning);
                return;
            }
        }

        _highlightMessageId = messageId;
        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("pingmeChatScroll.scrollElementIntoView", $"msg-{messageId}", "center");
        }
        catch
        {
        }

        _ = ClearHighlightLaterAsync(messageId);
    }

    public async Task ClearHighlightAsync()
    {
        _highlightMessageId = null;
        await InvokeAsync(StateHasChanged);
    }

    private string GetSenderDisplayName(MessageResponse msg)
    {
        if (PeerId.HasValue &&
            !GroupId.HasValue &&
            msg.SenderId == PeerId.Value &&
            !string.IsNullOrWhiteSpace(PeerDisplayNameOverride))
        {
            return PeerDisplayNameOverride;
        }

        return string.IsNullOrWhiteSpace(msg.SenderDisplayName)
            ? "Người dùng"
            : msg.SenderDisplayName;
    }

    private string GetForwardConversationDisplayName(ConversationDto conversation)
    {
        if (conversation.Type.Equals("group", StringComparison.OrdinalIgnoreCase))
            return conversation.GroupName ?? Loc.T("chat.groupLabel");

        return conversation.PeerDisplayName ?? string.Empty;
    }

    private async Task ClearHighlightLaterAsync(int messageId)
    {
        await Task.Delay(3600);

        if (_highlightMessageId == messageId)
        {
            _highlightMessageId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ScheduleMarkCurrentConversationAsRead()
    {
        if (!PeerId.HasValue && !GroupId.HasValue)
            return;

        _markReadCts?.Cancel();
        _markReadCts?.Dispose();
        _markReadCts = new CancellationTokenSource();

        var peerId = PeerId;
        var groupId = GroupId;
        var token = _markReadCts.Token;

        _ = MarkCurrentConversationAsReadLaterAsync(peerId, groupId, token);
    }

    private async Task MarkCurrentConversationAsReadLaterAsync(int? peerId, int? groupId, CancellationToken token)
    {
        try
        {
            await Task.Delay(180, token);
            await ReadReceiptService.MarkConversationReadAsync(peerId, groupId);

            if (!token.IsCancellationRequested && OnReadStateChanged.HasDelegate)
                await InvokeAsync(async () => await OnReadStateChanged.InvokeAsync());
        }
        catch (OperationCanceledException)
        {
        }
        catch
        {
        }
    }

    private void ScheduleMarkMessageRead(int messageId)
    {
        _ = MarkMessageReadLaterAsync(messageId);
    }

    private async Task MarkMessageReadLaterAsync(int messageId)
    {
        try
        {
            await Task.Delay(120);
            await ReadReceiptService.MarkMessageReadAsync(messageId);

            if (OnReadStateChanged.HasDelegate)
                await InvokeAsync(async () => await OnReadStateChanged.InvokeAsync());
        }
        catch
        {
        }
    }

    private bool BelongsToCurrentConversation(MessageResponse msg)
    {
        return (PeerId.HasValue && msg.GroupId == null &&
                ((msg.SenderId == CurrentUserId && msg.ReceiverId == PeerId) ||
                 (msg.SenderId == PeerId && msg.ReceiverId == CurrentUserId)))
            || (GroupId.HasValue && msg.GroupId == GroupId);
    }

    private string? CurrentConversationKey() => ConversationKey(PeerId, GroupId);

    private static string? ConversationKey(int? peerId, int? groupId)
    {
        if (groupId.HasValue)
            return $"group:{groupId.Value}";

        if (peerId.HasValue)
            return $"dm:{peerId.Value}";

        return null;
    }

    private string? ConversationKeyForMessage(MessageResponse msg)
    {
        if (msg.GroupId.HasValue)
            return $"group:{msg.GroupId.Value}";

        if (msg.SenderId == CurrentUserId && msg.ReceiverId.HasValue)
            return $"dm:{msg.ReceiverId.Value}";

        if (msg.ReceiverId == CurrentUserId)
            return $"dm:{msg.SenderId}";

        return null;
    }

    private string? ConversationKeyForReaction(ReactionUpdateEvent data)
    {
        if (data.GroupId.HasValue)
            return $"group:{data.GroupId.Value}";

        if (data.SenderId == CurrentUserId && data.ReceiverId.HasValue)
            return $"dm:{data.ReceiverId.Value}";

        if (data.ReceiverId == CurrentUserId)
            return $"dm:{data.SenderId}";

        return null;
    }

    private void UpdateFirstPageCache(string? key, List<MessageResponse> source)
    {
        if (key == null)
            return;

        _firstPageCache[key] = source
            .OrderByDescending(m => m.Id)
            .Take(CacheMessagesLimit)
            .OrderBy(m => m.Id)
            .ToList();

        _ = MessageCache.SetCachedMessagesAsync(key, _firstPageCache[key]);
    }

    private void UpsertMessageInCache(MessageResponse msg)
    {
        var key = ConversationKeyForMessage(msg);
        if (key == null)
            return;

        if (!_firstPageCache.TryGetValue(key, out var cached))
            cached = new List<MessageResponse>();

        var idx = cached.FindIndex(m => m.Id == msg.Id);
        if (idx >= 0)
            cached[idx] = msg;
        else
            cached.Add(msg);

        UpdateFirstPageCache(key, cached);
    }

    private void UpdateCachedMessage(int messageId, Action<MessageResponse> update, string? preferredKey = null)
    {
        if (preferredKey != null && _firstPageCache.TryGetValue(preferredKey, out var preferred))
        {
            var preferredMsg = preferred.FirstOrDefault(m => m.Id == messageId);
            if (preferredMsg != null)
            {
                update(preferredMsg);
                _ = MessageCache.SetCachedMessagesAsync(preferredKey, preferred);
                return;
            }
        }

        foreach (var pair in _firstPageCache)
        {
            var cached = pair.Value;
            var cachedMsg = cached.FirstOrDefault(m => m.Id == messageId);
            if (cachedMsg != null)
            {
                update(cachedMsg);
                _ = MessageCache.SetCachedMessagesAsync(pair.Key, cached);
                return;
            }
        }
    }

    private async Task ApplySavedStatesAsync(IEnumerable<MessageResponse> targetMessages)
    {
        var list = targetMessages.Where(m => m.Id > 0 && !m.IsDeleted).ToList();
        if (list.Count == 0)
            return;

        var states = await SavedMessageService.CheckSavedAsync(list.Select(m => m.Id));

        foreach (var msg in list)
        {
            if (states.TryGetValue(msg.Id, out var isSaved))
                msg.IsSaved = isSaved;
        }
    }

    private void HandleNewMessage(MessageResponse msg)
    {
        UpsertMessageInCache(msg);

        if (!BelongsToCurrentConversation(msg))
            return;

        if (messages.Any(m => m.Id == msg.Id))
            return;

        InvokeAsync(async () =>
        {
            var nearBottom = await IsNearBottomAsync();

            if (messages.Any(m => m.Id == msg.Id))
                return;

            messages.Add(msg);
            UpsertMessageInCache(msg);

            if (msg.SenderId == CurrentUserId || nearBottom)
                SetWindowToLatest();

            StateHasChanged();

            if (msg.SenderId == CurrentUserId || nearBottom)
                await ScrollToBottomAsync();

            if (msg.SenderId != CurrentUserId)
            {
                ScheduleMarkMessageRead(msg.Id);
            }
        });
    }

    private void HandleEdited(MessageResponse msg)
    {
        UpsertMessageInCache(msg);

        var idx = messages.FindIndex(m => m.Id == msg.Id);

        if (idx >= 0)
        {
            messages[idx] = msg;
            InvokeAsync(StateHasChanged);
        }
    }

    private void HandleDeleted(object raw)
    {
        InvokeAsync(() =>
        {
            var messageId = TryGetInt(raw, "messageId");
            if (messageId.HasValue)
            {
                UpdateCachedMessage(messageId.Value, msg =>
                {
                    msg.IsDeleted = true;
                    msg.Content = "Tin nhắn đã thu hồi";
                });

                var msg = messages.FirstOrDefault(m => m.Id == messageId.Value);
                if (msg != null)
                {
                    msg.IsDeleted = true;
                    msg.Content = "Tin nhắn đã thu hồi";
                    StateHasChanged();
                    return;
                }
            }

            _ = LoadAsync();
        });
    }

    private void HandleReaction(ReactionUpdateEvent data)
    {
        UpdateCachedMessage(
            data.MessageId,
            msg => msg.Reactions = data.Reactions ?? new List<ReactionSummary>(),
            ConversationKeyForReaction(data));

        InvokeAsync(() =>
        {
            var msg = messages.FirstOrDefault(m => m.Id == data.MessageId);

            if (msg != null)
                msg.Reactions = data.Reactions ?? new List<ReactionSummary>();

            StateHasChanged();
        });
    }

    private void HandleRead(ReadReceiptEvent data)
    {
        InvokeAsync(() =>
        {
            if (data.MessageId.HasValue)
                AddReadUserToMessage(data.MessageId.Value, data.UserId);

            if (data.MessageIds != null)
            {
                foreach (var id in data.MessageIds)
                    AddReadUserToMessage(id, data.UserId);
            }

            StateHasChanged();
        });
    }

    private void AddReadUserToMessage(int messageId, int userId)
    {
        UpdateCachedMessage(messageId, cachedMsg =>
        {
            cachedMsg.ReadByUserIds ??= new List<int>();
            if (!cachedMsg.ReadByUserIds.Contains(userId))
                cachedMsg.ReadByUserIds.Add(userId);
        });

        var msg = messages.FirstOrDefault(m => m.Id == messageId);

        if (msg == null)
            return;

        msg.ReadByUserIds ??= new List<int>();

        if (!msg.ReadByUserIds.Contains(userId))
            msg.ReadByUserIds.Add(userId);
    }

    private bool IsReadByOther(MessageResponse msg)
    {
        return msg.ReadByUserIds != null &&
               msg.ReadByUserIds.Any(id => id != CurrentUserId);
    }

    private bool ShouldRenderTextContent(MessageResponse msg)
    {
        if (string.IsNullOrWhiteSpace(msg.Content))
            return false;

        if (!msg.Attachments.Any())
            return true;

        return !msg.Attachments.Any(a =>
            string.Equals(a.FileName, msg.Content, StringComparison.Ordinal));
    }

