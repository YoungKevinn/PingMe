    private static int? TryGetInt(object raw, string propertyName)
    {
        if (raw is System.Text.Json.JsonElement element)
        {
            if (element.ValueKind == System.Text.Json.JsonValueKind.Object &&
                element.TryGetProperty(propertyName, out var property) &&
                property.TryGetInt32(out var value))
            {
                return value;
            }
        }

        var propertyInfo = raw.GetType().GetProperty(propertyName)
            ?? raw.GetType().GetProperty(char.ToUpperInvariant(propertyName[0]) + propertyName[1..]);

        if (propertyInfo?.GetValue(raw) is int valueFromObject)
            return valueFromObject;

        return null;
    }

    private static ReminderMessagePayload? ParseReminderPayload(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return null;

        try
        {
            return JsonSerializer.Deserialize<ReminderMessagePayload>(
                content,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch
        {
            return null;
        }
    }

    private string FormatReminderStatus(string? status)
    {
        return (status ?? string.Empty).Trim().ToLowerInvariant() switch
        {
            "pending" => Loc.T("reminder.pending"),
            "sent" => Loc.T("reminder.sent"),
            "completed" => Loc.T("reminder.completed"),
            "cancelled" => Loc.T("reminder.cancelled"),
            _ => status ?? string.Empty
        };
    }

    private sealed class ReminderMessagePayload
    {
        public int ReminderId { get; set; }
        public string Text { get; set; } = string.Empty;
        public DateTime RemindAtUtc { get; set; }
        public string Status { get; set; } = "Pending";
        public int? GroupId { get; set; }
        public int? PeerUserId { get; set; }
        public int? SourceMessageId { get; set; }
    }

    private sealed class VulnerabilityMessagePayload
    {
        public int FindingId { get; set; }
        public int GroupId { get; set; }
        public string Severity { get; set; } = "Medium";
        public string Status { get; set; } = "Open";
        public string Title { get; set; } = string.Empty;
        public string? AffectedTarget { get; set; }
        public string? AffectedEndpoint { get; set; }
        public string? HttpMethod { get; set; }
        public string? Payload { get; set; }
        public string? Url { get; set; }
    }
}

