    private async Task TogglePinAsync(MessageResponse msg)
    {
        var newPinned = !msg.IsPinned;
        var ok = await MsgService.PinMessageAsync(msg.Id, newPinned);

        if (!ok)
        {
            Snackbar.Add(newPinned ? "Không thể ghim tin nhắn." : "Không thể bỏ ghim.", Severity.Warning);
            return;
        }

        // Cập nhật optimistic; SignalR sẽ broadcast lại để đồng bộ
        msg.IsPinned = newPinned;
        UpdateCachedMessage(msg.Id, cachedMsg => cachedMsg.IsPinned = newPinned);
        StateHasChanged();
        Snackbar.Add(newPinned ? "Đã ghim tin nhắn." : "Đã bỏ ghim.", Severity.Success);
    }

    private void HandlePinned(MessagePinnedEvent data)
    {
        if (data == null) return;

        if (data.Message != null)
            UpsertMessageInCache(data.Message);
        else
            UpdateCachedMessage(data.MessageId, cachedMsg => cachedMsg.IsPinned = data.IsPinned);

        // Chỉ xử lý nếu thuộc hội thoại hiện tại
        bool belongs =
            (GroupId.HasValue && data.GroupId == GroupId) ||
            (PeerId.HasValue && !data.GroupId.HasValue &&
                ((data.SenderId == CurrentUserId && data.ReceiverId == PeerId) ||
                 (data.SenderId == PeerId && data.ReceiverId == CurrentUserId)));

        if (!belongs) return;

        InvokeAsync(async () =>
        {
            var msg = messages.FirstOrDefault(m => m.Id == data.MessageId);
            if (msg != null)
            {
                msg.IsPinned = data.IsPinned;
                UpdateCachedMessage(data.MessageId, cachedMsg => cachedMsg.IsPinned = data.IsPinned);
                StateHasChanged();
            }

            if (OnPinChanged.HasDelegate)
                await OnPinChanged.InvokeAsync(data);
        });
    }

    private void HandlePollVoteUpdated(PollVoteUpdatedEvent data)
    {
        if (data?.Poll == null) return;

        bool belongs =
            (GroupId.HasValue && data.GroupId == GroupId) ||
            (PeerId.HasValue && !data.GroupId.HasValue &&
                ((data.SenderId == CurrentUserId && data.ReceiverId == PeerId) ||
                 (data.SenderId == PeerId && data.ReceiverId == CurrentUserId)));

        if (!belongs) return;

        InvokeAsync(() =>
        {
            var msg = messages.FirstOrDefault(m => m.Id == data.MessageId);
            if (msg != null)
            {
                msg.Poll = data.Poll;
                StateHasChanged();
            }
            return Task.CompletedTask;
        });
    }

    private async Task VoteOnPollAsync(int pollId, int optionId, bool allowMultiple, List<int> myVotes)
    {
        List<int> newVotes;
        if (allowMultiple)
        {
            newVotes = myVotes.Contains(optionId)
                ? myVotes.Where(id => id != optionId).ToList()
                : myVotes.Concat([optionId]).ToList();
        }
        else
        {
            newVotes = myVotes.Contains(optionId) ? [] : [optionId];
        }

        if (newVotes.Count == 0)
            await PollService.UnvoteAsync(pollId);
        else
            await PollService.VoteAsync(pollId, newVotes);
    }

    private static bool IsPollMessage(MessageResponse msg) =>
        string.Equals(msg.MessageType, "Poll", StringComparison.OrdinalIgnoreCase);

    private RenderFragment RenderPollCard(MessageResponse msg) => builder =>
    {
        var poll = msg.Poll;
        var isOwn = msg.SenderId == CurrentUserId;
        var isEnded = poll?.EndsAt.HasValue == true && poll.EndsAt!.Value < DateTime.UtcNow;
        var sequence = 0;

        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "pm-poll-card");

        // Header
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "pm-poll-header");
        builder.OpenElement(sequence++, "span");
        builder.AddAttribute(sequence++, "class", "pm-poll-label");
        builder.AddContent(sequence++, "📊 Bình chọn");
        builder.CloseElement();
        if (isEnded)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "pm-poll-ended-badge");
            builder.AddContent(sequence++, "Đã kết thúc");
            builder.CloseElement();
        }
        if (poll?.AllowMultiple == true)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "pm-poll-multi-badge");
            builder.AddContent(sequence++, "Nhiều đáp án");
            builder.CloseElement();
        }
        builder.CloseElement();

        // Question
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "pm-poll-question");
        builder.AddContent(sequence++, msg.Content ?? poll?.Question ?? string.Empty);
        builder.CloseElement();

        if (poll != null)
        {
            // Options
            foreach (var option in poll.Options)
            {
                var opt = option;
                var isVoted = poll.MyVoteOptionIds.Contains(opt.Id);
                var pct = opt.Percentage;

                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", $"pm-poll-option {(isVoted ? "voted" : "")} {(isEnded ? "ended" : "")}");
                builder.AddAttribute(sequence++, "onclick",
                    EventCallback.Factory.Create(this, () => VoteOnPollAsync(poll.Id, opt.Id, poll.AllowMultiple, poll.MyVoteOptionIds)));

                // Progress bar fill
                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", $"pm-poll-bar {(isVoted ? "voted" : "")}");
                builder.AddAttribute(sequence++, "style", $"width:{pct}%");
                builder.CloseElement();

                // Option content row
                builder.OpenElement(sequence++, "div");
                builder.AddAttribute(sequence++, "class", "pm-poll-option-row");

                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", $"pm-poll-check {(isVoted ? "visible" : "")}");
                builder.AddContent(sequence++, isVoted ? "✓" : "");
                builder.CloseElement();

                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "pm-poll-option-text");
                builder.AddContent(sequence++, opt.Text);
                builder.CloseElement();

                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "pm-poll-pct");
                builder.AddContent(sequence++, $"{pct:0}%");
                builder.CloseElement();

                builder.CloseElement(); // option-row
                builder.CloseElement(); // option
            }

            // Footer
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "pm-poll-footer");
            builder.AddContent(sequence++, $"{poll.TotalVotes} lượt bình chọn");
            if (poll.EndsAt.HasValue && !isEnded)
            {
                builder.AddContent(sequence++, $" • Kết thúc {poll.EndsAt.Value.ToLocalTime():HH:mm dd/MM}");
            }
            builder.CloseElement();
        }

        builder.CloseElement(); // pm-poll-card
    };

