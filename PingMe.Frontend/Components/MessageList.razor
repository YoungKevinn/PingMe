    private string GetDownloadUrl(AttachmentResponse att, bool inline = false)
    {
        if (!Uri.TryCreate(att.FileUrl, UriKind.Absolute, out var uri))
            return att.FileUrl;

        var parts = uri.AbsolutePath.Split('/', StringSplitOptions.RemoveEmptyEntries);

        var messagesIndex = Array.FindIndex(
            parts,
            p => string.Equals(p, "messages", StringComparison.OrdinalIgnoreCase)
        );

        if (messagesIndex < 0 || parts.Length <= messagesIndex + 2)
            return att.FileUrl;

        var date = parts[messagesIndex + 1];
        var fileName = Uri.UnescapeDataString(parts[messagesIndex + 2]);

        var url = $"{uri.Scheme}://{uri.Authority}/api/files/download/messages/{date}/{Uri.EscapeDataString(fileName)}?originalName={Uri.EscapeDataString(att.FileName)}";
        if (inline)
            url += "&inline=true";
        return url;
    }

