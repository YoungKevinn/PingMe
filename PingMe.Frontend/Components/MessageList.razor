    private void ApplyReactionLocal(int msgId, string emoji, bool add)
    {
        var msg = messages.FirstOrDefault(m => m.Id == msgId);

        if (msg == null)
            return;

        msg.Reactions ??= new List<ReactionSummary>();

        var reaction = msg.Reactions.FirstOrDefault(r => r.Emoji == emoji);

        if (add)
        {
            if (reaction == null)
            {
                reaction = new ReactionSummary
                {
                    Emoji = emoji,
                    Count = 0,
                    UserIds = new List<int>()
                };

                msg.Reactions.Add(reaction);
            }

            if (!reaction.UserIds.Contains(CurrentUserId))
            {
                reaction.UserIds.Add(CurrentUserId);
                reaction.Count++;
            }
        }
        else
        {
            if (reaction == null)
                return;

            if (reaction.UserIds.Remove(CurrentUserId))
                reaction.Count = Math.Max(0, reaction.Count - 1);

            if (reaction.Count <= 0)
                msg.Reactions.Remove(reaction);
        }

        UpdateCachedMessage(msgId, cachedMsg =>
        {
            cachedMsg.Reactions = msg.Reactions;
        });
    }

