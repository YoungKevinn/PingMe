@using System.Security.Claims
@using System.Text.Json
@using PingMe.Frontend.Models
@using PingMe.Frontend.Helpers
@using Microsoft.AspNetCore.Components.Web
@inject MessageService MsgService
@inject MessageCacheService MessageCache
@inject ConversationService ConvService
@inject ReactionService ReactionService
@inject SavedMessageService SavedMessageService
@inject ChatHubService Hub
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ReadReceiptService ReadReceiptService
@inject GroupService GroupService
@inject IDialogService DialogService
@inject LocalizationService Loc
@inject PollService PollService
@implements IDisposable

<div style="height:100%; overflow-y:auto; padding:12px 16px; display:flex; flex-direction:column; gap:2px; background:var(--mud-palette-background);"
     id="msgScroll">

    @if (_loading && !messages.Any())
    {
        <div class="pm-message-skeleton-list">
            @for (var i = 0; i < 8; i++)
            {
                <div class="@($"pm-message-skeleton {(i % 3 == 0 ? "own" : "other")}")">
                    <span></span>
                    <span></span>
                </div>
            }
        </div>
    }
    else if (!messages.Any())
    {
        <div class="pm-empty" style="flex:1;">
            <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline"
                     Style="font-size:64px;opacity:.25;color:var(--mud-palette-primary);" />
            <p class="pm-empty-title">Chưa có tin nhắn nào</p>
            <p class="pm-empty-desc">Hãy gửi tin nhắn đầu tiên để bắt đầu cuộc trò chuyện</p>
        </div>
    }
    else
    {
        @if (_hasMore)
        {
            <div style="text-align:center;padding:8px;">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Size="Size.Small"
                           OnClick="LoadMoreAsync">
                    Tải thêm tin nhắn
                </MudButton>
            </div>
        }

        @foreach (var msg in VisibleMessages)
        {
            if (IsSystemMessage(msg))
            {
                <div @key="msg.Id" id="msg-@msg.Id" class="pm-system-message-row">
                    <span class="pm-system-message-text">@msg.Content</span>
                </div>
                continue;
            }

            if (string.Equals(msg.MessageType, "Call", StringComparison.OrdinalIgnoreCase))
            {
                var isMissed = msg.Content?.Contains("Missed", StringComparison.OrdinalIgnoreCase) == true || msg.Content?.Contains("declined", StringComparison.OrdinalIgnoreCase) == true;
                var isVideo = msg.Content?.Contains("video", StringComparison.OrdinalIgnoreCase) == true;
                var callIcon = isVideo ? (isMissed ? Icons.Material.Filled.MissedVideoCall : Icons.Material.Filled.Videocam) : (isMissed ? Icons.Material.Filled.PhoneMissed : Icons.Material.Filled.Phone);
                var callColor = isMissed ? "var(--mud-palette-error)" : "var(--mud-palette-text-secondary)";

                <div @key="msg.Id" id="msg-@msg.Id" class="pm-system-message-row">
                    <div class="pm-call-log-bubble" style="display:inline-flex; align-items:center; gap:8px; background:var(--mud-palette-background-grey); padding:8px 16px; border-radius:16px; margin: 4px 0;">
                        <MudIcon Icon="@callIcon" Style="@($"color:{callColor}; font-size:1.2rem;")" />
                        <span style="font-size:0.85rem; font-weight:500; color:var(--mud-palette-text-primary);">@msg.Content</span>
                    </div>
                </div>
                continue;
            }

            var isOwn = msg.SenderId == CurrentUserId;
            var senderName = GetSenderDisplayName(msg);

            <div @key="msg.Id"
                 id="msg-@msg.Id"
                 class="pm-message-row @(isOwn ? "d-flex flex-column align-end mb-1" : "d-flex flex-column align-start mb-1") @(_highlightMessageId == msg.Id ? "pm-message-highlight" : "")">

                @if (!isOwn && GroupId.HasValue && !msg.IsDeleted)
                {
                    <MudText Typo="Typo.caption"
                             Style="color:var(--mud-palette-primary);font-weight:600;margin:0 44px 2px;">
                        @senderName
                    </MudText>
                }

                <div class="@($"pm-message-line {(isOwn ? "own" : "other")}")">
                    @if (!isOwn)
                    {
                        var senderAvatarUrl = UrlHelper.BuildBackendUrl(msg.SenderAvatarUrl, _avatarVersion);

                        <MudAvatar Size="Size.Small"
                                   Color="Color.Primary"
                                   Style="width:32px;height:32px;font-size:.8rem;flex-shrink:0;">
                            <span class="pm-avatar-fallback">@senderName.FirstOrDefault()</span>
                            @if (!string.IsNullOrWhiteSpace(senderAvatarUrl))
                            {
                                <img src="@senderAvatarUrl"
                                     alt="@senderName"
                                     class="pm-avatar-image"
                                     loading="lazy"
                                     decoding="async"
                                     referrerpolicy="no-referrer"
                                     onerror="this.style.display='none';this.parentElement.classList.add('pm-avatar-fallback-active');" />
                            }
                        </MudAvatar>
                    }

                    <div style="display:flex;flex-direction:column;@(isOwn ? "align-items:flex-end;" : "align-items:flex-start;")">
                        @if (msg.ReplyToMessage != null)
                        {
                            <div class="pm-reply-preview" style="@(isOwn ? "margin-right:4px;" : "margin-left:4px;")">
                                <span class="author">@GetSenderDisplayName(msg.ReplyToMessage)</span>
                                <br />
                                <span style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:block;max-width:200px;">
                                    @msg.ReplyToMessage.Content
                                </span>
                            </div>
                        }

                        @if (msg.ForwardedFromMessageId.HasValue && !msg.IsDeleted)
                        {
                            <div class="pm-forwarded-label">
                                <MudIcon Icon="@Icons.Material.Filled.Forward"
                                         Style="font-size:13px;vertical-align:-2px;margin-right:3px;" />
                                Đã chuyển tiếp
                            </div>
                        }

                        <div class="@($"pm-bubble {(isOwn ? "own" : "other")} {(msg.IsDeleted ? "deleted" : "")}")"
                             style="position:relative;">

                            @if (msg.IsPinned && !msg.IsDeleted)
                            {
                                <div class="pm-pin-badge" title="Tin nhắn đã ghim">
                                    <MudIcon Icon="@Icons.Material.Filled.PushPin"
                                             Style="font-size:13px;color:#F59E0B;" />
                                </div>
                            }

                            @if (msg.IsDeleted)
                            {
                                <span>🚫 Tin nhắn đã thu hồi</span>
                            }
                            else
                            {
                                @if (msg.Attachments.Any())
                                {
                                    <div class="pm-attachments">
                                        @foreach (var att in msg.Attachments)
                                        {
                                            if (att.IsImage)
                                            {
                                                <div class="pm-image-link" @onclick="() => OpenImageViewer(att)">
                                                    <img src="@att.FileUrl"
                                                         alt="@att.FileName"
                                                         loading="lazy"
                                                         decoding="async"
                                                         class="pm-image-preview" />
                                                </div>

                                                <div class="pm-attachment-caption">
                                                    <span>@att.FileName</span>
                                                    <span>@att.DisplaySize</span>
                                                </div>
                                            }
                                            else if (att.IsAudio)
                                            {
                                                <div class="pm-audio-player">
                                                    <audio controls src="@att.FileUrl" preload="metadata" style="max-width:240px;height:40px;"></audio>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="pm-file-wrapper">
                                                    <div class="pm-file-card">
                                                        <div class="pm-file-icon">
                                                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile"
                                                                     Style="font-size:22px;" />
                                                        </div>

                                                        <div class="pm-file-info">
                                                            <span class="pm-file-name">@att.FileName</span>
                                                            <span class="pm-file-meta">@att.DisplaySize • @att.MimeType</span>
                                                        </div>
                                                    </div>

                                                    <div class="pm-file-actions">
                                                        <a href="@GetDownloadUrl(att)"
                                                           download="@att.FileName"
                                                           class="pm-file-action-btn primary">
                                                            Tải xuống
                                                        </a>
                                                    </div>
                                                </div>
                                            }
                                        }
                                    </div>
                                }

                                @if (IsPollMessage(msg))
                                {
                                    @RenderPollCard(msg)
                                }
                                else if (IsReminderMessage(msg))
                                {
                                    @RenderReminderCard(msg)
                                }
                                else if (IsTaskMessage(msg))
                                {
                                    @RenderTaskCard(msg)
                                }
                                else if (IsVulnerabilityMessage(msg))
                                {
                                    @RenderVulnerabilityCard(msg)
                                }
                                else if (ShouldRenderTextContent(msg))
                                {
                                    @if (MarkdownHelper.ContainsMarkdown(msg.Content))
                                    {
                                        <div class="pm-markdown-body @(MarkdownHelper.IsIocCommand(msg.Content) ? "pm-ioc-message" : "")">
                                            @RenderMarkdown(msg)
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="pm-message-text">@msg.Content</span>
                                    }
                                }
                            }
                        </div>

                        @if (msg.Reactions != null && msg.Reactions.Any())
                        {
                            <div class="pm-reactions">
                                @foreach (var r in msg.Reactions)
                                {
                                    <button type="button"
                                            class="@($"pm-reaction-pill {(r.UserIds.Contains(CurrentUserId) ? "mine" : "")}")"
                                            @onclick="() => ReactAsync(msg.Id, r.Emoji)">
                                        <span>@r.Emoji</span>
                                        <span class="count">@r.Count</span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="pm-msg-time" style="@(isOwn ? "text-align:right;" : "")">
                            @msg.CreatedAt.ToLocalTime().ToString("HH:mm")

                            @if (msg.IsEdited && !msg.IsDeleted)
                            {
                                <span style="margin-left:4px;opacity:.72;">
                                    đã sửa
                                    <MudIconButton Icon="@Icons.Material.Filled.History"
                                                Size="Size.Small"
                                                OnClick="() => ShowEditHistory(msg.Id)"
                                                Style="margin-left:4px; width:22px; height:22px;" />
                                </span>
                            }

                            @if (isOwn && IsReadByOther(msg))
                            {
                                <MudTooltip Text="Đã xem">
                                    <MudIcon Icon="@Icons.Material.Filled.DoneAll"
                                             Style="font-size:12px;color:#3B82F6;margin-left:2px;vertical-align:middle;" />
                                </MudTooltip>
                            }
                            else if (isOwn)
                            {
                                <MudTooltip Text="Đã gửi">
                                    <MudIcon Icon="@Icons.Material.Filled.Done"
                                             Style="font-size:12px;opacity:.65;margin-left:2px;vertical-align:middle;" />
                                </MudTooltip>
                            }
                        </div>
                    </div>

                    @if (!msg.IsDeleted)
                    {
                        <div class="@($"pm-message-actions {(isOwn ? "own" : "other")} {(_reactionPickerMessageId == msg.Id ? "show" : "")}")">
                            <MudTooltip Text="Trả lời">
                                <MudIconButton Icon="@Icons.Material.Filled.Reply"
                                               Size="Size.Small"
                                               OnClick="() => OnReply.InvokeAsync(msg)"
                                               Style="width:28px;height:28px;" />
                            </MudTooltip>

                            <MudTooltip Text="Chuyển tiếp">
                                <MudIconButton Icon="@Icons.Material.Filled.Forward"
                                               Size="Size.Small"
                                               OnClick="() => OpenForwardDialogAsync(msg)"
                                               Style="width:28px;height:28px;" />
                            </MudTooltip>

                            <MudTooltip Text="@(msg.IsPinned ? "Bỏ ghim" : "Ghim tin nhắn")">
                                <MudIconButton Icon="@(msg.IsPinned ? Icons.Material.Filled.PushPin : Icons.Material.Outlined.PushPin)"
                                               Size="Size.Small"
                                               Color="@(msg.IsPinned ? Color.Warning : Color.Default)"
                                               OnClick="() => TogglePinAsync(msg)"
                                               Style="width:28px;height:28px;" />
                            </MudTooltip>

                            <MudTooltip Text="@(msg.IsSaved ? Loc.T("message.unsave") : Loc.T("message.save"))">
                                <MudIconButton Icon="@(msg.IsSaved ? Icons.Material.Filled.Bookmark : Icons.Material.Outlined.BookmarkBorder)"
                                               Size="Size.Small"
                                               Color="@(msg.IsSaved ? Color.Primary : Color.Default)"
                                               OnClick="() => ToggleSaveAsync(msg)"
                                               Style="width:28px;height:28px;" />
                            </MudTooltip>

                            @if (isOwn && msg.MessageType.Equals("Text", StringComparison.OrdinalIgnoreCase))
                            {
                                <MudTooltip Text="Chỉnh sửa">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                   Size="Size.Small"
                                                   OnClick="() => StartEdit(msg)"
                                                   Style="width:28px;height:28px;" />
                                </MudTooltip>
                            }
                            @if (isOwn || _canModerateCurrentGroup)
                            {
                                <MudTooltip Text="Thu hồi">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="() => DeleteAsync(msg.Id)"
                                                   Style="width:28px;height:28px;" />
                                </MudTooltip>
                            }

                            <div class="pm-reaction-picker-wrap" @onclick:stopPropagation="true">
                                <MudTooltip Text="Thả reaction">
                                    <MudIconButton Icon="@Icons.Material.Filled.EmojiEmotions"
                                                   Size="Size.Small"
                                                   OnClick="() => ToggleReactionPicker(msg.Id)"
                                                   Style="width:28px;height:28px;" />
                                </MudTooltip>

                                @if (_reactionPickerMessageId == msg.Id)
                                {
                                    <div class="@($"pm-reaction-picker {(isOwn ? "own" : "other")}")">
                                        @foreach (var emoji in ReactionEmojis)
                                        {
                                            var selectedEmoji = emoji;
                                            var msgId = msg.Id;

                                            <button type="button"
                                                    class="pm-reaction-picker-btn"
                                                    title="@selectedEmoji"
                                                    @onclick="() => ReactFromMenuAsync(msgId, selectedEmoji)"
                                                    @onclick:stopPropagation="true">
                                                @selectedEmoji
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }

    @if (_loading && messages.Any())
    {
        <div class="pm-message-loading-overlay">
            <MudProgressCircular Indeterminate Size="Size.Small" Color="Color.Primary" />
        </div>
    }
</div>

@if (_editOpen)
{
    <div class="pm-chat-modal-backdrop" @onclick="CloseEditDialog">
        <div class="pm-chat-modal-card" @onclick:stopPropagation="true">
            <div class="pm-chat-modal-header">
                <div>
                    <MudText Typo="Typo.h6">Chỉnh sửa tin nhắn</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Nội dung sẽ được cập nhật ngay trong cuộc trò chuyện.
                    </MudText>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="CloseEditDialog" />
            </div>

            <div class="pm-chat-modal-body">
                <MudTextField @bind-Value="_editContent"
                              AutoFocus="true"
                              Variant="Variant.Outlined"
                              Lines="4"
                              Label="Nội dung"
                              FullWidth="true" />
            </div>

            <div class="pm-chat-modal-actions">
                <MudButton ButtonType="ButtonType.Button"
                           OnClick="CloseEditDialog">
                    Huỷ
                </MudButton>

                <MudButton ButtonType="ButtonType.Button"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Disabled="@string.IsNullOrWhiteSpace(_editContent)"
                           OnClick="SaveEditAsync">
                    Lưu
                </MudButton>
            </div>
        </div>
    </div>
}

@if (_forwardOpen)
{
    <div class="pm-chat-modal-backdrop" @onclick="CloseForwardDialog">
        <div class="pm-chat-modal-card" @onclick:stopPropagation="true">
            <div class="pm-chat-modal-header">
                <div>
                    <MudText Typo="Typo.h6">Chuyển tiếp tin nhắn</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Chọn một hội thoại để chuyển tiếp.
                    </MudText>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               OnClick="CloseForwardDialog" />
            </div>

            <div class="pm-chat-modal-body">
                <MudTextField @bind-Value="_forwardSearch"
                              Placeholder="Tìm hội thoại..."
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true"
                              Margin="Margin.Dense"
                              FullWidth="true" />

                @if (_forwardLoading)
                {
                    <div style="display:flex;justify-content:center;padding:22px;">
                        <MudProgressCircular Indeterminate Size="Size.Small" Color="Color.Primary" />
                    </div>
                }
                else if (!FilteredForwardConversations.Any())
                {
                    <div style="padding:18px;text-align:center;color:var(--mud-palette-text-secondary);">
                        Không tìm thấy hội thoại phù hợp.
                    </div>
                }
                else
                {
                    <div style="display:flex;flex-direction:column;gap:6px;margin-top:10px;max-height:360px;overflow:auto;">
                        @foreach (var conv in FilteredForwardConversations)
                        {
                            var c = conv;

                            <button type="button"
                                    class="pm-forward-item"
                                    @onclick="() => ForwardToConversationAsync(c)">
                                <MudAvatar Size="Size.Medium"
                                           Color="@(c.Type == "group" ? Color.Info : Color.Primary)"
                                           Style="width:40px;height:40px;flex-shrink:0;">
                                    @if (c.Type == "group")
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Groups" Style="font-size:20px;" />
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Style="font-size:20px;" />
                                    }
                                </MudAvatar>

                                <div style="min-width:0;text-align:left;">
                                    <div style="font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @GetForwardConversationDisplayName(c)
                                    </div>
                                    <div style="font-size:12px;color:var(--mud-palette-text-secondary);">
                                        @(c.Type == "group" ? Loc.T("chat.groupLabel") : "Tin nhắn riêng")
                                    </div>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>

            <div class="pm-chat-modal-actions">
                <MudButton ButtonType="ButtonType.Button" OnClick="CloseForwardDialog">
                    Đóng
                </MudButton>
            </div>
        </div>
    </div>
}

<style>
    .pm-message-highlight {
        animation: pm-highlight-pulse 1.2s ease-in-out 3;
        border-radius: 14px;
    }

    .pm-message-skeleton-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding: 8px 4px;
    }

    .pm-message-skeleton {
        width: min(420px, 68%);
        min-height: 58px;
        border-radius: 16px;
        padding: 12px;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        opacity: .78;
    }

        .pm-message-skeleton.own {
            align-self: flex-end;
            background: rgba(59, 130, 246, .14);
        }

        .pm-message-skeleton span {
            display: block;
            height: 10px;
            border-radius: 999px;
            background: rgba(148, 163, 184, .28);
        }

            .pm-message-skeleton span + span {
                width: 62%;
                margin-top: 10px;
            }

    .pm-message-loading-overlay {
        position: sticky;
        bottom: 10px;
        align-self: center;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-divider);
        box-shadow: 0 8px 24px rgba(15, 23, 42, .18);
        pointer-events: none;
    }

    @@keyframes pm-highlight-pulse {
        0%, 100% {
            background: transparent;
        }

        50% {
            background: rgba(250, 204, 21, .28);
        }
    }

    .pm-message-line {
        display: flex;
        gap: 8px;
        max-width: 72%;
        min-width: min(240px, 100%);
    }

        .pm-message-line.other {
            align-items: flex-start;
        }

        .pm-message-line.own {
            align-items: flex-end;
            flex-direction: row-reverse;
        }

    .pm-message-line.other .mud-avatar-root {
        margin-top: 2px;
        flex-shrink: 0;
    }

    .pm-bubble.other {
        background: var(--mud-palette-surface) !important;
        color: var(--mud-palette-text-primary) !important;
        border: 1px solid var(--mud-palette-divider) !important;
        box-shadow: var(--pm-shadow-sm);
    }

    .pm-message-text {
        display: block;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .pm-system-message-row {
        display: flex;
        justify-content: center;
        padding: 6px 12px;
    }

    .pm-system-message-text {
        max-width: min(560px, 92%);
        padding: 5px 10px;
        border-radius: 999px;
        background: rgba(148, 163, 184, .14);
        color: var(--mud-palette-text-secondary);
        font-size: .76rem;
        font-weight: 700;
        text-align: center;
        overflow-wrap: break-word;
        word-break: normal;
    }

        .pm-bubble.other span,
        .pm-bubble.other div,
        .pm-bubble.other p {
            color: var(--mud-palette-text-primary) !important;
        }

    .pm-bubble.own {
        background: linear-gradient(135deg, var(--pm-blue-600), var(--pm-blue-500)) !important;
        color: white !important;
    }

        .pm-bubble.own span,
        .pm-bubble.own div,
        .pm-bubble.own p {
            color: white !important;
        }

    .pm-forwarded-label {
        font-size: 11px;
        color: var(--mud-palette-text-secondary);
        margin: 0 6px 3px;
        opacity: .78;
    }

    .pm-attachments {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: min(320px, 70vw);
    }

    .pm-image-link {
        display: block;
        line-height: 0;
    }

    .pm-image-preview {
        max-width: min(340px, 70vw);
        max-height: 320px;
        border-radius: 14px;
        object-fit: cover;
        display: block;
        border: 1px solid var(--mud-palette-divider);
    }

    .pm-attachment-caption {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        font-size: 12px;
        color: var(--mud-palette-text-secondary) !important;
        word-break: break-word;
    }

    .pm-file-wrapper {
        min-width: min(340px, 70vw);
        max-width: min(380px, 70vw);
        color: var(--mud-palette-text-primary) !important;
    }

    .pm-file-card {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 14px;
        color: var(--mud-palette-text-primary) !important;
        background: rgba(59, 130, 246, .08) !important;
        border: 1px solid var(--mud-palette-divider) !important;
