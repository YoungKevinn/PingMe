    private async Task ForwardToConversationAsync(ConversationDto conv)
    {
        if (_forwardMessageId <= 0)
            return;

        MessageResponse? forwarded;

        if (conv.Type == "group")
            forwarded = await MsgService.ForwardMessageAsync(_forwardMessageId, null, conv.GroupId);
        else
            forwarded = await MsgService.ForwardMessageAsync(_forwardMessageId, conv.PeerId, null);

        if (forwarded == null)
        {
            Snackbar.Add("Chuyển tiếp thất bại.", Severity.Error);
            return;
        }

        Snackbar.Add("Đã chuyển tiếp tin nhắn.", Severity.Success);
        CloseForwardDialog();

        if (BelongsToCurrentConversation(forwarded))
            await AppendMessageAsync(forwarded);
