    private static string? FormatEndpoint(string? method, string? endpoint)
    {
        if (string.IsNullOrWhiteSpace(endpoint))
            return null;

        return string.IsNullOrWhiteSpace(method)
            ? endpoint.Trim()
            : $"{method.Trim().ToUpperInvariant()} {endpoint.Trim()}";
    }

    private static string? BuildPayloadPreview(string? payload)
    {
        if (string.IsNullOrWhiteSpace(payload))
            return null;

        var lines = payload.Trim().Replace("\r\n", "\n").Split('\n');
        return string.Join('\n', lines.Take(2));
    }

    private static VulnerabilityMessagePayload? ParseVulnerabilityPayload(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return null;

        try
        {
            return JsonSerializer.Deserialize<VulnerabilityMessagePayload>(
                content,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch
        {
            return null;
        }
    }

    private static TaskMessagePayload? ParseTaskPayload(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return null;

        try
        {
            return JsonSerializer.Deserialize<TaskMessagePayload>(
                content,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch
        {
            return null;
        }
    }

    private static bool IsSystemMessage(MessageResponse msg) =>
        string.Equals(msg.MessageType, "System", StringComparison.OrdinalIgnoreCase);

    private MarkupString RenderMarkdown(MessageResponse msg)
    {
        var content = msg.Content ?? string.Empty;

        if (_markdownCache.TryGetValue(msg.Id, out var cached) &&
            string.Equals(cached.Content, content, StringComparison.Ordinal))
        {
            return cached.Html;
        }

        var html = (MarkupString)MarkdownHelper.ToChatHtml(content);
        _markdownCache[msg.Id] = (content, html);
        return html;
    }

    private static MessageResponse CreateLocalSystemMessage(int groupId, string content) => new()
    {
        Id = -Math.Abs(groupId),
        SenderId = 0,
        GroupId = groupId,
        Content = content,
        MessageType = "System",
