@using PingMe.Frontend.Models
@inject ChatHubService Hub
@implements IDisposable

@if (_typingDisplayNames.Any())
{
    <div style="padding:0 16px 4px;display:flex;align-items:center;gap:8px;animation:pm-fade-in .2s ease-out;">
        <div style="display:flex;gap:3px;align-items:center;">
            <div class="pm-typing-dot"></div>
            <div class="pm-typing-dot"></div>
            <div class="pm-typing-dot"></div>
        </div>
        <span style="font-size:.75rem;color:#94A3B8;">
            @string.Join(", ", _typingDisplayNames) đang nhập...
        </span>
    </div>
}

@code {
    [Parameter] public List<string>? Users { get; set; }

    private HashSet<string> _typingDisplayNames = new();
    private int? _peerId;
    private int? _groupId;

    [Parameter] public int? PeerId { set => _peerId = value; get => _peerId; }
    [Parameter] public int? GroupId { set => _groupId = value; get => _groupId; }

    protected override void OnInitialized()
    {
        Hub.OnUserTyping += HandleTyping;
    }

    private void HandleTyping(object raw)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => Hub.OnUserTyping -= HandleTyping;
}
